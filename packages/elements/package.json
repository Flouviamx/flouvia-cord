{
  "name": "@flouviahq/elements",
  "version": "1.0.0",
  "description": "Embebe el cotizador B2B de Cord en cualquier sitio — Web Component + wrappers de React, Vue, Framer y Webflow. Tu marca, aprobación y pago en línea.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://cordhq.app/elements",
  "keywords": [
    "cord",
    "cotizaciones",
    "b2b",
    "quote",
    "embed",
    "web-component",
    "react",
    "mexico",
    "cfdi"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/types/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/types/react.d.ts",
        "default": "./dist/react.mjs"
      },
      "require": {
        "types": "./dist/types/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./vue": {
      "import": {
        "types": "./dist/types/vue.d.ts",
        "default": "./dist/vue.mjs"
      },
      "require": {
        "types": "./dist/types/vue.d.cts",
        "default": "./dist/vue.cjs"
      }
    },
    "./framer": {
      "import": {
        "types": "./dist/types/framer.d.ts",
        "default": "./dist/framer.mjs"
      },
      "require": {
        "types": "./dist/types/framer.d.cts",
        "default": "./dist/framer.cjs"
      }
    },
    "./webflow": {
      "browser": "./dist/webflow.js",
      "import": {
        "types": "./dist/types/webflow.d.ts",
        "default": "./dist/webflow.mjs"
      },
      "require": {
        "types": "./dist/types/webflow.d.cts",
        "default": "./dist/webflow.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/types/server.d.ts",
        "default": "./dist/server.mjs"
      },
      "require": {
        "types": "./dist/types/server.d.cts",
        "default": "./dist/server.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "src",
    "react.js",
    "react.d.ts",
    "vue.js",
    "vue.d.ts",
    "framer.js",
    "framer.d.ts",
    "webflow.js",
    "webflow.d.ts",
    "server.js",
    "server.d.ts",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check-exports": "node scripts/check-exports.mjs",
    "prepublishOnly": "npm run build && npm run check-exports && npx attw --pack . && npx publint"
  },
  "peerDependencies": {
    "framer": "*",
    "react": ">=17",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "framer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "esbuild": "*",
    "framer": "^2.4.0",
    "publint": "^0.2.0",
    "typescript": "^5.6.0",
    "vue": "^3.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
