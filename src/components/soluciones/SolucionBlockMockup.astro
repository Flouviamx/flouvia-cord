---
// Block-mockups motion-graphic por industria (/soluciones/[slug]).
// Rediseñados para integrarse nativamente en el Bento Grid de estilo Stripe Enterprise.
// Gráficos vectoriales abstractos con líneas neón y brillos sutiles.
export interface Props {
    slug: string;
    index: number;
}
const { slug, index } = Astro.props;

// Helper param para internacionalización visual si se requiere en un futuro
const lang = 'es'; // o inyectarlo por props
---

<div class="stripe-mockup-wrapper">
    <!-- Efecto de brillo de fondo detrás de los gráficos -->
    <div class="stripe-mockup-glow"></div>
    
    <!-- Renderizado condicional del gráfico SVG según la industria y el índice del bento -->
    <div class="stripe-mockup-svg">
        {slug === 'empresas' && index === 0 && (
            <svg viewBox="0 0 400 300" class="smk-svg">
                <!-- Nodos conectados (Aprobaciones) -->
                <circle cx="200" cy="150" r="40" fill="var(--stripe-card-bg)" stroke="var(--stripe-accent)" stroke-width="2"/>
                <circle cx="200" cy="150" r="20" fill="var(--stripe-accent)"/>
                
                <path d="M100,80 L165,130" stroke="var(--stripe-cyan)" stroke-width="2" stroke-dasharray="4"/>
                <circle cx="100" cy="80" r="15" fill="var(--stripe-card-bg)" stroke="var(--stripe-cyan)" stroke-width="2"/>
                
                <path d="M100,220 L165,170" stroke="var(--stripe-cyan)" stroke-width="2" stroke-dasharray="4"/>
                <circle cx="100" cy="220" r="15" fill="var(--stripe-card-bg)" stroke="var(--stripe-cyan)" stroke-width="2"/>
                
                <path d="M300,150 L240,150" stroke="var(--stripe-accent-light)" stroke-width="3"/>
                <circle cx="300" cy="150" r="15" fill="var(--stripe-accent-light)"/>
                <circle cx="300" cy="150" r="30" fill="none" stroke="var(--stripe-accent-light)" stroke-width="1" opacity="0.5"/>
                
                <!-- Animación pulsante del SVG principal -->
                <style>
                    .smk-svg circle:nth-child(2) { animation: pulse 2s infinite alternate; }
                    @keyframes pulse { 0% { transform: scale(1); opacity: 0.8; } 100% { transform: scale(1.1); opacity: 1; box-shadow: 0 0 20px var(--stripe-accent); } }
                </style>
            </svg>
        )}
        
        {slug === 'empresas' && index === 1 && (
            <svg viewBox="0 0 400 300" class="smk-svg">
                <!-- Gráfico de barras ascendente (Volumen) -->
                <line x1="50" y1="250" x2="350" y2="250" stroke="var(--stripe-border)" stroke-width="2"/>
                
                <rect x="80" y="180" width="40" height="70" fill="rgba(10, 25, 47, 0.2)" stroke="var(--stripe-accent)" stroke-width="1" rx="4"/>
                <rect x="150" y="130" width="40" height="120" fill="rgba(10, 25, 47, 0.4)" stroke="var(--stripe-accent)" stroke-width="1" rx="4"/>
                <rect x="220" y="90" width="40" height="160" fill="rgba(10, 25, 47, 0.7)" stroke="var(--stripe-accent)" stroke-width="1" rx="4"/>
                <rect x="290" y="40" width="40" height="210" fill="var(--stripe-cyan)" rx="4"/>
                
                <path d="M100,160 L170,110 L240,70 L310,20" stroke="var(--stripe-bg)" stroke-width="3" fill="none" />
                <circle cx="310" cy="20" r="6" fill="var(--stripe-bg)"/>
            </svg>
        )}

        {slug === 'empresas' && index > 1 && (
            <svg viewBox="0 0 400 300" class="smk-svg">
                <!-- Capas de seguridad (Compliance) -->
                <path d="M200,60 L320,120 L200,180 L80,120 Z" fill="rgba(59, 130, 246, 0.1)" stroke="var(--stripe-cyan)" stroke-width="2"/>
                <path d="M200,110 L320,170 L200,230 L80,170 Z" fill="rgba(10, 25, 47, 0.1)" stroke="var(--stripe-accent)" stroke-width="2"/>
                <path d="M200,160 L320,220 L200,280 L80,220 Z" fill="none" stroke="var(--stripe-border)" stroke-width="2" stroke-dasharray="5"/>
                
                <line x1="200" y1="60" x2="200" y2="280" stroke="var(--stripe-border)" stroke-width="1" stroke-dasharray="4"/>
            </svg>
        )}

        {slug === 'startups' && index === 0 && (
            <svg viewBox="0 0 400 300" class="smk-svg">
                <!-- Interfaz editor UI abstracta -->
                <rect x="50" y="50" width="300" height="200" rx="12" fill="var(--stripe-card-bg)" stroke="var(--stripe-border)" stroke-width="2"/>
                <rect x="70" y="70" width="80" height="12" rx="6" fill="var(--stripe-accent)"/>
                <rect x="70" y="100" width="160" height="8" rx="4" fill="var(--stripe-muted)" opacity="0.5"/>
                <rect x="70" y="120" width="120" height="8" rx="4" fill="var(--stripe-muted)" opacity="0.3"/>
                
                <rect x="70" y="150" width="260" height="60" rx="8" fill="rgba(10,25,47,0.03)" stroke="var(--stripe-border)"/>
                <rect x="90" y="170" width="30" height="20" rx="4" fill="var(--stripe-cyan)"/>
                <rect x="130" y="176" width="100" height="8" rx="4" fill="var(--stripe-text)"/>
                
                <circle cx="310" cy="180" r="10" fill="var(--stripe-border)"/>
            </svg>
        )}

        {slug === 'startups' && index === 1 && (
            <svg viewBox="0 0 400 300" class="smk-svg">
                <!-- Notificaciones / Velocidad -->
                <rect x="100" y="60" width="240" height="50" rx="25" fill="var(--stripe-card-bg)" stroke="var(--stripe-border)" stroke-width="1"/>
                <circle cx="125" cy="85" r="12" fill="var(--stripe-accent)"/>
                <rect x="150" y="80" width="120" height="10" rx="5" fill="var(--stripe-text)"/>
                
                <rect x="80" y="130" width="240" height="50" rx="25" fill="var(--stripe-card-bg)" stroke="var(--stripe-border)" stroke-width="1"/>
                <circle cx="105" cy="155" r="12" fill="var(--stripe-cyan)"/>
                <rect x="130" y="150" width="150" height="10" rx="5" fill="var(--stripe-text)"/>
                
                <rect x="120" y="200" width="240" height="50" rx="25" fill="var(--stripe-accent-light)"/>
                <circle cx="145" cy="225" r="12" fill="var(--stripe-bg)"/>
                <rect x="170" y="220" width="100" height="10" rx="5" fill="var(--stripe-bg)"/>
            </svg>
        )}

        {slug === 'startups' && index > 1 && (
            <svg viewBox="0 0 400 300" class="smk-svg">
                <!-- Pagos / Checkout (Stripe style) -->
                <rect x="120" y="50" width="160" height="200" rx="16" fill="var(--stripe-card-bg)" stroke="var(--stripe-border)" stroke-width="2"/>
                <rect x="140" y="80" width="120" height="20" rx="4" fill="var(--stripe-accent)" opacity="0.2"/>
                
                <rect x="140" y="120" width="120" height="30" rx="6" fill="rgba(10,25,47,0.03)" stroke="var(--stripe-border)"/>
                <circle cx="155" cy="135" r="5" fill="var(--stripe-cyan)"/>
                
                <rect x="140" y="160" width="120" height="30" rx="6" fill="rgba(10,25,47,0.03)" stroke="var(--stripe-border)"/>
                <circle cx="155" cy="175" r="5" fill="var(--stripe-muted)"/>
                
                <rect x="140" y="210" width="120" height="24" rx="12" fill="var(--stripe-accent)"/>
            </svg>
        )}
    </div>
</div>

<style>
    .stripe-mockup-wrapper {
        width: 100%;
        height: 100%;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .stripe-mockup-glow {
        position: absolute;
        width: 60%;
        height: 60%;
        background: radial-gradient(circle at center, rgba(10, 25, 47, 0.15) 0%, transparent 70%);
        filter: blur(40px);
        z-index: 0;
        animation: float 6s ease-in-out infinite;
    }

    .stripe-mockup-svg {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 400px;
        height: auto;
    }

    .smk-svg {
        width: 100%;
        height: 100%;
        overflow: visible;
    }

    @keyframes float {
        0% { transform: translateY(0px) scale(1); }
        50% { transform: translateY(-10px) scale(1.05); }
        100% { transform: translateY(0px) scale(1); }
    }
</style>
