  .sbm-serv-terms svg { width: 12px; height: 12px; opacity: 0.8; }
  .sbm-serv-foot { padding: 0.6rem 1.1rem 0.85rem; border-top: 1px solid rgba(255,255,255,0.06); display: flex; justify-content: flex-end; }
  .sbm-serv-foot-badge { font-size: 0.5rem; font-weight: 800; letter-spacing: 0.5px; padding: 3px 9px; border-radius: 6px; color: #7eb3ff; background: rgba(59,130,246,0.16); transition: color .5s ease, background .5s ease; }
  .sbm-serv-track { display: flex; flex-direction: column; }
  .sbm-serv-stagebar { display: flex; align-items: center; margin: 6px 0 4px; padding: 0 2px; }
  .sbm-serv-step { display: flex; flex-direction: column; align-items: center; gap: 5px; flex-shrink: 0; }
  .sbm-serv-step i { width: 14px; height: 14px; border-radius: 50%; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.18); box-shadow: 0 0 0 3px #0a192f; }
  .sbm-serv-step span { font-size: 0.5rem; font-weight: 700; color: rgba(255,255,255,0.4); letter-spacing: 0.2px; }
