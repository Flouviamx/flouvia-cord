---
// BlogCTA.astro
const { isEn } = Astro.props;
---
<section class="article-footer-cta">
    <div class="bento-grid">

        <!-- Columna Grande: Suscripción -->
        <div class="bento-card span-2">
            <h3>{isEn ? 'Subscribe to the Cord Blog' : 'Suscríbete al Blog de Cord'}</h3>
            <p>{isEn ? 'Financial strategies, market analysis, and product updates right in your inbox.' : 'Estrategias financieras, análisis de mercado y novedades de producto directamente en tu bandeja de entrada.'}</p>

            <form class="subscribe-form" onsubmit="event.preventDefault()">
                <input type="email" placeholder={isEn ? 'you@company.com' : 'tu@empresa.com'} required />
                <button type="submit" class="btn-primary">
                    {isEn ? 'Subscribe' : 'Suscribirme'} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
            </form>
            <span class="privacy-note">{isEn ? 'Cord will process your data according to our' : 'Cord tratará tus datos según su'} <a href={isEn ? "/en/privacidad" : "/privacidad"}>{isEn ? 'Privacy Policy' : 'Política de Privacidad'}</a>.</span>
        </div>

        <!-- Columna Pequeña 1: LinkedIn -->
        <div class="bento-card">
            <div class="bento-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" fill="currentColor" fill-opacity="0.14"></path>
                    <rect x="2" y="9" width="4" height="12" fill="currentColor" fill-opacity="0.14"></rect>
                    <circle cx="4" cy="4" r="2" fill="currentColor" fill-opacity="0.22"></circle>
                </svg>
            </div>
            <h4>{isEn ? 'Like what you read?' : '¿Te gusta lo que lees?'}</h4>
            <p>{isEn ? 'Cord builds financial infrastructure to accelerate B2B sales. Follow us for more analysis and case studies.' : 'Cord construye infraestructura financiera para acelerar las ventas B2B. Síguenos para más análisis y casos de estudio.'}</p>
            <a href="https://linkedin.com/company/flouviamx" target="_blank" rel="noopener" class="bento-link">{isEn ? 'Follow on LinkedIn' : 'Seguir en LinkedIn'} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        </div>

        <!-- Columna Pequeña 2: Contact -->
        <div class="bento-card">
            <div class="bento-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" fill="currentColor" fill-opacity="0.14"></path>
                    <path d="M7 8.5h10M7 12h6" stroke-opacity="0.55"></path>
                </svg>
            </div>
            <h4>{isEn ? 'Questions or comments?' : '¿Dudas o comentarios?'}</h4>
            <p>{isEn ? "We'd love to hear your thoughts on this article or your sales flow." : 'Nos encantaría escuchar tu opinión sobre este artículo o tu flujo de ventas.'}</p>
            <a href="mailto:hello@cord.mx" class="bento-link">{isEn ? 'Contact us' : 'Contáctanos'} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        </div>

    </div>
</section>

<style>
    .article-footer-cta {
        max-width: 1200px; margin: 0 auto 7rem; padding: 0 5%;
    }
    .bento-grid {
        display: grid; grid-template-columns: repeat(4, 1fr);
        gap: 1.75rem; align-items: stretch;
    }

    .bento-card {
        background: #ffffff; border-radius: 32px; padding: 3rem;
        display: flex; flex-direction: column; justify-content: space-between;
        box-shadow:
            0 1px 2px rgba(10,25,47,0.03),
            0 10px 24px -14px rgba(10,25,47,0.08),
            0 34px 68px -26px rgba(10,25,47,0.14),
            inset 0 1px 0 rgba(255,255,255,0.9),
            inset 0 0 0 1px rgba(10,25,47,0.045);
        transition: transform 0.5s cubic-bezier(0.16,1,0.3,1), box-shadow 0.5s cubic-bezier(0.16,1,0.3,1);
    }
    .bento-card:hover {
        transform: translateY(-4px);
        box-shadow:
            0 1px 2px rgba(10,25,47,0.03),
            0 16px 32px -16px rgba(10,25,47,0.10),
            0 44px 84px -28px rgba(10,25,47,0.18),
            inset 0 1px 0 rgba(255,255,255,0.9),
            inset 0 0 0 1px rgba(10,25,47,0.05);
    }

    .span-2 { grid-column: span 2; }

    .bento-card h3 {
        font-size: 1.7rem; font-weight: 700; color: #050505; letter-spacing: -0.03em;
        line-height: 1.15; margin-bottom: 0.9rem;
    }

    .bento-card h4 {
        font-size: 1.15rem; font-weight: 700; color: #050505; letter-spacing: -0.02em;
        margin-bottom: 0.6rem;
    }

    .bento-card p {
        font-size: 1rem; color: #555556; line-height: 1.55; margin-bottom: 2.25rem;
    }

    .bento-icon {
        width: 52px; height: 52px; border-radius: 16px;
        background: linear-gradient(160deg, rgba(10,25,47,0.07), rgba(10,25,47,0.03));
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.7), inset 0 0 0 1px rgba(10,25,47,0.05);
        color: var(--color-blue-deep);
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 1.75rem;
    }
    .bento-icon svg { width: 25px; height: 25px; }

    /* Formulario de Suscripción */
    .subscribe-form {
        display: flex; gap: 0.8rem; margin-bottom: 1.1rem;
    }
    .subscribe-form input {
        flex: 1; padding: 0 1.3rem; height: 52px; border-radius: 100px;
        background: #f5f5f7; border: none;
        font-family: inherit; font-size: 1rem; color: #050505;
        box-shadow: inset 0 0 0 1.5px transparent;
        transition: box-shadow 0.3s ease, background 0.3s ease;
    }
    .subscribe-form input::placeholder { color: #86868b; }
    .subscribe-form input:focus {
        outline: none; background: #fff;
        box-shadow: inset 0 0 0 1.5px rgba(10,25,47,0.16), 0 6px 16px -8px rgba(10,25,47,0.16);
    }

    .btn-primary {
        background: #0a192f; color: #fff;
        padding: 0 1.6rem; height: 52px; border-radius: 100px;
        font-weight: 600; font-size: 0.95rem; border: none;
        display: inline-flex; align-items: center; gap: 6px; cursor: pointer; white-space: nowrap;
        transition: background 0.3s ease, transform 0.25s cubic-bezier(0.16,1,0.3,1), box-shadow 0.3s ease;
    }
    .btn-primary:hover {
        background: #132a4d; transform: translateY(-1px);
        box-shadow: 0 12px 28px -12px rgba(10,25,47,0.4);
    }
    .btn-primary:active { transform: scale(0.97); }
    .btn-primary svg { width: 16px; height: 16px; transition: transform 0.3s; }
    .btn-primary:hover svg { transform: translateX(3px); }

    .privacy-note {
        font-size: 0.8rem; color: #86868b;
    }
    .privacy-note a { color: inherit; text-decoration: underline; }

    .bento-link {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 0.95rem; font-weight: 600; color: var(--color-blue-deep);
        text-decoration: none; transition: gap 0.3s;
    }
    .bento-link svg { width: 16px; height: 16px; transition: transform 0.3s; }
    .bento-link:hover { gap: 10px; }

    @media (max-width: 992px) {
        .bento-grid { grid-template-columns: 1fr 1fr; }
        .span-2 { grid-column: span 2; }
    }
    @media (max-width: 768px) {
        .bento-grid { grid-template-columns: 1fr; gap: 1.25rem; }
        .span-2 { grid-column: span 1; }
        .bento-card { padding: 2.25rem; border-radius: 26px; }
        .subscribe-form { flex-direction: column; }
        .subscribe-form input { height: 52px; }
    }
</style>
