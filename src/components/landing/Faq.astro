---
// FAQ — acordeón nativo (<details>) con estilo Flouvia.
const faqs = [
    {
        q: '¿Qué es Cord?',
        a: 'Cord es una plataforma B2B para cotizaciones, pedidos y facturación, creada por Flouvia. Permite gestionar precios negociados por cliente, términos de crédito Net 30/60 y timbrar CFDI 4.0 automáticamente ante el SAT. Disponible para cualquier negocio B2B en México.',
    },
    {
        q: '¿Necesito tener una tienda en línea para usar Cord?',
        a: 'No. Cord es independiente — funciona para cualquier negocio B2B: distribuidoras, mayoristas, manufactura o servicios. Subes tu catálogo (o cotizas líneas libres) y empiezas a mandar cotizaciones. Si además vendes en Shopify, tenemos una app que se integra.',
    },
    {
        q: '¿Cómo funciona el plan gratis?',
        a: 'Gratis para siempre, hasta 5 cotizaciones activas a la vez, con la marca "Powered by Cord" en el link público. Cuando cierras una cotización liberas el cupo. Sin tarjeta para empezar.',
    },
    {
        q: '¿El CFDI funciona con el SAT de verdad?',
        a: 'Sí. En el plan Negocio timbras CFDI 4.0 real ante el SAT directo desde la cotización aprobada. Solo necesitas tu CSD (Certificado de Sello Digital). La conexión toma menos de 5 minutos. Disponible solo para México.',
    },
    {
        q: '¿Mi cliente tiene que crear una cuenta para aprobar?',
        a: 'No. Tu cliente abre el link, revisa la cotización con tu marca y aprueba o paga sin registrarse. Cero fricción — por eso cierran más rápido.',
    },
    {
        q: '¿Mis datos están seguros?',
        a: 'Cord está construido por Flouvia sobre la misma infraestructura que usamos para marcas con operación establecida. Cada negocio vive aislado: tus cotizaciones, precios y clientes solo los ves tú.',
    },
    {
        q: '¿Puedo cancelar cuando quiera?',
        a: 'Cuando quieras, desde tu panel. Sin contratos ni penalizaciones. Si cancelas un plan de pago, bajas al gratis y conservas tu información.',
    },
];
---

<section class="faq" id="faq">
    <div class="faq-inner">
        <div class="faq-head">
            <p class="faq-eyebrow reveal">PREGUNTAS FRECUENTES</p>
            <h2 class="faq-title reveal">Lo que más nos preguntan.</h2>
        </div>

        <div class="pr-faq-list reveal">
            {faqs.map((f) => (
                <details class="pr-faq-item">
                    <summary>
                        <span>{f.q}</span>
                        <i class="pr-faq-ico" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        </i>
                    </summary>
                    <div class="pr-faq-body"><p>{f.a}</p></div>
                </details>
            ))}
        </div>
    </div>
</section>

<style>
    .faq { padding: 6rem 5%; }
    .faq-inner { max-width: 760px; margin: 0 auto; }
    .faq-head { text-align: center; margin-bottom: 3rem; }
    .faq-eyebrow { font-size: 0.65rem; font-weight: 800; letter-spacing: 3px; text-transform: uppercase; color: #888; margin: 0 0 1.2rem; }
    .faq-title { font-size: clamp(1.8rem, 3.2vw, 2.6rem); font-weight: 800; letter-spacing: -1px; color: var(--color-text); margin: 0; }

    /* ── NATIVE DETAILS FAQ (QUIET LUXURY) ── */
    .pr-faq-list {
        display: flex;
        flex-direction: column;
        max-width: 860px;
        margin: 0 auto;
        border-top: 1px solid var(--color-border);
    }
    .pr-faq-item {
        border-bottom: 1px solid var(--color-border);
        overflow: hidden;
    }
    .pr-faq-item summary {
        list-style: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.5rem 0;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--color-text);
    }
    .pr-faq-item summary::-webkit-details-marker { display: none; }
    .pr-faq-ico {
        flex-shrink: 0;
        color: var(--color-text-muted);
        transition: transform 0.4s var(--ease-spring), color 0.3s;
    }
    .pr-faq-ico svg { width: 20px; height: 20px; }
    .pr-faq-item[open] .pr-faq-ico {
        transform: rotate(135deg);
        color: var(--color-text);
    }
    .pr-faq-body {
        padding: 0 0 1.5rem;
    }
    .pr-faq-body p {
        margin: 0;
        font-size: 1rem;
        line-height: 1.6;
        color: var(--color-text-muted);
        max-width: 700px;
    }
</style>
