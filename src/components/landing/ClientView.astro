---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const l = (p: string) => lang === 'es' ? p : `/en${p === '/' ? '' : p}`;
// El diferenciador — cómo ve tu cliente la cotización (mockup del link público /q/).
// Calca fiel del /q actual: fondo suave, card blanca con marca del vendedor,
// total hero, líneas, strip de confianza, botón pill y compose de chat abierto.
// El teléfono auto-reproduce un demo: el monto cuenta hacia arriba, un cursor
// aparece, aprueba la cotización y se dibuja un checkmark de éxito. (Orquestado
// desde index.astro con GSAP; reduced-motion → estado estático.)
---

<section class="cv">
    <div class="cv-inner">
        <div class="cv-text">
            <p class="cv-eyebrow reveal">{t("cv.eyebrow")}</p>
            <h2 class="cv-title reveal" set:html={t("cv.title")} />
            <p class="cv-p reveal">
                {t("cv.p")}
            </p>
            <ul class="cv-list">
                <li class="reveal"><span class="cv-check">✓</span> {t("cv.l1")}</li>
                <li class="reveal"><span class="cv-check">✓</span> {t("cv.l2")}</li>
                <li class="reveal"><span class="cv-check">✓</span> {t("cv.l3")}</li>
                <li class="reveal"><span class="cv-check">✓</span> {t("cv.l4")}</li>
            </ul>
        </div>

        <div class="cv-visual reveal-mockup">
            <div class="phone" id="cvPhone">
                <div class="phone-island"></div>
                <div class="phone-screen">
                    <div class="ps-card">
                        <div class="ps-brand">
                            <div class="ps-logo">MV</div>
                            <div class="ps-brand-text">
                                <div class="ps-company">Materiales del Valle</div>
                                <div class="ps-rfc">RFC MVA-910618-QK3 · COT-0148</div>
                            </div>
                        </div>

                        <div class="ps-meta">
                            <div class="ps-meta-col">
                                <span class="ps-meta-label">{t("cv.mk.para")}</span>
                                <span class="ps-meta-val">Distribuidora El Zarco</span>
                            </div>
                            <span class="ps-vig">{t("cv.mk.vig")}</span>
                        </div>

                        <div class="ps-amount">
                            <span class="ps-amount-label">TOTAL</span>
                            <span class="editorial ps-amount-val" id="cvAmount">$196,469.20</span>
                            <span class="ps-amount-cur">{t("cv.mk.cur")}</span>
                        </div>

                        <div class="ps-items">
                            <div class="ps-item"><span class="ps-item-name">{lang === 'en' ? 'Grey cement 50kg' : 'Cemento gris 50kg'}<span class="ps-item-qty">×120 · $182.00</span></span><span class="editorial">$21,840</span></div>
                            <div class="ps-item"><span class="ps-item-name">{lang === 'en' ? 'Rebar 3/8"' : 'Varilla 3/8"'}<span class="ps-item-qty">×340 · $168.50</span></span><span class="editorial">$57,290</span></div>
                            <div class="ps-item"><span class="ps-item-name">{lang === 'en' ? 'Hollow block' : 'Block hueco'}<span class="ps-item-qty">×2,400 · $14.20</span></span><span class="editorial">$34,080</span></div>
                            <div class="ps-item ps-more">{t("cv.mk.more")}</div>
                        </div>

                        <div class="ps-trust">
                            <span class="ps-live-dot"></span>
                            <span>{t("cv.mk.live")}</span>
                        </div>

                        <div class="ps-actions">
                            <button class="ps-approve" id="cvApprove">
                                <span>{t("cv.mk.app")}</span>
                                <span class="ps-ring" aria-hidden="true"></span>
                            </button>
                            <button class="ps-secondary">{t("cv.mk.pdf")}</button>
                        </div>
                    </div>

                    <div class="ps-footer">{t("cv.mk.foot1")}<b>cord</b></div>

                    <!-- Cursor del demo (animado) -->
                    <svg class="ps-cursor" id="cvCursor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M5 2.5l14.5 7.8-6.2 1.6-2 6.1z" fill="#0a192f" stroke="#fff" stroke-width="1.2" stroke-linejoin="round"/>
                    </svg>

                    <!-- Overlay de éxito (animado) -->
                    <div class="ps-success" id="cvSuccess" aria-hidden="true">
                        <div class="ps-success-circle">
                            <svg class="ps-check" viewBox="0 0 24 24"><path id="cvCheck" d="M4 12.5l5 5L20 6.5"/></svg>
                        </div>
                        <div class="ps-success-text">{t("cv.mk.ok")}</div>
                        <div class="ps-success-sub">{t("cv.mk.oksub")}</div>
                    </div>
                </div>
            </div>
            <div class="cv-glow" aria-hidden="true"></div>
        </div>
    </div>
</section>

<style>
    .cv {
        padding: 9rem 5%;
        background: var(--color-bg-soft);
        overflow: clip;
    }
    .cv-inner {
        max-width: 1120px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 0.85fr;
        gap: 5rem;
        align-items: center;
    }

    .cv-eyebrow { font-size: 0.65rem; font-weight: 800; letter-spacing: 3px; text-transform: uppercase; color: #888; margin: 0 0 1.2rem; }
    .cv-title { font-size: clamp(1.9rem, 3.6vw, 3.4rem); font-weight: 800; line-height: 1.14; letter-spacing: -1.2px; color: var(--color-text); margin: 0 0 1.4rem; }
    .cv-p { font-size: 1.08rem; line-height: 1.65; color: var(--color-text-muted); margin: 0 0 2rem; max-width: 460px; }
    .cv-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1rem; }
    .cv-list li { display: flex; align-items: center; gap: 12px; font-size: 1rem; color: var(--color-text); font-weight: 500; }
    .cv-check { width: 24px; height: 24px; flex-shrink: 0; background: rgba(16,185,129,0.12); color: #059669; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; }

    /* ── Phone mockup (calca del /q "Quiet Luxury") ── */
    .cv-visual { position: relative; display: flex; justify-content: center; perspective: 1300px; }
    .cv-glow { position: absolute; inset: 10% 0; background: radial-gradient(ellipse at center, rgba(10,25,47,0.12) 0%, transparent 70%); z-index: 0; filter: blur(20px); }
    .phone {
        position: relative; z-index: 1; width: 332px;
        background: #0a192f; border-radius: 48px; padding: 10px;
        box-shadow:
            0 2px 6px rgba(10,25,47,0.2),
            0 40px 80px -24px rgba(10,25,47,0.5),
            inset 0 0 0 2px rgba(255,255,255,0.07);
        transform-style: preserve-3d;
        will-change: transform;
    }
    .phone-island { position: absolute; top: 20px; left: 50%; transform: translateX(-50%); width: 86px; height: 22px; background: #0a192f; border-radius: 100px; z-index: 3; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.04); }
    .phone-screen {
        position: relative;
        background: #ededf0; border-radius: 37px; padding: 3.3rem 0.9rem 1.1rem;
        display: flex; flex-direction: column; gap: 0.85rem;
        overflow: hidden;
    }

    /* La card blanca (el corazón del /q) — más aire, estilo Apple */
    .ps-card {
        background: #fff; border-radius: 26px; padding: 1.4rem 1.25rem 1.3rem;
        display: flex; flex-direction: column; gap: 1.15rem;
        border: 1px solid rgba(10,25,47,0.04);
        box-shadow: 0 2px 6px rgba(10,25,47,0.05), 0 26px 50px -20px rgba(10,25,47,0.16);
    }

    .ps-brand { display: flex; align-items: center; gap: 11px; }
    .ps-logo { width: 38px; height: 38px; border-radius: 12px; flex-shrink: 0; background: var(--color-blue-deep); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.82rem; letter-spacing: -0.5px; }
    .ps-brand-text { min-width: 0; flex: 1; }
    .ps-company { font-size: 0.9rem; font-weight: 700; color: #0a192f; letter-spacing: -0.015em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .ps-rfc { font-size: 0.62rem; color: #9aa3b2; margin-top: 2px; }
    .ps-folio-chip {
        flex-shrink: 0; font-size: 0.62rem; font-weight: 700; color: #5b6472;
        background: #f2f3f6; border: 1px solid rgba(10,25,47,0.05);
        padding: 4px 9px; border-radius: 99px; font-variant-numeric: tabular-nums; letter-spacing: -0.01em;
    }

    .ps-meta {
        display: flex; align-items: center; justify-content: space-between; gap: 8px;
    }
    .ps-meta-col { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
    .ps-meta-label { font-size: 0.52rem; font-weight: 800; letter-spacing: 1.4px; color: #a3adbd; }
    .ps-meta-val { font-size: 0.78rem; font-weight: 600; color: #0a192f; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .ps-vig {
        flex-shrink: 0; font-size: 0.6rem; font-weight: 700; color: #b45309;
        background: rgba(245,158,11,0.12); padding: 5px 10px; border-radius: 99px;
    }

    /* TOTAL — el héroe de la tarjeta */
    .ps-amount { display: flex; flex-direction: column; align-items: center; gap: 4px; padding: 1.35rem 0.5rem; border-radius: 20px; background: #f5f5f7; text-align: center; }
    .ps-amount-label { font-size: 0.56rem; font-weight: 800; letter-spacing: 2.4px; color: #aab; }
    .ps-amount-val { font-size: 2.35rem; color: #0a192f; line-height: 1; font-variant-numeric: tabular-nums; letter-spacing: -0.04em; }
    .ps-amount-cur { font-size: 0.64rem; color: #889; font-weight: 500; margin-top: 1px; }

    .ps-items { display: flex; flex-direction: column; }
    .ps-item { display: flex; justify-content: space-between; align-items: center; gap: 8px; font-size: 0.78rem; color: #445; padding: 0.62rem 0; border-bottom: 1px solid rgba(10,25,47,0.05); }
    .ps-item:first-child { padding-top: 0; }
    .ps-item:last-child { border-bottom: none; }
    .ps-item .editorial { color: #0a192f; font-weight: 600; }
    .ps-item-name { display: flex; flex-direction: column; gap: 2px; font-weight: 600; color: #0a192f; min-width: 0; }
    .ps-item-qty { font-size: 0.62rem; font-weight: 500; color: #9aa3b2; }
    .ps-more { color: #99a; font-size: 0.7rem; padding-top: 0.5rem; }

    .ps-trust {
        display: flex; align-items: center; justify-content: center; gap: 6px;
        font-size: 0.62rem; font-weight: 600; color: #7b8494;
    }
    .ps-live-dot { width: 6px; height: 6px; border-radius: 50%; background: #10b981; animation: ps-pulse 2s infinite; }
    @keyframes ps-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(16,185,129,0.35); }
        50% { box-shadow: 0 0 0 4px rgba(16,185,129,0); }
    }

    .ps-actions { display: flex; flex-direction: column; gap: 0.6rem; }
    .ps-approve {
        position: relative; overflow: hidden;
        background: var(--color-blue-deep); color: #fff; border: none; cursor: pointer;
        font-size: 0.92rem; font-weight: 600; padding: 15px; border-radius: 999px;
        font-family: var(--font-sans); box-shadow: inset 0 1px 0 rgba(255,255,255,0.14), 0 14px 30px -12px rgba(10,25,47,0.55);
        will-change: transform; letter-spacing: -0.01em;
    }
    .ps-ring { position: absolute; inset: 0; border-radius: 999px; box-shadow: 0 0 0 2px rgba(16,185,129,0.7) inset, 0 0 22px 2px rgba(16,185,129,0.35); opacity: 0; pointer-events: none; }
    .ps-secondary { background: none; border: none; color: #7b8494; cursor: pointer; font-size: 0.82rem; font-weight: 600; padding: 2px; border-radius: 999px; font-family: var(--font-sans); }

    .ps-footer { font-size: 0.64rem; color: #a3a9b4; text-align: center; padding: 0.1rem 0 0.2rem; }
    .ps-footer b { color: #667; }

    /* Cursor del demo */
    .ps-cursor {
        position: absolute; top: 0; left: 0; width: 24px; height: 24px;
        z-index: 8; pointer-events: none; opacity: 0;
        filter: drop-shadow(0 4px 5px rgba(10,25,47,0.3));
        will-change: transform;
    }

    /* Overlay de éxito */
    .ps-success {
        position: absolute; inset: 0; border-radius: 37px;
        background: #ededf0;
        display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.7rem;
        z-index: 7; opacity: 0; pointer-events: none;
    }
    .ps-success-circle { width: 86px; height: 86px; border-radius: 50%; background: rgba(16,185,129,0.12); display: flex; align-items: center; justify-content: center; }
    .ps-check { width: 46px; height: 46px; }
    .ps-check path { fill: none; stroke: #059669; stroke-width: 3; stroke-linecap: round; stroke-linejoin: round; }
    .ps-success-text { font-weight: 700; color: #0a192f; font-size: 1.12rem; }
    .ps-success-sub { font-size: 0.78rem; color: #667; margin-top: -0.3rem; }

    @media (max-width: 860px) {
        .cv-inner { grid-template-columns: 1fr; gap: 3.5rem; }
        .cv-p { max-width: 100%; }
    }
</style>
