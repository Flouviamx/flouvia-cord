---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import StepShaderBg from './StepShaderBg.jsx';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const l = (p: string) => lang === 'es' ? p : `/en${p === '/' ? '' : p}`;
// Cómo funciona — 3 pasos como tarjetas premium (fondo claro, igual al resto
// de la landing) con un shader azul reactivo (mismo motor que BlogCover) como
// visual de cada tarjeta.
---

<section class="steps" id="como">
    <div class="steps-inner">
        <div class="steps-head">
            <h2 class="steps-title reveal" set:html={t("st.title")} />
            <p class="steps-sub reveal">
                {t("st.sub")}
            </p>
        </div>

        <div class="steps-grid">
            <article class="step reveal">
                <div class="step-shader">
                    <StepShaderBg client:only="react" />
                </div>
                <div class="step-scrim"></div>
                <div class="step-content">
                    <span class="step-num editorial">01</span>
                    <h3 class="step-h">{t("st.1.h")}</h3>
                    <p class="step-p">
                        {t("st.1.p")}
                    </p>
                </div>
            </article>

            <article class="step reveal">
                <div class="step-shader">
                    <StepShaderBg client:only="react" />
                </div>
                <div class="step-scrim"></div>
                <div class="step-content">
                    <span class="step-num editorial">02</span>
                    <h3 class="step-h">{t("st.2.h")}</h3>
                    <p class="step-p">
                        {t("st.2.p")}
                    </p>
                </div>
            </article>

            <article class="step reveal">
                <div class="step-shader">
                    <StepShaderBg client:only="react" />
                </div>
                <div class="step-scrim"></div>
                <div class="step-content">
                    <span class="step-num editorial">03</span>
                    <h3 class="step-h">{t("st.3.h")}</h3>
                    <p class="step-p">
                        {t("st.3.p")}
                    </p>
                </div>
            </article>
        </div>
    </div>
</section>

<style>
    .steps {
        position: relative;
        background: var(--color-bg-soft);
        padding: 7rem 5%;
        overflow: clip;
    }
    .steps-inner { position: relative; z-index: 2; max-width: 1180px; margin: 0 auto; }

    /* Título a la izquierda, texto a la derecha (mismo patrón de Features/Hero) */
    .steps-head {
        display: grid;
        grid-template-columns: 1.25fr 1fr;
        gap: 3.5rem;
        align-items: start;
        margin-bottom: 4rem;
    }
    .steps-title {
        font-size: clamp(2.1rem, 3.4vw, 3.6rem);
        font-weight: 700; line-height: 1.1; letter-spacing: -0.035em;
        margin: 0; color: #0a192f;
    }
    .steps-sub {
        font-size: 1.02rem; line-height: 1.65;
        color: var(--color-text-muted); margin: 0;
        padding-top: 0.4rem;
    }
    @media (max-width: 800px) {
        .steps-head { grid-template-columns: 1fr; gap: 1.3rem; }
        .steps-sub { padding-top: 0; }
    }

    .steps-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.9rem;
    }
    .step {
        position: relative;
        border-radius: 32px;
        overflow: hidden;
        min-height: 440px;
        display: flex;
        align-items: flex-end;
        box-shadow:
            0 2px 4px rgba(10,25,47,0.06),
            0 30px 60px -22px rgba(6,16,45,0.45),
            inset 0 1px 0 rgba(255,255,255,0.12);
        transition: transform 0.5s var(--ease-spring), box-shadow 0.5s var(--ease-spring);
    }
    .step:hover {
        transform: translateY(-6px);
        box-shadow:
            0 2px 4px rgba(10,25,47,0.08),
            0 42px 80px -22px rgba(6,16,45,0.55),
            inset 0 1px 0 rgba(255,255,255,0.14);
    }

    .step-shader { position: absolute; inset: 0; z-index: 0; }
    .step-scrim {
        position: absolute; inset: 0; z-index: 1; pointer-events: none;
        background: linear-gradient(to top, rgba(2,6,20,0.72) 0%, rgba(2,6,20,0.28) 48%, rgba(2,6,20,0.02) 75%);
    }

    .step-content {
        position: relative; z-index: 2;
        padding: 2rem 2.1rem 2.3rem;
        display: flex; flex-direction: column; gap: 0.55rem;
    }
    .step-num {
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        color: rgba(255,255,255,0.65);
    }
    .step-h { font-size: 1.28rem; font-weight: 700; letter-spacing: -0.02em; margin: 0; color: #fff; text-shadow: 0 2px 14px rgba(0,0,0,0.25); }
    .step-p { font-size: 0.94rem; line-height: 1.6; color: rgba(255,255,255,0.82); margin: 0; }

    @media (max-width: 860px) {
        .steps-grid { grid-template-columns: 1fr; }
    }
</style>
