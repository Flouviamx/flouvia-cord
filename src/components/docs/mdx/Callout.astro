---
export interface Props {
  type?: 'info' | 'warning' | 'success';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const icons = {
  info: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>`,
  warning: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>`,
  success: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>`
};
---

<div class={`callout callout-${type}`}>
  <div class="callout-icon" set:html={icons[type]} />
  <div class="callout-content">
    {title && <div class="callout-title">{title}</div>}
    <div class="callout-body">
      <slot />
    </div>
  </div>
</div>

<style>
  .callout {
    display: flex;
    gap: 16px;
    padding: 20px 24px;
    border-radius: 12px;
    margin: 24px 0;
    font-size: 15px;
    line-height: 1.6;
    border: 1px solid transparent;
  }
  
  .callout-icon {
    flex-shrink: 0;
    margin-top: 2px;
  }
  
  .callout-content {
    flex: 1;
    min-width: 0;
  }
  
  .callout-title {
    font-weight: 600;
    margin-bottom: 4px;
  }
  
  .callout-body :global(p:first-child) { margin-top: 0; }
  .callout-body :global(p:last-child) { margin-bottom: 0; }
  
  /* Info */
  .callout-info {
    background: #f8fafc;
    border-color: #e2e8f0;
  }
  .callout-info .callout-icon { color: #0f172a; }
  .callout-info .callout-title { color: #0f172a; }
  .callout-info .callout-body { color: #334155; }
  
  /* Warning */
  .callout-warning {
    background: #fffbeb;
    border-color: #fde68a;
  }
  .callout-warning .callout-icon { color: #b45309; }
  .callout-warning .callout-title { color: #92400e; }
  .callout-warning .callout-body { color: #78350f; }
  
  /* Success */
  .callout-success {
    background: #f0fdf4;
    border-color: #bbf7d0;
  }
  .callout-success .callout-icon { color: #15803d; }
  .callout-success .callout-title { color: #166534; }
  .callout-success .callout-body { color: #14532d; }
</style>
