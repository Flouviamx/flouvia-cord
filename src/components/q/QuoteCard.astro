---
// QuoteCard — Quiet Luxury edition.
// Flujo de aprobación en 3 pasos: revisar → firmar digitalmente → confirmado/pagar.
// Reutilizado por /q/[token] (página pública) y /embed/[token] (CORD Elements).
import { money, lineTotal, quoteSubtotal, quoteIva, quoteTotal } from '../../lib/queries';
import { splitAnticipo } from '../../lib/cobros';

interface Props {
    quote: any;
    org: any;
    conversacion: { tipo: string; detalle: string; cuando: string; mine: boolean }[];
    yaAprobada: boolean;
    yaRechazada: boolean;
    puedePagar: boolean;
    standalone?: boolean;   // true en /q (permite barra fija); false en /embed (iframe)
}

const { quote: q, org: ORG, conversacion, yaAprobada, yaRechazada, puedePagar, standalone = false } = Astro.props;
const color = `var(--cord-color-primary, ${ORG.colorMarca || '#0a192f'})`;
const mostrarChat = ORG.portalMostrarChat !== false;
const banner = (ORG.portalBanner ?? '').trim();
const bienvenida = (ORG.portalBienvenida ?? '').trim();
const logoUrl = (ORG.logoUrl ?? '').trim();
const folio = q.folio as string;
const total = money(quoteTotal(q));
const viva = !yaAprobada && !yaRechazada;

// Vigencia / urgencia
const dias: number | undefined = typeof q.diasVigencia === 'number' ? q.diasVigencia : undefined;
const vigenciaUrgente = viva && typeof dias === 'number' && dias >= 0 && dias <= 7;
const vigenciaVencida = viva && typeof dias === 'number' && dias < 0;
const vigenciaTexto = vigenciaVencida ? 'Vigencia expirada'
    : typeof dias === 'number' && dias === 0 ? 'Vence hoy'
    : typeof dias === 'number' && dias > 0 ? `Vence en ${dias} día${dias === 1 ? '' : 's'}`
    : '';

// Cobros parciales (anticipo/saldo/cuotas) + gating por términos de crédito.
// q.cobros y q.pagoDisponible vienen de getCotizacionByToken.
const cobrosReales: any[] = Array.isArray(q.cobros) ? q.cobros : [];
// PREVIEW del plan anticipo+saldo ANTES de materializarse (los cobros reales se
// crean al aprobar): el link muestra desde el inicio "total X · hoy pagas Y", y
// la aprobación EN VIVO (sin recargar) ya enseña el monto correcto del anticipo.
const anticipoPct = Number(q.anticipoPct) || 0;
// q.total = total de BD — el MISMO que usa materializeAnticipoCobros, para que
// el preview coincida al centavo con los cobros reales que se crean al aprobar.
const totalNum = Number(q.total) || quoteTotal(q);
let cobros = cobrosReales;
if (!cobrosReales.length && anticipoPct >= 1 && anticipoPct <= 99 && q.status !== 'paid' && !yaRechazada) {
    const { anticipo, saldo } = splitAnticipo(totalNum, anticipoPct);
    cobros = [
        { id: '', tipo: 'anticipo', numeroCuota: 0, monto: anticipo, status: 'pendiente', vence: '', venceEnFuturo: false, pagado: false },
        { id: '', tipo: 'saldo', numeroCuota: 0, monto: saldo, status: 'pendiente', vence: q.saldoVence || '', venceEnFuturo: q.pagoDisponible === false, pagado: false },
    ];
}
const nextCobro = cobros.find((co: any) => co.status === 'pendiente' && !co.venceEnFuturo) || null;
const cobroTipoLabel = (co: any) =>
    co.tipo === 'anticipo' ? 'Anticipo'
    : co.tipo === 'saldo' ? 'Saldo'
    : co.tipo === 'cuota' ? `Cuota ${co.numeroCuota}`
    : 'Total';
const montoAPagar = nextCobro ? money(nextCobro.monto) : total;
const orgCobraOnline = (ORG.aceptaTarjeta || ORG.cobroSpeiAuto) && ORG.stripeAccountId && ORG.stripeChargesEnabled;
// Crédito (Net 30/60) SIN cobros parciales y sin nada pagable todavía: en vez
// del botón de pago se muestra la fecha en la que vence el saldo.
const esCreditoPendiente = q.pagoDisponible === false && cobros.length === 0 && !!q.saldoVence;
// Hay plan de cobros pero ninguno pagable hoy (p. ej. anticipo cubierto y saldo
// o cuota con fecha futura): mostrar cuándo es el siguiente pago.
const proxCobro = cobros.find((co: any) => co.status === 'pendiente') || null;
const esperaCobro = cobros.length > 0 && !nextCobro && !!proxCobro;

// Nota bajo el total hero: deja claro que el total es X pero HOY se paga Y.
const pagadoSum = cobros.filter((co: any) => co.pagado).reduce((s: number, co: any) => s + co.monto, 0);
const pendSum = cobros.filter((co: any) => co.status === 'pendiente').reduce((s: number, co: any) => s + co.monto, 0);
let splitNote = '';
if (cobros.length && q.status !== 'paid') {
    const ant = cobros.find((co: any) => co.tipo === 'anticipo');
    const sal = cobros.find((co: any) => co.tipo === 'saldo');
    if (pagadoSum > 0) {
        splitNote = `Pagado: ${money(pagadoSum)} · Pendiente: ${money(pendSum)}`;
    } else if (anticipoPct >= 1 && ant && sal) {
        splitNote = `${viva ? 'Al aprobar pagas' : 'Hoy pagas'} ${money(ant.monto)} de anticipo (${anticipoPct}%) · Saldo: ${money(sal.monto)}${sal.vence ? ` — vence el ${sal.vence}` : ''}`;
    }
}

// Iguala recurrente (retainer): se cobra el total automáticamente cada mes vía
// Stripe Subscription sobre la cuenta conectada del vendedor. Excluyente con
// anticipo/cuotas y con SPEI (una iguala automática necesita tarjeta para renovar).
const esRecurrente = !!q.esRecurrente;
const sus = (q.suscripcion as any) || null;
const susActiva = !!(sus && ['active', 'trialing', 'past_due'].includes(sus.estado));
const montoMensual = money(totalNum);
const orgCobraTarjeta = ORG.aceptaTarjeta && ORG.stripeAccountId && ORG.stripeChargesEnabled;
const puedeAutorizarSus = esRecurrente && !susActiva && orgCobraTarjeta && q.status !== 'paid';
if (esRecurrente && q.status !== 'paid') {
    splitNote = susActiva
        ? `Iguala activa · se cobra ${montoMensual} cada mes`
        : `Iguala mensual · ${montoMensual} cada mes`;
}

// Contacto del vendedor
const vEmail = (ORG.emailContacto ?? '').trim();
const vWa = (ORG.whatsapp ?? '').trim();
const vTel = (ORG.telefono ?? '').trim();
const waDigits = vWa.replace(/\D/g, '');
const hayContacto = !!(vEmail || vWa || vTel);
---

<div class="q-card" data-token={q.token} data-folio={folio} data-iva={ORG.ivaPct} data-pais={ORG.paisCode || 'MX'} data-init={yaAprobada ? 'approved' : yaRechazada ? 'rejected' : 'review'}>
    {ORG.esPrueba && (
        <div class="q-test-ribbon" role="status">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.5 4h-5L7 12h4l-1.5 8L17 9h-4.5z"/></svg>
            Cotización de prueba — sin validez comercial ni fiscal
        </div>
    )}
    {banner && <div class="q-banner" style={`background:${color}`}>{banner}</div>}

    <!-- Cabecera: marca del emisor -->
    <header class="q-header">
        <div class="q-brand-row">
            {logoUrl
                ? <img src={logoUrl} alt={ORG.nombre} class="q-logo-img" />
                : <div class="q-logo-initial" style={`background:${color}`}>{ORG.inicial}</div>
            }
            <div class="q-brand-text">
                <span class="q-company">{ORG.nombre}</span>
                {ORG.rfc && <span class="q-rfc">RFC {ORG.rfc}</span>}
            </div>
        </div>
        <div class="q-folio-tag">
            <span class="q-folio-eyebrow">COTIZACIÓN</span>
            <span class="q-folio-num">{folio}</span>
        </div>
    </header>

    <div class="q-rule"></div>

    <!-- Para / vigencia / términos -->
    <div class="q-meta">
        <div class="q-meta-col">
            <span class="q-meta-label">PARA</span>
            <span class="q-meta-val">{q.cliente}</span>
        </div>
        {q.vigencia && (
            <div class="q-meta-col">
                <span class="q-meta-label">VÁLIDA HASTA</span>
                <span class="q-meta-val">{q.vigencia}</span>
                {vigenciaTexto && (
                    <span class:list={['q-vig-chip', { urgent: vigenciaUrgente || vigenciaVencida }]}>{vigenciaTexto}</span>
                )}
            </div>
        )}
        {q.terminos && (
            <div class="q-meta-col">
                <span class="q-meta-label">TÉRMINOS</span>
                <span class="q-meta-val">{q.terminos}</span>
            </div>
        )}
    </div>

    {bienvenida && <p class="q-welcome">{bienvenida}</p>}

    <!-- Total protagonista -->
    <div class="q-total-hero">
        <div class="q-total-inner">
            <span class="q-total-eyebrow">TOTAL A PAGAR</span>
            <span class="editorial q-total-amount" style={`color:${color}`} data-countup={quoteTotal(q)}>{total}</span>
            <span class="q-total-note">MXN · IVA incluido</span>
            {splitNote && <span class="q-total-split">{splitNote}</span>}
        </div>
    </div>

    <!-- Tabla de conceptos -->
    <div class="q-items">
        <div class="qi-head">
            <span>Concepto</span>
            <span class="qi-center">Cant.</span>
            <span class="qi-right">P. Unit.</span>
            <span class="qi-right">Importe</span>
        </div>
        {q.items.map((it: any) => (
            <div data-line-id={it.id} data-importe={lineTotal(it)} class:list={['qi-row-wrapper', { 'qi-excluida': yaAprobada && it.aprobado === false }]}>
                <div class="qi-row">
                    <span class="qi-name">
                        {!yaAprobada && !yaRechazada && (
                            <label class="qi-pick" title="Incluir esta línea en tu aprobación">
                                <input type="checkbox" class="qi-pick-cb" data-pick={it.id} checked />
                                <span class="qi-pick-box"></span>
                            </label>
                        )}
                        {it.descripcion}
                        {yaAprobada && it.aprobado === false && <span class="qi-excluida-tag">No incluida</span>}
                        {mostrarChat && !yaAprobada && !yaRechazada && (
                            <button class="qi-chat-btn" data-item-id={it.id} aria-label="Comentar en esta línea">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                                {it.comentarios?.length > 0 ? it.comentarios.length : ''}
                            </button>
                        )}
                    </span>
                    <span class="qi-center qi-qty">{it.cantidad.toLocaleString('es-MX')} {it.unidad}</span>
                    <span class="editorial qi-right qi-price">{money(it.precioNegociado ?? it.precioLista)}</span>
                    <span class="editorial qi-right qi-total">{money(lineTotal(it))}</span>
                </div>
                
                {mostrarChat && (
                    <div class="qi-thread ql-hidden" id={`thread-${it.id}`}>
                        <div class="qi-thread-inner">
                            {(it.comentarios || []).map((c: any) => (
                                <div class={`qi-msg ${c.tipo === 'cliente' ? 'mine' : 'theirs'}`}>
                                    <span class="qi-msg-text">{c.contenido}</span>
                                    <span class="qi-msg-time">{c.cuando}</span>
                                </div>
                            ))}
                            {!yaAprobada && !yaRechazada && (
                                <div class="qi-reply-box">
                                    <input type="text" class="ql-input qi-reply-input" placeholder="Comentar sobre esta línea..." />
                                    <button class="ql-ghost qi-reply-btn" data-item-id={it.id}>Enviar</button>
                                </div>
                            )}
                        </div>
                    </div>
                )}
            </div>
        ))}
        <div class="qi-subtotals">
            <div class="qt-row"><span>Subtotal</span><span class="editorial">{money(quoteSubtotal(q))}</span></div>
            <div class="qt-row"><span>IVA {ORG.ivaPct}%</span><span class="editorial">{money(quoteIva(q))}</span></div>
            <div class="qt-row qt-grand"><span>Total</span><span class="editorial">{money(quoteTotal(q))}</span></div>
        </div>
    </div>

    {q.notas && <p class="q-notes">{q.notas}</p>}

    {viva && (
        <div class="q-trust">
            <span class="q-trust-live"><span class="q-live-dot"></span> Conectado en tiempo real</span>
            <span class="q-trust-secure">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                Cifrado · firma con validez legal{ORG.paisCode === 'MX' ? ' · CFDI 4.0' : ''}
            </span>
        </div>
    )}

    <!-- ──────────────────────────────────────────
         ÁREA DE ACCIÓN — flujo de aprobación en pasos
    ────────────────────────────────────────── -->
    <div class="q-actions-area">

        <!-- Paso: review (default si cotización viva) -->
        <div class="ql-step" id="stepReview">
            <div class="ql-partial" id="qPartialNote" hidden>
                Aprobarás <b id="qPartialCount"></b> · Total a aprobar: <b class="editorial" id="qPartialTotal"></b>
            </div>
            <button class="ql-cta" id="qApproveBtn" style={`background:${color}`}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Aprobar cotización
            </button>
            <div class="ql-secondary-row">
                <button class="ql-ghost" id="qPdfBtn">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    Descargar PDF
                </button>
                <button class="ql-ghost ql-reject-link" id="qRejectOpenBtn">Rechazar</button>
            </div>
        </div>

        <!-- Paso: firma digital -->
        <div class="ql-step ql-hidden" id="stepSign">
            <div class="ql-step-header">
                <button class="ql-back" id="qSignBack" aria-label="Volver">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <span class="ql-step-title">Firma digital</span>
            </div>
            <div class="ql-summary-pill">
                Aprobando <strong>{folio}</strong> por <strong style={`color:${color}`}>{total} MXN</strong>
            </div>
            <div class="ql-field">
                <label class="ql-label" for="qSignerName">Nombre completo del firmante</label>
                <input class="ql-input" id="qSignerName" type="text" autocomplete="name" placeholder="Ej. María García López" />
            </div>
            <div class="ql-field">
                <label class="ql-label" for="qSignerEmail">Correo electrónico (opcional)</label>
                <input class="ql-input" id="qSignerEmail" type="email" autocomplete="email" placeholder="Ej. maria@empresa.com" />
            </div>
            <label class="ql-check-row">
                <input type="checkbox" id="qTermsCheck" class="ql-checkbox" />
                <span class="ql-check-text">He revisado esta cotización y acepto los términos y condiciones indicados</span>
            </label>
            <button class="ql-cta" id="qConfirmSign" style={`background:${color}`} disabled>
                Confirmar y firmar
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>
            <p class="ql-error" id="qSignError"></p>
            <div class="ql-legal-box">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                <span>Firma electrónica con validez legal. Tu nombre, IP y la fecha quedarán vinculados a un hash inmutable de esta cotización.</span>
            </div>
        </div>

        <!-- Paso: rechazo -->
        <div class="ql-step ql-hidden" id="stepReject">
            <div class="ql-step-header">
                <button class="ql-back" id="qRejectBack" aria-label="Volver">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <span class="ql-step-title">Rechazar cotización</span>
            </div>
            <div class="ql-field">
                <label class="ql-label" for="qRejectMsg">Motivo (opcional — ayuda al vendedor a mejorar)</label>
                <textarea class="ql-input ql-textarea" id="qRejectMsg" rows="3" placeholder="Ej. El precio está fuera de presupuesto, necesitamos más tiempo…"></textarea>
            </div>
            <button class="ql-cta ql-danger" id="qConfirmReject">Confirmar rechazo</button>
            <p class="ql-error" id="qRejectError"></p>
        </div>

        <!-- Estado: aprobada -->
        <div class="ql-step ql-hidden" id="stepApproved">
            <div class="ql-success">
                <div class="ql-check-ring">
                    <svg class="ql-check-svg" viewBox="0 0 52 52">
                        <circle class="ql-check-circle" cx="26" cy="26" r="23" fill="none" stroke={color} stroke-width="2"/>
                        <polyline class="ql-check-mark" points="14,27 22,35 38,18" fill="none" stroke={color} stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <span class="ql-done-title">Cotización aprobada</span>
                <span class="ql-done-sub" id="qApprovedSub">
                    {ORG.nombre} recibió tu confirmación y se pondrá en contacto contigo en breve.
                </span>
                <div class="ql-done-actions">
                    {esperaCobro && (
                        <div class="ql-credit-note">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="3" fill="currentColor" fill-opacity="0.08"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M9 15l2 2 4-4"/></svg>
                            <div class="ql-credit-text">
                                <strong>No tienes pagos pendientes por ahora</strong>
                                <span>
                                    Tu siguiente pago es el {cobroTipoLabel(proxCobro).toLowerCase()} de {money(proxCobro.monto)}{proxCobro.vence ? `, el ${proxCobro.vence}` : ''}.
                                    {orgCobraOnline ? ' Podrás pagarlo en línea desde este mismo link cuando llegue la fecha.' : ''}
                                </span>
                            </div>
                        </div>
                    )}
                    {esCreditoPendiente && (
                        <div class="ql-credit-note">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="3" fill="currentColor" fill-opacity="0.08"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M9 15l2 2 4-4"/></svg>
                            <div class="ql-credit-text">
                                <strong>Pedido confirmado con crédito {q.terminos}</strong>
                                <span>
                                    El pago de {total} MXN vence el {q.saldoVence}.
                                    {orgCobraOnline ? ' Cuando llegue la fecha podrás pagar en línea desde este mismo link.' : ' Coordina el pago directamente con el vendedor.'}
                                </span>
                            </div>
                        </div>
                    )}
                    {cobros.length > 0 && (
                        <div class="ql-cobros">
                            <div class="ql-cobros-title">Plan de pago</div>
                            {cobros.map((co: any) => (
                                <div class:list={['ql-cobro-row', { paid: co.pagado, cancelled: co.status === 'cancelado' }]}>
                                    <span class="ql-cobro-tipo">{cobroTipoLabel(co)}</span>
                                    <span class="editorial ql-cobro-monto">{money(co.monto)}</span>
                                    <span class="ql-cobro-status">
                                        {co.pagado ? 'Pagado' : co.status === 'cancelado' ? 'Cancelado' : co.venceEnFuturo ? `Vence el ${co.vence}` : 'Por pagar'}
                                    </span>
                                </div>
                            ))}
                        </div>
                    )}
                    {esRecurrente && susActiva && (
                        <div class="ql-credit-note ql-sub-active">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l8 3v6c0 5-3.4 9-8 11-4.6-2-8-6-8-11V5z" fill="currentColor" fill-opacity="0.1"/><polyline points="8.5 12 11 14.5 15.5 9"/></svg>
                            <div class="ql-credit-text">
                                <strong>Iguala activa</strong>
                                <span>
                                    Se te cobra {montoMensual} cada mes automáticamente con tu tarjeta{sus && sus.currentPeriodEnd ? ` — próximo cargo el ${sus.currentPeriodEnd}` : ''}. Para cancelar, contacta a {ORG.nombre}.
                                </span>
                            </div>
                        </div>
                    )}
                    {puedeAutorizarSus && (
                        <div class="ql-pay">
                            <div class="ql-sub-copy">
                                <strong>Autoriza tu iguala mensual</strong>
                                <span>Se cobrará <b>{montoMensual}</b> a tu tarjeta hoy y ese mismo monto automáticamente cada mes, hasta que se cancele. Puedes cancelar cuando quieras.</span>
                            </div>
                            <button class="ql-cta" id="qSubBtn" style={`background:${color}`}>
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                Autorizar cobro mensual
                            </button>
                            <div class="ql-pay-secure">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                Suscripción con tarjeta · procesada por Stripe
                                <span class="ql-pay-cards"><span>VISA</span><span>MASTERCARD</span><span>AMEX</span></span>
                            </div>
                        </div>
                    )}
                    {puedePagar && !esRecurrente && (
                        <div class="ql-pay-options">
                            {ORG.aceptaTransferencia && (
                                <div class="ql-pay-transfer">
                                    <div class="ql-transfer-title">Datos para transferencia bancaria</div>
                                    <div class="ql-transfer-details">
                                        <div class="ql-transfer-row"><span>Banco</span><strong>{ORG.bancoNombre || 'N/A'}</strong></div>
                                        <div class="ql-transfer-row"><span>CLABE</span><strong>{ORG.bancoClabe || 'N/A'}</strong></div>
                                        <div class="ql-transfer-row"><span>Beneficiario</span><strong>{ORG.bancoBeneficiario || 'N/A'}</strong></div>
                                        <div class="ql-transfer-note">Tras transferir, envía tu comprobante al vendedor para confirmar el pago.</div>
                                    </div>
                                </div>
                            )}

                            {ORG.aceptaTransferencia && (ORG.aceptaTarjeta || ORG.cobroSpeiAuto) && ORG.stripeAccountId && ORG.stripeChargesEnabled && (
                                <div class="ql-pay-divider">O paga en línea</div>
                            )}

                            {(ORG.aceptaTarjeta || ORG.cobroSpeiAuto) && ORG.stripeAccountId && ORG.stripeChargesEnabled && (
                                <div class="ql-pay">
                                    <div class="ql-pay-amount">
                                        <span class="ql-pay-label">{nextCobro && nextCobro.tipo !== 'total' ? `A PAGAR AHORA · ${cobroTipoLabel(nextCobro).toUpperCase()}` : 'A PAGAR AHORA'}</span>
                                        <span class="editorial ql-pay-total" style={`color:${color}`}>{montoAPagar} <small>MXN</small></span>
                                    </div>
                                    <button class="ql-cta" id="qPayBtn" style={`background:${color}`}>
                                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                        {ORG.aceptaTarjeta ? 'Pagar de forma segura' : 'Pagar por transferencia (SPEI)'}
                                    </button>
                                    <div class="ql-pay-secure">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                        {ORG.aceptaTarjeta && ORG.cobroSpeiAuto ? 'Tarjeta o transferencia SPEI · vía Stripe' : ORG.cobroSpeiAuto ? 'Transferencia SPEI con CLABE · vía Stripe' : 'Pago protegido vía Stripe'}
                                        {ORG.aceptaTarjeta && <span class="ql-pay-cards"><span>VISA</span><span>MASTERCARD</span><span>AMEX</span></span>}
                                    </div>
                                </div>
                            )}
                        </div>
                    )}
                    <button class="ql-ghost" id="qPdfApproved" style="margin-top: 1rem;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                        Descargar comprobante
                    </button>
                </div>
                {q.firma ? (
                    <div class="ql-audit-stamp">
                        <div class="ql-audit-header">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l8 3v6c0 5-3.4 9-8 11-4.6-2-8-6-8-11V5z" fill="currentColor" fill-opacity="0.14"/><polyline points="8.5 12 11 14.5 15.5 9"/></svg>
                            <span>Documento verificado{ORG.paisCode === 'MX' ? ' · Listo para CFDI 4.0' : ''}</span>
                        </div>
                        <div class="ql-audit-row"><strong>Firmante:</strong> {q.firma.nombre} (IP: {q.firma.ip})</div>
                        <div class="ql-audit-row"><strong>Fecha:</strong> {q.firma.cuando}</div>
                        <div class="ql-audit-row"><strong>Sello:</strong> <span class="ql-hash">{q.firma.hash}</span></div>
                    </div>
                ) : (
                    <p class="ql-stamp" id="qSignedStamp"></p>
                )}
            </div>
        </div>

        <!-- Estado: rechazada -->
        <div class="ql-step ql-hidden" id="stepRejected">
            <div class="ql-success">
                <div class="ql-check-ring ql-reject-ring">
                    <svg viewBox="0 0 52 52" width="68" height="68">
                        <circle cx="26" cy="26" r="23" fill="none" stroke="#d1d5db" stroke-width="2"/>
                        <line x1="16" y1="16" x2="36" y2="36" stroke="#9ca3af" stroke-width="2.8" stroke-linecap="round"/>
                        <line x1="36" y1="16" x2="16" y2="36" stroke="#9ca3af" stroke-width="2.8" stroke-linecap="round"/>
                    </svg>
                </div>
                <span class="ql-done-title" style="color:#6b7280">Cotización rechazada</span>
                <span class="ql-done-sub">Le notificamos a {ORG.nombre}. Si cambias de opinión, contáctalos directamente.</span>
            </div>
        </div>
    </div>

    <!-- Conversación + chat directo -->
    {mostrarChat && (
        <div class="q-chat">
            <div class="q-thread" id="qThread" hidden={conversacion.length === 0}>
                <div class="q-chat-eyebrow">CONVERSACIÓN</div>
                {conversacion.map((m) => (
                    <div class:list={['q-msg', m.mine ? 'mine' : 'theirs', { counter: m.tipo === 'counter' }]}>
                        <span class="q-msg-text">{m.detalle}</span>
                        <span class="q-msg-time">{m.cuando}</span>
                    </div>
                ))}
            </div>

            {!yaAprobada && !yaRechazada && (
                <div class="q-compose" data-token={q.token}>
                    <div class="q-compose-row">
                        <textarea
                            class="q-compose-ta"
                            id="qMsg"
                            rows="1"
                            placeholder="Escribe un mensaje o propuesta…"
                        ></textarea>
                        <button class="q-compose-send" id="qSendMsg" aria-label="Enviar" style={`background:${color}`}>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                        </button>
                    </div>
                    <div class="q-compose-extras">
                        <input class="q-compose-price" type="number" id="qProp" min="0" step="100" placeholder="Propuesta en MXN (opcional)" />
                        <button class="q-counter-pill" id="qSendCounter" style={`color:${color}; border-color:${color}`}>
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                            Contraoferta
                        </button>
                    </div>
                    <p class="q-compose-ok" id="qNegOk" hidden>Enviado. {ORG.nombre} lo verá al instante.</p>
                    <p class="ql-error" id="qNegErr"></p>
                </div>
            )}
        </div>
    )}

    {hayContacto && (
        <div class="q-contact">
            <span class="q-contact-label">¿Dudas sobre esta cotización? Contacta a {ORG.nombre}</span>
            <div class="q-contact-links">
                {vWa && (
                    <a class="q-contact-link" href={`https://wa.me/${waDigits}`} target="_blank" rel="noopener">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.15-1.7-.85-2-.95-.26-.1-.46-.15-.65.15-.2.3-.74.94-.9 1.13-.17.2-.34.22-.63.07-.3-.15-1.25-.46-2.38-1.47-.88-.78-1.47-1.75-1.64-2.04-.17-.3-.02-.46.13-.6.13-.14.3-.34.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.65-1.57-.9-2.15-.24-.56-.48-.48-.65-.49h-.56c-.2 0-.5.07-.77.37-.26.3-1 .98-1 2.4 0 1.4 1.03 2.76 1.17 2.96.14.2 2.02 3.08 4.9 4.32.68.3 1.22.47 1.64.6.69.22 1.31.19 1.8.12.55-.08 1.7-.7 1.94-1.36.24-.67.24-1.24.17-1.36-.07-.12-.26-.2-.56-.34zM12 2a10 10 0 0 0-8.6 15.06L2 22l5.06-1.33A10 10 0 1 0 12 2z"/></svg>
                        WhatsApp
                    </a>
                )}
                {vEmail && (
                    <a class="q-contact-link" href={`mailto:${vEmail}`}>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg>
                        Correo
                    </a>
                )}
                {vTel && (
                    <a class="q-contact-link" href={`tel:${vTel}`}>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                        Llamar
                    </a>
                )}
            </div>
        </div>
    )}

    {ORG.portalPowered !== false && (
        <div class="q-cord-badge">
            <span class="q-cord-badge-trust">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l8 3v6c0 5-3.4 9-8 11-4.6-2-8-6-8-11V5z" fill="currentColor" fill-opacity="0.14"/><polyline points="8.5 12 11 14.5 15.5 9"/></svg>
                Firma con validez legal{ORG.paisCode === 'MX' ? ' · Listo para CFDI 4.0' : ''}
            </span>
            <a href="https://cordhq.app" class="q-cord-badge-cta" target="_blank" rel="noopener">
                Verificado por <img src="/imgs/logo-cord-navy.png" alt="Cord" /> — crea las tuyas gratis →
            </a>
        </div>
    )}
</div>

{standalone && viva && (
    <div class="q-sticky" id="qSticky" aria-hidden="true">
        <div class="q-sticky-inner">
            <div class="q-sticky-info">
                <span class="q-sticky-label">Total a pagar</span>
                <span class="editorial q-sticky-total" style={`color:${color}`}>{total}</span>
            </div>
            <button class="q-sticky-cta" id="qStickyApprove" style={`background:${color}`}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Aprobar
            </button>
        </div>
    </div>
)}

<script>
    const card = document.querySelector('.q-card') as HTMLElement | null;
    const folio = card?.dataset.folio ?? '';
    const token = card?.dataset.token ?? '';

    const emit = (name: string, detail: Record<string, unknown> = {}) =>
        window.dispatchEvent(new CustomEvent(name, { detail: { token, folio, ...detail } }));

    // ── Pasos ──
    const showStep = (id: string) => {
        document.querySelectorAll<HTMLElement>('.ql-step').forEach(s => {
            const active = s.id === id;
            s.classList.toggle('ql-hidden', !active);
            if (active) {
                s.classList.remove('ql-hidden');
                void s.offsetHeight; // reflow para trigger animation
                s.classList.add('ql-entering');
                s.addEventListener('animationend', () => s.classList.remove('ql-entering'), { once: true });
            }
        });
    };

    // Estado inicial
    const initStep = (() => {
        // yaAprobada / yaRechazada vienen del SSR en data-init
        const init = card?.dataset.init;
        if (init === 'approved') return 'stepApproved';
        if (init === 'rejected') return 'stepRejected';
        return 'stepReview';
    })();
    showStep(initStep);

    // ── Helper fetch ──
    const api = async (action: string, extra: Record<string, unknown> = {}) => {
        const res = await fetch(`/api/q/${token}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action, ...extra }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Error inesperado');
        return data;
    };

    // ── Aprobación parcial: selección de líneas + total en vivo ──
    const ivaPct = Number((document.querySelector('.q-card') as HTMLElement)?.dataset.iva ?? '16') / 100;
    const moneyFmt = (n: number) => '$' + new Intl.NumberFormat('es-MX', { minimumFractionDigits: 2 }).format(n);
    const picks = Array.from(document.querySelectorAll<HTMLInputElement>('.qi-pick-cb'));
    const approveBtn = document.getElementById('qApproveBtn') as HTMLButtonElement | null;
    const partialNote = document.getElementById('qPartialNote');

    function acceptedIds(): string[] {
        return picks.filter(p => p.checked).map(p => p.dataset.pick!).filter(Boolean);
    }
    function refreshSelection() {
        if (!picks.length) return;
        const total = picks.length;
        const sel = picks.filter(p => p.checked);
        const n = sel.length;
        // Subtotal de lo seleccionado (data-importe ya es el importe por línea, sin IVA).
        let sub = 0;
        sel.forEach(p => {
            const w = p.closest('.qi-row-wrapper') as HTMLElement | null;
            sub += Number(w?.dataset.importe ?? 0);
            if (w) w.classList.toggle('qi-deseleccionada', false);
        });
        picks.filter(p => !p.checked).forEach(p => {
            const w = p.closest('.qi-row-wrapper') as HTMLElement | null;
            if (w) w.classList.toggle('qi-deseleccionada', true);
        });
        if (approveBtn) approveBtn.disabled = n === 0;
        // Solo mostramos la nota cuando es una selección PARCIAL (no todas).
        if (partialNote) {
            if (n > 0 && n < total) {
                partialNote.hidden = false;
                const cnt = document.getElementById('qPartialCount');
                const tot = document.getElementById('qPartialTotal');
                if (cnt) cnt.textContent = `${n} de ${total} líneas`;
                if (tot) tot.textContent = moneyFmt(sub * (1 + ivaPct));
            } else {
                partialNote.hidden = true;
            }
        }
    }
    picks.forEach(p => p.addEventListener('change', refreshSelection));
    refreshSelection();

    // ── Abrir firma ──
    approveBtn?.addEventListener('click', () => {
        if (picks.length && acceptedIds().length === 0) return;
        showStep('stepSign');
        (document.getElementById('qSignerName') as HTMLInputElement | null)?.focus();
    });

    // ── Habilitar botón de firma ──
    const nameInput = document.getElementById('qSignerName') as HTMLInputElement | null;
    const emailInput = document.getElementById('qSignerEmail') as HTMLInputElement | null;
    const termsCheck = document.getElementById('qTermsCheck') as HTMLInputElement | null;
    const confirmSignBtn = document.getElementById('qConfirmSign') as HTMLButtonElement | null;
    const updateSignBtn = () => {
        if (!confirmSignBtn) return;
        confirmSignBtn.disabled = !((nameInput?.value.trim().length ?? 0) >= 2 && termsCheck?.checked);
    };
    nameInput?.addEventListener('input', updateSignBtn);
    termsCheck?.addEventListener('change', updateSignBtn);

    // ── Confirmar firma ──
    confirmSignBtn?.addEventListener('click', async () => {
        const signedBy = nameInput?.value.trim() ?? '';
        const email = emailInput?.value.trim() ?? '';
        const errEl = document.getElementById('qSignError');
        if (errEl) errEl.textContent = '';
        confirmSignBtn.disabled = true;
        confirmSignBtn.textContent = 'Firmando…';
        try {
            const res = await api('approve', { signed_by: signedBy, email, accepted_items: acceptedIds() });
            const stamp = document.getElementById('qSignedStamp');
            if (stamp && signedBy) {
                // MISMO markup que el render del servidor (.ql-audit-stamp). Sus
                // estilos viven en <style is:global> porque este DOM se inyecta
                // en runtime y no lleva data-astro-cid (regla del proyecto).
                const now = new Date().toLocaleString('es-MX', { dateStyle: 'long', timeStyle: 'short' });
                const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
                const pais = card?.dataset.pais || 'MX';
                stamp.outerHTML = `<div class="ql-audit-stamp">
                    <div class="ql-audit-header">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l8 3v6c0 5-3.4 9-8 11-4.6-2-8-6-8-11V5z" fill="currentColor" fill-opacity="0.14"/><polyline points="8.5 12 11 14.5 15.5 9"/></svg>
                        <span>Documento verificado${pais === 'MX' ? ' · Listo para CFDI 4.0' : ''}</span>
                    </div>
                    <div class="ql-audit-row"><strong>Firmante:</strong> ${esc(signedBy)}</div>
                    <div class="ql-audit-row"><strong>Fecha:</strong> ${esc(now)}</div>
                    <div class="ql-audit-row"><strong>Sello:</strong> <span class="ql-hash">${esc(String(res.hash ?? ''))}</span></div>
                </div>`;
            }
            showStep('stepApproved');
            emit('cord:approved', { signed_by: signedBy, hash: res.hash });
            emit('cord:signed', { signed_by: signedBy, hash: res.hash });
        } catch (err: any) {
            if (errEl) errEl.textContent = (err as Error).message;
            confirmSignBtn.disabled = false;
            confirmSignBtn.textContent = 'Confirmar y firmar';
        }
    });

    document.getElementById('qSignBack')?.addEventListener('click', () => showStep('stepReview'));

    // ── Abrir rechazo ──
    document.getElementById('qRejectOpenBtn')?.addEventListener('click', () => {
        showStep('stepReject');
        (document.getElementById('qRejectMsg') as HTMLTextAreaElement | null)?.focus();
    });
    document.getElementById('qRejectBack')?.addEventListener('click', () => showStep('stepReview'));

    // ── Confirmar rechazo ──
    document.getElementById('qConfirmReject')?.addEventListener('click', async (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        const errEl = document.getElementById('qRejectError');
        const comentario = (document.getElementById('qRejectMsg') as HTMLTextAreaElement | null)?.value.trim() ?? '';
        if (errEl) errEl.textContent = '';
        btn.disabled = true;
        btn.textContent = 'Procesando…';
        try {
            await api('reject', { comentario });
            showStep('stepRejected');
            emit('cord:rejected', { comentario });
        } catch (err: any) {
            if (errEl) errEl.textContent = (err as Error).message;
            btn.disabled = false;
            btn.textContent = 'Confirmar rechazo';
        }
    });

    // ── PDF ──
    document.getElementById('qPdfBtn')?.addEventListener('click', () => window.print());
    document.getElementById('qPdfApproved')?.addEventListener('click', () => window.print());

    // ── Pago en línea ──
    document.getElementById('qPayBtn')?.addEventListener('click', async (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        btn.disabled = true;
        btn.textContent = 'Redirigiendo…';
        try {
            const url = `/q/${token}/pay`;
            emit('cord:pay', { url });
            window.location.href = url;
        } catch (err: any) {
            alert((err as Error).message);
            btn.disabled = false;
            btn.textContent = 'Pagar en línea';
        }
    });

    // ── Autorizar iguala recurrente (misma página de pago, modo suscripción) ──
    document.getElementById('qSubBtn')?.addEventListener('click', (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        btn.disabled = true;
        btn.textContent = 'Redirigiendo…';
        const url = `/q/${token}/pay`;
        emit('cord:pay', { url });
        window.location.href = url;
    });

    // ── Conversación / negociación ──
    const thread = document.getElementById('qThread');
    const negOk = document.getElementById('qNegOk');
    const negErr = document.getElementById('qNegErr');
    const msgEl = document.getElementById('qMsg') as HTMLTextAreaElement | null;
    const propEl = document.getElementById('qProp') as HTMLInputElement | null;

    const appendMsg = (text: string, kind: 'comment' | 'counter') => {
        if (!thread) return;
        thread.hidden = false;
        const div = document.createElement('div');
        div.className = 'q-msg mine' + (kind === 'counter' ? ' counter' : '');
        const t = document.createElement('span'); t.className = 'q-msg-text'; t.textContent = text;
        const time = document.createElement('span'); time.className = 'q-msg-time'; time.textContent = 'ahora';
        div.append(t, time);
        thread.appendChild(div);
        requestAnimationFrame(() => { thread.scrollTop = thread.scrollHeight; });
    };

    // Mensaje entrante del VENDEDOR (vía SSE) — burbuja izquierda, sin recargar.
    const appendIncoming = (text: string) => {
        if (!thread) return;
        thread.hidden = false;
        const div = document.createElement('div');
        div.className = 'q-msg theirs';
        const t = document.createElement('span'); t.className = 'q-msg-text'; t.textContent = text;
        const time = document.createElement('span'); time.className = 'q-msg-time'; time.textContent = 'ahora';
        div.append(t, time);
        thread.appendChild(div);
        requestAnimationFrame(() => { thread.scrollTop = thread.scrollHeight; });
    };

    // ── Auto-resize del compose textarea ──
    (() => {
        const ta = document.getElementById('qMsg') as HTMLTextAreaElement | null;
        if (!ta) return;
        const resize = () => {
            ta.style.height = 'auto';
            ta.style.height = Math.min(ta.scrollHeight, 110) + 'px';
        };
        ta.addEventListener('input', resize);
    })();

    const sendNeg = async (action: 'comment' | 'counter', btn: HTMLButtonElement) => {
        const mensaje = msgEl?.value.trim() ?? '';
        const propuesta = action === 'counter' ? Number(propEl?.value || 0) : 0;
        if (negErr) negErr.textContent = '';
        if (action === 'comment' && !mensaje) { if (negErr) negErr.textContent = 'Escribe un mensaje.'; return; }
        if (action === 'counter' && !mensaje && !propuesta) { if (negErr) negErr.textContent = 'Indica tu propuesta o escribe un mensaje.'; return; }
        btn.disabled = true;
        try {
            await api(action, { mensaje, propuesta });
            const label = action === 'counter' && propuesta
                ? `Propuesta: $${propuesta.toLocaleString('es-MX')}${mensaje ? ` — ${mensaje}` : ''}`
                : mensaje;
            appendMsg(label, action);
            if (msgEl) msgEl.value = '';
            if (propEl) propEl.value = '';
            if (negOk) negOk.hidden = false;
            emit('cord:message', { action, mensaje, propuesta });
        } catch (err: any) {
            if (negErr) negErr.textContent = (err as Error).message;
        } finally {
            btn.disabled = false;
        }
    };

    document.getElementById('qSendMsg')?.addEventListener('click', (e) => sendNeg('comment', e.currentTarget as HTMLButtonElement));
    document.getElementById('qSendCounter')?.addEventListener('click', (e) => sendNeg('counter', e.currentTarget as HTMLButtonElement));

    // ── Comentarios por línea ──
    document.querySelectorAll('.qi-chat-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            const itemId = (e.currentTarget as HTMLElement).dataset.itemId;
            if (!itemId) return;
            const thread = document.getElementById(`thread-${itemId}`);
            if (thread) {
                thread.classList.toggle('ql-hidden');
            }
        });
    });

    document.querySelectorAll('.qi-reply-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
            const target = e.currentTarget as HTMLButtonElement;
            const itemId = target.dataset.itemId;
            const input = target.previousElementSibling as HTMLInputElement;
            const mensaje = input?.value.trim();
            if (!itemId || !mensaje) return;

            target.disabled = true;
            try {
                await api('item_comment', { item_id: itemId, mensaje });
                
                // Agregarlo a la UI localmente
                const threadInner = target.closest('.qi-thread-inner');
                const div = document.createElement('div');
                div.className = 'qi-msg mine';
                const t = document.createElement('span'); t.className = 'qi-msg-text'; t.textContent = mensaje;
                const time = document.createElement('span'); time.className = 'qi-msg-time'; time.textContent = 'ahora';
                div.append(t, time);
                threadInner?.insertBefore(div, target.closest('.qi-reply-box'));
                
                input.value = '';
                emit('cord:item_comment', { item_id: itemId, mensaje });
            } catch (err: any) {
                alert((err as Error).message);
            } finally {
                target.disabled = false;
            }
        });
    });

    // ── Heartbeat de presencia ──
    if (token) {
        const ping = () => {
            if (document.visibilityState !== 'visible') return;
            fetch(`/api/q/${token}`, {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ action: 'ping' }), keepalive: true,
            }).catch(() => {});
        };
        ping();
        setInterval(ping, 10000);
        document.addEventListener('visibilitychange', () => { if (document.visibilityState === 'visible') ping(); });
    }

    // ── Tiempo real: respuestas del vendedor en vivo (SSE, sin recargar) ──
    if (token && typeof EventSource !== 'undefined') {
        let es: EventSource | null = null;
        const connect = () => {
            es = new EventSource(`/api/q/${token}/stream`);
            es.addEventListener('message', (e: MessageEvent) => {
                try {
                    const d = JSON.parse(e.data);
                    if (d?.detalle) appendIncoming(d.detalle);
                } catch { /* ignora */ }
            });
            es.addEventListener('status', () => {
                // El estado cambió del lado del vendedor (ej. se marcó pagada) —
                // el snapshot vivo de este script no cubre todos los estados,
                // así que la forma segura de reflejarlo es recargar.
                location.reload();
            });
            es.onerror = () => { es?.close(); setTimeout(connect, 4000); };
        };
        connect();
        document.addEventListener('visibilitychange', () => {
            if (document.visibilityState === 'visible' && es?.readyState === EventSource.CLOSED) connect();
        });
    }

    // ── Micro-lujo: count-up del total ──
    (() => {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const el = document.querySelector('.q-total-amount') as HTMLElement | null;
        const raw = el?.dataset.countup;
        if (!el || !raw) return;
        const target = parseFloat(raw);
        if (!isFinite(target) || target <= 0) return;
        const fmt = (n: number) => '$' + new Intl.NumberFormat('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
        const dur = 1000; let t0 = 0;
        const tick = (t: number) => {
            if (!t0) t0 = t;
            const p = Math.min((t - t0) / dur, 1);
            el.textContent = fmt(target * (1 - Math.pow(1 - p, 3)));
            if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
    })();

    // ── Micro-lujo: reveal escalonado de las líneas ──
    (() => {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        document.querySelectorAll<HTMLElement>('.qi-row-wrapper').forEach((r, i) => {
            r.style.animationDelay = (0.04 + i * 0.05) + 's';
            r.classList.add('qi-reveal');
        });
    })();

    // ── Barra de acción flotante (sticky) ──
    (() => {
        const sticky = document.getElementById('qSticky');
        if (!sticky) return;
        const realCta = document.getElementById('qApproveBtn');
        const inReview = () => !document.getElementById('stepReview')?.classList.contains('ql-hidden');
        const setVisible = (v: boolean) => sticky.classList.toggle('q-sticky-show', v && inReview());
        document.getElementById('qStickyApprove')?.addEventListener('click', () => {
            document.querySelector('.q-actions-area')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
            setVisible(false);
            setTimeout(() => realCta?.click(), 450);
        });
        realCta?.addEventListener('click', () => setVisible(false));
        if ('IntersectionObserver' in window && realCta) {
            const io = new IntersectionObserver((entries) => {
                setVisible(!(entries[0]?.isIntersecting ?? false));
            }, { threshold: 0.4 });
            io.observe(realCta);
        } else {
            setVisible(true);
        }
    })();
</script>

