---
// /src/components/support/SupportHero.astro
import BlueAuroraBg from './BlueAuroraBg.jsx'
const { isEn = false } = Astro.props;
---

<section class="support-hero">
    <!-- Fondo: color sólido mientras el shader carga (evita flash blanco) -->
    <div class="sh-bg" aria-hidden="true">
        <BlueAuroraBg client:only="react" />
    </div>

    <!-- Contenido sobre el shader -->
    <div class="hero-content">
        <p class="sh-eyebrow reveal">{isEn ? 'HELP CENTER' : 'CENTRO DE AYUDA'}</p>
        <h1 class="sh-h1 masked-title">{isEn ? 'How can we help you?' : '¿Cómo podemos ayudarte?'}</h1>

        <div class="search-container reveal">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input
                type="text"
                id="support-search-input"
                placeholder={isEn ? "Search guides, troubleshooting and more..." : "Busca guías, solución de problemas y más..."}
                class="search-input"
                autocomplete="off"
            />
            <div id="search-results-dropdown" class="search-dropdown hidden"></div>
        </div>

    </div>
</section>

<style>
    /* ── Hero shell ─────────────────────────────────────────────────────────── */
    .support-hero {
        position: relative;
        z-index: 10;
        overflow-x: clip;
        overflow-y: visible;
    }

    /* Fondo oscuro: el color base coincide con el colorBase del shader para
       que no haya flash mientras WebGL inicializa */
    .sh-bg {
        position: absolute;
        inset: 0;
        background: #030d16;
        z-index: 0;
    }

    /* ── Contenido ──────────────────────────────────────────────────────────── */
    .hero-content {
        position: relative;
        z-index: 2;
        text-align: center;
        max-width: 740px;
        margin: 0 auto;
        /* Compacto como ElevenLabs: el hero no es viewport completo */
        padding: 7rem 5% 3.5rem;
    }

    /* ── Eyebrow ────────────────────────────────────────────────────────────── */
    .sh-eyebrow {
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: rgba(148, 187, 233, 0.70);
        margin: 0 0 1.4rem;
    }

    /* ── Título ─────────────────────────────────────────────────────────────── */
    .sh-h1 {
        font-size: clamp(2.4rem, 5.4vw, 4.2rem);
        font-weight: 800;
        line-height: 1.04;
        letter-spacing: -0.035em;
        color: #ffffff;
        margin: 0 0 2.8rem;
    }

    /* ── Barra de búsqueda ──────────────────────────────────────────────────── */
    .search-container {
        position: relative;
        width: 100%;
        max-width: 640px;
        margin: 0 auto;
        border-radius: 16px;
        transition: transform 0.4s var(--ease-spring), box-shadow 0.4s var(--ease-spring);
    }
    .search-container:hover,
    .search-container:focus-within {
        transform: translateY(-3px);
        box-shadow: 0 24px 60px rgba(13, 71, 227, 0.18), 0 0 0 1px rgba(255,255,255,0.14);
    }

    .search-icon {
        position: absolute;
        left: 24px;
        top: 50%;
        transform: translateY(-50%);
        width: 22px;
        height: 22px;
        color: rgba(255, 255, 255, 0.45);
        pointer-events: none;
        transition: color 0.3s ease;
    }
    .search-container:focus-within .search-icon {
        color: rgba(255, 255, 255, 0.85);
    }

    .search-input {
        width: 100%;
        padding: 22px 24px 22px 62px;
        font-size: 1.1rem;
        font-family: var(--font-sans);
        font-weight: 500;
        color: #ffffff;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 16px;
        outline: none;
        background: rgba(255, 255, 255, 0.07);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        transition: border-color 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
    }
    .search-input:focus {
        border-color: rgba(100, 160, 255, 0.40);
        background: rgba(255, 255, 255, 0.10);
        box-shadow: 0 0 0 4px rgba(13, 71, 227, 0.14), inset 0 1px 0 rgba(255,255,255,0.08);
    }
    .search-input::placeholder {
        color: rgba(255, 255, 255, 0.38);
        font-weight: 400;
    }


    /* ── Dropdown de resultados ─────────────────────────────────────────────── */
    .search-dropdown {
        position: absolute;
        top: calc(100% + 10px);
        left: 0;
        right: 0;
        background: #ffffff;
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12), 0 2px 8px rgba(0, 0, 0, 0.06);
        max-height: 400px;
        overflow-y: auto;
        z-index: 9999;
        text-align: left;
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
        transition: all 0.25s var(--ease-spring);
    }
    .search-dropdown.hidden {
        opacity: 0;
        visibility: hidden;
        transform: translateY(-8px);
        pointer-events: none;
    }

    :global(.search-result-item) {
        display: block;
        padding: 14px 22px;
        text-decoration: none;
        color: var(--color-text, #050505);
        border-bottom: 1px solid rgba(0,0,0,0.06);
        transition: background 0.15s;
    }
    :global(.search-result-item:last-child) { border-bottom: none; }
    :global(.search-result-item:hover),
    :global(.search-result-item.active) {
        background: #f5f5f7;
    }
    :global(.sr-title) {
        font-weight: 600;
        font-size: 0.975rem;
        color: var(--color-blue-deep, #0a192f);
        margin-bottom: 3px;
    }
    :global(.sr-title mark) {
        background: rgba(13,71,227,0.12);
        color: inherit;
        border-radius: 3px;
    }
    :global(.sr-desc) {
        font-size: 0.85rem;
        color: var(--color-text-muted, #555556);
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    :global(.sr-desc mark) {
        background: rgba(13,71,227,0.10);
        color: inherit;
        border-radius: 3px;
    }
    :global(.sr-cat) {
        font-size: 0.70rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #888;
        margin-bottom: 4px;
        font-weight: 700;
    }
    :global(.sr-header) {
        padding: 12px 22px 8px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #aaa;
        border-bottom: 1px solid rgba(0,0,0,0.06);
    }
    :global(.sr-empty) {
        padding: 24px;
        text-align: center;
        color: #888;
        font-size: 0.9rem;
    }

    /* ── Mobile ─────────────────────────────────────────────────────────────── */
    @media (max-width: 768px) {
        .hero-content {
            padding-top: 6.5rem;
            padding-bottom: 3rem;
        }
        .search-input {
            font-size: 1rem;
            padding: 18px 18px 18px 54px;
        }
        .search-icon {
            left: 18px;
            width: 20px;
            height: 20px;
        }
        .sh-h1 {
            font-size: clamp(2rem, 8vw, 3rem);
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const input = document.getElementById('support-search-input') as HTMLInputElement;
        const dropdown = document.getElementById('search-results-dropdown');
        if (!input || !dropdown) return;

        let articles: any[] = [];
        let searchTimeout: any;

        function highlightText(text: string, term: string) {
            if (!term) return text;
            const regex = new RegExp(`(${term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
            return text.replace(regex, '<mark>$1</mark>');
        }

        function renderArticles(results: any[], term = '', title = '') {
            if (results.length === 0) {
                dropdown.innerHTML = `<div class="sr-empty">No se encontraron artículos para "${term}"</div>`;
                return;
            }
            const headerHtml = title ? `<div class="sr-header">${title}</div>` : '';
            const listHtml = results.map((r: any) => `
                <a href="${r.url}" class="search-result-item">
                    <div class="sr-cat">${r.category}</div>
                    <div class="sr-title">${highlightText(r.title, term)}</div>
                    <div class="sr-desc">${highlightText(r.description, term)}</div>
                </a>
            `).join('');
            dropdown.innerHTML = headerHtml + listHtml;
        }

        const showSuggestions = () => {
            if (articles.length === 0) return;
            const defaultSlugs = ['emitir-cfdi', 'cobro-divisas', 'cord-elements', 'manejo-disputas'];
            const suggestions = articles.filter((a: any) => defaultSlugs.some(slug => a.url.includes(slug)));
            renderArticles(suggestions, '', 'Sugerencias');
            dropdown.classList.remove('hidden');
        };

        input.addEventListener('focus', async () => {
            if (articles.length === 0) {
                try {
                    const res = await fetch('/api/support-search.json');
                    articles = await res.json();
                } catch (e) {
                    console.error('Failed to load search index', e);
                }
            }
            if (input.value.trim().length === 0) {
                showSuggestions();
            } else {
                input.dispatchEvent(new Event('input'));
            }
        });

        input.addEventListener('input', (e) => {
            const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
            clearTimeout(searchTimeout);
            if (query.length === 0) {
                showSuggestions();
                return;
            }
            searchTimeout = setTimeout(() => {
                dropdown.classList.remove('hidden');
                const results = articles.filter((a: any) =>
                    a.title.toLowerCase().includes(query) ||
                    a.description.toLowerCase().includes(query) ||
                    a.category.toLowerCase().includes(query)
                ).slice(0, 6);
                renderArticles(results, query, 'Resultados');
            }, 150);
        });

        document.addEventListener('click', (e) => {
            if (!input.contains(e.target as Node) && !dropdown.contains(e.target as Node)) {
                dropdown.classList.add('hidden');
            }
        });
    });
</script>
