---
// /src/components/support/SupportCards.astro
import { getCollection } from 'astro:content';
import FaqAccordion from '../landing/FaqAccordion.astro';
import { SUPPORT_FAQ_ES, SUPPORT_FAQ_EN } from '../../lib/support-faq';

const { isEn = false } = Astro.props;
const allSupport = await getCollection('support');

// Only filter current language articles for counts
const langPrefix = isEn ? 'en/' : 'es/';
const localSupport = allSupport.filter(a => a.id.startsWith(langPrefix));

const categoryMap = [
    {
        name: isEn ? 'Payments & Deposits' : 'Pagos y Depósitos',
        slug: 'pagos',
        icon: '<path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>'
    },
    {
        name: isEn ? 'Quotes' : 'Cotizaciones',
        slug: 'cotizaciones',
        icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline>'
    },
    {
        name: isEn ? 'Billing & CFDI' : 'Facturación y CFDI',
        slug: 'facturacion',
        icon: '<path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path><path d="M22 12A10 10 0 0 0 12 2v10z"></path>'
    },
    {
        name: isEn ? 'Account & Team' : 'Cuenta y Equipo',
        slug: 'cuenta',
        icon: '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle>'
    },
    {
        name: isEn ? 'Developers' : 'Desarrolladores',
        slug: 'desarrolladores',
        icon: '<polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline>'
    },
    {
        name: isEn ? 'Security & Privacy' : 'Seguridad y Privacidad',
        slug: 'seguridad',
        icon: '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path>'
    }
];

const categoriesWithArticles = categoryMap.map(cat => {
    const articles = localSupport.filter(a => a.data.category === cat.name);
    return {
        ...cat,
        articles: articles.slice(0, 4),
        totalCount: articles.length
    };
});

const faqs = isEn ? SUPPORT_FAQ_EN : SUPPORT_FAQ_ES;
---

<section class="support-content">
    <div class="content-wrapper">
        
        <!-- ── RUTAS RÁPIDAS (SIMPLE HAIRLINE LIST) ── -->
        <h2 class="pr-h2 masked-title">{isEn ? 'Quick links' : 'Rutas rápidas'}</h2>
        <div class="ql-simple-list reveal">
            <a href={isEn ? "/en/support/primeros-pasos" : "/soporte/primeros-pasos"} class="ql-row">
                <div class="ql-row-info">
                    <h3>{isEn ? 'Cord 101: Getting Started' : 'Cord 101: Primeros Pasos'}</h3>
                    <p>{isEn ? 'Set up your corporate account, upload your SAT certificates, and issue your first charge.' : 'Configura tu cuenta empresarial, sube tus certificados del SAT y emite tu primer cobro.'}</p>
                </div>
                <svg class="ql-row-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
            <a href={isEn ? "/en/support/glosario-terminos" : "/soporte/glosario-terminos"} class="ql-row">
                <div class="ql-row-info">
                    <h3>{isEn ? 'B2B Glossary' : 'Glosario B2B'}</h3>
                    <p>{isEn ? 'The translator between engineers and accountants. Understand CFDI PPD vs PUE.' : 'El traductor entre ingenieros y contadores. Entiende qué es un CFDI PPD vs PUE.'}</p>
                </div>
                <svg class="ql-row-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
            <a href={isEn ? "/en/support/migracion-stripe" : "/soporte/migracion-stripe"} class="ql-row">
                <div class="ql-row-info">
                    <h3>{isEn ? 'Migrate from Stripe' : 'Migrar desde Stripe'}</h3>
                    <p>{isEn ? 'Guide to export your clients and import your card vault (PCI-DSS).' : 'Guía para exportar tus clientes e importar tu bóveda de tarjetas.'}</p>
                </div>
                <svg class="ql-row-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
            <a href={isEn ? "/en/support/category/desarrolladores" : "/soporte/categoria/desarrolladores"} class="ql-row">
                <div class="ql-row-info">
                    <h3>{isEn ? 'Dev Portal' : 'Portal Devs'}</h3>
                    <p>{isEn ? 'Technical docs for the REST API, Webhooks, and UI components.' : 'Documentación técnica de API REST, Webhooks y componentes.'}</p>
                </div>
                <svg class="ql-row-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
        </div>

        <!-- ── EXPLORAR POR CATEGORÍA (EDITORIAL/HAIRLINES) ── -->
        <h2 class="pr-h2 masked-title mt-32">{isEn ? 'Explore by category' : 'Explorar por categoría'}</h2>
        <div class="editorial-grid reveal">
            {categoriesWithArticles.map(cat => (
                <div class="editorial-block">
                    <div class="eb-header">
                        <svg class="eb-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={cat.icon} />
                        <h3>{cat.name}</h3>
                    </div>
                    <ul class="eb-links">
                        {cat.articles.map((a: any) => (
                            <li>
                                <a href={isEn ? `/en/support/${a.id.replace('en/', '')}` : `/soporte/${a.id.replace('es/', '')}`}>{a.data.title}</a>
                            </li>
                        ))}
                    </ul>
                    <a href={isEn ? `/en/support/category/${cat.slug}` : `/soporte/categoria/${cat.slug}`} class="eb-view-all">{isEn ? `View all (${cat.totalCount}) \u2192` : `Ver todos (${cat.totalCount}) \u2192`}</a>
                </div>
            ))}
        </div>

        <!-- ── PREGUNTAS FRECUENTES (FAQ) ── -->
        <FaqAccordion
            faqs={faqs}
            eyebrow={isEn ? 'FREQUENTLY ASKED QUESTIONS' : 'PREGUNTAS FRECUENTES'}
            title={isEn ? 'Frequently asked questions' : 'Preguntas frecuentes'}
            id="support"
            class="supp-faq-acc"
            maxWidth="860px"
        />

        <!-- ── CONTACT CTA PREMIUM (HAIRLINE STYLE) ── -->
        <div class="premium-cta reveal">
            <div class="pcta-content">
                <h2>{isEn ? "Can't find what you're looking for?" : '¿No encuentras lo que buscas?'}</h2>
                <p>{isEn ? 'Advanced technical support is included in all plans. Contact us directly and we will resolve your issue in less than 2 business hours.' : 'El soporte técnico avanzado está incluido en todos los planes. Contáctanos directamente y resolvemos tu duda en menos de 2 horas hábiles.'}</p>
            </div>
            <a href="mailto:soporte@flouvia.com" class="pcta-button">
                {isEn ? 'Talk to an expert' : 'Hablar con un experto'}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
        </div>
    </div>
</section>

<style>
    .support-content {
        padding: 5rem 5% 8rem;
        background-color: var(--color-bg);
    }
    .content-wrapper {
        max-width: 1200px;
        margin: 0 auto;
    }
    .pr-h2 {
        font-size: clamp(1.6rem, 3vw, 2.2rem);
        font-weight: 800;
        line-height: 1.12;
        letter-spacing: -0.03em;
        color: var(--color-text);
        margin: 0 0 3rem;
    }
    .mt-32 {
        margin-top: 6rem;
    }

    /* ── QUICK LINKS (SIMPLE HAIRLINE LIST) ── */
    .ql-simple-list {
        display: flex;
        flex-direction: column;
        border-top: 1px solid var(--color-border);
        margin-bottom: 4rem;
        width: 100%;
    }
    .ql-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.5rem 0;
        border-bottom: 1px solid var(--color-border);
        text-decoration: none;
        color: var(--color-text);
        transition: padding-left 0.3s ease;
    }
    .ql-row:hover {
        padding-left: 8px;
    }
    .ql-row-info h3 {
        font-size: 1.15rem;
        font-weight: 700;
        margin: 0 0 0.25rem 0;
        color: var(--color-text);
    }
    .ql-row-info p {
        font-size: 0.95rem;
        color: var(--color-text-muted);
        line-height: 1.5;
        margin: 0;
        max-width: 650px;
    }
    .ql-row-arrow {
        width: 20px;
        height: 20px;
        color: var(--color-text-muted);
        flex-shrink: 0;
        transition: color 0.3s ease, transform 0.3s ease;
    }
    .ql-row:hover .ql-row-arrow {
        color: var(--color-text);
        transform: translateX(4px);
    }

    /* ── CATEGORÍAS (EDITORIAL BLOCK, SIN CARDS) ── */
    .editorial-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 4rem 3rem;
    }
    .editorial-block {
        display: flex;
        flex-direction: column;
    }
    .eb-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 1.5rem;
    }
    .eb-icon {
        width: 24px;
        height: 24px;
        color: var(--color-text);
        stroke-width: 1.5px;
    }
    .eb-header h3 {
        font-size: 1.25rem;
        font-weight: 700;
        margin: 0;
        color: var(--color-text);
        letter-spacing: -0.01em;
    }
    .eb-links {
        list-style: none;
        padding: 0;
        margin: 0 0 1.5rem 0;
        display: flex;
        flex-direction: column;
    }
    .eb-links li {
        border-bottom: 1px solid var(--color-border);
    }
    .eb-links li:last-child {
        border-bottom: none;
    }
    .eb-links li a {
        color: var(--color-text-muted);
        text-decoration: none;
        font-size: 0.95rem;
        line-height: 1.4;
        transition: color 0.2s ease, padding-left 0.2s ease;
        display: block;
        padding: 12px 0;
    }
    .eb-links li a:hover {
        color: var(--color-text);
        padding-left: 6px;
    }
    .eb-view-all {
        margin-top: auto;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--color-text);
        text-decoration: none;
        display: inline-block;
        transition: color 0.2s;
    }
    .eb-view-all:hover {
        color: var(--color-blue-deep);
    }

    /* ── FAQ accordion override (inside content-wrapper, strips extra padding) ── */
    :global(.supp-faq-acc) { padding: 4rem 0; }

    /* ── PREMIUM CONTACT CTA (HAIRLINE) ── */
    .premium-cta {
        margin-top: 6rem;
        padding: 4rem 0;
        border-top: 1px solid var(--color-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .pcta-content {
        max-width: 500px;
    }
    .pcta-content h2 {
        font-size: 2.2rem;
        font-weight: 800;
        margin: 0 0 16px 0;
        letter-spacing: -0.03em;
        color: var(--color-text);
    }
    .pcta-content p {
        font-size: 1.05rem;
        color: var(--color-text-muted);
        margin: 0;
        line-height: 1.6;
    }
    .pcta-button {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 17px 36px;
        background: #111827;
        color: #ffffff;
        font-weight: 600;
        font-size: 1rem;
        border-radius: 999px;
        text-decoration: none;
        position: relative;
        overflow: hidden;
        white-space: nowrap;
        margin-left: 2rem;
        transition: transform 0.35s var(--ease-spring), box-shadow 0.35s var(--ease-spring);
        box-shadow: 0 4px 14px rgba(10,25,47,0.12);
    }
    .pcta-button::after {
        content: '';
        position: absolute;
        top: 0; left: -110%;
        width: 60%; height: 100%;
        background: linear-gradient(105deg, transparent, rgba(255,255,255,0.16), transparent);
        transition: left 0.5s ease;
        pointer-events: none;
    }
    .pcta-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(10,25,47,0.18);
    }
    .pcta-button:hover::after { left: 160%; }
    .pcta-button:active { transform: scale(0.97); }

    @media (max-width: 1024px) {
        .editorial-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        .premium-cta {
            flex-direction: column;
            text-align: left;
            align-items: flex-start;
            gap: 2rem;
        }
        .pcta-button {
            margin-left: 0;
        }
    }
    @media (max-width: 768px) {
        .editorial-grid {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
        .pr-h2 {
            font-size: 2rem;
        }
    }
</style>
