---
// /src/components/support/SupportCards.astro
import { getCollection } from 'astro:content';

const allSupport = await getCollection('support');

const categoryMap = [
    {
        name: 'Pagos y Depósitos',
        slug: 'pagos',
        icon: '<path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>'
    },
    {
        name: 'Cotizaciones',
        slug: 'cotizaciones',
        icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline>'
    },
    {
        name: 'Facturación y CFDI',
        slug: 'facturacion',
        icon: '<path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path><path d="M22 12A10 10 0 0 0 12 2v10z"></path>'
    },
    {
        name: 'Cuenta y Equipo',
        slug: 'cuenta',
        icon: '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle>'
    },
    {
        name: 'Desarrolladores',
        slug: 'desarrolladores',
        icon: '<polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline>'
    },
    {
        name: 'Seguridad y Privacidad',
        slug: 'seguridad',
        icon: '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path>'
    }
];

const categoriesWithArticles = categoryMap.map(cat => {
    const articles = allSupport.filter(a => a.data.category === cat.name);
    return {
        ...cat,
        articles: articles.slice(0, 4),
        totalCount: articles.length
    };
});

const faqs = [
    { q: "¿Cuándo se deposita el dinero en mi cuenta?", a: "Los pagos procesados con tarjeta se depositan en tu cuenta bancaria configurada en un plazo de T+3 a T+7 días naturales, dependiendo del calendario Payout de tu cuenta conectada de Stripe." },
    { q: "¿Cómo cancelo una factura (CFDI)?", a: "Ve a la sección de Facturación en tu portal, busca la factura emitida, selecciona 'Opciones' y haz clic en 'Generar Egreso (Nota de Crédito)'. Cord vinculará automáticamente el UUID padre." },
    { q: "¿Puedo cobrar en dólares (USD)?", a: "Sí. Cord te permite emitir cotizaciones en USD. Stripe se encargará de hacer la conversión cambiaria si tu cuenta destino está en pesos." },
    { q: "¿Qué pasa si un cliente no paga a tiempo?", a: "Cord enviará recordatorios automáticos según la configuración de tu cuenta y, si configuraste el interés moratorio, lo calculará sobre el saldo vencido." },
    { q: "¿Cord cobra comisiones por transacción?", a: "No. Cord es una plataforma SaaS y solo pagas tu mensualidad. Los cobros con tarjeta generan la comisión estándar directa de Stripe, sin intermediarios." },
    { q: "¿Dónde encuentro mis API Keys?", a: "Puedes encontrar tus llaves (Test y Live) en Ajustes > Desarrolladores > Claves de API. Las llaves de producción requieren el plan Scale o Developer." }
];
---

<section class="support-content">
    <div class="content-wrapper">
        
        <!-- ── RUTAS RÁPIDAS (BENTO LAYOUT SIN CARDS) ── -->
        <h2 class="pr-h2 masked-title">Rutas rápidas</h2>
        <div class="editorial-bento reveal">
            <a href="/soporte/categoria/desarrolladores" class="bento-region bento-devs">
                <div class="br-header">
                    <svg class="br-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>
                    <h3>Portal de Desarrolladores</h3>
                </div>
                <p>Guías técnicas para implementar Cord. Aprende a crear integraciones M2M usando nuestra API REST, configurar webhooks para pagos, y desplegar componentes nativos UI.</p>
                <div class="br-links">
                    <span>API REST</span>
                    <span>Webhooks</span>
                    <span>Componentes</span>
                </div>
            </a>
            <a href="/soporte/categoria/facturacion" class="bento-region">
                <div class="br-header">
                    <svg class="br-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><line x1="12" x2="12" y1="18" y2="18.01"/><path d="M12 14v-2"/><path d="M12 10V8"/></svg>
                    <h3>Para Contadores</h3>
                </div>
                <p>Catálogos del SAT, Emisión de Complementos (REP) automáticos y facturación multidivisa (MXN a USD).</p>
                <span class="br-cta">Guía fiscal &rarr;</span>
            </a>
            <a href="/soporte/estructura-cotizacion" class="bento-region">
                <div class="br-header">
                    <svg class="br-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <h3>Primeros Pasos</h3>
                </div>
                <p>Domina tu pipeline de ventas. Crea tu primera cotización, añade descuentos y establece términos de crédito.</p>
                <span class="br-cta">Aprende lo básico &rarr;</span>
            </a>
            <a href="/soporte/cobro-divisas" class="bento-region">
                <div class="br-header">
                    <svg class="br-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                    <h3>Tesorería B2B</h3>
                </div>
                <p>Gestiona tu flujo de efectivo, anticipos y la conciliación bancaria de transferencias masivas.</p>
                <span class="br-cta">Ver Tesorería &rarr;</span>
            </a>
        </div>

        <!-- ── EXPLORAR POR CATEGORÍA (EDITORIAL/HAIRLINES) ── -->
        <h2 class="pr-h2 masked-title mt-32">Explorar por categoría</h2>
        <div class="editorial-grid reveal">
            {categoriesWithArticles.map(cat => (
                <div class="editorial-block">
                    <div class="eb-header">
                        <svg class="eb-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={cat.icon} />
                        <h3>{cat.name}</h3>
                    </div>
                    <ul class="eb-links">
                        {cat.articles.map((a: any) => (
                            <li>
                                <a href={`/soporte/${a.id}`}>{a.data.title}</a>
                            </li>
                        ))}
                    </ul>
                    <a href={`/soporte/categoria/${cat.slug}`} class="eb-view-all">Ver todos ({cat.totalCount}) &rarr;</a>
                </div>
            ))}
        </div>

        <!-- ── PREGUNTAS FRECUENTES (FAQ) ── -->
        <h2 class="pr-h2 masked-title mt-32 text-center">Preguntas frecuentes</h2>
        <div class="pr-faq-list reveal">
            {faqs.map((f) => (
                <details class="pr-faq-item">
                    <summary>
                        <span>{f.q}</span>
                        <i class="pr-faq-ico" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        </i>
                    </summary>
                    <div class="pr-faq-body"><p>{f.a}</p></div>
                </details>
            ))}
        </div>

        <!-- ── CONTACT CTA PREMIUM (HAIRLINE STYLE) ── -->
        <div class="premium-cta reveal">
            <div class="pcta-content">
                <h2>¿No encuentras lo que buscas?</h2>
                <p>El soporte técnico avanzado está incluido en todos los planes. Contáctanos directamente y resolvemos tu duda en menos de 2 horas hábiles.</p>
            </div>
            <a href="mailto:soporte@flouvia.com" class="pcta-button">
                Hablar con un experto
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
        </div>
    </div>
</section>

<style>
    .support-content {
        padding: 5rem 5% 8rem;
        background-color: var(--color-bg);
    }
    .content-wrapper {
        max-width: 1200px;
        margin: 0 auto;
    }
    .pr-h2 {
        font-size: clamp(1.6rem, 3vw, 2.2rem);
        font-weight: 800;
        line-height: 1.12;
        letter-spacing: -0.03em;
        color: var(--color-text);
        margin: 0 0 3rem;
    }
    .mt-32 {
        margin-top: 6rem;
    }

    /* ── BENTO LAYOUT (EDITORIAL, SIN CARDS) ── */
    .editorial-bento {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0;
        border-top: 1px solid var(--color-border);
        border-bottom: 1px solid var(--color-border);
    }
    .bento-region {
        padding: 3rem 2rem;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        border-right: 1px solid var(--color-border);
        transition: background 0.3s;
    }
    .bento-region:hover {
        background: var(--color-bg-soft);
    }
    .bento-devs {
        grid-column: span 3;
        border-right: none;
        border-bottom: 1px solid var(--color-border);
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        gap: 3rem;
    }
    .bento-region:last-child {
        border-right: none;
    }
    .br-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 1rem;
    }
    .br-icon {
        width: 24px;
        height: 24px;
        color: var(--color-text);
    }
    .bento-devs .br-icon {
        width: 32px;
        height: 32px;
    }
    .bento-region h3 {
        font-size: 1.3rem;
        font-weight: 800;
        color: var(--color-text);
        margin: 0;
        letter-spacing: -0.02em;
    }
    .bento-devs h3 {
        font-size: 1.8rem;
    }
    .bento-region p {
        font-size: 1rem;
        line-height: 1.6;
        color: var(--color-text-muted);
        margin: 0;
    }
    .bento-devs p {
        font-size: 1.1rem;
        flex: 1;
        max-width: 600px;
        margin: 0;
    }
    .br-cta {
        margin-top: auto;
        padding-top: 1.5rem;
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--color-text);
        display: inline-block;
        transition: color 0.2s;
    }
    .bento-region:hover .br-cta {
        color: var(--color-blue-deep);
    }
    .br-links {
        display: flex;
        gap: 16px;
        margin-top: 0;
        flex-shrink: 0;
    }
    .br-links span {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--color-text);
        background: var(--color-bg-soft);
        padding: 6px 14px;
        border-radius: 20px;
        border: 1px solid var(--color-border);
    }

    /* ── CATEGORÍAS (EDITORIAL BLOCK, SIN CARDS) ── */
    .editorial-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 4rem 3rem;
    }
    .editorial-block {
        display: flex;
        flex-direction: column;
    }
    .eb-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 1.5rem;
    }
    .eb-icon {
        width: 24px;
        height: 24px;
        color: var(--color-text);
        stroke-width: 1.5px;
    }
    .eb-header h3 {
        font-size: 1.25rem;
        font-weight: 700;
        margin: 0;
        color: var(--color-text);
        letter-spacing: -0.01em;
    }
    .eb-links {
        list-style: none;
        padding: 0;
        margin: 0 0 1.5rem 0;
        display: flex;
        flex-direction: column;
    }
    .eb-links li {
        border-bottom: 1px solid var(--color-border);
    }
    .eb-links li:last-child {
        border-bottom: none;
    }
    .eb-links li a {
        color: var(--color-text-muted);
        text-decoration: none;
        font-size: 0.95rem;
        line-height: 1.4;
        transition: color 0.2s ease, padding-left 0.2s ease;
        display: block;
        padding: 12px 0;
    }
    .eb-links li a:hover {
        color: var(--color-text);
        padding-left: 6px;
    }
    .eb-view-all {
        margin-top: auto;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--color-text);
        text-decoration: none;
        display: inline-block;
        transition: color 0.2s;
    }
    .eb-view-all:hover {
        color: var(--color-blue-deep);
    }

    /* ── FAQ (HAIRLINE STYLE) ── */
    .text-center {
        text-align: center;
    }
    .pr-faq-list {
        display: flex;
        flex-direction: column;
        max-width: 860px;
        margin: 0 auto;
        border-top: 1px solid var(--color-border);
    }
    .pr-faq-item {
        border-bottom: 1px solid var(--color-border);
        overflow: hidden;
    }
    .pr-faq-item summary {
        list-style: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.5rem 0;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--color-text);
    }
    .pr-faq-item summary::-webkit-details-marker { display: none; }
    .pr-faq-ico {
        flex-shrink: 0;
        color: var(--color-text-muted);
        transition: transform 0.4s var(--ease-spring), color 0.3s;
    }
    .pr-faq-ico svg { width: 20px; height: 20px; }
    .pr-faq-item[open] .pr-faq-ico {
        transform: rotate(135deg);
        color: var(--color-text);
    }
    .pr-faq-body {
        padding: 0 0 1.5rem;
    }
    .pr-faq-body p {
        margin: 0;
        font-size: 1rem;
        line-height: 1.6;
        color: var(--color-text-muted);
        max-width: 700px;
    }

    /* ── PREMIUM CONTACT CTA (HAIRLINE) ── */
    .premium-cta {
        margin-top: 6rem;
        padding: 4rem 0;
        border-top: 1px solid var(--color-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .pcta-content {
        max-width: 500px;
    }
    .pcta-content h2 {
        font-size: 2.2rem;
        font-weight: 800;
        margin: 0 0 16px 0;
        letter-spacing: -0.03em;
        color: var(--color-text);
    }
    .pcta-content p {
        font-size: 1.05rem;
        color: var(--color-text-muted);
        margin: 0;
        line-height: 1.6;
    }
    .pcta-button {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        padding: 16px 32px;
        background: var(--color-text);
        color: var(--color-bg);
        font-weight: 600;
        font-size: 1rem;
        border-radius: 12px;
        text-decoration: none;
        transition: transform 0.3s ease;
        white-space: nowrap;
        margin-left: 2rem;
    }
    .pcta-button:hover {
        transform: translateY(-2px);
    }

    @media (max-width: 1024px) {
        .editorial-bento {
            grid-template-columns: repeat(2, 1fr);
        }
        .bento-devs {
            grid-column: span 2;
            flex-direction: column;
            align-items: flex-start;
            gap: 1.5rem;
        }
        .bento-devs h3 {
            font-size: 1.5rem;
        }
        .editorial-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        .premium-cta {
            flex-direction: column;
            text-align: left;
            align-items: flex-start;
            gap: 2rem;
        }
        .pcta-button {
            margin-left: 0;
        }
    }
    @media (max-width: 768px) {
        .editorial-bento {
            grid-template-columns: 1fr;
            border-left: 1px solid var(--color-border);
            border-right: 1px solid var(--color-border);
        }
        .bento-devs {
            grid-column: span 1;
            border-right: none;
        }
        .bento-region {
            border-right: none;
            border-bottom: 1px solid var(--color-border);
        }
        .bento-region:last-child {
            border-bottom: none;
        }
        .editorial-grid {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
        .pr-h2 {
            font-size: 2rem;
        }
        .br-links {
            flex-wrap: wrap;
        }
    }
</style>
