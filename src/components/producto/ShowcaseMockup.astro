  .shwm-dual-rate { margin: 6px 20px 0; padding: 11px 14px; background: #f8fafc; border: 1px solid rgba(10,25,47,0.05); border-radius: 10px; font-size: 0.76rem; color: #64748b; text-align: center; }
  .shwm-dual-rate b { color: #0f172a; font-weight: 600; }

  /* ══════════════════ INTERNACIONAL ══════════════════ */
  .shwm-border { display: grid; grid-template-columns: 1fr 1.1fr 1fr; align-items: center; gap: 0; padding: 24px 20px; }
  .shwm-border-node { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 7px; background: #f8fafc; border: 1px solid rgba(10,25,47,0.06); border-radius: 16px; padding: 20px 16px; }
  .shwm-border-node b { font-size: 0.92rem; color: #0f172a; font-weight: 700; }
  .shwm-border-node em { font-style: normal; font-size: 0.72rem; color: #94a3b8; }
  .shwm-flag-lg { min-width: 40px; height: 28px; border-radius: 6px; font-size: 0.82rem; margin-bottom: 4px; }
  .shwm-border-link { display: flex; flex-direction: column; align-items: center; gap: 8px; position: relative; }
  .shwm-border-link::before, .shwm-border-link::after { content: ''; position: absolute; top: 50%; width: 22%; height: 2px; background: repeating-linear-gradient(90deg,#cbd5e1 0,#cbd5e1 4px,transparent 4px,transparent 8px); }
  .shwm-border-link::before { left: 4px; }
  .shwm-border-link::after { right: 4px; }
  .shwm-border-doc { width: 48px; height: 48px; border-radius: 13px; background: #fff; border: 1px solid rgba(10,25,47,0.08); box-shadow: 0 8px 20px -10px rgba(10,25,47,0.2); display: flex; align-items: center; justify-content: center; color: #0a192f; z-index: 1; }
  .shwm-border-doc svg { width: 24px; height: 24px; }
  .shwm-border-cap { font-size: 0.64rem; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; color: #a3adba; }

  .shwm-buffer { padding: 20px 20px 8px; display: flex; flex-direction: column; gap: 14px; }
  .shwm-buffer-row { display: flex; align-items: center; justify-content: space-between; font-size: 0.86rem; color: #64748b; }
  .shwm-buffer-row b { color: #0f172a; font-weight: 600; font-size: 1rem; }
  .shwm-buffer-out { padding-top: 14px; border-top: 1px solid rgba(10,25,47,0.07); }
  .shwm-buffer-out b { font-size: 1.28rem; letter-spacing: -0.02em; }
  .shwm-buffer-ctrl { background: #f8fafc; border: 1px solid rgba(10,25,47,0.05); border-radius: 12px; padding: 14px 16px; }
  .shwm-buffer-label { display: flex; align-items: center; justify-content: space-between; font-size: 0.76rem; font-weight: 600; color: #64748b; margin-bottom: 12px; }
  .shwm-buffer-track { position: relative; height: 6px; border-radius: 100px; background: #e2e8f0; }
  .shwm-buffer-fill { position: absolute; left: 0; top: 0; height: 100%; border-radius: 100px; background: #059669; }
  .shwm-buffer-knob { position: absolute; top: 50%; width: 18px; height: 18px; border-radius: 50%; background: #fff; border: 2px solid #059669; box-shadow: 0 2px 8px rgba(10,25,47,0.18); transform: translate(-50%,-50%); }
  .shwm-buffer-scale { display: flex; justify-content: space-between; margin-top: 10px; font-size: 0.64rem; font-weight: 600; color: #a3adba; }
  .shwm-lock-strip { display: flex; align-items: center; gap: 13px; margin: 8px 20px 6px; padding: 14px 15px; background: rgba(16,185,129,0.05); border: 1px solid rgba(16,185,129,0.18); border-radius: 12px; }
  .shwm-lock-ico { width: 34px; height: 34px; border-radius: 10px; background: rgba(16,185,129,0.12); color: #059669; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .shwm-lock-ico svg { width: 17px; height: 17px; }
  .shwm-lock-strip b { display: block; font-size: 0.86rem; color: #0f172a; font-weight: 600; }
  .shwm-lock-strip em { display: block; font-style: normal; font-size: 0.7rem; color: #94a3b8; margin-top: 2px; }

  .shwm-stamp { padding: 20px 20px 8px; }
  .shwm-stamp-doc { display: flex; align-items: center; gap: 14px; padding-bottom: 16px; border-bottom: 1px solid rgba(10,25,47,0.06); margin-bottom: 14px; }
  .shwm-stamp-seal { width: 52px; height: 52px; border-radius: 14px; background: rgba(16,185,129,0.08); color: #059669; display: flex; align-items: center; justify-content: center; flex-shrink: 0; border: 1px solid rgba(16,185,129,0.2); }
  .shwm-stamp-seal svg { width: 28px; height: 28px; }
  .shwm-stamp-tx b { display: block; font-size: 0.96rem; color: #0f172a; font-weight: 700; }
  .shwm-stamp-tx em { display: block; font-style: normal; font-size: 0.74rem; color: #94a3b8; margin-top: 3px; }
  .shwm-uuid { color: #2563eb !important; font-size: 0.76rem; }
  .shwm-stamp-cta { display: flex; gap: 10px; margin-top: 16px; }
  .shwm-stamp-btn { flex: 1; text-align: center; font-size: 0.8rem; font-weight: 600; color: #475569; padding: 11px; border-radius: 10px; border: 1px solid rgba(10,25,47,0.12); }

  /* ══════════════════ FINANZAS ══════════════════ */
  .shwm-dso { display: flex; flex-direction: column; padding: 10px 16px; }
  .shwm-dso-r { display: grid; grid-template-columns: 1.4fr 2fr 0.7fr; align-items: center; gap: 16px; padding: 15px 8px; border-bottom: 1px solid rgba(10,25,47,0.05); }
  .shwm-dso-r:last-child { border-bottom: none; }
  .shwm-dso-who { display: flex; align-items: center; gap: 11px; }
  .shwm-dso-who b { font-size: 0.84rem; color: #0f172a; font-weight: 600; }
  .shwm-dso-cmp { display: flex; align-items: center; gap: 10px; font-size: 0.78rem; }
  .shwm-dso-strike { color: #b6bcc6; text-decoration: line-through; }
  .shwm-dso-arrow { color: #cbd5e1; font-weight: 700; }
  .shwm-dso-real { color: #0f172a; font-weight: 700; }
  .shwm-dso-r > .shwm-badge { justify-self: end; }

  .shwm-conc { display: grid; grid-template-columns: 150px 1fr; align-items: center; gap: 24px; padding: 18px 22px 10px; }
  .shwm-donut { position: relative; width: 130px; height: 130px; }
  .shwm-donut-ring { width: 100%; height: 100%; border-radius: 50%; background: conic-gradient(#0a192f 0% 40%, #64748b 40% 64%, #94a3b8 64% 82%, #cbd5e1 82% 100%); }
  .shwm-donut-hole { position: absolute; inset: 22px; border-radius: 50%; background: #fff; display: flex; flex-direction: column; align-items: center; justify-content: center; box-shadow: inset 0 1px 0 rgba(255,255,255,0.7); }
  .shwm-donut-hole b { font-size: 1.5rem; color: #0f172a; letter-spacing: -0.03em; }
  .shwm-donut-hole span { font-size: 0.62rem; color: #94a3b8; margin-top: 2px; }
  .shwm-conc-legend { display: flex; flex-direction: column; gap: 4px; }
  .shwm-conc-r { display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 11px; padding: 8px 0; font-size: 0.82rem; color: #475569; border-bottom: 1px solid rgba(10,25,47,0.04); }
  .shwm-conc-r:last-child { border-bottom: none; }
  .shwm-conc-r b { color: #0f172a; font-weight: 600; }
  .shwm-conc-hot span { color: #0f172a; font-weight: 600; }
  .shwm-lg-sw { width: 12px; height: 12px; border-radius: 4px; }
  .shwm-lg-sw.navy { background: #0a192f; } .shwm-lg-sw.g1 { background: #64748b; } .shwm-lg-sw.g2 { background: #94a3b8; } .shwm-lg-sw.g3 { background: #cbd5e1; }
  .shwm-alert-strip { display: flex; align-items: center; gap: 12px; margin: 6px 20px 6px; padding: 13px 15px; background: rgba(245,158,11,0.06); border: 1px solid rgba(245,158,11,0.2); border-radius: 12px; font-size: 0.8rem; color: #78530a; }
  .shwm-alert-strip b { color: #92400e; font-weight: 700; }
  .shwm-alert-ico { width: 30px; height: 30px; color: #d97706; flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center; }
  .shwm-alert-ico svg { width: 22px; height: 22px; }

  .shwm-exec-chart { margin: 8px 18px 4px; padding: 14px 16px 10px; background: #f8fafc; border: 1px solid rgba(10,25,47,0.05); border-radius: 12px; }
  .shwm-exec-cap { display: block; font-size: 0.62rem; font-weight: 700; letter-spacing: 0.4px; text-transform: uppercase; color: #a3adba; margin-bottom: 12px; }
  .shwm-bars { display: grid; grid-template-columns: repeat(5,1fr); gap: 14px; align-items: end; height: 110px; }
  .shwm-bar-col { display: flex; flex-direction: column; align-items: center; justify-content: flex-end; height: 100%; gap: 8px; }
  .shwm-bar-col > i { display: block; width: 100%; max-width: 42px; border-radius: 6px 6px 3px 3px; background: #e2e8f0; }
  .shwm-bar-col > i.hot { background: linear-gradient(180deg,#1e3a5f,#0a192f); }
  .shwm-bar-col > span { font-size: 0.62rem; font-weight: 600; color: #a3adba; }
  .shwm-exec-foot { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 15px 20px; border-top: 1px solid rgba(10,25,47,0.06); background: #fcfdfe; font-size: 0.8rem; color: #94a3b8; }
  .shwm-exec-btn { display: inline-flex; align-items: center; gap: 8px; font-size: 0.8rem; font-weight: 700; color: #fff; background: #0a192f; padding: 9px 16px; border-radius: 100px; }
  .shwm-exec-btn svg { width: 15px; height: 15px; }

  /* ══════════════════ APROBACIONES ══════════════════ */
  .shwm-thresh { padding: 22px 22px 8px; }
  .shwm-thresh-scale { position: relative; padding-top: 34px; }
  .shwm-thresh-zones { display: flex; height: 20px; border-radius: 6px; overflow: hidden; }
  .shwm-tz { display: flex; align-items: center; justify-content: center; position: relative; }
  .shwm-tz span { font-size: 0.58rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3px; white-space: nowrap; }
  .shwm-tz-ok { background: rgba(16,185,129,0.14); } .shwm-tz-ok span { color: #059669; }
  .shwm-tz-warn { background: rgba(245,158,11,0.15); } .shwm-tz-warn span { color: #b45309; }
  .shwm-tz-bad { background: rgba(220,38,38,0.13); } .shwm-tz-bad span { color: #dc2626; }
  .shwm-thresh-ticks { display: flex; justify-content: space-between; margin-top: 7px; font-size: 0.62rem; font-weight: 600; color: #a3adba; }
  .shwm-thresh-marker { position: absolute; top: 0; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; }
  .shwm-thresh-marker i { width: 2px; height: 44px; background: #0a192f; margin-top: -2px; }
  .shwm-thresh-flag { font-size: 0.66rem; font-weight: 800; color: #fff; background: #0a192f; padding: 3px 9px; border-radius: 6px; white-space: nowrap; box-shadow: 0 4px 12px -4px rgba(10,25,47,0.4); }
  .shwm-thresh-rows { margin-top: 20px; }
  .shwm-thresh-r { display: flex; align-items: center; justify-content: space-between; padding: 11px 2px; font-size: 0.84rem; color: #64748b; border-bottom: 1px solid rgba(10,25,47,0.05); }
  .shwm-thresh-r:last-child { border-bottom: none; }
  .shwm-thresh-r b { color: #0f172a; font-weight: 600; }

  /* mobile approval notif */
  .shwm-notif { width: 100%; max-width: 380px; background: #fff; border: 1px solid rgba(10,25,47,0.07); border-radius: 20px; box-shadow: 0 30px 60px -22px rgba(10,25,47,0.24); overflow: hidden; }
  .shwm-notif-head { display: flex; align-items: center; gap: 8px; padding: 13px 16px 4px; }
  .shwm-notif-app { width: 22px; height: 22px; border-radius: 6px; background: #0a192f; display: inline-flex; align-items: center; justify-content: center; overflow: hidden; }
  .shwm-notif-app img { width: 16px; height: 16px; border-radius: 4px; }
  .shwm-notif-name { font-size: 0.72rem; font-weight: 700; color: #64748b; }
  .shwm-notif-time { margin-left: auto; font-size: 0.68rem; color: #b6bcc6; }
  .shwm-notif-body { padding: 6px 16px 12px; }
  .shwm-notif-body b { display: block; font-size: 0.9rem; color: #0f172a; font-weight: 700; }
  .shwm-notif-body span { display: block; font-size: 0.78rem; color: #64748b; margin-top: 4px; line-height: 1.45; }
  .shwm-notif-detail { padding: 4px 16px 12px; }
  .shwm-nd-r { display: flex; align-items: center; justify-content: space-between; padding: 7px 0; font-size: 0.8rem; color: #64748b; border-bottom: 1px solid rgba(10,25,47,0.05); }
  .shwm-nd-r:last-child { border-bottom: none; }
  .shwm-nd-r b { color: #0f172a; font-weight: 600; }
  .shwm-notif-actions { display: flex; gap: 10px; padding: 12px 16px 16px; }
  .shwm-notif-btn { flex: 1; text-align: center; font-size: 0.86rem; font-weight: 700; padding: 12px; border-radius: 12px; }
  .shwm-notif-approve { background: #0a192f; color: #fff; }
  .shwm-notif-reject { background: transparent; color: #64748b; border: 1px solid rgba(10,25,47,0.12); }

  /* ══════════════════ EQUIPO ══════════════════ */
  .shwm-matrix { padding: 16px 18px 8px; }
  .shwm-mx-head { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; align-items: center; gap: 10px; padding: 0 8px 12px; border-bottom: 1px solid rgba(10,25,47,0.07); }
  .shwm-mx-head span { font-size: 0.66rem; font-weight: 700; letter-spacing: 0.4px; text-transform: uppercase; color: #a3adba; text-align: center; }
  .shwm-mx-corner { text-align: left !important; }
  .shwm-mx-r { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; align-items: center; gap: 10px; padding: 13px 8px; border-bottom: 1px solid rgba(10,25,47,0.045); }
  .shwm-mx-r:last-child { border-bottom: none; }
  .shwm-mx-perm { font-size: 0.84rem; color: #334155; font-weight: 500; }
  .shwm-mx-yes, .shwm-mx-no { justify-self: center; }
  .shwm-mx-yes { width: 20px; height: 20px; border-radius: 50%; background: #10b981; position: relative; }
  .shwm-mx-yes::after { content: ''; position: absolute; left: 50%; top: 47%; width: 5px; height: 9px; border: solid #fff; border-width: 0 2px 2px 0; transform: translate(-50%,-50%) rotate(45deg); }
  .shwm-mx-no { width: 20px; height: 20px; border-radius: 50%; background: #eef2f7; border: 1px solid rgba(10,25,47,0.06); position: relative; }
  .shwm-mx-no::after { content: ''; position: absolute; left: 50%; top: 50%; width: 8px; height: 1.5px; background: #cbd5e1; transform: translate(-50%,-50%); }

  .shwm-switch-current { display: flex; align-items: center; gap: 13px; margin: 18px 20px 4px; padding: 14px 16px; background: #f8fafc; border: 1px solid rgba(10,25,47,0.08); border-radius: 13px; }
  .shwm-switch-current b { display: block; font-size: 0.92rem; color: #0f172a; font-weight: 700; }
  .shwm-switch-current em { display: block; font-style: normal; font-size: 0.72rem; color: #94a3b8; margin-top: 2px; }
  .shwm-switch-current > div { flex: 1; }
  .shwm-switch-chev { width: 20px; height: 20px; color: #94a3b8; flex-shrink: 0; }
  .shwm-switch-drop { margin: 6px 20px 6px; background: #fff; border: 1px solid rgba(10,25,47,0.08); border-radius: 13px; box-shadow: 0 18px 40px -18px rgba(10,25,47,0.2); overflow: hidden; }
  .shwm-switch-r { display: flex; align-items: center; gap: 12px; padding: 13px 16px; border-bottom: 1px solid rgba(10,25,47,0.05); }
  .shwm-switch-r:last-child { border-bottom: none; }
  .shwm-switch-active { background: rgba(16,185,129,0.05); }
  .shwm-switch-r b { display: block; font-size: 0.84rem; color: #0f172a; font-weight: 600; }
  .shwm-switch-r em { display: block; font-style: normal; font-size: 0.7rem; color: #94a3b8; margin-top: 1px; }
  .shwm-switch-r > div { flex: 1; }

  .shwm-sec { padding: 16px 20px 6px; }
  .shwm-sec-sso { display: flex; flex-direction: column; gap: 9px; margin-bottom: 16px; }
  .shwm-sec-sso-r { display: flex; align-items: center; gap: 13px; background: #f8fafc; border: 1px solid rgba(10,25,47,0.06); border-radius: 12px; padding: 12px 15px; }
  .shwm-sec-logo { width: 34px; height: 34px; border-radius: 9px; background: #fff; border: 1px solid rgba(10,25,47,0.08); display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .shwm-sec-logo img { border-radius: 4px; }
  .shwm-sec-sso-r > div { flex: 1; }
  .shwm-sec-sso-r b { display: block; font-size: 0.84rem; color: #0f172a; font-weight: 600; }
  .shwm-sec-sso-r em { display: block; font-style: normal; font-size: 0.7rem; color: #94a3b8; margin-top: 2px; }
  .shwm-sec-cap { display: block; font-size: 0.62rem; font-weight: 700; letter-spacing: 0.4px; text-transform: uppercase; color: #a3adba; margin-bottom: 10px; }
  .shwm-sec-sessions { display: flex; flex-direction: column; gap: 9px; }
  .shwm-sess-r { display: flex; align-items: center; gap: 13px; padding: 11px 4px; border-bottom: 1px solid rgba(10,25,47,0.05); }
  .shwm-sess-r:last-child { border-bottom: none; }
  .shwm-sess-ico { width: 34px; height: 34px; border-radius: 9px; background: rgba(10,25,47,0.04); color: #64748b; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .shwm-sess-ico svg { width: 18px; height: 18px; }
  .shwm-sess-r > div { flex: 1; }
  .shwm-sess-r b { display: block; font-size: 0.84rem; color: #0f172a; font-weight: 600; }
  .shwm-sess-r em { display: block; font-style: normal; font-size: 0.7rem; color: #94a3b8; margin-top: 2px; }
  .shwm-sess-revoke { font-size: 0.76rem; font-weight: 700; color: #dc2626; }

  /* ══════════════════ NEGOCIACIÓN ══════════════════ */
  .shwm-ver { display: flex; flex-direction: column; padding: 12px 20px 6px; position: relative; }
  .shwm-ver-r { display: flex; align-items: flex-start; gap: 14px; padding: 13px 0; border-bottom: 1px solid rgba(10,25,47,0.05); position: relative; }
  .shwm-ver-r:last-child { border-bottom: none; }
  .shwm-ver-tag { flex-shrink: 0; width: 34px; height: 26px; border-radius: 7px; display: inline-flex; align-items: center; justify-content: center; font-size: 0.68rem; font-weight: 800; color: #64748b; background: rgba(10,25,47,0.05); border: 1px solid rgba(10,25,47,0.09); }
  .shwm-ver-tag.amber { color: #d97706; background: rgba(245,158,11,0.1); border-color: rgba(245,158,11,0.22); }
  .shwm-ver-tag.green { color: #059669; background: rgba(16,185,129,0.1); border-color: rgba(16,185,129,0.22); }
  .shwm-ver-tx { flex: 1; }
  .shwm-ver-tx b { display: block; font-size: 0.86rem; color: #0f172a; font-weight: 600; }
  .shwm-ver-tx em { display: block; font-style: normal; font-size: 0.72rem; color: #94a3b8; margin-top: 2px; }
  .shwm-ver-r > b { flex-shrink: 0; font-weight: 600; color: #0f172a; }
  .shwm-ver-open { background: rgba(16,185,129,0.03); border-radius: 10px; margin: 0 -8px; padding: 13px 8px; }
  .shwm-ver-diff { margin-top: 9px; display: flex; flex-direction: column; gap: 4px; font-family: var(--font-mono, monospace); font-size: 0.72rem; }
  .shwm-diff-del { color: #dc2626; background: rgba(220,38,38,0.05); padding: 4px 8px; border-radius: 5px; }
  .shwm-diff-add { color: #059669; background: rgba(16,185,129,0.06); padding: 4px 8px; border-radius: 5px; }

  .shwm-sign { width: 100%; max-width: 480px; background: #fff; border: 1px solid rgba(10,25,47,0.07); border-radius: 20px; box-shadow: 0 30px 60px -22px rgba(10,25,47,0.2); padding: 30px 30px; text-align: center; }
  .shwm-sign-seal { width: 62px; height: 62px; border-radius: 16px; margin: 0 auto 16px; background: rgba(16,185,129,0.08); color: #059669; display: flex; align-items: center; justify-content: center; border: 1px solid rgba(16,185,129,0.2); }
