  .shwm-wa-bar em { display: block; font-style: normal; font-size: 0.64rem; color: rgba(255,255,255,0.75); }
  .shwm-wa-bar > div { flex: 1; min-width: 0; }
  .shwm-wa-av { width: 32px; height: 32px; border-radius: 50%; background: rgba(255,255,255,0.2); display: inline-flex; align-items: center; justify-content: center; font-size: 0.68rem; font-weight: 700; flex-shrink: 0; }
  .shwm-wa-icons { display: flex; align-items: center; gap: 15px; flex-shrink: 0; }
  .shwm-wa-icons svg { width: 17px; height: 17px; color: rgba(255,255,255,0.9); }

  .shwm-wa-body {
    position: relative;
    padding: 14px 14px 30px;
    background: #e5ddd5;
    background-image: radial-gradient(rgba(10,25,47,0.05) 1px, transparent 1px);
    background-size: 15px 15px;
    display: flex; flex-direction: column; gap: 10px; min-height: 254px;
  }
  .shwm-wa-date {
    align-self: center;
    font-size: 0.6rem; font-weight: 600; color: #6d7c85;
    background: rgba(255,255,255,0.7); padding: 3px 11px; border-radius: 8px;
    margin-bottom: 2px;
  }
  .shwm-wa-in, .shwm-wa-out { max-width: 84%; font-size: 0.76rem; line-height: 1.44; padding: 8px 11px 6px; border-radius: 11px; box-shadow: 0 1px 1px rgba(10,25,47,0.06); }
  .shwm-wa-in { align-self: flex-start; background: #fff; color: #2c2c2c; border-radius: 11px 11px 11px 3px; }
  .shwm-wa-out { align-self: flex-end; background: #dcf8c6; color: #2c2c2c; border-radius: 11px 11px 3px 11px; }
  .shwm-wa-time {
    display: block; font-style: normal; font-size: 0.58rem; color: rgba(0,0,0,0.36);
    text-align: right; margin-top: 3px;
  }
  .shwm-wa-tick { color: #34b7f1; margin-left: 3px; }
  .shwm-wa-link {
    align-self: flex-start; max-width: 88%;
    display: flex; align-items: center; gap: 11px;
    background: #fff; border: 1px solid rgba(10,25,47,0.07); border-radius: 13px;
    padding: 10px 12px; box-shadow: 0 6px 16px -8px rgba(10,25,47,0.22);
  }
  .shwm-wa-link-thumb {
    width: 42px; height: 42px; border-radius: 10px; flex-shrink: 0;
    background: linear-gradient(150deg, #0e2240, #0a192f);
    display: inline-flex; align-items: center; justify-content: center; color: #fff;
  }
  .shwm-wa-link-thumb svg { width: 19px; height: 19px; }
  .shwm-wa-link-tx { min-width: 0; }
  .shwm-wa-link-tx b { display: block; font-size: 0.74rem; color: #0f172a; font-weight: 600; }
  .shwm-wa-link-amt { display: block; font-size: 0.76rem; color: #0a192f; font-weight: 700; margin: 2px 0; }
  .shwm-wa-link-tx em { display: block; font-style: normal; font-size: 0.6rem; color: #94a3b8; }
  .shwm-ph-home {
    position: absolute; left: 50%; bottom: 8px; transform: translateX(-50%);
    width: 112px; height: 4.5px; border-radius: 100px; background: rgba(10,25,47,0.2);
  }

  /* browser */
  .shwm-browser { width: 100%; max-width: 640px; background: #ffffff; border-radius: 16px; border: 1px solid rgba(10,25,47,0.08); box-shadow: 0 30px 60px -20px rgba(10,25,47,0.18), inset 0 1px 0 rgba(255,255,255,0.7); overflow: hidden; }
  .shwm-url { display: flex; align-items: center; gap: 9px; padding: 12px 16px; background: #f4f5f6; border-bottom: 1px solid rgba(10,25,47,0.06); }
  .shwm-lock { width: 15px; height: 15px; color: #059669; flex-shrink: 0; }
  .shwm-url-t { font-size: 0.78rem; color: #64748b; font-family: var(--font-mono, ui-monospace, monospace); }
  .shwm-portal { padding: 26px 28px 28px; text-align: center; }
  .shwm-portal-head { display: flex; align-items: center; gap: 12px; text-align: left; }
  .shwm-portal-logo { width: 42px; height: 42px; border-radius: 11px; background: var(--brand,#0a192f); color: #fff; display: inline-flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 800; flex-shrink: 0; }
  .shwm-portal-head b { display: block; font-size: 0.92rem; color: #0f172a; font-weight: 700; }
  .shwm-portal-head em { display: block; font-style: normal; font-size: 0.72rem; color: #94a3b8; margin-top: 2px; }
  .shwm-portal-total { padding: 22px 0 18px; }
  .shwm-portal-total > span { display: block; font-size: 0.62rem; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; color: #a3adba; }
  .shwm-portal-total > b { display: block; font-size: 2.4rem; color: #0f172a; letter-spacing: -0.035em; margin-top: 6px; }
  .shwm-portal-total > em { display: block; font-style: normal; font-size: 0.74rem; color: #94a3b8; margin-top: 6px; }
  .shwm-portal-lines { text-align: left; border-top: 1px solid rgba(10,25,47,0.06); border-bottom: 1px solid rgba(10,25,47,0.06); }
  .shwm-pl { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 11px 2px; font-size: 0.82rem; color: #475569; border-bottom: 1px solid rgba(10,25,47,0.04); }
  .shwm-pl:last-child { border-bottom: none; }
  .shwm-pl b { color: #0f172a; font-weight: 600; }
  .shwm-portal-cta { margin-top: 20px; background: var(--brand,#0a192f); color: #fff; font-size: 0.9rem; font-weight: 700; padding: 14px; border-radius: 12px; box-shadow: 0 10px 24px -10px rgba(180,83,9,0.5); }

  /* approve → vendor cause/effect */
  .shwm-approve-card { width: 100%; max-width: 300px; background: #fff; border: 1px solid rgba(10,25,47,0.07); border-radius: 18px; box-shadow: 0 24px 50px -20px rgba(10,25,47,0.2); padding: 26px 22px; text-align: center; }
  .shwm-approve-ring { width: 58px; height: 58px; border-radius: 50%; margin: 0 auto 14px; background: #10b981; color: #fff; display: flex; align-items: center; justify-content: center; box-shadow: 0 0 0 8px rgba(16,185,129,0.12); }
  .shwm-approve-ring svg { width: 28px; height: 28px; }
  .shwm-approve-card b { display: block; font-size: 1rem; color: #0f172a; font-weight: 700; }
  .shwm-approve-card em { display: block; font-style: normal; font-size: 0.74rem; color: #94a3b8; margin-top: 6px; }
  .shwm-approve-hash { margin-top: 12px; font-size: 0.64rem; color: #b6bcc6; font-family: var(--font-mono, monospace); }

  .shwm-vendor-toast { width: 100%; max-width: 320px; display: flex; align-items: flex-start; gap: 13px; background: #fff; border: 1px solid rgba(10,25,47,0.07); border-radius: 14px; box-shadow: 0 20px 44px -18px rgba(10,25,47,0.22); padding: 15px 16px; }
  .shwm-vt-ico { width: 38px; height: 38px; border-radius: 10px; background: rgba(16,185,129,0.1); color: #059669; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .shwm-vt-ico svg { width: 19px; height: 19px; }
  .shwm-vt-tx b { display: block; font-size: 0.86rem; color: #0f172a; font-weight: 700; }
  .shwm-vt-tx span { display: block; font-size: 0.72rem; color: #94a3b8; margin-top: 3px; line-height: 1.4; }
  .shwm-vendor-status { margin-top: 14px; }

  /* ══════════════════ SEGUIMIENTO ══════════════════ */
  .shwm-temp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; padding: 18px 18px 10px; }
  .shwm-temp { border-radius: 14px; padding: 16px; display: flex; flex-direction: column; gap: 4px; }
  .shwm-temp-hot { background: linear-gradient(160deg, rgba(245,158,11,0.07), rgba(245,158,11,0.02)); border: 1px solid rgba(245,158,11,0.2); }
  .shwm-temp-cold { background: #f8fafc; border: 1px solid rgba(10,25,47,0.06); filter: saturate(0.6); }
  .shwm-temp-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
  .shwm-temp b { font-size: 0.92rem; color: #0f172a; font-weight: 700; }
  .shwm-temp em { font-style: normal; font-size: 0.72rem; color: #94a3b8; }
  .shwm-temp-meta { display: flex; align-items: center; gap: 8px; font-size: 0.76rem; color: #64748b; margin-top: 8px; }
  .shwm-temp-cta { margin-top: 12px; text-align: center; font-size: 0.78rem; font-weight: 700; padding: 9px; border-radius: 10px; background: #0a192f; color: #fff; }
  .shwm-temp-cta-off { background: transparent; color: #b6bcc6; border: 1px dashed rgba(10,25,47,0.14); font-weight: 500; }

  .shwm-feed { display: flex; flex-direction: column; padding: 8px 18px; }
  .shwm-feed-r { display: flex; align-items: center; gap: 14px; padding: 13px 0; border-bottom: 1px solid rgba(10,25,47,0.05); }
  .shwm-feed-r:last-child { border-bottom: none; }
  .shwm-feed-now { }
  .shwm-feed-ico { width: 34px; height: 34px; border-radius: 10px; background: rgba(10,25,47,0.04); color: #64748b; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .shwm-feed-now .shwm-feed-ico { background: rgba(245,158,11,0.12); color: #d97706; }
  .shwm-feed-ico svg { width: 18px; height: 18px; }
  .shwm-feed-tx { flex: 1; }
  .shwm-feed-tx b { display: block; font-size: 0.86rem; color: #0f172a; font-weight: 600; }
  .shwm-feed-tx span { display: block; font-size: 0.72rem; color: #94a3b8; margin-top: 2px; }
  .shwm-feed-n { flex-shrink: 0; font-size: 0.7rem; font-weight: 800; color: #d97706; background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.22); border-radius: 8px; padding: 4px 9px; }
  .shwm-feed-r:not(.shwm-feed-now) .shwm-feed-n { color: #94a3b8; background: rgba(10,25,47,0.04); border-color: rgba(10,25,47,0.09); }

  .shwm-pipe { display: flex; flex-direction: column; gap: 4px; padding: 6px 18px 12px; }
  .shwm-pipe-r { display: grid; grid-template-columns: 1.1fr 2.2fr 1fr; align-items: center; gap: 14px; padding: 9px 0; font-size: 0.82rem; color: #475569; }
  .shwm-pipe-r b { text-align: right; color: #0f172a; font-weight: 600; }

  /* ══════════════════ CFDI ══════════════════ */
  .shwm-flow { display: grid; grid-template-columns: 1fr 60px 1fr; align-items: stretch; gap: 0; padding: 18px 20px; }
  .shwm-flow-col { display: flex; flex-direction: column; gap: 8px; }
  .shwm-flow-cap { font-size: 0.62rem; font-weight: 700; letter-spacing: 0.4px; text-transform: uppercase; color: #a3adba; margin-bottom: 2px; }
  .shwm-flow-node { display: flex; align-items: center; justify-content: space-between; gap: 8px; background: #f8fafc; border: 1px solid rgba(10,25,47,0.06); border-radius: 9px; padding: 10px 12px; font-size: 0.76rem; color: #94a3b8; }
  .shwm-flow-node b { color: #0f172a; font-weight: 600; font-size: 0.78rem; }
  .shwm-flow-filled { background: rgba(16,185,129,0.05); border-color: rgba(16,185,129,0.18); }
  .shwm-flow-wires { display: flex; align-items: center; justify-content: center; color: rgba(16,185,129,0.4); }
  .shwm-flow-wires svg { width: 100%; height: 90%; }
  .shwm-flow-out { }

  .shwm-thread { display: flex; flex-direction: column; padding: 14px 20px 6px; position: relative; }
  .shwm-thread-node { display: flex; align-items: center; gap: 14px; padding: 12px 0; position: relative; }
  .shwm-thread-node:not(:last-child)::after { content: ''; position: absolute; left: 15px; top: 42px; bottom: -8px; width: 2px; background: rgba(16,185,129,0.3); }
  .shwm-tn-ico { width: 32px; height: 32px; border-radius: 50%; background: #10b981; color: #fff; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; z-index: 1; box-shadow: 0 0 0 4px #fff; }
  .shwm-tn-ico svg { width: 16px; height: 16px; }
  .shwm-tn-tx { flex: 1; }
  .shwm-tn-tx b { display: block; font-size: 0.88rem; color: #0f172a; font-weight: 600; }
  .shwm-tn-tx span { display: block; font-size: 0.72rem; color: #94a3b8; margin-top: 2px; }
  .shwm-thread-node > b { flex-shrink: 0; color: #0f172a; font-weight: 600; }
  .shwm-brand-mini { border-radius: 5px; flex-shrink: 0; }
  .shwm-uuid-strip { margin: 4px 20px 0; padding: 11px 14px; background: #f8fafc; border: 1px solid rgba(10,25,47,0.05); border-radius: 9px; font-family: var(--font-mono, monospace); font-size: 0.68rem; color: #94a3b8; word-break: break-all; }
  .shwm-uuid-strip b { color: #2563eb; font-weight: 600; }

  /* CSD upload */
  .shwm-drop-zone { padding: 20px 20px 8px; display: flex; flex-direction: column; gap: 10px; }
  .shwm-file { display: flex; align-items: center; gap: 13px; background: #f8fafc; border: 1px solid rgba(10,25,47,0.06); border-radius: 12px; padding: 13px 15px; }
  .shwm-file-ico { width: 38px; height: 38px; border-radius: 10px; background: rgba(16,185,129,0.09); color: #059669; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .shwm-file-ico svg { width: 19px; height: 19px; }
  .shwm-file > div { flex: 1; }
  .shwm-file b { display: block; font-size: 0.84rem; color: #0f172a; font-weight: 600; }
  .shwm-file em { display: block; font-style: normal; font-size: 0.7rem; color: #94a3b8; margin-top: 2px; }
  .shwm-connected { display: flex; align-items: center; gap: 13px; margin: 12px 20px 6px; padding: 14px 15px; background: rgba(16,185,129,0.05); border: 1px solid rgba(16,185,129,0.18); border-radius: 12px; }
  .shwm-conn-ring { width: 34px; height: 34px; border-radius: 50%; background: #10b981; color: #fff; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .shwm-conn-ring svg { width: 17px; height: 17px; }
  .shwm-connected > div { flex: 1; }
  .shwm-connected b { display: block; font-size: 0.86rem; color: #0f172a; font-weight: 600; }
  .shwm-connected em { display: block; font-style: normal; font-size: 0.7rem; color: #94a3b8; margin-top: 2px; }

  /* ══════════════════ CLIENTES & CRÉDITO ══════════════════ */
  .shwm-credit { display: flex; flex-direction: column; padding: 10px 16px; }
  .shwm-credit-r { display: grid; grid-template-columns: 1.5fr 1.3fr 1fr; align-items: center; gap: 16px; padding: 13px 8px; border-bottom: 1px solid rgba(10,25,47,0.05); border-radius: 8px; }
  .shwm-credit-r:last-child { border-bottom: none; }
  .shwm-credit-hot { background: rgba(245,158,11,0.045); }
  .shwm-credit-who { display: flex; align-items: center; gap: 11px; }
  .shwm-credit-who b { display: block; font-size: 0.84rem; color: #0f172a; font-weight: 600; }
  .shwm-credit-who em { display: block; font-style: normal; font-size: 0.7rem; color: #94a3b8; margin-top: 1px; }
  .shwm-gauge { height: 10px; border-radius: 100px; background: #eef2f7; overflow: hidden; }
  .shwm-gauge > i { display: block; height: 100%; border-radius: 100px; background: #2563eb; }
  .shwm-gauge > i.warn { background: linear-gradient(90deg,#f59e0b,#dc2626); }
  .shwm-gauge-off { opacity: 0.5; }
  .shwm-credit-r > b { text-align: right; font-weight: 600; color: #0f172a; }
  .shwm-credit-r > .shwm-badge { justify-self: end; }

  .shwm-cli-who { display: flex; align-items: center; gap: 11px; }
  .shwm-cli-who .shwm-avat { width: 30px; height: 30px; font-size: 0.66rem; }

  .shwm-profile { padding: 18px 18px 6px; }
  .shwm-profile-head { display: flex; align-items: center; gap: 14px; padding-bottom: 16px; border-bottom: 1px solid rgba(10,25,47,0.06); margin-bottom: 14px; }
  .shwm-profile-head b { display: block; font-size: 1.02rem; color: #0f172a; font-weight: 700; }
  .shwm-profile-head em { display: block; font-style: normal; font-size: 0.74rem; color: #94a3b8; margin-top: 3px; }
  .shwm-plist { display: flex; flex-direction: column; }

  /* ══════════════════ COBRANZA IA ══════════════════ */
  .shwm-log { display: flex; flex-direction: column; padding: 8px 18px; }
  .shwm-log-r { display: flex; align-items: center; gap: 14px; padding: 12px 0; border-bottom: 1px solid rgba(10,25,47,0.05); }
  .shwm-log-r:last-child { border-bottom: none; }
  .shwm-log-time { flex-shrink: 0; width: 92px; font-size: 0.72rem; font-weight: 700; color: #b45309; font-family: var(--font-mono, monospace); }
  .shwm-log-ico { width: 32px; height: 32px; border-radius: 9px; background: rgba(10,25,47,0.04); color: #64748b; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .shwm-log-ico svg { width: 16px; height: 16px; }
  .shwm-log-tx { flex: 1; }
  .shwm-log-tx b { display: block; font-size: 0.84rem; color: #0f172a; font-weight: 600; }
  .shwm-log-tx span { display: block; font-size: 0.72rem; color: #94a3b8; margin-top: 2px; }

  .shwm-chat { display: flex; flex-direction: column; gap: 10px; padding: 18px 20px 10px; }
  .shwm-msg { max-width: 76%; font-size: 0.84rem; line-height: 1.45; padding: 11px 14px; box-shadow: 0 4px 14px -8px rgba(10,25,47,0.14); }
  .shwm-msg-ai { align-self: flex-start; background: #f4f6f9; color: #334155; border: 1px solid rgba(10,25,47,0.05); border-radius: 15px 15px 15px 4px; }
  .shwm-msg-cl { align-self: flex-end; background: #0a192f; color: #fff; border-radius: 15px 15px 4px 15px; }
  .shwm-msg-tag { display: block; font-size: 0.58rem; font-weight: 800; letter-spacing: 0.4px; text-transform: uppercase; color: #2563eb; margin-bottom: 4px; }
  .shwm-plan-card { margin: 8px 20px 0; padding: 14px 16px; background: rgba(16,185,129,0.04); border: 1px solid rgba(16,185,129,0.18); border-radius: 12px; }
  .shwm-plan-head { display: flex; align-items: center; justify-content: space-between; padding-bottom: 10px; margin-bottom: 6px; border-bottom: 1px solid rgba(16,185,129,0.14); }
  .shwm-plan-head b { font-size: 0.84rem; color: #0f172a; font-weight: 700; }
  .shwm-plan-row { display: flex; align-items: center; justify-content: space-between; padding: 6px 0; font-size: 0.8rem; color: #475569; }
  .shwm-plan-row b { color: #0f172a; font-weight: 600; }

  .shwm-audit-what { display: flex; align-items: center; gap: 9px; color: #0f172a; font-weight: 500; }
  .shwm-ad-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .shwm-ad-dot.blue { background: #2563eb; }
  .shwm-ad-dot.amber { background: #f59e0b; }
  .shwm-ad-dot.green { background: #10b981; }
  .shwm-audit-actor { font-size: 0.78rem; color: #64748b; }

  /* ══════════════════ DIVISAS / FX ══════════════════ */
  .shwm-fxchart { padding: 16px 20px 4px; }
  .shwm-fxchart-plot { position: relative; height: 130px; background: #f8fafc; border: 1px solid rgba(10,25,47,0.05); border-radius: 12px; overflow: hidden; }
  .shwm-fxchart-plot svg { position: absolute; inset: 0; width: 100%; height: 100%; }
  .shwm-fx-lockbadge { position: absolute; top: 14px; right: 14px; display: inline-flex; align-items: center; gap: 6px; font-size: 0.64rem; font-weight: 700; color: #0a192f; background: rgba(255,255,255,0.9); border: 1px solid rgba(10,25,47,0.1); border-radius: 100px; padding: 4px 10px; }
  .shwm-fx-lockbadge svg { width: 13px; height: 13px; }
  .shwm-fx-legend { display: flex; gap: 20px; padding: 10px 2px 0; }
  .shwm-fx-legend span { display: inline-flex; align-items: center; gap: 7px; font-size: 0.72rem; color: #64748b; }
  .shwm-lg-line { width: 16px; height: 3px; border-radius: 2px; }
  .shwm-lg-line.gray { background: #cbd5e1; }
  .shwm-lg-line.navy { background: #0a192f; }

  .shwm-ticker { padding: 18px 20px 8px; display: flex; flex-direction: column; gap: 12px; }
  .shwm-tick-r { display: grid; grid-template-columns: 1.2fr 1fr 1.2fr; align-items: center; gap: 14px; background: #f8fafc; border: 1px solid rgba(10,25,47,0.05); border-radius: 12px; padding: 14px 16px; }
  .shwm-tick-cur { font-size: 0.78rem; font-weight: 700; color: #475569; }
  .shwm-tick-big { font-size: 1.5rem; color: #0f172a; letter-spacing: -0.03em; text-align: center; }
  .shwm-tick-live { display: inline-flex; align-items: center; gap: 7px; justify-self: end; font-size: 0.7rem; color: #94a3b8; }
  .shwm-pulse { width: 8px; height: 8px; border-radius: 50%; background: #10b981; box-shadow: 0 0 0 3px rgba(16,185,129,0.18); }

  .shwm-dual { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 0; padding: 20px 20px 12px; }
  .shwm-dual-col { background: #f8fafc; border: 1px solid rgba(10,25,47,0.06); border-radius: 14px; padding: 18px 18px; }
  .shwm-dual-fiscal { background: rgba(16,185,129,0.04); border-color: rgba(16,185,129,0.18); }
  .shwm-dual-cap { display: block; font-size: 0.62rem; font-weight: 700; letter-spacing: 0.4px; text-transform: uppercase; color: #a3adba; }
  .shwm-dual-flag { display: flex; align-items: center; gap: 8px; margin-top: 10px; font-size: 0.74rem; font-weight: 600; color: #64748b; }
  .shwm-dual-amt { display: block; font-size: 1.7rem; color: #0f172a; letter-spacing: -0.03em; margin-top: 8px; }
  .shwm-dual-col em { display: block; font-style: normal; font-size: 0.7rem; color: #94a3b8; margin-top: 6px; }
  .shwm-dual-eq { font-size: 1.4rem; font-weight: 300; color: #cbd5e1; padding: 0 16px; }
  .shwm-flag { display: inline-flex; align-items: center; justify-content: center; min-width: 24px; height: 17px; padding: 0 4px; border-radius: 3px; background: #1d4ed8; color: #fff; font-size: 0.56rem; font-weight: 800; letter-spacing: 0.3px; }
