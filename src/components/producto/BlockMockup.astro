---
const { slug, index } = Astro.props;
---
<div class={`bm-wrap bm-${slug}-${index}`}>
  <div class="bm-mesh" aria-hidden="true"></div>
  <div class="bm-glow" aria-hidden="true"></div>

  {/* ────────────────── EDITOR ────────────────── */}
  {slug === 'editor' && index === 0 && (
    <div class="bm-stage bm-editor-m0">
      <div class="bm-floating bm-float-top-right">
        <div class="bm-pill">
          <i class="bm-dot bm-dot-blue"></i>
          <span>Guardado automático</span>
        </div>
      </div>
      <div class="bm-card">
        <div class="bm-row"><span>Cemento gris 50kg</span><span>120</span><b class="editorial">$182.00</b></div>
        <div class="bm-row bm-row-target">
          <span>Varilla 3/8" × 12m</span><span>340</span>
          <b class="editorial mk-green"><span class="price-val">$191.48</span> <i class="mk-chip bm-chip-hide">−12%</i></b>
        </div>
        <div class="bm-row"><span>Block hueco</span><span>2400</span><b class="editorial">$14.20</b></div>
      </div>
      <!-- Cursor falso -->
      <div class="bm-fake-cursor">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3l7.07 16.97 2.51-7.39 7.39-2.51L3 3z"/></svg>
      </div>
    </div>
  )}

  {slug === 'editor' && index === 1 && (
    <div class="bm-stage bm-editor-m1">
      <div class="bm-floating bm-float-bottom-left">
        <div class="bm-pill bm-pill-dark">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20V10M18 20V4M6 20v-4"/></svg>
          <span class="bm-margin-text">Margen 24%</span>
        </div>
      </div>
      <div class="bm-card">
        <div class="bm-head"><span>Costo Base</span><span>Lista</span></div>
        <div class="bm-row"><span>$128.00</span><b>$182.00</b></div>
        <div class="bm-row bm-active">
           <span>$140.00</span>
           <div class="bm-margin-bar-bg"><div class="bm-margin-bar-fill"></div></div>
           <b>$168.50</b>
        </div>
        <div class="bm-row"><span>$9.80</span><b>$14.20</b></div>
      </div>
    </div>
  )}

  {slug === 'editor' && index === 2 && (
    <div class="bm-stage bm-editor-m2">
      <div class="bm-floating bm-float-bottom-right bm-stamp-hide">
        <div class="bm-pill">
          <i class="bm-dot bm-dot-green"></i>
          <span>Subtotal calculado</span>
        </div>
      </div>
      <div class="bm-card">
        <div class="bm-row bm-stag-row"><span>Subtotal</span><b>$169,370.00</b></div>
        <div class="bm-row bm-stag-row"><span>IVA 16%</span><b>$27,099.20</b></div>
        <div class="bm-divider bm-stag-row"></div>
        <div class="bm-row bm-stag-row bm-total-row"><span class="bm-bold">Total a pagar</span><b class="bm-large">$196,469.20</b></div>
      </div>
    </div>
  )}

  {/* ────────────────── LINK PÚBLICO ────────────────── */}
  {slug === 'link-publico' && index === 0 && (
    <div class="bm-stage bm-public-m0">
      <div class="bm-floating bm-float-bottom-left bm-toast-hide">
        <div class="bm-toast">
          <span class="bm-avatar">MR</span>
          <div class="bm-toast-text"><b>Mario Ruiz</b><i>dejó un comentario</i></div>
        </div>
      </div>
      <div class="bm-card bm-chat">
        <div class="bm-msg bm-msg-in"><span>¿Incluye la maniobra de descarga?</span></div>
        <div class="bm-msg bm-msg-typing"><span>...</span></div>
        <div class="bm-msg bm-msg-out bm-msg-hide"><span>Sí, la descarga a pie de obra está incluida en el total.</span></div>
      </div>
    </div>
  )}

  {slug === 'link-publico' && index === 1 && (
    <div class="bm-stage bm-public-m1">
      <div class="bm-floating bm-float-top-right">
        <div class="bm-pill bm-pill-brand bm-logo-pill">
          <span>Tu Logo</span>
        </div>
      </div>
      <div class="bm-card bm-brand-card">
        <div class="bm-brand-head">
          <div class="bm-brand-logo"></div>
          <div><b>Acero Monterrey</b><i>acero-monterrey.cord.mx</i></div>
        </div>
        <div class="bm-brand-color">
          <span>Brand Color</span>
          <div class="bm-color-swatch-wrap">
             <div class="bm-color-swatch bm-swatch-1"></div>
             <div class="bm-color-swatch bm-swatch-2"></div>
             <div class="bm-color-swatch bm-swatch-3"></div>
          </div>
        </div>
      </div>
      <div class="bm-fake-cursor">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3l7.07 16.97 2.51-7.39 7.39-2.51L3 3z"/></svg>
      </div>
    </div>
  )}

  {slug === 'link-publico' && index === 2 && (
    <div class="bm-stage bm-public-m2">
      <div class="bm-push-notif">
         <div class="bm-push-icon"><img src="/imgs/logo-cord-white.png" alt="" /></div>
         <div class="bm-push-body">
            <b>Cord B2B</b>
            <span>Distribuidora El Zarco acaba de abrir la cotización COT-0148.</span>
         </div>
      </div>
      <div class="bm-card bm-dim">
        <div class="bm-row"><span>Estado</span><b>Pendiente</b></div>
        <div class="bm-row"><span>Total</span><b>$196k</b></div>
      </div>
    </div>
  )}

  {/* ────────────────── SEGUIMIENTO ────────────────── */}
  {slug === 'seguimiento' && index === 0 && (
    <div class="bm-stage bm-track-m0">
      <div class="bm-timeline-card">
         <div class="bm-tl-line">
            <div class="bm-tl-fill"></div>
         </div>
         <div class="bm-tl-nodes">
            <div class="bm-tl-node"><i class="bm-icon-check">✓</i><span>Borrador</span></div>
            <div class="bm-tl-node"><i class="bm-icon-check">✓</i><span>Enviada</span></div>
            <div class="bm-tl-node"><i class="bm-icon-check">✓</i><span>Vista</span></div>
            <div class="bm-tl-node bm-node-pending"><i></i><span>Aprobada</span></div>
         </div>
      </div>
    </div>
  )}

  {slug === 'seguimiento' && index === 1 && (
    <div class="bm-stage bm-track-m1">
      <div class="bm-kanban">
        <div class="bm-board-col">
          <div class="bm-col-head">Negociación</div>
          <div class="bm-board-card bm-kanban-drag">
            <span class="bm-badge bm-badge-orange">COT-0148</span>
            <b>$196k</b>
            <div class="bm-card-foot"><span class="bm-avatar-sm">EZ</span><i>Hace 1h</i></div>
          </div>
        </div>
        <div class="bm-board-col">
          <div class="bm-col-head">Ganadas</div>
          <div class="bm-board-card bm-dim">
            <span class="bm-badge bm-badge-gray">COT-0149</span>
            <b>$24k</b>
            <div class="bm-card-foot"><span class="bm-avatar-sm">GF</span><i>Ayer</i></div>
          </div>
          <!-- Drop target -->
          <div class="bm-kanban-drop"></div>
        </div>
      </div>
      <div class="bm-fake-cursor">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3l7.07 16.97 2.51-7.39 7.39-2.51L3 3z"/></svg>
      </div>
    </div>
  )}

  {slug === 'seguimiento' && index === 2 && (
    <div class="bm-stage bm-track-m2">
      <div class="bm-search">
        <div class="bm-search-bar">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <span class="bm-search-type">_</span>
        </div>
        <div class="bm-search-res">
          <div class="bm-s-res-1"><b>COT-0148</b><span>Varilla 3/8" × 12m</span></div>
          <div class="bm-s-res-2"><b>COT-0092</b><span>Varilla 1/2" × 12m</span></div>
        </div>
      </div>
    </div>
  )}

  {/* ────────────────── CFDI ────────────────── */}
  {slug === 'cfdi' && index === 0 && (
    <div class="bm-stage bm-cfdi-m0">
      <div class="bm-floating bm-float-top-left">
          <div class="bm-pill bm-pill-brand">
             <span>Timbrado SAT 4.0</span>
          </div>
      </div>
      <div class="bm-card bm-cfdi-card">
        <div class="bm-fake-xml bm-matrix-text">
          &lt;cfdi:Comprobante Version="4.0"&gt;           &lt;cfdi:Emisor Rfc="MVA24..."/&gt;           &lt;cfdi:Conceptos&gt;...&lt;/cfdi&gt;
        </div>
        <div class="bm-row"><span>Status</span><b class="bm-green">Generado</b></div>
        <div class="bm-row"><span>UUID</span><b>a1b2c3d4-9f01...</b></div>
      </div>
    </div>
  )}

  {slug === 'cfdi' && index === 1 && (
    <div class="bm-stage bm-cfdi-m1">
      <div class="bm-floating bm-float-bottom-right bm-cert-stamp">
        <div class="bm-pill">
           <i class="bm-dot bm-dot-green"></i>
           <span>Conectado</span>
        </div>
      </div>
      <div class="bm-terminal">
        <div class="bm-term-head">
          <i></i><i></i><i></i>
          <span>cert.key</span>
        </div>
        <div class="bm-term-body">
          <span class="bm-term-line line-1">Loading CSD...</span>
          <span class="bm-term-line bm-term-ok line-2">[OK] Validating .CER</span>
          <span class="bm-term-line line-3">Decrypting .KEY password...</span>
          <span class="bm-term-line bm-term-ok line-4">[OK] Ready for signing</span>
          <span class="bm-term-cursor">_</span>
        </div>
      </div>
    </div>
  )}

  {slug === 'cfdi' && index === 2 && (
    <div class="bm-stage bm-cfdi-m2">
      <div class="bm-floating bm-float-top-right">
        <div class="bm-pill bm-pill-dark">
          <i class="bm-icon-check">✓</i>
          <span>Autofactura</span>
        </div>
      </div>
      <div class="bm-card">
        <div class="bm-barcode">
          <div class="bm-bars"></div>
          <div class="bm-laser"></div>
          <span>Ticket: 9812-7361-0021</span>
        </div>
        <div class="bm-btn bm-btn-outline">Ver PDF</div>
      </div>
    </div>
  )}

  {/* ────────────────── CLIENTES & CRÉDITO ────────────────── */}
  {slug === 'clientes-credito' && index === 0 && (
    <div class="bm-stage bm-credit-m0">
       <div class="bm-floating bm-float-top-left bm-req-appr">
          <div class="bm-pill">
             <i class="bm-dot bm-dot-orange"></i>
             <span>Requiere aprobación</span>
          </div>
       </div>
      <div class="bm-card">
        <div class="bm-head"><b>Distribuidora El Zarco</b><span class="bm-tag bm-tag-warn">Net 30</span></div>
        <div class="bm-credit-bar">
          <div class="bm-credit-fill"></div>
        </div>
        <div class="bm-row"><span>Crédito usado</span><b>$<span class="bm-credit-val">0</span>k / $500k</b></div>
      </div>
    </div>
  )}

  {slug === 'clientes-credito' && index === 1 && (
    <div class="bm-stage bm-credit-m1">
       <div class="bm-floating bm-float-bottom-left bm-spei-toast">
          <div class="bm-toast bm-toast-sm bm-toast-success">
             <i class="bm-icon-check">✓</i>
             <div><span>Pago registrado</span><b>$45,000.00</b></div>
          </div>
       </div>
      <div class="bm-card">
        <div class="bm-row"><span>Factura F-102</span><b>$45,000.00</b></div>
        <div class="bm-divider"></div>
        <div class="bm-row"><span>Estado</span><b class="bm-spei-status bm-orange">Pendiente</b></div>
        <div class="bm-row"><span>Método</span><b>SPEI</b></div>
      </div>
    </div>
  )}

  {slug === 'clientes-credito' && index === 2 && (
    <div class="bm-stage bm-credit-m2">
      <div class="bm-card">
        <div class="bm-head"><span>Líneas de crédito</span></div>
        <div class="bm-chart">
          <div class="bm-chart-col c-1"><div class="bm-chart-col-fill"></div></div>
          <div class="bm-chart-col c-2"><div class="bm-chart-col-fill"></div></div>
          <div class="bm-chart-col c-3"><div class="bm-chart-col-fill"></div></div>
          <div class="bm-chart-col c-4 bm-chart-active"><div class="bm-chart-col-fill"></div></div>
          <div class="bm-chart-col c-5"><div class="bm-chart-col-fill"></div></div>
        </div>
        <div class="bm-row"><span>Total riesgo</span><b>$1.2M</b></div>
      </div>
    </div>
  )}

  {/* ────────────────── COBRANZA CON IA ────────────────── */}
  {slug === 'cobranza-ia' && index === 0 && (
    <div class="bm-stage bm-ar-m0">
      <div class="bm-floating bm-float-top-right bm-ar-badge-hide">
        <div class="bm-pill"><i class="bm-dot bm-dot-green"></i><span>Plan aceptado</span></div>
      </div>
      <div class="bm-card bm-chat">
        <div class="bm-msg bm-msg-in"><span>El agente escribió a Raúl por correo</span></div>
        <div class="bm-msg bm-msg-out"><span>Propuesta: 3 pagos de $137,433 · sin recargos</span></div>
        <div class="bm-msg bm-msg-in bm-ar-reply-hide"><span>De acuerdo, empiezo el 15 de julio</span></div>
      </div>
    </div>
  )}

  {slug === 'cobranza-ia' && index === 1 && (
    <div class="bm-stage bm-ar-m1">
      <div class="bm-floating bm-float-top-left">
        <div class="bm-pill bm-pill-brand"><span>AI CFO Insight</span></div>
      </div>
      <div class="bm-card">
        <div class="bm-head"><span>Flujo esperado · 90 días</span><span class="bm-green">IA</span></div>
        <div class="bm-chart">
          <div class="bm-chart-col"><div class="bm-chart-col-fill"></div></div>
          <div class="bm-chart-col"><div class="bm-chart-col-fill"></div></div>
          <div class="bm-chart-col"><div class="bm-chart-col-fill"></div></div>
          <div class="bm-chart-col bm-chart-active"><div class="bm-chart-col-fill"></div></div>
          <div class="bm-chart-col"><div class="bm-chart-col-fill"></div></div>
        </div>
        <div class="bm-row"><span>Ingreso proyectado</span><b>$1.84M</b></div>
      </div>
    </div>
  )}

  {slug === 'cobranza-ia' && index === 2 && (
    <div class="bm-stage bm-ar-m2">
      <div class="bm-card">
        <div class="bm-head"><span>Conversaciones de cobranza</span></div>
        <div class="bm-row bm-ar-row"><span>Distribuidora El Zarco</span><b class="bm-ar-status bm-orange">Negociando</b></div>
        <div class="bm-row bm-ar-row"><span>Constructora GAMA</span><b class="bm-green">Plan activo</b></div>
        <div class="bm-row bm-ar-row"><span>Grupo Ferrex</span><b>Esperando tu OK</b></div>
      </div>
    </div>
  )}

  {/* ────────────────── MULTI-DIVISA / FX ────────────────── */}
  {slug === 'divisas' && index === 0 && (
    <div class="bm-stage bm-fx-m0">
      <div class="bm-floating bm-float-top-right">
        <div class="bm-pill"><i class="bm-dot bm-dot-blue"></i><span>Factura en MXN</span></div>
      </div>
      <div class="bm-card">
        <div class="bm-head"><span>Presentación</span><span>Factura</span></div>
        <div class="bm-row"><span>USD 10,620.50</span><b class="editorial">$196,469.20</b></div>
        <div class="bm-row"><span>EUR 9,760.00</span><b class="editorial">$196,176.00</b></div>
      </div>
    </div>
  )}

  {slug === 'divisas' && index === 1 && (
    <div class="bm-stage bm-fx-m1">
      <div class="bm-floating bm-float-top-left">
        <div class="bm-pill"><i class="bm-dot bm-dot-green"></i><span>En vivo</span></div>
      </div>
      <div class="bm-terminal">
        <div class="bm-term-head"><i></i><i></i><i></i><span>fx.spot</span></div>
        <div class="bm-term-body">
          <span class="bm-term-line">Consultando BCE…</span>
          <span class="bm-term-line bm-term-ok">[OK] USD/MXN 18.50</span>
          <span class="bm-term-line bm-term-ok">[OK] EUR/MXN 20.10</span>
          <span class="bm-term-line">spot lock listo · 30 días</span>
          <span class="bm-term-cursor">_</span>
        </div>
      </div>
    </div>
  )}

  {slug === 'divisas' && index === 2 && (
    <div class="bm-stage bm-fx-m2">
      <div class="bm-floating bm-float-bottom-right">
        <div class="bm-pill bm-pill-brand"><span>🔒 Lock 30 días</span></div>
      </div>
      <div class="bm-card">
        <div class="bm-head"><span>Cobertura</span></div>
        <div class="bm-row"><span>Tasa spot</span><b class="editorial">$18.50</b></div>
        <div class="bm-row"><span>Buffer +2%</span><div class="bm-margin-bar-bg"><div class="bm-margin-bar-fill bm-fx-buffer-fill"></div></div></div>
        <div class="bm-row bm-active"><span>Tasa aplicada</span><b class="editorial bm-green bm-fx-applied">$18.50</b></div>
      </div>
    </div>
  )}

  {/* ────────────────── FACTURACIÓN INTERNACIONAL ────────────────── */}
  {slug === 'internacional' && index === 0 && (
    <div class="bm-stage bm-intl-m0">
      <div class="bm-floating bm-float-top-right">
        <div class="bm-pill bm-pill-brand"><span>🔒 30 días</span></div>
      </div>
      <div class="bm-card">
        <div class="bm-head"><span>Cobertura cambiaria</span></div>
        <div class="bm-row"><span>Tasa spot (BCE)</span><b class="editorial bm-intl-spot">$18.42</b></div>
        <div class="bm-row bm-row-target"><span>Tasa aplicada</span><b class="editorial bm-green"><span class="bm-intl-applied">$18.79</span> <i class="mk-chip bm-intl-chip">+2%</i></b></div>
        <div class="bm-row"><span>FX lock</span><b>30 días</b></div>
      </div>
    </div>
  )}

  {slug === 'internacional' && index === 1 && (
    <div class="bm-stage bm-intl-m1">
      <div class="bm-card">
        <div class="bm-head"><span>Divisas del trato</span></div>
        <div class="bm-row"><span>Presentación (cliente)</span><span class="bm-tag bm-tag-blue">USD</span></div>
        <div class="bm-row"><span>Fiscal (factura)</span><span class="bm-tag bm-tag-mxn">MXN</span></div>
        <div class="bm-divider"></div>
        <div class="bm-row"><span>Convertido</span><b class="editorial bm-intl-conv">$230,880.00</b></div>
      </div>
    </div>
  )}

  {slug === 'internacional' && index === 2 && (
    <div class="bm-stage bm-intl-m2">
      <div class="bm-floating bm-float-top-right">
        <div class="bm-pill bm-pill-brand"><span>México · SAT 4.0</span></div>
      </div>
      <div class="bm-floating bm-float-bottom-left bm-intl-us">
        <div class="bm-pill bm-pill-dark"><span>EE.UU. · en desarrollo</span></div>
      </div>
      <div class="bm-card bm-cfdi-card">
        <div class="bm-fake-xml">&lt;cfdi:Comprobante Version="4.0"&gt; &lt;cfdi:Emisor Rfc="MVA24..."/&gt; &lt;/cfdi:Comprobante&gt;</div>
        <div class="bm-row"><span>Status</span><b class="bm-green bm-intl-status">Timbrado</b></div>
        <div class="bm-row"><span>UUID</span><b>a1b2c3d4-9f01...</b></div>
      </div>
    </div>
  )}
  {/* ────────────────── FINANZAS ────────────────── */}
  {slug === 'finanzas' && index === 0 && (
    <div class="bm-stage bm-fin-m0">
      <div class="bm-floating bm-float-top-right">
        <div class="bm-pill bm-pill-brand"><span>AI CFO</span></div>
      </div>
      <div class="bm-card">
        <div class="bm-head"><span>Flujo de caja 90 días</span></div>
        <div class="bm-chart">
          <div class="bm-chart-col"><div class="bm-chart-col-fill" style="height:40%"></div></div>
          <div class="bm-chart-col"><div class="bm-chart-col-fill" style="height:60%"></div></div>
          <div class="bm-chart-col"><div class="bm-chart-col-fill" style="height:80%"></div></div>
          <div class="bm-chart-col bm-chart-active"><div class="bm-chart-col-fill" style="height:100%"></div></div>
          <div class="bm-chart-col"><div class="bm-chart-col-fill" style="height:50%"></div></div>
        </div>
        <div class="bm-row"><span>Proyección ajustada (DSO)</span><b class="bm-green">$2.4M</b></div>
      </div>
    </div>
  )}

  {slug === 'finanzas' && index === 1 && (
    <div class="bm-stage bm-fin-m1">
      <div class="bm-floating bm-float-bottom-left">
        <div class="bm-pill">
           <i class="bm-dot bm-dot-orange"></i>
           <span>Alerta temprana</span>
        </div>
      </div>
      <div class="bm-card">
        <div class="bm-head"><span>Riesgo de concentración</span></div>
        <div class="bm-row"><span>Grupo Constructor A</span><b class="bm-orange">42% de cartera</b></div>
        <div class="bm-row"><span>DSO promedio histórico</span><b>+18 días</b></div>
        <div class="bm-divider"></div>
        <div class="bm-row"><span>Recomendación AI</span><b>Limitar crédito</b></div>
      </div>
