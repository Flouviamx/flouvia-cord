---
// SettingsShell — chasis de las sub-páginas de Ajustes (estilo Stripe).
// Encabezado "Configuración › Categoría" + BARRA DE PESTAÑAS horizontal de la
// categoría (NO rail lateral) + contenido. Si `save`, pinta la barra de guardar
// y corre el guardado genérico que lee los [data-field] → PATCH /api/org.
// Si `perm` está presente, verifica el permiso del usuario y muestra acceso
// denegado inline (sin redirigir) si no lo tiene.
import AppLayout from '../../layouts/AppLayout.astro';
import { categoryOfTab } from '../../lib/settings';
import { getMyMembership } from '../../lib/queries';
import { memberCan, type PermKey } from '../../lib/permissions';

interface Props {
    title: string;       // título del documento
    tab: string;         // id de la pestaña activa (deriva la categoría)
    intro?: string;      // bajada opcional bajo las pestañas
    save?: boolean;      // ¿barra de guardar + guardado genérico?
    perm?: PermKey;      // permiso requerido para ver el contenido
}
const { title, tab, intro, save = false, perm } = Astro.props;
const category = categoryOfTab(tab)!;
const single = category.tabs.length <= 1;

const ME = perm ? await getMyMembership() : null;
const hasAccess = !perm || memberCan(ME!, perm);
---

<AppLayout title={title} page="ajustes" heading="Ajustes">
    <div class="set2">
        <a href="/app/ajustes" class="set2-crumb">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            Configuración
        </a>
        <h2 class="set2-title">{category.label}</h2>
        <p class="set2-desc">{category.desc}</p>

        {!single && (
            <nav class="set2-tabs" aria-label={`Pestañas de ${category.label}`}>
                {category.tabs.map((t) => (
                    <a href={t.href} class:list={['set2-tab', { active: t.id === tab }]}>{t.label}</a>
                ))}
            </nav>
        )}

        <div class="set2-content" data-settings-form>
            {!hasAccess && (
                <div class="access-denied">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    <h3>Sin acceso</h3>
                    <p>Tu rol actual no tiene permiso para ver esta sección. Contacta al administrador de tu organización.</p>
                </div>
            )}
            {hasAccess && intro && <p class="set2-intro">{intro}</p>}
            {hasAccess && <slot />}
            {hasAccess && save && (
                <div class="s-save-row">
                    <button class="s-save" id="sBtn">
                        <span class="s-save-label">Guardar cambios</span>
                        <svg class="s-save-spinner" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="2" opacity="0.25"/><path d="M18 10a8 8 0 0 1-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    </button>
                    <span class="s-saved" id="sMsg">
                        <svg class="s-check-icon" viewBox="0 0 20 20" fill="none"><path d="M4 10.5l4.5 4L16 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        <span class="s-saved-text">Cambios guardados</span>
                    </span>
                </div>
            )}
        </div>
    </div>
</AppLayout>

<style is:global>
    /* ════════ ESTILOS COMPARTIDOS DE AJUSTES (globales: cruzan el slot) ════════ */
    .set2 { max-width: 760px; }
    .set2-crumb { display: inline-flex; align-items: center; gap: 5px; font-size: 0.78rem; font-weight: 600; color: var(--color-text-muted); text-decoration: none; margin-bottom: 0.7rem; transition: color 0.2s; }
    .set2-crumb svg { width: 14px; height: 14px; }
    .set2-crumb:hover { color: var(--color-blue-deep); }
    .set2-title { font-size: 1.7rem; font-weight: 700; letter-spacing: -0.6px; margin: 0; }
    .set2-desc { font-size: 0.88rem; color: var(--color-text-muted); margin: 0.4rem 0 0; }

    /* Pestañas horizontales con subrayado (estilo Stripe) */
    .set2-tabs { display: flex; gap: 1.4rem; margin: 1.5rem 0 0; border-bottom: 1px solid var(--color-border); overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
    .set2-tabs::-webkit-scrollbar { display: none; }
    .set2-tab { position: relative; font-size: 0.88rem; font-weight: 600; color: var(--color-text-muted); text-decoration: none; padding: 0 0 12px; white-space: nowrap; transition: color 0.2s; }
    .set2-tab::after { content: ''; position: absolute; left: 0; right: 0; bottom: -1px; height: 2px; background: var(--color-blue-deep); border-radius: 2px; transform: scaleX(0); transition: transform 0.25s var(--ease-spring); }
    .set2-tab:hover { color: var(--color-text); }
    .set2-tab.active { color: var(--color-blue-deep); }
    .set2-tab.active::after { transform: scaleX(1); }

    .set2-content { padding-top: 1.8rem; }
    .set2-intro { font-size: 0.86rem; color: var(--color-text-muted); margin: 0 0 1.6rem; line-height: 1.5; max-width: 62ch; }

    /* Bloques y campos (compartidos por todas las sub-páginas) */
    .s-block { margin-bottom: 2.2rem; }
    .s-block > h3 { font-size: 0.7rem; font-weight: 800; letter-spacing: 1.4px; text-transform: uppercase; color: #99a2af; margin: 0 0 1rem; padding-bottom: 0.6rem; border-bottom: 1px solid var(--color-border); }
    .s-body { display: flex; flex-direction: column; gap: 1.1rem; }
    .s-row { display: grid; grid-template-columns: 1fr; gap: 1rem; }
    @media (min-width: 601px) {
        .s-row { grid-template-columns: 1fr 1fr; }
    }
    .s-field { display: flex; flex-direction: column; gap: 0.45rem; }
    .s-field label { font-size: 0.62rem; font-weight: 800; letter-spacing: 1.2px; text-transform: uppercase; color: #99a2af; }
    .s-input {
        font-family: var(--font-sans); font-size: 0.86rem; font-weight: 500;
        color: var(--color-text); background: var(--color-bg-soft);
        border: 1px solid var(--color-border); border-radius: 9px; padding: 10px 12px;
        transition: border-color 0.25s;
    }
    .s-input:focus { outline: none; border-color: var(--color-blue-deep); }
    .s-textarea { resize: vertical; min-height: 70px; line-height: 1.5; }
    .s-hint { font-size: 0.68rem; color: #99a2af; }

    .color-row { display: flex; align-items: center; gap: 12px; }
    .color-row input[type="color"] {
        -webkit-appearance: none; -moz-appearance: none; appearance: none;
        width: 38px; height: 38px; padding: 0; border: none; background: none; cursor: pointer; flex-shrink: 0;
    }
    .color-row input[type="color"]::-webkit-color-swatch-wrapper { padding: 0; }
    .color-row input[type="color"]::-webkit-color-swatch {
        border: 1px solid rgba(0,0,0,0.15);
        border-radius: 50%;
        box-shadow: inset 0 2px 4px rgba(0,0,0,0.04);
        transition: transform 0.2s;
    }
    .color-row input[type="color"]::-moz-color-swatch {
        border: 1px solid rgba(0,0,0,0.15);
        border-radius: 50%;
    }
    .color-row input[type="color"]:hover::-webkit-color-swatch { transform: scale(1.05); }
    .color-row .s-input { flex: 1; }

    /* Barra de guardar */
    .s-save-row { display: flex; align-items: center; gap: 1rem; margin-top: 0.4rem; flex-wrap: wrap; }
    .s-save {
        font-family: var(--font-sans); font-size: 0.88rem; font-weight: 600;
        background: var(--color-blue-deep); color: #fff; border: none; border-radius: 10px;
        padding: 12px 26px; cursor: pointer; box-shadow: 0 8px 22px -10px rgba(10,25,47,0.5);
        transition: transform 0.4s var(--ease-spring), background 0.35s var(--ease-ios), box-shadow 0.35s;
        width: 100%;
        justify-content: center;
        display: flex;
        align-items: center;
        gap: 0;
        position: relative;
        min-height: 44px;
    }
    @media (min-width: 601px) {
        .s-save { width: auto; display: inline-flex; }
    }
    .s-save:hover:not(:disabled):not(.saving):not(.saved) { transform: translateY(-2px); }
    .s-save:active:not(:disabled):not(.saving) { transform: translateY(0) scale(0.97); }
    .s-save:disabled { cursor: wait; transform: none; }

    /* Label + spinner layout */
    .s-save-label { transition: opacity 0.2s, transform 0.2s var(--ease-spring); }
    .s-save-spinner { width: 18px; height: 18px; position: absolute; opacity: 0; transition: opacity 0.2s; animation: s-spin 0.7s linear infinite; }
    .s-save.saving .s-save-label { opacity: 0; transform: scale(0.9); }
    .s-save.saving .s-save-spinner { opacity: 1; }
    .s-save.saving { opacity: 0.85; pointer-events: none; }

    /* Dirty — hay cambios sin guardar: el botón "respira" con un anillo sutil
       para llamar la atención sin gritar (patrón Stripe). */
    .s-save.dirty:not(.saving):not(.saved) {
        box-shadow: 0 8px 22px -10px rgba(10,25,47,0.5), 0 0 0 3px rgba(10,25,47,0.10);
        animation: s-breathe 2.2s ease-in-out infinite;
    }
    @keyframes s-breathe {
        0%, 100% { box-shadow: 0 8px 22px -10px rgba(10,25,47,0.5), 0 0 0 2px rgba(10,25,47,0.06); }
        50%      { box-shadow: 0 8px 22px -10px rgba(10,25,47,0.5), 0 0 0 4px rgba(10,25,47,0.14); }
    }
    @media (prefers-reduced-motion: reduce) {
        .s-save.dirty:not(.saving):not(.saved) { animation: none; }
    }

    /* Saved flash — botón pulsa verde brevemente */
    .s-save.saved { background: #0f766e; box-shadow: 0 8px 22px -10px rgba(15,118,110,0.5); animation: s-pulse 0.45s var(--ease-spring); pointer-events: none; }
    .s-save.saved .s-save-label { opacity: 0; transform: scale(0.9); }
    .s-save.saved .s-save-spinner { opacity: 0; }

    @keyframes s-pulse {
        0% { transform: scale(1); }
        35% { transform: scale(0.95); }
        70% { transform: scale(1.03); }
        100% { transform: scale(1); }
    }

    @keyframes s-spin {
        to { transform: rotate(360deg); }
    }

    @keyframes s-shake {
        0%, 100% { transform: translateX(0); }
        15% { transform: translateX(-3px); }
        30% { transform: translateX(3px); }
        45% { transform: translateX(-2px); }
        60% { transform: translateX(2px); }
        75% { transform: translateX(-1px); }
    }

    /* Mensaje de estado (check + texto) */
    .s-saved {
        display: inline-flex; align-items: center; gap: 5px;
        font-size: 0.8rem; font-weight: 600; color: var(--color-ok);
        opacity: 0; transform: translateY(4px);
        transition: opacity 0.35s var(--ease-ios), transform 0.35s var(--ease-spring);
    }
    .s-saved.show { opacity: 1; transform: translateY(0); }
    .s-saved.error { color: var(--color-danger); }

    /* Checkmark SVG animado */
    .s-check-icon { width: 16px; height: 16px; flex-shrink: 0; }
    .s-check-icon path {
        stroke-dasharray: 24;
        stroke-dashoffset: 24;
        transition: stroke-dashoffset 0.4s var(--ease-spring) 0.05s;
    }
    .s-saved.show .s-check-icon path { stroke-dashoffset: 0; }

    /* Panel de acceso denegado inline */
    .access-denied { display: flex; flex-direction: column; align-items: flex-start; gap: 0.6rem; padding: 2.4rem 0 1rem; }
    .access-denied svg { width: 32px; height: 32px; color: #c9d2de; }
    .access-denied h3 { font-size: 1rem; font-weight: 700; margin: 0; color: var(--color-text); }
    .access-denied p { font-size: 0.84rem; color: var(--color-text-muted); margin: 0; line-height: 1.55; }
</style>

<script>
    // Guardado genérico de Ajustes: junta todos los [data-field] del formulario
    // y los manda a PATCH /api/org (que solo toca los campos presentes).
    // Micro-animaciones: spinner durante fetch, pulse+check en éxito, shake en error.
    function initSettingsSave() {
        const btn = document.getElementById('sBtn') as HTMLButtonElement | null;
        const msg = document.getElementById('sMsg');
        const form = document.querySelector('[data-settings-form]');
        if (!btn || !msg || !form) return;

        const msgText = msg.querySelector('.s-saved-text') as HTMLElement | null;

        const cp = document.getElementById('oColorPick') as HTMLInputElement | null;
        const ct = document.getElementById('oColor') as HTMLInputElement | null;
        if (cp && ct) {
            cp.addEventListener('input', () => { ct.value = cp.value; ct.dispatchEvent(new Event('input', { bubbles: true })); });
            ct.addEventListener('input', () => { if (/^#[0-9a-fA-F]{6}$/.test(ct.value)) cp.value = ct.value; });
        }

        // ── Detección de cambios sin guardar (estilo Stripe) ──
        // Serializa los [data-field]; si difiere del snapshot inicial, la barra
        // entra en estado "dirty" (botón resaltado + aviso al salir de la página).
        const serialize = () => {
            const state: Record<string, unknown> = {};
            form.querySelectorAll('[data-field]').forEach((node) => {
                const el = node as HTMLInputElement;
                const k = el.dataset.field!;
                if (el.type === 'checkbox') state[k] = el.checked;
                else if (el.type === 'radio') { if (el.checked) state[k] = el.value; }
                else state[k] = el.value;
            });
            return JSON.stringify(state);
        };
        let baseline = serialize();
        let dirty = false;
        const syncDirty = () => {
            const now = serialize() !== baseline;
            if (now === dirty) return;
            dirty = now;
            btn.classList.toggle('dirty', dirty);
        };
        form.addEventListener('input', syncDirty);
        form.addEventListener('change', syncDirty);
        window.addEventListener('beforeunload', (e) => {
            if (!dirty) return;
            e.preventDefault();
            e.returnValue = '';
        });

        // ⌘S / Ctrl+S guarda (en vez del "Guardar página" del navegador).
        window.addEventListener('keydown', (e) => {
            if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 's') {
                e.preventDefault();
                if (!btn.disabled) btn.click();
            }
        });

        btn.addEventListener('click', async () => {
            const body: Record<string, unknown> = {};
            form.querySelectorAll('[data-field]').forEach((node) => {
                const el = node as HTMLInputElement;
                const k = el.dataset.field!;
                if (el.type === 'checkbox') body[k] = el.checked;
                else if (el.type === 'radio') { if (el.checked) body[k] = el.value; }
                else body[k] = el.value;
            });

            // Estado: saving (spinner)
            btn.disabled = true;
            btn.classList.remove('saved');
            btn.classList.add('saving');
            msg.className = 's-saved';

            try {
                const res = await fetch('/api/org', { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
                const d = await res.json();
                if (!res.ok) throw new Error(d.error || 'No se pudo guardar');

                // Estado: saved (pulse verde + check animado). El snapshot se
                // re-toma: lo guardado es el nuevo estado "limpio".
                baseline = serialize();
                syncDirty();
                btn.classList.remove('saving');
                btn.classList.add('saved');
                if (msgText) msgText.textContent = 'Cambios guardados';
                msg.className = 's-saved show';

                setTimeout(() => {
                    btn.classList.remove('saved');
                    btn.disabled = false;
                }, 500);
                setTimeout(() => msg.classList.remove('show'), 2800);

            } catch (err: any) {
                // Estado: error (shake + mensaje rojo)
                btn.classList.remove('saving');
                btn.disabled = false;
                btn.style.animation = 's-shake 0.4s var(--ease-spring)';
                btn.addEventListener('animationend', () => { btn.style.animation = ''; }, { once: true });

                if (msgText) msgText.textContent = err.message || 'No se pudo guardar';
                msg.className = 's-saved show error';
                setTimeout(() => msg.classList.remove('show'), 3500);
            }
        });
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initSettingsSave);
    else initSettingsSave();
</script>
