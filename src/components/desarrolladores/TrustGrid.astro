---
// TrustGrid — sección de confianza/infraestructura debajo del bento en
// /desarrolladores/[slug]. Layout tipo Stripe: fondo claro (igual que la
// página), texto oscuro a la izquierda, globo 3D grande a la derecha sin
// nada encima. Los 4 datos del grid van debajo como fila horizontal.
import type { DevTrust, DevTrustIcon } from '../../lib/desarrolladores';
import TrustGlobe from './TrustGlobe.jsx';

export interface Props { trust: DevTrust }
const { trust } = Astro.props;

const svg = (inner: string) => `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">${inner}</svg>`;

const ICONS: Record<DevTrustIcon, string> = {
    shield: svg(`<path d="M12 3l7 3v6c0 4.5-3 8-7 9-4-1-7-4.5-7-9V6l7-3z" fill="currentColor" fill-opacity="0.14"/><path d="M12 3l7 3v6c0 4.5-3 8-7 9-4-1-7-4.5-7-9V6l7-3z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M8.5 12l2.3 2.3L15.5 9.5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>`),
    key: svg(`<circle cx="8" cy="15" r="4.25" fill="currentColor" fill-opacity="0.14"/><circle cx="8" cy="15" r="4.25" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="M11 12l8.5-8.5M16.5 6.5l2 2M14 9l2 2" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>`),
    doc: svg(`<path d="M6 3.5h8l4 4v13a1 1 0 01-1 1H6a1 1 0 01-1-1v-16a1 1 0 011-1z" fill="currentColor" fill-opacity="0.12"/><path d="M6 3.5h8l4 4v13a1 1 0 01-1 1H6a1 1 0 01-1-1v-16a1 1 0 011-1z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M14 3.5v4h4" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M8 12.5h8M8 15.5h8M8 18.5h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`),
    gauge: svg(`<path d="M4 15a8 8 0 1116 0" fill="currentColor" fill-opacity="0.12"/><path d="M4 15a8 8 0 1116 0" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><path d="M12 15l4.3-4.8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><circle cx="12" cy="15" r="1.35" fill="currentColor"/>`),
    globe: svg(`<circle cx="12" cy="12" r="8.5" fill="currentColor" fill-opacity="0.12"/><circle cx="12" cy="12" r="8.5" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="M3.5 12h17" stroke="currentColor" stroke-width="1.4"/><path d="M12 3.5c2.6 2.3 4 5.3 4 8.5s-1.4 6.2-4 8.5c-2.6-2.3-4-5.3-4-8.5s1.4-6.2 4-8.5z" fill="none" stroke="currentColor" stroke-width="1.4"/>`),
    unlock: svg(`<rect x="5" y="11" width="14" height="9.5" rx="2.2" fill="currentColor" fill-opacity="0.14"/><rect x="5" y="11" width="14" height="9.5" rx="2.2" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="M8 11V7.5a4 4 0 017.6-1.8" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><circle cx="12" cy="15.5" r="1.4" fill="currentColor"/>`),
    lock: svg(`<rect x="5" y="11" width="14" height="9.5" rx="2.2" fill="currentColor" fill-opacity="0.14"/><rect x="5" y="11" width="14" height="9.5" rx="2.2" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="M8 11V7.5a4 4 0 018 0V11" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><circle cx="12" cy="15.5" r="1.4" fill="currentColor"/>`),
    layers: svg(`<path d="M12 3.5l8 4.2-8 4.2-8-4.2 8-4.2z" fill="currentColor" fill-opacity="0.16" stroke="currentColor" stroke-width="1.55" stroke-linejoin="round"/><path d="M4 12l8 4.2 8-4.2" fill="none" stroke="currentColor" stroke-width="1.55" stroke-linejoin="round"/><path d="M4 15.8l8 4.2 8-4.2" fill="none" stroke="currentColor" stroke-width="1.55" stroke-linejoin="round"/>`),
    toggle: svg(`<rect x="3" y="8" width="18" height="9" rx="4.5" fill="currentColor" fill-opacity="0.12" stroke="currentColor" stroke-width="1.7"/><circle cx="15" cy="12.5" r="2.9" fill="currentColor"/>`),
    route: svg(`<circle cx="6" cy="6.5" r="2.3" fill="currentColor" fill-opacity="0.18" stroke="currentColor" stroke-width="1.55"/><circle cx="18" cy="17.5" r="2.3" fill="currentColor" fill-opacity="0.18" stroke="currentColor" stroke-width="1.55"/><path d="M6 8.8v3.4a3 3 0 003 3h6a3 3 0 003 3v-.2" fill="none" stroke="currentColor" stroke-width="1.55" stroke-linecap="round"/>`),
    refresh: svg(`<path d="M4.5 12a7.5 7.5 0 0112.6-5.5" fill="currentColor" fill-opacity="0.1"/><path d="M4.5 12a7.5 7.5 0 0112.6-5.5M19.5 12a7.5 7.5 0 01-12.6 5.5" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/><path d="M17.5 4.7v3.5H14M6.5 19.3v-3.5H10" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>`),
};
---

<section class="dvt-section">
    <!-- Globo — posición absoluta sobre la derecha, sin clip -->
    <div class="dvt-bg-globe" aria-hidden="true">
        <TrustGlobe client:only="react" />
    </div>

    <!-- Contenido de texto — ocupa solo la mitad izquierda -->
    <div class="dvt-inner">
        <p class="dvt-eyebrow">{trust.eyebrow}</p>
        <h2 class="dvt-title masked-title" set:html={trust.titulo} />

        <div class="dvt-protect dvt-anim-protect">
            <span class="dvt-picon" set:html={ICONS[trust.proteccion.icon]} />
            <div class="dvt-protect-tx">
                <h3>{trust.proteccion.titulo}</h3>
                <p>{trust.proteccion.copy}</p>
            </div>
        </div>

        <ul class="dvt-points">
            {trust.puntos.map((p) => (
                <li class="dvt-anim-point">
                    <span class="dvt-sicon" set:html={ICONS[p.icon]} />
                    <span>{p.titulo}</span>
                </li>
            ))}
        </ul>
    </div>

    <!-- Grid de datos — fila de 4 debajo -->
    <div class="dvt-grid dvt-anim-right">
        {trust.grid.map((g) => (
            <div class="dvt-gitem">
                <span class="dvt-gicon" set:html={ICONS[g.icon]} />
                <span class="dvt-glabel">{g.titulo}</span>
                {g.copy && <p class="dvt-gcopy">{g.copy}</p>}
            </div>
        ))}
    </div>
</section>

<style>
    /* ── Sección clara, sin overflow hidden — el globo puede extenderse ── */
    .dvt-section {
        position: relative;
        padding: 6rem 0 4rem;
        overflow: visible;
    }

    /* ── Globo — absoluto, centrado verticalmente, anclado a la derecha ── */
    .dvt-bg-globe {
        position: absolute;
        top: 38%; right: 0;
        width: 58vw; max-width: 820px; min-width: 500px;
        aspect-ratio: 1 / 1;
        transform: translateY(-50%);
        z-index: 0;
        pointer-events: none;
    }

    /* ── Contenido — solo la mitad izquierda ── */
    .dvt-inner {
        position: relative; z-index: 2;
        max-width: 580px;
        margin: 0 0 0 max(5%, calc((100% - 1360px) / 2 + 5%));
        padding: 0;
    }

    .dvt-eyebrow {
        font-size: 0.62rem; font-weight: 800; letter-spacing: 2.8px;
        text-transform: uppercase; color: var(--color-blue-deep, #2563eb);
        margin: 0 0 1.1rem;
    }
    .dvt-title {
        font-size: clamp(2rem, 3.15vw, 2.75rem); font-weight: 800;
        line-height: 1.08; letter-spacing: -0.04em;
        color: var(--color-text, #0f172a); margin: 0 0 2.9rem;
    }

    .dvt-protect {
        display: flex; align-items: flex-start; gap: 1.2rem;
        padding-bottom: 2.1rem;
        border-bottom: 1px solid var(--color-border, rgba(10,25,47,0.08));
    }
    .dvt-picon {
        flex-shrink: 0; width: 36px; height: 36px; border-radius: 11px;
        background: rgba(10,25,47,0.05); color: var(--color-blue-deep, #2563eb);
        display: flex; align-items: center; justify-content: center;
    }
    .dvt-picon :global(svg) { width: 18px; height: 18px; }
    .dvt-protect-tx h3 {
        font-size: 1.1rem; font-weight: 700; letter-spacing: -0.02em;
        color: var(--color-text, #0f172a); margin: 0 0 0.5rem;
    }
    .dvt-protect-tx p {
        font-size: 0.92rem; line-height: 1.72;
        color: var(--color-text-muted, #64748b); margin: 0;
    }

    .dvt-points { list-style: none; margin: 0; padding: 0; }
    .dvt-points li {
        display: flex; align-items: center; gap: 0.95rem;
        padding: 1.25rem 0;
        border-bottom: 1px solid var(--color-border, rgba(10,25,47,0.08));
        font-size: 0.93rem; font-weight: 500; letter-spacing: -0.005em;
        color: var(--color-text, #0f172a);
    }
    .dvt-points li:last-child { border-bottom: none; }
    .dvt-sicon {
        flex-shrink: 0; width: 36px; height: 36px; border-radius: 11px;
        background: rgba(10,25,47,0.05); color: var(--color-blue-deep, #2563eb);
        display: flex; align-items: center; justify-content: center;
    }
    .dvt-sicon :global(svg) { width: 18px; height: 18px; }

    /* ── Grid de datos — fila de 4 debajo ── */
    .dvt-grid {
        position: relative; z-index: 2;
        max-width: 1360px; margin: 3.5rem auto 0; padding: 0 5%;
        display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px;
        border-top: 1px solid var(--color-border, rgba(10,25,47,0.08));
    }
    .dvt-gitem {
        padding: 2rem 1.6rem;
        border-right: 1px solid var(--color-border, rgba(10,25,47,0.08));
    }
    .dvt-gitem:last-child { border-right: none; }
    .dvt-gicon {
        display: flex; width: 32px; height: 32px; border-radius: 9px;
        background: rgba(10,25,47,0.05); color: var(--color-blue-deep, #2563eb);
        align-items: center; justify-content: center; margin-bottom: 0.9rem;
    }
    .dvt-gicon :global(svg) { width: 16px; height: 16px; }
    .dvt-glabel {
        display: block; font-size: 0.88rem; font-weight: 600;
        letter-spacing: -0.01em; line-height: 1.4;
        color: var(--color-text, #0f172a); margin-bottom: 0.5rem;
    }
    .dvt-gcopy {
        margin: 0; font-size: 0.82rem; line-height: 1.6;
        color: var(--color-text-muted, #64748b);
    }

    @media (max-width: 1000px) {
        .dvt-inner { max-width: 50%; margin-left: 5%; }
        .dvt-bg-globe { width: 55vw; min-width: 400px; }
        .dvt-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 720px) {
        .dvt-section { padding: 4rem 0 2.5rem; }
        .dvt-inner { max-width: 100%; margin: 0 5%; }
        .dvt-bg-globe {
            position: relative; top: auto; right: auto; transform: none;
            width: 90vw; min-width: unset; max-width: 400px;
            margin: 0 auto 2rem;
        }
        .dvt-grid { grid-template-columns: 1fr; }
        .dvt-gitem { border-right: none; border-bottom: 1px solid var(--color-border, rgba(10,25,47,0.08)); }
        .dvt-gitem:last-child { border-bottom: none; }
    }
</style>

<style is:global>
    .js-anim .dvt-anim-protect,
    .js-anim .dvt-anim-point,
    .js-anim .dvt-anim-right { opacity: 0; }
</style>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    const BLUR_IN = 'blur(14px)';

    const init = () => {
        const section = document.querySelector<HTMLElement>('.dvt-section');
        if (!section) return;

        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        const picon = section.querySelector<HTMLElement>('.dvt-picon');
        const protectTx = section.querySelector<HTMLElement>('.dvt-protect-tx');
        const protect = section.querySelector<HTMLElement>('.dvt-anim-protect');
        const points = gsap.utils.toArray<HTMLElement>('.dvt-anim-point', section);
        const grid = section.querySelector<HTMLElement>('.dvt-anim-right');
        const gitems = gsap.utils.toArray<HTMLElement>('.dvt-gitem', section);

        const revealAll = () => {
            gsap.set([protect, ...points, grid, ...gitems], { clearProps: 'all', opacity: 1 });
            gsap.set([picon, protectTx], { clearProps: 'all', opacity: 1 });
        };

        if (reduced) { revealAll(); return; }

        if (picon) gsap.set(picon, { opacity: 0, scale: 0.6, filter: BLUR_IN });
        if (protectTx) gsap.set(protectTx, { opacity: 0, y: 12, filter: BLUR_IN });
        gsap.set(points, { y: 14, filter: BLUR_IN });
        gsap.set(gitems, { opacity: 0, y: 18 });

        ScrollTrigger.create({
            trigger: section,
            start: 'top 85%',
            once: true,
            onEnter: () => {
                const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

                tl.to(picon, { opacity: 1, scale: 1, filter: 'blur(0px)', duration: 0.55 }, 0)
                  .to(protectTx, { opacity: 1, y: 0, filter: 'blur(0px)', duration: 0.6 }, 0.14)
                  .set(protect, { opacity: 1 }, 0);

                tl.to(points, {
                    opacity: 1, y: 0, filter: 'blur(0px)',
                    duration: 0.55, stagger: 0.09,
                }, 0.22);

                tl.set(grid, { opacity: 1 }, 0.3);
                tl.to(gitems, {
                    opacity: 1, y: 0, duration: 0.5, stagger: 0.08,
                }, 0.4);

                tl.set([picon, protectTx, ...points, ...gitems], { clearProps: 'filter,transform' });
            },
        });
    };

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
</script>
