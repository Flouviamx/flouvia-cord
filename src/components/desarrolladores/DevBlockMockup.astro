---
// DevBlockMockup — mockups de los bloques de /desarrolladores/[slug].
// Reescrito (jul 2026) al estándar de components/producto/BlockMockup.astro:
// ventanas COMPLETAS y densas (.dbm-app / .dbm-app-bar / .dbm-app-body /
// .dbm-app-foot) que llenan la tarjeta del bento — toolbar real de producto
// (título izq + badge der, SIN los 3 puntos macOS), tabla/lista/timeline con
// datos plausibles y footer. Para escenas de CÓDIGO/JSON se usa la variante
// .dbm-term — misma superficie LIGHT que .dbm-app (jul 2026: se eliminó la
// variante de terminal oscura, todos los mockups del sitio son claros).
// El prefijo dbm-* es autocontenido (Astro scopea <style> por componente).
// Cada escena expone hooks (ids/clases) que el <script> de [slug].astro anima
// como motion-graphic en loop. Copy/estructura vienen de desarrolladores.ts.
export interface Props {
    slug: string;
    index: number;
}
const { slug, index } = Astro.props;
---
<div class={`dbm-wrap dbm-${slug}-${index}`}>

  {/* ══════════════════════ API ══════════════════════ */}
  {slug === 'api' && index === 0 && (
    <div class="dbm-app dbm-api-m0">
      <div class="dbm-app-bar">
        <span class="dbm-app-title">Sincronización · ERP ↔ Cord</span>
        <span class="dbm-app-badge dbm-badge-green">● Conectado</span>
      </div>
      <div class="dbm-sync-lane">
        <div class="dbm-node dbm-node-soft">Tu ERP</div>
        <div class="dbm-rail">
          <span class="dbm-rail-dot dbm-rail-r" id="apiSyncR"></span>
          <span class="dbm-rail-dot dbm-rail-l" id="apiSyncL"></span>
        </div>
        <div class="dbm-node dbm-node-brand">
          <img src="/imgs/logo-cord-navy.png" alt="Cord" />
        </div>
      </div>
      <div class="dbm-app-body">
        <div class="dbm-kv dbm-sync-row" id="apiSyncRow1"><div class="dbm-uid"><span class="dbm-ar">→</span><div class="dbm-uid-tx"><b>POST /api/v1/productos</b><span>412 productos importados del ERP</span></div></div><span class="dbm-tg dbm-tg-blue">Entrante</span></div>
        <div class="dbm-kv dbm-sync-row" id="apiSyncRow2"><div class="dbm-uid"><span class="dbm-al">←</span><div class="dbm-uid-tx"><b>GET /api/v1/cotizaciones/q_19a</b><span>COT-0149 · aprobada · $196,469.20</span></div></div><span class="dbm-tg dbm-tg-green">Saliente</span></div>
        <div class="dbm-kv"><span>Última sincronización</span><b>hace 12 s · 142 ms</b></div>
      </div>
      <div class="dbm-app-foot"><span>Sin recapturar de un lado a otro</span><b>Bidireccional</b></div>
    </div>
  )}

  {slug === 'api' && index === 1 && (
    <div class="dbm-app dbm-api-m1">
      <div class="dbm-app-bar">
        <span class="dbm-app-title">Ajustes · Claves de API</span>
        <span class="dbm-app-badge dbm-badge-blue">2 activas</span>
      </div>
      <div class="dbm-app-body">
        <div class="dbm-keychip" id="apiKey">
          <span class="dbm-key-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="15.5" r="3.5"/><path d="M10 13l8-8 3 3M16 7l2 2"/></svg></span>
          <span class="dbm-key-val">sk_live_8f2a••••••••3d1c</span>
          <span class="dbm-tg dbm-tg-gray" id="apiKeyTag">Producción</span>
        </div>
        <div class="dbm-scopes">
          <div class="dbm-scope"><i class="dbm-scope-ck">✓</i><span>read</span><b>consultar</b></div>
          <div class="dbm-scope"><i class="dbm-scope-ck">✓</i><span>write</span><b>crear</b></div>
        </div>
        <div class="dbm-kv"><span>Último uso</span><b>hace 3 min · 89.4.12.2</b></div>
        <div class="dbm-reqline"><span>GET /cotizaciones</span><b class="dbm-status" id="apiAuthStatus">200 OK</b></div>
      </div>
      <div class="dbm-app-foot"><span>Revócala y muere al instante</span><b class="dbm-tg dbm-tg-red dbm-revoke-tag" id="apiRevoke">Revocar</b></div>
    </div>
  )}

  {slug === 'api' && index === 2 && (
    <div class="dbm-term dbm-api-m2">
      <div class="dbm-term-bar">
        <span class="dbm-term-title"><span class="dbm-term-method">GET</span> /api/v1/<span id="apiEndpointName">cotizaciones</span></span>
        <span class="dbm-term-badge">200 OK</span>
      </div>
      <div class="dbm-seg dbm-api-tabs">
        <span class="dbm-seg-on">cotizaciones</span><span>clientes</span><span>productos</span><span>cobranza</span>
      </div>
      <pre class="dbm-code dbm-api-json" id="apiJson"><code>{`{`}
  <span class="dbm-jkey">"folio"</span>: <span class="dbm-jstr">"COT-0149"</span>,
  <span class="dbm-jkey">"cliente"</span>: <span class="dbm-jstr">"Distribuidora El Zarco"</span>,
  <span class="dbm-jkey">"status"</span>: <span class="dbm-jstr">"sent"</span>,
  <span class="dbm-jkey">"total"</span>: <span class="dbm-jnum dbm-hl-target">196469.2</span>
{`}`}</code></pre>
      <div class="dbm-term-foot"><span>limit 50 · offset 0 · pesos, no centavos</span><span class="dbm-term-total" id="apiMetaTotal">total 412</span></div>
    </div>
  )}

  {/* ══════════════════════ MCP ══════════════════════ */}
  {slug === 'mcp' && index === 0 && (
    <div class="dbm-app dbm-mcp-m0">
      <div class="dbm-app-bar">
        <span class="dbm-app-title">Cord como servidor MCP</span>
        <span class="dbm-app-badge dbm-badge-blue">JSON-RPC 2.0</span>
      </div>
      <div class="dbm-app-body">
        <div class="dbm-seg dbm-mcp-transports">
          <span class="dbm-seg-on" id="mcpT0">HTTP</span><span id="mcpT1">SSE · streaming</span>
        </div>
        <div class="dbm-toollist">
          <div class="dbm-toolrow"><i class="dbm-tool-dot"></i><code>listar_cotizaciones</code><span class="dbm-tg dbm-tg-gray">read</span></div>
          <div class="dbm-toolrow"><i class="dbm-tool-dot"></i><code>cartera_vencida</code><span class="dbm-tg dbm-tg-gray">read</span></div>
          <div class="dbm-toolrow"><i class="dbm-tool-dot"></i><code>resumen_negocio</code><span class="dbm-tg dbm-tg-gray">read</span></div>
          <div class="dbm-toolrow"><i class="dbm-tool-dot"></i><code>buscar_cliente</code><span class="dbm-tg dbm-tg-gray">read</span></div>
          <div class="dbm-toolrow"><i class="dbm-tool-dot"></i><code>listar_productos</code><span class="dbm-tg dbm-tg-gray">read</span></div>
          <div class="dbm-toolrow"><i class="dbm-tool-dot"></i><code>detalle_cotizacion</code><span class="dbm-tg dbm-tg-gray">read</span></div>
          <div class="dbm-toolrow dbm-toolrow-w"><i class="dbm-tool-dot dbm-w"></i><code>crear_cotizacion_borrador</code><span class="dbm-tg dbm-tg-amber">write</span></div>
        </div>
      </div>
      <div class="dbm-app-foot"><span>Mismo header, misma llave que la API</span><b>7 herramientas</b></div>
    </div>
  )}

  {slug === 'mcp' && index === 1 && (
    <div class="dbm-app dbm-mcp-m1">
      <div class="dbm-app-bar">
        <span class="dbm-app-title">Cord como cliente MCP</span>
        <span class="dbm-app-badge dbm-badge-blue">Agent loop · máx 5</span>
      </div>
      <div class="dbm-sync-lane">
        <div class="dbm-node dbm-node-brand"><img src="/imgs/logo-cord-navy.png" alt="Cord" /></div>
        <div class="dbm-rail"><span class="dbm-rail-dot dbm-rail-r" id="mcpClientDot"></span></div>
        <div class="dbm-node dbm-node-ext">CRM del cliente</div>
      </div>
      <div class="dbm-app-body">
        <div class="dbm-log" id="mcpClientLog">
          <div><span class="dbm-log-t">→</span> connect(https://crm.cliente.com/mcp)</div>
          <div><span class="dbm-log-t">→</span> listTools() → 4 herramientas</div>
          <div><span class="dbm-log-t">←</span> get_saldo("El Zarco") → $412,300</div>
          <div class="dbm-log-ok"><span class="dbm-log-t">✓</span> contexto listo · la IA cotiza</div>
        </div>
      </div>
      <div class="dbm-app-foot"><span>Consulta antes de cotizar</span><b>Con tu permiso</b></div>
    </div>
  )}

  {slug === 'mcp' && index === 2 && (
    <div class="dbm-app dbm-mcp-m2">
      <div class="dbm-app-bar">
        <span class="dbm-app-title">Gobernanza de agentes</span>
        <span class="dbm-app-badge dbm-badge-green">RLS · por org</span>
      </div>
      <div class="dbm-app-body">
        <div class="dbm-kv"><div class="dbm-uid"><span class="dbm-avat a2">A</span><div class="dbm-uid-tx"><b>Servidor A · ventas</b><span>2 herramientas firmadas</span></div></div><span class="dbm-gov-pill dbm-gov-on">permitido</span></div>
        <div class="dbm-kv dbm-gov-target"><div class="dbm-uid"><span class="dbm-avat a4">E</span><div class="dbm-uid-tx"><b>CRM externo</b><span>esperando tu firma</span></div></div><span class="dbm-gov-pill dbm-gov-off" id="mcpGovPill">sin acceso</span></div>
        <div class="dbm-kv"><div class="dbm-uid"><span class="dbm-avat a1">F</span><div class="dbm-uid-tx"><b>Servidor C · finanzas</b><span>bloqueado por política</span></div></div><span class="dbm-gov-pill dbm-gov-off">sin acceso</span></div>
      </div>
      <div class="dbm-app-foot"><span>Cada acción queda en el audit log</span><b>Tú firmas</b></div>
    </div>
  )}

  {/* ══════════════════════ ELEMENTS ══════════════════════ */}
  {slug === 'elements' && index === 0 && (
    <div class="dbm-term dbm-el-m0">
      <div class="dbm-term-bar">
        <span class="dbm-term-title">index.html</span>
        <span class="dbm-term-badge">Altura automática</span>
      </div>
      <div class="dbm-code dbm-el-code">
        <span class="dbm-jtag">&lt;script src=</span><span class="dbm-jstr">"…/embed.js"</span><span class="dbm-jtag">&gt;&lt;/script&gt;</span>
        <span class="dbm-jtag">&lt;div</span> data-cord-token=<span class="dbm-jstr">"…"</span><span class="dbm-jtag">&gt;</span><span class="dbm-cursor"></span>
      </div>
      <div class="dbm-el-preview">
        <div class="dbm-el-skel" id="elSkel"></div>
        <div class="dbm-el-mini" id="elMini"><span>Cotización lista</span><b class="editorial">$196,469.20</b></div>
      </div>
      <div class="dbm-term-foot"><span>Una línea de código</span><span class="dbm-term-total">iframe seguro</span></div>
    </div>
  )}

  {slug === 'elements' && index === 1 && (
    <div class="dbm-term dbm-el-m1">
      <div class="dbm-term-bar">
        <span class="dbm-term-title">@flouviahq/elements</span>
        <span class="dbm-term-badge">v1.0.0</span>
      </div>
      <div class="dbm-seg dbm-el-tabs">
        <span class="dbm-seg-on">HTML</span><span>React</span><span>Web Component</span>
      </div>
      <div class="dbm-code dbm-el-codebox" id="elCode">
        <span class="dbm-jtag">&lt;script src=</span><span class="dbm-jstr">"…/embed.js"</span><span class="dbm-jtag">&gt;</span>
      </div>
      <div class="dbm-term-foot"><span>npm i @flouviahq/elements</span><span class="dbm-term-total">React · Vue · Astro</span></div>
    </div>
  )}

  {slug === 'elements' && index === 2 && (
    <div class="dbm-app dbm-el-m2">
      <div class="dbm-app-bar">
        <span class="dbm-app-title">portal.tucliente.com</span>
        <span class="dbm-app-badge dbm-badge-blue">frame-ancestors</span>
      </div>
      <div class="dbm-el-embed">
        <div class="dbm-el-card">
          <div class="dbm-el-cardhead"><span class="dbm-avat a1" style="border-radius:7px;">MV</span><b>Tu cotización</b><span class="dbm-el-badge" id="elBadge">Revisar</span></div>
          <div class="dbm-kv"><span>Cemento gris 50kg × 120</span><b class="editorial">$21,840.00</b></div>
          <div class="dbm-kv"><span>Total con IVA</span><b class="editorial">$196,469.20</b></div>
          <div class="dbm-btn2 dbm-btn2-nav" id="elApprove">Aprobar cotización</div>
        </div>
        <div class="dbm-fake-cursor" id="elCursor">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M7 2l12 11.2-5.8.5 3.3 7.3-2.25 1-3.2-7.4-4.4 4.7z"/></svg>
        </div>
      </div>
      <div class="dbm-app-foot dbm-el2-event"><span><i class="dbm-evt-dot"></i>cord:approved · COT-0148</span><b>Evento nativo</b></div>
    </div>
  )}

  {/* ══════════════════════ FX ══════════════════════ */}
  {slug === 'fx' && index === 0 && (
    <div class="dbm-app dbm-fx-m0">
      <div class="dbm-app-bar">
        <span class="dbm-app-title">COT-0150 · Acme Imports</span>
        <span class="dbm-app-badge dbm-badge-green">● Banxico FIX</span>
      </div>
      <div class="dbm-app-body">
        <div class="dbm-fx-hero">
          <div class="dbm-fx-side"><span>El cliente ve</span><b class="editorial">US$10,620.50</b></div>
          <div class="dbm-fx-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg><em id="fxRate">1 USD = $18.4520</em></div>
          <div class="dbm-fx-side"><span>Se factura</span><b class="editorial g">$196,469.20</b></div>
        </div>
        <div class="dbm-kv"><span>Buffer de cobertura</span><div class="dbm-cbar" style="width:110px;"><i style="width:60%;background:#059669;"></i></div></div>
        <div class="dbm-kv"><span>Tasa congelada (FX lock)</span><span class="dbm-tg dbm-tg-green">30 días</span></div>
        <div class="dbm-kv"><span>Fuente</span><b>Banxico FIX · 2026-06-26 12:00 UTC</b></div>
      </div>
      <div class="dbm-app-foot"><span>El margen que cierras es el que cobras</span><b>Protegido</b></div>
    </div>
  )}

  {/* ══════════════════════ FISCAL ══════════════════════ */}
  {slug === 'fiscal' && index === 0 && (
    <div class="dbm-app dbm-fiscal-m0">
      <div class="dbm-app-bar">
        <span class="dbm-app-title">Tax engine · multi-región</span>
        <span class="dbm-app-badge dbm-badge-green">Cumplimiento</span>
      </div>
      <div class="dbm-app-body">
        <div class="dbm-kv"><div class="dbm-uid"><span class="dbm-avat a2" style="border-radius:8px;">MX</span><div class="dbm-uid-tx"><b>México · IVA 16%</b><span>CFDI 4.0 · timbrado real</span></div></div><b class="editorial">$240.00</b></div>
        <div class="dbm-kv"><div class="dbm-uid"><span class="dbm-avat a4" style="border-radius:8px;">US</span><div class="dbm-uid-tx"><b>EE.UU. · Sales Tax</b><span>Commercial Invoice</span></div></div><span class="dbm-tg dbm-tg-gray">Próximo</span></div>
        <div class="dbm-term-inline"><code>POST /api/v1/tax/calculate</code> → <b class="dbm-jnum">$1,740.00</b></div>
        <div class="dbm-kv"><span>Subtotal · impuesto · total</span><b class="editorial">1,500 · 240 · 1,740</b></div>
      </div>
      <div class="dbm-app-foot"><span>Impuestos locales, globales</span><b>Un solo endpoint</b></div>
    </div>
  )}

  {/* ══════════════════════ INTEGRACIONES ══════════════════════ */}
  {slug === 'integraciones' && index === 0 && (
    <div class="dbm-term dbm-int-m0">
      <div class="dbm-term-bar">
        <span class="dbm-term-title"><span class="dbm-term-method">POST</span> tu-erp.com/webhooks/cord</span>
        <span class="dbm-term-badge">200 OK</span>
      </div>
      <div class="dbm-int-headers">
        <div><span class="dbm-jkey">X-Cord-Event</span>: <span class="dbm-jstr">quote.paid</span></div>
        <div><span class="dbm-jkey">X-Cord-Signature</span>: <span class="dbm-jstr">sha256=4f1ad8c…</span></div>
      </div>
      <pre class="dbm-code dbm-api-json"><code>{`{`}
  <span class="dbm-jkey">"event"</span>: <span class="dbm-jstr">"quote.paid"</span>,
  <span class="dbm-jkey">"data"</span>: {`{`}
    <span class="dbm-jkey">"folio"</span>: <span class="dbm-jstr">"COT-0149"</span>,
    <span class="dbm-jkey">"total"</span>: <span class="dbm-jnum">196469.2</span>,
    <span class="dbm-jkey">"cliente"</span>: <span class="dbm-jstr">"El Zarco"</span>
  {`}`}
{`}`}</code></pre>
      <div class="dbm-term-foot"><span>HMAC-SHA256 del cuerpo crudo</span><span class="dbm-term-total">reintento auto</span></div>
    </div>
  )}

  {slug === 'integraciones' && index === 1 && (
    <div class="dbm-app dbm-int-m1">
      <div class="dbm-app-bar">
        <span class="dbm-app-title">Destinos del webhook</span>
        <span class="dbm-app-badge dbm-badge-blue">1 → ∞ apps</span>
      </div>
      <div class="dbm-app-body">
        <div class="dbm-kv"><div class="dbm-uid"><img class="dbm-logo" src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://zapier.com&size=128" alt="Zapier" width="24" height="24" loading="lazy" /><div class="dbm-uid-tx"><b>Zapier</b><span>6,000+ apps sin código</span></div></div><span class="dbm-tg dbm-tg-green">Activo</span></div>
        <div class="dbm-kv"><div class="dbm-uid"><img class="dbm-logo" src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://make.com&size=128" alt="Make" width="24" height="24" loading="lazy" /><div class="dbm-uid-tx"><b>Make</b><span>escenarios visuales</span></div></div><span class="dbm-tg dbm-tg-green">Activo</span></div>
        <div class="dbm-kv"><div class="dbm-uid"><img class="dbm-logo" src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://n8n.io&size=128" alt="n8n" width="24" height="24" loading="lazy" /><div class="dbm-uid-tx"><b>n8n</b><span>self-hosted</span></div></div><span class="dbm-tg dbm-tg-gray">Listo</span></div>
        <div class="dbm-kv"><div class="dbm-uid"><img class="dbm-logo" src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://slack.com&size=128" alt="Slack" width="24" height="24" loading="lazy" /><div class="dbm-uid-tx"><b>Slack</b><span>integración nativa</span></div></div><span class="dbm-tg dbm-tg-blue">Nativo</span></div>
        <div class="dbm-kv"><div class="dbm-uid"><span class="dbm-avat a1" style="border-radius:7px;"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path fill="currentColor" fill-opacity="0.15" d="M4 5h16v14H4z"/><path d="M4 9h16M9 5v14"/></svg></span><div class="dbm-uid-tx"><b>Tu backend / ERP</b><span>endpoint HTTP propio</span></div></div><span class="dbm-tg dbm-tg-gray">Directo</span></div>
      </div>
      <div class="dbm-app-foot"><span>Sin esperar un conector propietario</span><b>6 eventos</b></div>
    </div>
  )}
</div>

<style>
  /* ════════════════════════════════════════════════════════════
     DEV BLOCK MOCKUP — ventanas completas (espejo de BlockMockup.astro)
     Prefijo dbm-* autocontenido. Superficie LIGHT para ambas variantes:
     ventanas de producto (.dbm-app) y escenas de código (.dbm-term).
  ════════════════════════════════════════════════════════════ */
  .dbm-wrap {
    position: relative; width: 100%; height: 100%;
    display: flex; align-items: flex-start; justify-content: center;
  }

  /* ── VENTANA LIGHT COMPLETA ── */
  .dbm-app {
    width: 100%;
    background: #ffffff;
    border-radius: 16px;
    border: 1px solid rgba(10,25,47,0.06);
    box-shadow: 0 1px 2px rgba(10,25,47,0.04), 0 18px 44px -14px rgba(10,25,47,0.16), 0 44px 90px -30px rgba(10,25,47,0.20);
    overflow: hidden; color: #0f172a; font-size: 0.76rem; text-align: left;
  }
  .dbm-app-bar { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 13px 16px; border-bottom: 1px solid rgba(10,25,47,0.06); background: #fcfdfe; }
  .dbm-app-title { font-size: 0.78rem; font-weight: 600; color: #0f172a; letter-spacing: -0.01em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .dbm-app-badge { flex-shrink: 0; font-size: 0.6rem; font-weight: 800; letter-spacing: 0.5px; text-transform: uppercase; padding: 4px 10px; border-radius: 100px; color: #64748b; background: rgba(10,25,47,0.05); border: 1px solid rgba(10,25,47,0.09); }
  .dbm-badge-blue { color: #2563eb; background: rgba(37,99,235,0.09); border-color: rgba(37,99,235,0.2); }
  .dbm-badge-green { color: #059669; background: rgba(16,185,129,0.09); border-color: rgba(16,185,129,0.22); }
  .dbm-app-body { padding: 4px 6px 6px; }
