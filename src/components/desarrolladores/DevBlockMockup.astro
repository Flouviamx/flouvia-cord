---
export interface Props {
    slug: string;
    index: number;
}

const { slug, index } = Astro.props;
---
<div class="dbm-wrap">
  <div class="dbm-mesh" aria-hidden="true"></div>
  
  <div class="dbm-stage">
    {slug === 'api' && index === 0 && (
      <div class="dbm-api-m0 dbm-card">
        <div class="dbm-head">Data Flow</div>
        <div class="dbm-flow-container">
            <div class="dbm-node">ERP</div>
            <div class="dbm-path"><div class="dbm-dot"></div></div>
            <div class="dbm-node dbm-brand">Cord</div>
        </div>
      </div>
    )}
    {slug === 'api' && index === 1 && (
      <div class="dbm-api-m1 dbm-terminal">
        <div class="dbm-head">Auth Header</div>
        <div class="dbm-code">
            <span class="dbm-prompt">$</span> curl -X GET \
            <br>&nbsp;&nbsp;-H <span class="dbm-str">"Auth: Bearer sk_live_"</span><span class="dbm-cursor"></span>
        </div>
      </div>
    )}
    {slug === 'api' && index === 2 && (
      <div class="dbm-api-m2 dbm-terminal">
        <div class="dbm-head">Respuesta JSON</div>
        <pre class="dbm-code"><code>{`{`}
  <span class="dbm-key">"folio"</span>: <span class="dbm-str">"COT-0149"</span>,
  <span class="dbm-key">"total"</span>: <span class="dbm-num dbm-hl-target">196469.2</span>
{`}`}</code></pre>
      </div>
    )}

    {slug === 'mcp' && index === 0 && (
      <div class="dbm-mcp-m0 dbm-card">
        <div class="dbm-head">MCP Bridge</div>
        <svg class="dbm-bridge-svg" viewBox="0 0 100 50">
            <circle cx="20" cy="25" r="10" fill="#0a192f" stroke="#3b82f6" stroke-width="2"/>
            <text x="20" y="28" fill="#3b82f6" font-size="8" text-anchor="middle">AI</text>
            <circle cx="80" cy="25" r="10" fill="#0a192f" stroke="#10b981" stroke-width="2"/>
            <text x="80" y="28" fill="#10b981" font-size="8" text-anchor="middle">DB</text>
            <path d="M30 25 L70 25" stroke="rgba(255,255,255,0.2)" stroke-width="2"/>
            <path class="dbm-pulse-line" d="M30 25 L70 25" stroke="#3b82f6" stroke-width="2"/>
        </svg>
      </div>
    )}
    {slug === 'mcp' && index === 1 && (
      <div class="dbm-mcp-m1 dbm-terminal">
        <div class="dbm-head">Server Init</div>
        <div class="dbm-code dbm-log-lines">
            <div><span class="dbm-prompt">&gt;</span> npx @flouvia/cord-mcp</div>
            <div class="dbm-log-1">Starting MCP Server...</div>
            <div class="dbm-log-2 dbm-success">✓ Server running on stdio</div>
        </div>
      </div>
    )}
    {slug === 'mcp' && index === 2 && (
      <div class="dbm-mcp-m2 dbm-card">
        <div class="dbm-head">AI Context</div>
        <div class="dbm-chat-bubble">
            Entendido. La cotización <b>COT-0149</b> tiene un saldo de <span class="dbm-hl-target">$196k</span>. Procedo a notificar.
        </div>
      </div>
    )}

  </div>
</div>

<style>
  .dbm-wrap {
    position: relative; width: 100%; height: 100%; min-height: 240px;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden; padding: 1.5rem; background: transparent;
  }
  .dbm-mesh {
    position: absolute; inset: -50%;
    background: 
      radial-gradient(circle at 50% 20%, rgba(59, 130, 246, 0.15) 0%, transparent 40%),
      radial-gradient(circle at 80% 80%, rgba(16, 185, 129, 0.12) 0%, transparent 40%);
    filter: blur(40px); opacity: 0.8;
    animation: dbm-mesh-rotate 20s linear infinite; pointer-events: none;
  }
  @keyframes dbm-mesh-rotate { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

  .dbm-stage { position: relative; display: flex; align-items: center; justify-content: center; width: 100%; max-width: 260px; z-index: 2; }

  .dbm-card, .dbm-terminal {
    background: rgba(10, 25, 47, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
    border-radius: 12px; padding: 1rem; width: 100%;
    color: #f8fafc; font-size: 0.7rem; font-weight: 500;
  }

  .dbm-head {
    display: flex; justify-content: space-between; font-size: 0.65rem;
    text-transform: uppercase; letter-spacing: 0.5px; color: rgba(255,255,255,0.4);
    margin-bottom: 12px; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 6px;
  }

  .dbm-code { font-family: var(--font-mono, monospace); line-height: 1.6; }
  .dbm-prompt { color: #ec4899; }
  .dbm-str { color: #34d399; }
  .dbm-key { color: #93c5fd; }
  .dbm-num { color: #fcd34d; }
  .dbm-cursor { display: inline-block; width: 6px; height: 12px; background: #fff; vertical-align: middle; margin-left: 2px; }
  
  /* Flows & Chat */
  .dbm-flow-container { display: flex; align-items: center; justify-content: space-between; }
  .dbm-node { background: rgba(255,255,255,0.05); padding: 6px 12px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.1); }
  .dbm-node.dbm-brand { background: rgba(59,130,246,0.15); border-color: #3b82f6; color: #93c5fd; }
  .dbm-path { flex: 1; height: 2px; background: rgba(255,255,255,0.1); margin: 0 10px; position: relative; }
  .dbm-dot { position: absolute; top: -3px; left: 0; width: 8px; height: 8px; background: #3b82f6; border-radius: 50%; box-shadow: 0 0 10px #3b82f6; }

  .dbm-pulse-line { stroke-dasharray: 40; stroke-dashoffset: 40; }
  .dbm-success { color: #34d399; }
  
  .dbm-chat-bubble {
    background: rgba(255,255,255,0.05); padding: 12px; border-radius: 10px 10px 10px 2px;
    line-height: 1.5; border: 1px solid rgba(255,255,255,0.05);
  }
  .dbm-chat-bubble b { color: #fff; }
</style>
