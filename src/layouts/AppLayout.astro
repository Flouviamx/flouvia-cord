        .notif-panel { width: min(340px, calc(100vw - 1.5rem)); }
        .ph-pin { display: none; }
    }
</style>

<script>
    // ── Salir del entorno de prueba (banner ámbar) ──
    // Limpia la cookie (fuente de verdad server-side) + el espejo en localStorage
    // y regresa al dashboard real.
    document.getElementById('testEnvExit')?.addEventListener('click', () => {
        document.cookie = 'cord_test_mode=; path=/; max-age=0; SameSite=Lax';
        try { localStorage.setItem('cord_test_mode', 'false'); } catch {}
        window.location.assign('/app');
    });

    // Vaciar datos de prueba (tipo Stripe "delete all test data"): borra la org
    // sandbox por completo; se recrea fresca + reseed al recargar.
    document.getElementById('testEnvReset')?.addEventListener('click', async () => {
        const cc = (window as any).cordConfirm;
        const ok = cc ? await cc({
            title: 'Vaciar datos de prueba',
            body: 'Se borrarán TODAS las cotizaciones, clientes y productos de prueba. Tus datos reales no se tocan. El entorno de prueba arrancará limpio.',
            danger: true,
            confirmText: 'Vaciar todo',
        }) : true;
        if (!ok) return;
        try {
            const res = await fetch('/api/test-mode/reset', { method: 'POST' });
            if (!res.ok) { const d = await res.json().catch(() => ({})); throw new Error(d.error || 'No se pudo vaciar'); }
            try { sessionStorage.setItem('cord.flash', JSON.stringify({ msg: 'Datos de prueba vaciados', type: 'ok' })); } catch {}
            window.location.assign('/app');
        } catch (e: any) {
            (window as any).cordToast?.(e.message || 'No se pudo vaciar los datos de prueba', 'error');
        }
    });

    // ── Menú de comandos (Cmd+K) ── buscador global + navegación rápida.
    function initCmdk() {
        const cmdk = document.getElementById('cmdk');
        const input = document.getElementById('cmdkInput') as HTMLInputElement | null;
        const results = document.getElementById('cmdkResults');
        if (!cmdk || !input || !results) return;

        const I = {
            dashboard: '<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/>',
            doc: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>',
            card: '<rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/>',
            users: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>',
            box: '<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/>',
            chart: '<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>',
            gear: '<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>',
            plus: '<line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>',
            sparkle: '<path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3Z"/>',
            check: '<path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>',
            external: '<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>',
        };
        const NAV: any[] = [
            ['Inicio', '/app', I.dashboard, 'Resumen y actividad'], ['Cotizaciones', '/app/cotizaciones', I.doc, 'Lista y pipeline'], ['Cobranza', '/app/cobranza', I.card, 'Cuentas por cobrar'],
            ['Finanzas', '/app/cfo', I.chart, 'Proyección de flujo de caja (CFO)'], ['Analítica', '/app/analitica', I.chart, 'Métricas y forecast'],
            ['Flujo de caja', '/app/tesoreria/flujo', I.chart, 'Flujo predictivo (tesorería)'], ['Cobranza con IA', '/app/tesoreria/cobranza', I.users, 'Agentes de cobranza (tesorería)'],
            ['Clientes', '/app/clientes', I.users, 'Directorio de clientes'], ['Productos', '/app/productos', I.box, 'Catálogo'], ['Ajustes', '/app/ajustes', I.gear, 'Marca, fiscal, PDF…'],
        ].map(([title, href, icon, hint]) => ({ group: 'Ir a', title, href, icon, hint }));
        const ACTIONS: any[] = [
            { group: 'Acciones', title: 'Armar con IA', href: '/app/cotizaciones/nueva', icon: I.sparkle, kbd: 'C', hint: 'Nueva cotización' },
            { group: 'Acciones', title: 'Nuevo cliente', href: '/app/clientes?nuevo=1', icon: I.plus, hint: 'Agregar al directorio' },
            { group: 'Acciones', title: 'Nuevo producto', href: '/app/productos?nuevo=1', icon: I.plus, hint: 'Agregar al catálogo' },
            { group: 'Acciones', title: 'Nueva tarea', icon: I.check, hint: 'Recordatorio rápido', run: () => (window as any).cordQuickTask?.() },
            { group: 'Acciones', title: 'Ver sitio público', href: '/', icon: I.external, hint: 'Abrir la landing' },
        ];
        const norm = (s: string) => s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
        const esc = (s: string) => String(s).replace(/</g, '&lt;');

        // ── Recientes (localStorage) — se muestran cuando el buscador está vacío ──
        const RECENT_KEY = 'cord.recent.v1';
        const getRecents = (): any[] => { try { return JSON.parse(localStorage.getItem(RECENT_KEY) || '[]'); } catch { return []; } };
        const pushRecent = (it: any) => {
            if (!it?.href || it.href === '/') return;
            try {
                const r = getRecents().filter((x: any) => x.href !== it.href);
                r.unshift({ title: it.title, href: it.href, icon: it.icon });
                localStorage.setItem(RECENT_KEY, JSON.stringify(r.slice(0, 5)));
            } catch {}
        };

        let items: any[] = []; let sel = 0; let seq = 0;

        const staticMatches = (q: string) => {
            const all = [...NAV, ...ACTIONS];
            if (!q.trim()) return all;
            const nq = norm(q);
            return all.filter((c) => norm(c.title).includes(nq));
        };
        const buildItems = (q: string, ent: any) => {
            const list: any[] = [];
            if (!q.trim()) {
                getRecents().forEach((r: any) => list.push({ group: 'Recientes', title: r.title, href: r.href, icon: r.icon || I.doc }));
            }
            if (ent) {
                (ent.cotizaciones || []).forEach((c: any) => list.push({ group: 'Cotizaciones', title: `${c.folio} · ${c.cliente}`, href: `/app/cotizaciones/${c.id}`, icon: I.doc }));
                (ent.clientes || []).forEach((c: any) => list.push({ group: 'Clientes', title: c.empresa, href: '/app/clientes', icon: I.users }));
                (ent.productos || []).forEach((p: any) => list.push({ group: 'Productos', title: p.sku ? `${p.nombre} · ${p.sku}` : p.nombre, href: '/app/productos', icon: I.box }));
            }
            staticMatches(q).forEach((c) => list.push(c));
            return list;
        };
        const paint = (q = '') => {
            if (!items.length) {
                results.innerHTML = `<div class="cmdk-empty"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg><p>Sin resultados para “${esc(q)}”</p><span>Prueba con un folio, cliente, producto o sección.</span></div>`;
                return;
            }
            let html = ''; let last = '';
            items.forEach((it, i) => {
                if (it.group !== last) { html += `<div class="cmdk-group-label">${it.group}</div>`; last = it.group; }
                const right = it.kbd ? `<kbd class="cmdk-kbd">${esc(it.kbd)}</kbd>`
                    : it.hint ? `<span class="cmdk-hint">${esc(it.hint)}</span>`
                    : it.sub ? `<span class="cmdk-hint">${esc(it.sub)}</span>` : '';
                html += `<button class="cmdk-item ${i === sel ? 'sel' : ''}" data-i="${i}"><span class="cmdk-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">${it.icon}</svg></span><span class="cmdk-item-body"><span class="cmdk-item-title">${esc(it.title)}</span></span>${right}</button>`;
            });
            results.innerHTML = html;
            results.querySelector('.cmdk-item.sel')?.scrollIntoView({ block: 'nearest' });
        };
        const render = async (q: string) => {
            items = buildItems(q, null); sel = 0; paint(q);
            if (q.trim().length >= 2) {
                const my = ++seq;
                try {
                    const res = await fetch('/api/search?q=' + encodeURIComponent(q.trim()));
                    const data = await res.json();
                    if (my !== seq) return;
                    items = buildItems(q, data); sel = 0; paint(q);
                } catch { /* ignora */ }
            }
        };
        const activate = (i: number) => {
            const it = items[i];
            if (!it) return;
            if (typeof it.run === 'function') { close(); it.run(); return; }
            if (it.href) { pushRecent(it); close(); window.location.href = it.href; }
        };
        const open = () => { (cmdk as HTMLElement).hidden = false; document.body.style.overflow = 'hidden'; input.value = ''; render(''); setTimeout(() => input.focus(), 20); };
        const close = () => { (cmdk as HTMLElement).hidden = true; document.body.style.overflow = ''; };

        input.addEventListener('input', () => render(input.value));
        results.addEventListener('click', (e) => { const b = (e.target as HTMLElement).closest('.cmdk-item') as HTMLElement; if (b) activate(parseInt(b.dataset.i!, 10)); });
        results.addEventListener('mousemove', (e) => { const b = (e.target as HTMLElement).closest('.cmdk-item') as HTMLElement; if (b) { const i = parseInt(b.dataset.i!, 10); if (i !== sel) { sel = i; paint(); } } });
        input.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowDown') { e.preventDefault(); sel = Math.min(sel + 1, items.length - 1); paint(); }
            else if (e.key === 'ArrowUp') { e.preventDefault(); sel = Math.max(sel - 1, 0); paint(); }
            else if (e.key === 'Enter') { e.preventDefault(); activate(sel); }
        });

        document.getElementById('cmdkOpen')?.addEventListener('click', open);
        document.getElementById('cmdkBackdrop')?.addEventListener('click', close);
        document.addEventListener('keydown', (e) => {
            if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') { e.preventDefault(); (cmdk as HTMLElement).hidden ? open() : close(); }
            else if (e.key === 'Escape' && !(cmdk as HTMLElement).hidden) { close(); }
        });
    }


    // ── Tema claro / oscuro (persistente, sin flash; el <head> lo aplica al cargar) ──
    function initTheme() {
        const btn = document.getElementById('themeBtn');
        if (!btn) return;
        btn.addEventListener('click', () => {
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            if (isDark) { document.documentElement.removeAttribute('data-theme'); try { localStorage.setItem('cord.theme', 'light'); } catch (e) {} }
            else { document.documentElement.setAttribute('data-theme', 'dark'); try { localStorage.setItem('cord.theme', 'dark'); } catch (e) {} }
            // Reposiciona el indicador del sidebar por si cambió alguna métrica.
            window.dispatchEvent(new Event('resize'));
        });
    }

    // ── Indicador deslizante del sidebar (segmented control tipo iOS) ──


    // ── Toasts globales — window.cordToast(msg, 'ok'|'error'|'info') ──
    function initToasts() {
        const stack = document.getElementById('toastStack');
        if (!stack) return;
        const ICONS: any = {
            ok: '<path d="M20 6L9 17l-5-5"/>',
            error: '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>',
            info: '<circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>',
        };
        (window as any).cordToast = (msg: string, type = 'info', ms = 3800) => {
            const t = document.createElement('div');
            t.className = 'toast ' + (type === 'ok' || type === 'error' ? type : '');
            const ico = ICONS[type] || ICONS.info;
            t.innerHTML = `<svg class="toast-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${ico}</svg><span>${String(msg).replace(/</g, '&lt;')}</span><button class="toast-close" aria-label="Cerrar"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>`;
            stack.appendChild(t);
            const remove = () => { t.classList.add('out'); setTimeout(() => t.remove(), 250); };
            t.querySelector('.toast-close')?.addEventListener('click', remove);
            const timer = setTimeout(remove, ms);
            t.addEventListener('mouseenter', () => clearTimeout(timer));
            return t;
        };
        // Flash tras navegación: sessionStorage 'cord.flash' = {msg,type}
        try {
            const flash = sessionStorage.getItem('cord.flash');
            if (flash) { sessionStorage.removeItem('cord.flash'); const f = JSON.parse(flash); (window as any).cordToast(f.msg, f.type); }
        } catch (e) {}
    }

    // ── Confirmación global — window.cordConfirm(opts): Promise<boolean> ──
    // Reemplaza confirm() nativo con un modal con estética Cord. Uso:
    //   if (!await cordConfirm({ title, body, danger, confirmText })) return;
    //   cordConfirm('¿Texto simple?')  → también acepta un string.
    function initConfirm() {
        const modal = document.getElementById('cordConfirm');
        if (!modal) return;
        const backdrop = document.getElementById('cconfBackdrop');
        const titleEl = document.getElementById('cconfTitle')!;
        const bodyEl = document.getElementById('cconfBody')!;
        const okBtn = document.getElementById('cconfOk') as HTMLButtonElement;
        const cancelBtn = document.getElementById('cconfCancel') as HTMLButtonElement;

        let resolver: ((v: boolean) => void) | null = null;
        const close = (result: boolean) => {
            if (!resolver) return;
            const r = resolver; resolver = null;
            modal.setAttribute('hidden', '');
            document.removeEventListener('keydown', onKey);
            r(result);
        };
        const onKey = (e: KeyboardEvent) => {
            if (e.key === 'Escape') { e.preventDefault(); close(false); }
            else if (e.key === 'Enter') { e.preventDefault(); close(true); }
        };
        okBtn.addEventListener('click', () => close(true));
        cancelBtn.addEventListener('click', () => close(false));
        backdrop?.addEventListener('click', () => close(false));

        (window as any).cordConfirm = (opts: any): Promise<boolean> => {
            const o = typeof opts === 'string' ? { body: opts } : (opts || {});
            titleEl.textContent = o.title || '¿Estás seguro?';
            bodyEl.textContent = o.body || '';
            bodyEl.style.display = o.body ? '' : 'none';
            okBtn.textContent = o.confirmText || 'Confirmar';
            cancelBtn.textContent = o.cancelText || 'Cancelar';
            modal.classList.toggle('danger', !!o.danger);
            modal.removeAttribute('hidden');
            // Foco en cancelar por defecto (acción no destructiva) para evitar
            // confirmar sin querer al presionar Enter apurado.
            setTimeout(() => (o.danger ? cancelBtn : okBtn).focus(), 20);
            document.addEventListener('keydown', onKey);
            return new Promise<boolean>((resolve) => { resolver = resolve; });
        };
    }

    // ── Barra de progreso al navegar (feedback de carga) ──
    function initNavProgress() {
        const bar = document.getElementById('navProgress');
        if (!bar) return;
        let timer = 0; let prog = 0;
        const start = () => {
            bar.classList.add('active'); prog = 8; (bar as HTMLElement).style.width = '8%';
            clearInterval(timer);
            timer = window.setInterval(() => { prog = Math.min(prog + Math.random() * 12, 90); (bar as HTMLElement).style.width = prog + '%'; }, 220);
        };
        const done = () => { clearInterval(timer); bar.classList.remove('active'); (bar as HTMLElement).style.width = '0'; };
        document.addEventListener('click', (e) => {
            const a = (e.target as HTMLElement).closest('a');
            if (!a) return;
            const href = a.getAttribute('href');
            if (!href || href.startsWith('#') || a.target === '_blank' || a.hasAttribute('download')) return;
            if (e.metaKey || e.ctrlKey || e.shiftKey || (e as MouseEvent).button !== 0) return;
            try { const u = new URL(a.href); if (u.origin !== location.origin) return; if (u.pathname === location.pathname && u.search === location.search) return; } catch { return; }
            start();
        });
        window.addEventListener('pageshow', done);
        window.addEventListener('beforeunload', start);
    }

    // ── "Fijados" en el sidebar (localStorage) + botón de fijar en el page-head ──
    // ── Utilidades Globales ──

    // Helpers para IA Chat
    window.openCordAi = function(e) {
        const drawer = document.getElementById('helpDrawer');
        if (!drawer || drawer.classList.contains('ai-active')) return;
        drawer.classList.add('ai-active');
        
    };
    window.closeCordAi = function(e) {
        if (e) e.stopPropagation();
        const drawer = document.getElementById('helpDrawer');
        if (drawer) drawer.classList.remove('ai-active');
    };

    function initNotifs() {
        const btn = document.getElementById('notifBtn');
        const panel = document.getElementById('notifPanel');
        const list = document.getElementById('notifList');
        const dot = document.getElementById('notifDot');
        const markAll = document.getElementById('notifMarkAll');
        if (!btn || !panel || !list) return;
        const SEEN_KEY = 'cord.notif.seen';
        const ICONS: any = {
            send: '<line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>',
            eye: '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>',
            check: '<path d="M20 6L9 17l-5-5"/>',
            x: '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>',
            card: '<rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/>',
            doc: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>',
            chat: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
        };
        const TONE: any = { approved: 'ok', paid: 'ok', viewed: 'warn', counter: 'warn', rejected: 'danger' };
        let latest = 0;
        const esc = (s: string) => String(s).replace(/</g, '&lt;');
        const getSeen = () => { try { return parseInt(localStorage.getItem(SEEN_KEY) || '0', 10) || 0; } catch { return 0; } };
        const paint = (data: any) => {
            const items = data.items || []; latest = data.latest || 0;
            if (!items.length) { list.innerHTML = '<div class="notif-empty">Sin actividad reciente</div>'; return; }
            const seen = getSeen();
            list.innerHTML = items.map((n: any) => {
                const unread = n.ts > seen ? ' unread' : '';
                const tone = TONE[n.tipo] ? ' ' + TONE[n.tipo] : '';
                const icon = ICONS[n.icon] || ICONS.doc;
                return `<a class="notif-item${unread}" href="${n.href}"><span class="notif-ico${tone}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">${icon}</svg></span><span class="notif-body"><span class="notif-title">${esc(n.title)}</span><span class="notif-sub">${esc(n.sub)}</span><span class="notif-when">${esc(n.cuando)}</span></span></a>`;
            }).join('');
        };
        const closeP = () => { (panel as HTMLElement).hidden = true; btn.setAttribute('aria-expanded', 'false'); };
        const load = async () => {
            list.innerHTML = '<div class="notif-empty">Cargando…</div>';
            try {
                const res = await fetch('/api/notificaciones'); const data = await res.json();
                paint(data);
                try { localStorage.setItem(SEEN_KEY, String(latest || Date.now())); } catch (e) {}
                (dot as HTMLElement).hidden = true;
            } catch { list.innerHTML = '<div class="notif-empty">No se pudo cargar</div>'; }
        };
        const openP = () => { (panel as HTMLElement).hidden = false; btn.setAttribute('aria-expanded', 'true'); load(); };
        btn.addEventListener('click', (e) => { e.stopPropagation(); (panel as HTMLElement).hidden ? openP() : closeP(); });
        document.addEventListener('click', (e) => { if (!(panel as HTMLElement).hidden && !panel.contains(e.target as Node) && !btn.contains(e.target as Node)) closeP(); });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeP(); });
        markAll?.addEventListener('click', () => {
            try { localStorage.setItem(SEEN_KEY, String(Date.now())); } catch (e) {}
            (dot as HTMLElement).hidden = true;
            list.querySelectorAll('.notif-item.unread').forEach((el) => el.classList.remove('unread'));
        });
        // Punto rojo si hay actividad más nueva que la última vista.
        (async () => {
            try {
                const res = await fetch('/api/notificaciones'); const data = await res.json();
                (dot as HTMLElement).hidden = !((data.latest || 0) > getSeen());
            } catch (e) {}
        })();
    }

    // ── Atajos de teclado globales ──
    function initShortcuts() {
        const help = document.getElementById('kbdHelp');
        document.getElementById('kbdHelpBackdrop')?.addEventListener('click', () => { if (help) (help as HTMLElement).hidden = true; });
        const ROUTES: any = { d: '/app', c: '/app/cotizaciones', l: '/app/clientes', p: '/app/productos', b: '/app/cobranza', a: '/app/analitica' };
        const typing = (el: any) => el && (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA' || el.tagName === 'SELECT' || el.isContentEditable);
        let gPending = false; let gTimer = 0;
        document.addEventListener('keydown', (e) => {
            if (e.metaKey || e.ctrlKey || e.altKey) return;
            if (typing(e.target)) return;
            if (!(document.getElementById('cmdk') as HTMLElement)?.hidden) return; // cmdk abierto
            const k = e.key.toLowerCase();
            if (e.key === '?') { e.preventDefault(); if (help) (help as HTMLElement).hidden = !(help as HTMLElement).hidden; return; }
            if (help && !(help as HTMLElement).hidden) return; // overlay de ayuda abierto
            if (gPending) {
                gPending = false; clearTimeout(gTimer);
                if (ROUTES[k]) { e.preventDefault(); window.location.href = ROUTES[k]; return; }
            }
            if (k === 'g') { gPending = true; gTimer = window.setTimeout(() => { gPending = false; }, 1200); return; }
            if (k === '/') { e.preventDefault(); document.getElementById('cmdkOpen')?.click(); return; }
            if (k === 'c') { e.preventDefault(); window.location.href = '/app/cotizaciones/nueva'; return; }
            if (k === 'f') { e.preventDefault(); (window as any).__cordTogglePin?.(); return; }
        });
    }

    // ── Drawer de Ayuda (icono ? de la topbar) ──
    function initHelp() {
        const btn = document.getElementById('helpBtn');
        const drawer = document.getElementById('helpDrawer');
        const backdrop = document.getElementById('helpBackdrop');
        const closeBtn = document.getElementById('helpClose');
        const search = document.getElementById('helpSearch') as HTMLInputElement | null;
        const faqWrap = document.getElementById('helpFaq');
        const empty = document.getElementById('helpEmpty');
        if (!btn || !drawer || !faqWrap) return;

        const FAQ = [
            { q: '¿Cómo creo una cotización?', a: 'Ve a Cotizaciones y pulsa "Nueva cotización" (atajo C). Elige un cliente, agrega productos de tu catálogo o líneas libres, ajusta el precio negociado y guarda. Puedes guardarla como borrador o enviarla de inmediato.' },
            { q: '¿Cómo le envío la cotización a mi cliente?', a: 'Desde el detalle de la cotización usa "Enviar" para mandar el link público por correo, o "Enviar por WhatsApp" para compartir un mensaje con el link ya armado. También puedes copiar el link y pegarlo donde quieras.' },
            { q: '¿Qué ve mi cliente en el link público?', a: 'Tu cliente abre una página con tu marca donde revisa la cotización, descarga el PDF y la aprueba o rechaza con firma digital. Tú ves en vivo cuándo la abrió y cuándo la está viendo.' },
            { q: '¿Cómo facturo (CFDI) una cotización?', a: 'Cuando una cotización está aprobada o pagada, usa la acción "Facturar" en el detalle para generar el CFDI. Antes asegúrate de tener tus datos fiscales completos en Ajustes › Fiscal.' },
            { q: '¿Puedo importar mis productos y clientes?', a: 'Sí. En Productos y en Clientes hay un botón de Importar por CSV: subes el archivo, mapeas las columnas, revisas la vista previa y confirmas. Los productos se deduplican por SKU y los clientes por RFC o empresa.' },
            { q: '¿Qué incluye mi plan y cómo subo de nivel?', a: 'En Ajustes › Plan ves tu uso del periodo (IA, CFDI, API) y los límites de tu plan. Desde ahí puedes subir de plan o abrir el portal de facturación para gestionar tu suscripción.' },
            { q: '¿Cómo personalizo el PDF y el portal del cliente?', a: 'En Ajustes › PDF eliges plantilla, subes tu logo y defines color y mensajes, con vista previa en vivo. En Ajustes › Portal del cliente personalizas el banner, la bienvenida y qué se muestra en el link público.' },
        ];

        // Render del acordeón
        faqWrap.innerHTML = FAQ.map((f, i) => `
            <div class="faq-item" data-faq>
                <button type="button" class="faq-q" aria-expanded="false">
                    <span>${f.q}</span>
                    <svg class="faq-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                </button>
                <div class="faq-a"><div><p>${f.a}</p></div></div>
            </div>`).join('');

        faqWrap.querySelectorAll('.faq-q').forEach((q) => {
            q.addEventListener('click', () => {
                const item = q.closest('.faq-item') as HTMLElement;
                const wasOpen = item.classList.contains('open');
                faqWrap.querySelectorAll('.faq-item.open').forEach((el) => {
                    el.classList.remove('open');
                    el.querySelector('.faq-q')?.setAttribute('aria-expanded', 'false');
                });
                if (!wasOpen) { 
                    item.classList.add('open'); 
                    q.setAttribute('aria-expanded', 'true'); 
                    setTimeout(() => {
                        item.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                    }, 300);
                }
            });
        });

        // Buscador
        search?.addEventListener('input', () => {
            const term = search.value.trim().toLowerCase();
            let visible = 0;
            FAQ.forEach((f, i) => {
                const item = faqWrap.children[i] as HTMLElement;
                if (!item) return;
                const match = !term || (f.q + ' ' + f.a).toLowerCase().includes(term);
                item.hidden = !match;
                if (match) visible++;
            });
            if (empty) (empty as HTMLElement).hidden = visible > 0;
        });

        const open = () => { (drawer as HTMLElement).hidden = false; btn.setAttribute('aria-expanded', 'true'); document.body.style.overflow = 'hidden'; setTimeout(() => search?.focus(), 60); };
        const close = () => { (drawer as HTMLElement).hidden = true; btn.setAttribute('aria-expanded', 'false'); document.body.style.overflow = ''; setTimeout(() => drawer.classList.remove('ai-active'), 350); };

        btn.addEventListener('click', () => { (drawer as HTMLElement).hidden ? open() : close(); });
        closeBtn?.addEventListener('click', close);
        backdrop?.addEventListener('click', close);
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !(drawer as HTMLElement).hidden) close(); });

        // AI Chat UI Logic
        const aiChatInput = document.getElementById('chatRealInput');
        const aiChatSend = document.getElementById('chatSendBtn');
        const chatHistory = document.getElementById('chatHistory');

        aiChatInput?.addEventListener('input', () => {
            if ((aiChatInput as HTMLInputElement).value.trim()) aiChatSend?.classList.add('active');
            else aiChatSend?.classList.remove('active');
        });
        
        const sendAiMessage = () => {
            const input = aiChatInput as HTMLInputElement;
            const text = input.value.trim();
            if (!text || !chatHistory) return;
            
            const userB = document.createElement('div');
            userB.className = 'chat-bubble user';
            userB.textContent = text;
            chatHistory.appendChild(userB);
            
            input.value = '';
            aiChatSend?.classList.remove('active');
            chatHistory.scrollTop = chatHistory.scrollHeight;
            
            // Mostrar estado "pensando..."
            const thinkingB = document.createElement('div');
            thinkingB.className = 'chat-bubble bot thinking';
            thinkingB.innerHTML = '<div class="typing-dots"><span></span><span></span><span></span></div>';
            chatHistory.appendChild(thinkingB);
            chatHistory.scrollTop = chatHistory.scrollHeight;
            
            setTimeout(() => {
                thinkingB.remove();
                
                const botB = document.createElement('div');
                botB.className = 'chat-bubble bot';
                chatHistory.appendChild(botB);
                
                const reply = "He analizado tus métricas. En este entorno demo, Cord AI aún se está conectando a tu base de datos principal, pero muy pronto podré redactar cotizaciones automáticas y generar reportes predictivos para ti.";
                let i = 0;
                const typeWriter = setInterval(() => {
                    botB.textContent += reply.charAt(i);
                    i++;
                    chatHistory.scrollTop = chatHistory.scrollHeight;
                    if (i >= reply.length) clearInterval(typeWriter);
                }, 20);
            }, 1200);
        };
        
        aiChatInput?.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') { e.preventDefault(); sendAiMessage(); }
        });
        aiChatSend?.addEventListener('click', sendAiMessage);

        // Enlaces rápidos
        drawer.querySelectorAll('[data-help-action]').forEach((el) => {
            el.addEventListener('click', () => {
                const action = (el as HTMLElement).dataset.helpAction;
                if (action === 'shortcuts') { close(); const h = document.getElementById('kbdHelp'); if (h) (h as HTMLElement).hidden = false; }
                else if (action === 'guide') { close(); document.getElementById('onbPill')?.click(); }
            });
        });
    }

    // ── Menú "Crear" genérico (botón + popover) — reusado por móvil y desktop ──
    // ── Menú "Crear" de la topbar (desktop) ──
    function initCreateMenu(btnId: string, menuId: string) {
        const btn = document.getElementById(btnId);
        const menu = document.getElementById(menuId);
        if (!btn || !menu) return;
        const m = menu as HTMLElement;
        const closeMenu = () => { m.hidden = true; btn.setAttribute('aria-expanded', 'false'); };
        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const willOpen = m.hidden;
            m.hidden = !willOpen;
            btn.setAttribute('aria-expanded', String(willOpen));
        });
        document.addEventListener('click', (e) => {
            if (!m.hidden && !menu.contains(e.target as Node) && !btn.contains(e.target as Node)) closeMenu();
        });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });
    }

    // ── Quick-add de Tarea (modal desde el botón "Crear") ──
    function initQuickTask() {
        const modal = document.getElementById('qtask');
        const form = document.getElementById('qtaskForm') as HTMLFormElement | null;
        const titulo = document.getElementById('qtaskTitulo') as HTMLInputElement | null;
        const due = document.getElementById('qtaskDue') as HTMLInputElement | null;
        if (!modal || !form || !titulo) return;
        const open = () => { (modal as HTMLElement).hidden = false; document.body.style.overflow = 'hidden'; setTimeout(() => titulo.focus(), 30); };
        const close = () => { (modal as HTMLElement).hidden = true; document.body.style.overflow = ''; form.reset(); };
        // Disparadores: botón de la topbar y el menú móvil (si existiera un item de tarea).
        document.getElementById('tbCreateTarea')?.addEventListener('click', () => { document.getElementById('tbCreateMenu')!.hidden = true; document.getElementById('tbCreate')?.setAttribute('aria-expanded', 'false'); open(); });
        (window as any).cordQuickTask = open;
        document.getElementById('qtaskClose')?.addEventListener('click', close);
        document.getElementById('qtaskBackdrop')?.addEventListener('click', close);
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !(modal as HTMLElement).hidden) close(); });
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const t = titulo.value.trim();
            if (!t) return;
            try {
                const res = await fetch('/api/tareas', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ titulo: t, due_date: due?.value || null }) });
                if (!res.ok) throw new Error();
                close();
                if (location.pathname === '/app') location.reload();
                else (window as any).cordToast?.('Tarea creada', 'ok');
            } catch { (window as any).cordToast?.('No se pudo crear la tarea', 'error'); }
        });
    }

    function initApp() { initCmdk(); initTheme(); initToasts(); initConfirm(); initNavProgress(); initNotifs(); initHelp(); initShortcuts(); initCreateMenu('tbCreate', 'tbCreateMenu'); initQuickTask(); }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initApp);
    else initApp();
</script>
