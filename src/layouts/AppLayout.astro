    .qtask-input:focus, .qtask-date:focus { outline: none; border-color: var(--color-blue-deep); }
    .qtask-row { display: flex; gap: 10px; }
    .qtask-date { flex: 0 0 auto; font-family: var(--font-sans); font-size: 0.85rem; color: var(--color-text); background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: 10px; padding: 10px 12px; }
    .qtask-btn { flex: 1; font-family: var(--font-sans); font-size: 0.86rem; font-weight: 600; color: #fff; background: var(--color-blue-deep); border: none; border-radius: 10px; padding: 10px 16px; cursor: pointer; transition: transform 0.3s var(--ease-spring), box-shadow 0.3s var(--ease-spring); box-shadow: 0 6px 18px -8px rgba(10,25,47,0.5); }
    .qtask-btn:hover { transform: translateY(-1px); box-shadow: 0 10px 24px -8px rgba(10,25,47,0.55); }
    @media (max-width: 560px) { .qtask-row { flex-direction: column; } .qtask-date { width: 100%; } }

    /* ── MOBILE ── */
    @media (max-width: 880px) {
        .tb-burger { display: inline-flex; }
        .app-content {
            padding: 1rem 1rem 2rem;
            padding-left: max(1rem, env(safe-area-inset-left));
            padding-right: max(1rem, env(safe-area-inset-right));
            padding-bottom: calc(2rem + env(safe-area-inset-bottom));
        }
        /* La pill flotante respeta el notch (se mantiene sticky por debajo de él). */
        .topbar {
            margin: calc(0.6rem + env(safe-area-inset-top)) 0.6rem 0;
            padding: 0.45rem 0.6rem; border-radius: 14px;
        }
        .topbar { top: calc(0.6rem + env(safe-area-inset-top)); }
        .page-head { padding: 1.1rem 1rem 0; }
        .ph-title { font-size: 1.35rem; }
        .ph-actions { width: 100%; }
        .tb-demo { display: none; }
        /* La barra de búsqueda se reduce a un ícono de lupa (estilo Stripe móvil) */
        .tb-search {
            flex: 0 0 auto; width: 36px; height: 36px; padding: 0; gap: 0;
            justify-content: center; border: none; background: transparent; border-radius: 9px;
        }
