    .cmdk-foot { display: flex; gap: 1.2rem; padding: 9px 16px; border-top: 1px solid var(--color-border); background: var(--color-bg-soft); }
    .cmdk-foot span { font-size: 0.68rem; color: #99a2af; display: inline-flex; align-items: center; gap: 5px; }
    .cmdk-foot kbd { font-size: 0.62rem; font-weight: 700; background: #fff; border: 1px solid var(--color-border); border-radius: 4px; padding: 1px 5px; color: var(--color-text-muted); }

    /* ── Quick-add de Tarea (modal centrado) ── */
    .qtask { position: fixed; inset: 0; z-index: 510; display: flex; align-items: flex-start; justify-content: center; padding: 16vh 1rem 1rem; }
    .qtask[hidden] { display: none; }
    .qtask-backdrop { position: absolute; inset: 0; background: rgba(10,25,47,0.35); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); animation: cmdk-fade 0.2s ease; }
    .qtask-panel {
