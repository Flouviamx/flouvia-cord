    /* ── Page header (título de la sección, debajo de la topbar, dentro del contenido) ── */
    .page-head {
        padding: 1.6rem 2rem 0;
        animation: app-fadein 0.5s var(--ease-spring) both;
    }
    .ph-inner {
        max-width: var(--content-max); width: 100%;
        display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem;
        flex-wrap: wrap;
        transition: max-width 0.28s var(--ease-spring);
    }
    .ph-titles { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
