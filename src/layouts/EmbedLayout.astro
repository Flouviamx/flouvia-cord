---
// EmbedLayout — chrome mínimo para CORD Elements (/embed/[token] dentro de un
// <iframe> en el sitio de un tercero). Sin navbar, sin watermark, fondo
// TRANSPARENTE para que herede el del sitio anfitrión. Trae los tokens de diseño
// e Inter (necesarios para la clase .editorial). Siempre noindex.
interface Props {
    title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="robots" content="noindex, nofollow" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
        <link rel="icon" href="/favicon.ico" sizes="any" />

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

        <title>{title}</title>
    </head>
    <body>
        <slot />
    </body>
</html>

<style is:global>
    /* Tokens del sistema Flouvia (réplica del bloque de Layout.astro — el embed no
       hereda los estilos globales de la landing). */
    :root {
        --color-bg: var(--cord-color-background, #ffffff);
        --color-bg-soft: #fcfcfc;
        --color-blue-deep: #0a192f;
        --color-text: var(--cord-color-text, #050505);
        --color-text-muted: #555556;
        --color-border: rgba(0, 0, 0, 0.08);
        --color-ok: #10b981;
        --color-warn: #f59e0b;
        --color-danger: #ef4444;
        --font-sans: var(--cord-font-family, 'Inter', system-ui, sans-serif);
        --ease-ios: cubic-bezier(0.25, 1, 0.5, 1);
        --ease-spring: cubic-bezier(0.22, 1, 0.36, 1);
        --ease-smooth: cubic-bezier(0.16, 1, 0.3, 1);
    }

    *, *::before, *::after { box-sizing: border-box; }

    html, body {
        width: 100%;
        margin: 0;
        padding: 0;
        background: transparent;   /* hereda el fondo del sitio anfitrión */
        font-family: var(--font-sans);
        color: var(--color-text);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
    }

    .editorial {
        font-family: var(--font-sans);
        font-style: normal;
        font-weight: 600;
        letter-spacing: -0.03em;
        font-variant-numeric: tabular-nums;
    }
</style>
