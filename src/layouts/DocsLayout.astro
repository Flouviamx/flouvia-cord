                      <li class={Astro.url.pathname.includes(getUrl('/docs/desarrolladores/herramientas/elements/apariencia')) ? 'active' : ''}><a href={getUrl('/docs/desarrolladores/herramientas/elements/apariencia')}>{lang === 'es' ? 'Apariencia' : 'Appearance'}</a></li>
