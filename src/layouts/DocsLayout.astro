                    </ul>
                  </li>
                  <li class="sidebar-dropdown open">
                    <button class="sidebar-dropdown-toggle">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="chevron"><polyline points="6 9 12 15 18 9"></polyline></svg>
                      {lang === 'es' ? 'Crea una cotización' : 'Create a quote'}
                    </button>
                    <ul class="sidebar-submenu">
                      <li class={Astro.url.pathname === getUrl('/docs/cotizacion/resumen') || Astro.url.pathname === getUrl('/docs/cotizacion/resumen/') ? 'active' : ''}><a href={getUrl('/docs/cotizacion/resumen')}>{lang === 'es' ? 'Resumen' : 'Overview'}</a></li>
                      <li class={Astro.url.pathname.includes(getUrl('/docs/cotizacion/ia')) ? 'active' : ''}><a href={getUrl('/docs/cotizacion/ia')}>{lang === 'es' ? 'Generar con IA' : 'Generate with AI'}</a></li>
