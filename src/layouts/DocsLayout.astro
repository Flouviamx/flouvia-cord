              <div class="sidebar-section">
                <h4 class="sidebar-heading">{lang === 'es' ? 'EMPIEZA A DESARROLLARLA' : 'START BUILDING'}</h4>
                <ul class="sidebar-menu">
                  <li class="sidebar-dropdown open">
                    <button class="sidebar-dropdown-toggle">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="chevron"><polyline points="6 9 12 15 18 9"></polyline></svg>
