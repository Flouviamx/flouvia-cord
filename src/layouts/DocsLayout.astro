                      <li class={Astro.url.pathname.includes(getUrl('/docs/desarrolladores/seguridad/sso')) ? 'active' : ''}><a href={getUrl('/docs/desarrolladores/seguridad/sso')}>{lang === 'es' ? 'SSO y SAML' : 'SSO & SAML'}</a></li>
                    </ul>
                  </li>
                </ul>
              </div>
            </>
