---
import Layout from "./Layout.astro";

import type { MarkdownHeading } from "astro";
import TableOfContents from "../components/docs/TableOfContents.astro";

export interface Props {
  headings?: MarkdownHeading[];
  title: string;
  lang?: "es" | "en";
  description?: string;
}

import { altLangUrls } from "../i18n/utils";

const { title, lang = "es", description, headings = [] } = Astro.props;
const { esUrl, enUrl } = altLangUrls(Astro.url);

const getUrl = (path: string) => lang === 'en' ? `/en${path}` : path;

const isOverviewPage = Astro.url.pathname.endsWith('/resumen') || Astro.url.pathname.endsWith('/resumen/') || Astro.url.pathname === '/docs' || Astro.url.pathname === '/docs/' || Astro.url.pathname === '/en/docs' || Astro.url.pathname === '/en/docs/';

// Build breadcrumb from URL path
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems = pathSegments.map((segment, index) => {
  const path = '/' + pathSegments.slice(0, index + 1).join('/');
  const label = segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, ' ');
  return { name: label, url: `https://cordhq.app${path}` };
});

// JSON-LD structured data
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://cordhq.app/#organization",
      "name": "Cord",
      "url": "https://cordhq.app",
      "logo": {
        "@type": "ImageObject",
        "url": "https://cordhq.app/imgs/logo-cord-navy.png"
      },
      "sameAs": []
    },
    {
      "@type": "WebSite",
      "@id": "https://cordhq.app/#website",
      "url": "https://cordhq.app",
      "name": "Cord",
      "publisher": { "@id": "https://cordhq.app/#organization" },
      "inLanguage": lang === "es" ? "es-MX" : "en-US"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbItems.map((item, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": item.name,
        "item": item.url
      }))
    },
    {
      "@type": "WebPage",
      "name": title,
      ...(description ? { "description": description } : {}),
      "url": `https://cordhq.app${Astro.url.pathname}`,
      "inLanguage": lang === "es" ? "es-MX" : "en-US",
      "isPartOf": { "@id": "https://cordhq.app/#website" },
      "about": { "@id": "https://cordhq.app/#organization" },
      "dateModified": new Date().toISOString().split('T')[0]
    }
  ]
};
---

<Layout title={`${title} | Cord Docs`} description={description} ogType="article">
  <style is:inline>
    :root { color-scheme: light; }
    html { lang: ${lang}; }
  </style>
  <!-- Set lang dynamically for JS scripts to read -->
  <script is:inline define:vars={{ lang }}>
    document.documentElement.lang = lang;
  </script>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="docs-layout">
    
    <!-- Header -->
    <header class="docs-header">
      <div class="header-top">
        <div class="header-left">
          <a href="/docs" class="logo">
            <img src="/imgs/logo-cord-navy.png" alt="Cord" height="24" style="height: 24px; margin-right: 6px;" />
            <span class="brand-docs">DOCS</span>
          </a>
        </div>
        
        <div class="header-center">
          <div class="search-container">
            <button class="search-input" id="search-trigger">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
              <span>{lang === 'es' ? 'Buscar en la document...' : 'Search docs...'}</span>
              <kbd>/</kbd>
            </button>
          </div>
        </div>

        <div class="header-right">
          <div class="lang-toggle">
            <a href={esUrl} class={`lang-option ${lang === 'es' ? 'active' : ''}`}>ES</a>
            <a href={enUrl} class={`lang-option ${lang === 'en' ? 'active' : ''}`}>EN</a>
          </div>
        </div>
      </div>

      <nav class="header-bottom">
        <ul class="nav-links">
          <li class={!Astro.url.pathname.includes(getUrl('/docs/pagos')) && !Astro.url.pathname.includes(getUrl('/docs/presupuestos')) && !Astro.url.pathname.includes(getUrl('/docs/desarrolladores')) ? 'active' : ''}><a href={getUrl('/docs')}>{lang === 'es' ? 'Empezar' : 'Get Started'}</a></li>
          <li class={Astro.url.pathname.includes(getUrl('/docs/pagos')) ? 'active' : ''}><a href={getUrl('/docs/pagos/resumen')}>{lang === 'es' ? 'Pagos' : 'Payments'}</a></li>
          <li class={Astro.url.pathname.includes(getUrl('/docs/presupuestos')) ? 'active' : ''}><a href={getUrl('/docs/presupuestos/resumen')}>{lang === 'es' ? 'Presupuestos' : 'Budgets'}</a></li>
          <li class={Astro.url.pathname.includes(getUrl('/docs/desarrolladores')) ? 'active' : ''}><a href={getUrl('/docs/desarrolladores/empezar/apikey')}>{lang === 'es' ? 'Desarrolladores' : 'Developers'}</a></li>
        </ul>
        <div class="nav-tools">
          <div class="nav-dropdown-wrapper">
            <button class="nav-dropdown">{lang === 'es' ? 'Ayuda' : 'Help'} <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
            <div class="dropdown-menu">
              <a href="/soporte">{lang === 'es' ? 'Centro de soporte' : 'Support Center'}</a>
              <a href="/contacto/ventas">{lang === 'es' ? 'Contactar a ventas' : 'Contact Sales'}</a>
            </div>
          </div>
        </div>
      </nav>
    </header>

    <div class="docs-body">
      <!-- Sidebar -->
      <aside class="docs-sidebar">
        <nav class="sidebar-nav">
          {Astro.url.pathname.includes(getUrl('/docs/presupuestos')) ? (
            <>
              <ul class="sidebar-menu">
                <li class={Astro.url.pathname === getUrl('/docs/presupuestos/resumen') || Astro.url.pathname === getUrl('/docs/presupuestos/resumen/') ? 'active' : ''}><a href={getUrl('/docs/presupuestos/resumen')}>{lang === 'es' ? 'Resumen' : 'Overview'}</a></li>
                <li class={Astro.url.pathname.includes(getUrl('/docs/presupuestos/primera-cedula')) ? 'active' : ''}><a href={getUrl('/docs/presupuestos/primera-cedula')}>{lang === 'es' ? 'Plantillas y plan completo' : 'Templates and full plan'}</a></li>
              </ul>

              <div class="sidebar-section">
                <h4 class="sidebar-heading">{lang === 'es' ? 'PRESUPUESTA CON CORD' : 'BUDGET WITH CORD'}</h4>
