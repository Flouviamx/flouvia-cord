                    </button>
                    <ul class="sidebar-submenu">
                      <li class={Astro.url.pathname === getUrl('/docs/cuenta/resumen') || Astro.url.pathname === getUrl('/docs/cuenta/resumen/') ? 'active' : ''}><a href={getUrl('/docs/cuenta/resumen')}>{lang === 'es' ? 'Resumen' : 'Overview'}</a></li>
                      <li class={Astro.url.pathname.includes(getUrl('/docs/cuenta/configuracion')) ? 'active' : ''}><a href={getUrl('/docs/cuenta/configuracion')}>{lang === 'es' ? 'Configura tu cuenta' : 'Configure your account'}</a></li>
                      <li class={Astro.url.pathname.includes(getUrl('/docs/cuenta/csd')) ? 'active' : ''}><a href={getUrl('/docs/cuenta/csd')}>{lang === 'es' ? 'Agrega la información fiscal (CSD)' : 'Add tax information (CSD)'}</a></li>
