                    <ul class="sidebar-submenu">
                      <li class={Astro.url.pathname.includes(getUrl('/docs/presupuestos/interfaz')) ? 'active' : ''}><a href={getUrl('/docs/presupuestos/interfaz')}>{lang === 'es' ? 'La interfaz' : 'The interface'}</a></li>
