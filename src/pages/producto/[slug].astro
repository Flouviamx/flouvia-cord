    }
    /* Progress bars */
    .pp-bcard-visual .bm-margin-bar-bg { background: rgba(0,0,0,0.07) !important; }
    .pp-bcard-visual .bm-margin-bar-fill { background: linear-gradient(90deg, #10b981, #34d399) !important; }
    .pp-bcard-visual .bm-credit-bar-bg { background: rgba(0,0,0,0.07) !important; }
    .pp-bcard-visual .bm-credit-bar-fill { background: linear-gradient(90deg, #10b981, #34d399) !important; }
    /* Avatars */
    .pp-bcard-visual .bm-avatar,
    .pp-bcard-visual .bm-avatar-sm { background: #0a192f !important; color: #ffffff !important; }
    /* Chat bubbles */
    .pp-bcard-visual .bm-msg-in { background: #f3f4f6 !important; color: #111827 !important; }
    .pp-bcard-visual .bm-msg-out { background: #0a192f !important; color: #fff !important; }
    /* Brand */
    .pp-bcard-visual .bm-brand-dots span { background: #d1d5db !important; }
    .pp-bcard-visual .bm-brand-card { background: #f9fafb !important; }
    /* Tags */
    .pp-bcard-visual .bm-tag-warn { background: rgba(245,158,11,0.1) !important; color: #d97706 !important; }
    .pp-bcard-visual .bm-tag-blue { background: rgba(37,99,235,0.1) !important; color: #2563eb !important; }
    /* Large total number */
    .pp-bcard-visual .bm-large { color: #050505 !important; }
    /* Fake cursor */
    .pp-bcard-visual .bm-fake-cursor svg { stroke: #0a192f !important; }

    /* Full-width (row) cards: big mockup fills the right column, bleeds bottom */
    .pp-bcard-2 .pp-bcard-visual .bm-wrap,
    .pp-bcard-3 .pp-bcard-visual .bm-wrap {
        padding: 0 1rem;
        align-items: flex-end;
        justify-content: center;
    }
    .pp-bcard-2 .pp-bcard-visual .bm-stage,
    .pp-bcard-3 .pp-bcard-visual .bm-stage {
        width: max(360px, 88%);
        transform: translateY(3%);
        transform-origin: bottom center;
    }
    /* Ventana completa en card full-width — centrada en TODO el espacio
       visual disponible (no solo horizontal, también vertical): antes
       quedaba pegada arriba con un hueco grande abajo y se veía desalineada. */
    .pp-bcard-2 .pp-bcard-visual .bm-wrap:has(.bm-app),
    .pp-bcard-3 .pp-bcard-visual .bm-wrap:has(.bm-app) {
        padding: 2rem;
        align-items: center;
        justify-content: center;
    }
    .pp-bcard-2 .pp-bcard-visual .bm-stage:has(.bm-app),
    .pp-bcard-3 .pp-bcard-visual .bm-stage:has(.bm-app) {
        width: 100%;
        max-width: 600px;
        transform: none;
    }
</style>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener('DOMContentLoaded', () => {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (!reduced) {
            // Entrada limpia de los BlockMockups: fade + rise (sin rotación 3D — igual al index)
            const blocks = document.querySelectorAll('.pp-block-visual');
            blocks.forEach((block) => {
                const stage = block.querySelector('.bm-stage');
                if (!stage) return;

                const internals = block.querySelectorAll('.bm-card, .bm-floating, .bm-search, .bm-timeline, .bm-board-col, .bm-stage > div');
                const glow = block.querySelector('.bm-glow');

                gsap.set(internals, { y: 28, opacity: 0 });
                if (glow) gsap.set(glow, { opacity: 0, scale: 0.6 });

                ScrollTrigger.create({
                    trigger: block,
                    start: 'top 85%',
                    once: true,
                    onEnter: () => {
                        gsap.to(internals, {
                            y: 0, opacity: 1,
                            duration: 0.9, ease: 'power3.out', stagger: 0.08, clearProps: 'transform',
                        });
                        if (glow) gsap.to(glow, { opacity: 1, scale: 1, duration: 1.6, ease: 'power3.out' });
                    },
                });
            });
            
            // ───────────────────────── HERO MOCKUP ─────────────────────────
            // El "settle" del mockup del hero (perspectiva → plano con el scroll) lo
            // maneja PageAnims.astro, idéntico al index. Aquí solo viven las
            // micro-historias que se auto-reproducen DENTRO del mockup (motion graphics):
            // cursor que negocia el precio, aprobación, timeline, timbrado, crédito.
            const wrap = document.querySelector('.pp-mockup-wrap');
            if (wrap) {
                // Editor Animation
                const editorTarget = document.getElementById('editorTargetRow');
                if (editorTarget) {
                    const cursor = document.getElementById('editorCursor');
                    const chip = document.getElementById('editorChip');
                    const price = document.getElementById('editorPrice');
                    const imp = document.getElementById('editorImport');
                    const total = document.getElementById('editorTotal');
                    
                    const tl = gsap.timeline({ repeat: -1, repeatDelay: 3 });
                    tl.set(cursor, { x: 300, y: 250, opacity: 0 })
                      .set(chip, { scale: 0, opacity: 0 })
                      .to(cursor, { opacity: 1, duration: 0.5 })
                      .to(cursor, { x: 280, y: 155, duration: 1, ease: 'power3.inOut' })
                      .to(cursor, { scale: 0.8, duration: 0.1, yoyo: true, repeat: 1 }) // click
                      .to(editorTarget, { backgroundColor: 'rgba(16,185,129,0.16)', duration: 0.3 })
                      .to(chip, { scale: 1, opacity: 1, duration: 0.4, ease: 'back.out(1.5)' })
                      .to(editorTarget, { backgroundColor: 'rgba(16,185,129,0.04)', duration: 0.3 })
                      .to(cursor, { x: 100, y: 350, opacity: 0, duration: 1, ease: 'power2.inOut' }, '+=0.5')
                      .to([price, imp, total], { color: '#34d399', duration: 0.2 }, '-=1')
                      .to([price, imp, total], { color: '', duration: 0.4 }, '-=0.5');
                }

                // Public Link Animation
                const pubWrap = document.getElementById('publicWrap');
                if (pubWrap) {
                    const btn = document.getElementById('publicApproveBtn');
                    const glow = document.getElementById('publicGlow');
                    const card = document.getElementById('publicCard');
                    const success = document.getElementById('publicSuccess');
                    const ring = document.querySelector('.mk-success-ring');
                    const check = document.querySelector('.mk-success-check');
                    
                    const tl = gsap.timeline({ repeat: -1, repeatDelay: 2 });
                    tl.to(glow, { opacity: 0.8, duration: 0.8, yoyo: true, repeat: 3 })
                      .to(btn, { scale: 0.95, duration: 0.1 }) // click
                      .to(btn, { scale: 1, duration: 0.1 })
                      .to(card, { scale: 0.95, opacity: 0, duration: 0.4, ease: 'power2.in' })
                      .to(success, { opacity: 1, duration: 0.3 })
                      .fromTo(ring, { scale: 0.5, opacity: 1 }, { scale: 1.5, opacity: 0, duration: 0.8, ease: 'power2.out' }, '<')
                      .fromTo(check, { scale: 0, rotation: -45 }, { scale: 1, rotation: 0, duration: 0.6, ease: 'back.out(2)' }, '<0.1')
                      .to(success, { opacity: 0, duration: 0.5 }, '+=2')
                      .to(card, { scale: 1, opacity: 1, duration: 0.5 }, '<');
                }

                // Seguimiento Animation (filas del timeline; el toast lo maneja el sistema de satélites)
                const trackItems = document.querySelectorAll('.track-item');
                if (trackItems.length) {
                    gsap.to(trackItems, {
                        opacity: 1, x: 0, duration: 0.7, stagger: 0.14, ease: 'power2.out', delay: 0.4,
                        scrollTrigger: { trigger: '.mk-track2', start: 'top 80%', once: true }
                    });
                }
                
                // CFDI Animation
                const cfdiStamp = document.getElementById('cfdiStamp');
                if (cfdiStamp) {
                    const check = cfdiStamp.querySelector('.mk-check');
                    const ring = cfdiStamp.querySelector('.mk-stamp-ring');
                    gsap.to(check, { 
                        scale: 1, duration: 0.6, ease: 'back.out(1.5)',
                        scrollTrigger: { trigger: '.mk-cfdi', start: 'top 80%', once: true }
                    });
                    gsap.fromTo(ring, { scale: 0.5, opacity: 1 }, { scale: 2, opacity: 0, duration: 1,
                        scrollTrigger: { trigger: '.mk-cfdi', start: 'top 80%', once: true }
                    });
                }
                
                // Clientes Animation
                const cliItems = document.querySelectorAll('.cli-item');
                if (cliItems.length) {
                    const bars = document.querySelectorAll('.mk-credit-bar i');
                    gsap.to(cliItems, {
                        opacity: 1, y: 0, duration: 0.6, stagger: 0.1, ease: 'power2.out',
                        scrollTrigger: { trigger: '.mk-cli', start: 'top 80%', once: true }
                    });
                    gsap.to(bars, {
                        scaleX: 1, duration: 1, stagger: 0.1, ease: 'power3.out', delay: 0.4,
                        scrollTrigger: { trigger: '.mk-cli', start: 'top 80%', once: true }
                    });
                }

                // Cobranza IA — chat LIBRE sobre el hero con "escribiendo…" real (loop)
                const arFree = document.getElementById('arFree');
                if (arFree) {
                    const steps = [...arFree.querySelectorAll('[data-cf]')];
                    const approve = document.getElementById('cfApprove');
                    const cuotas = arFree.querySelectorAll('.cf-cuota');
                    const makeTyping = (isOut) => {
                        const m = document.createElement('div');
                        m.className = 'cf-typing-msg ' + (isOut ? 'cf-out' : 'cf-in');
                        m.innerHTML = '<div class="cf-dots"><span></span><span></span><span></span></div>';
                        return m;
                    };
                    const reset = () => { gsap.set(steps, { opacity: 0, y: 16, scale: 0.96 }); gsap.set(cuotas, { opacity: 0, x: -8 }); arFree.querySelectorAll('.cf-typing-msg').forEach(n => n.remove()); };
                    reset();
                    ScrollTrigger.create({
                        trigger: arFree, start: 'top 80%', once: true,
                        onEnter: () => {
                            const tl = gsap.timeline({ delay: 0.4, repeat: -1, repeatDelay: 3.2 });
                            steps.forEach((s, i) => {
                                const isOut = s.classList.contains('cf-out');
                                const isPlan = s.classList.contains('cf-plan');
                                if (!isPlan) {
                                    // aparece "escribiendo…" en el lugar del mensaje, luego lo reemplaza la burbuja
                                    tl.call(() => {
                                        const t = makeTyping(isOut); s.parentNode.insertBefore(t, s); s._t = t;
                                        gsap.fromTo(t, { opacity: 0, scale: 0.8, y: 8 }, { opacity: 1, scale: 1, y: 0, duration: 0.3, ease: 'back.out(2)' });
                                    }, null, i === 0 ? '>' : '+=0.45');
                                    tl.to({}, { duration: 0.75 });
                                    tl.call(() => { if (s._t) { const t = s._t; gsap.to(t, { opacity: 0, scale: 0.8, duration: 0.2, onComplete: () => t.remove() }); } });
                                    tl.to(s, { opacity: 1, y: 0, scale: 1, duration: 0.45, ease: 'back.out(1.4)' }, '+=0.06');
                                } else {
                                    tl.to(s, { opacity: 1, y: 0, scale: 1, duration: 0.5, ease: 'back.out(1.3)' }, '+=0.5');
                                    tl.to(cuotas, { opacity: 1, x: 0, duration: 0.4, stagger: 0.12, ease: 'power2.out' }, '-=0.1');
                                    if (approve) tl.fromTo(approve, { boxShadow: '0 6px 16px -4px rgba(10,25,47,0.4), 0 0 0 0 rgba(10,25,47,0)' }, { boxShadow: '0 6px 16px -4px rgba(10,25,47,0.4), 0 0 0 6px rgba(10,25,47,0.12)', duration: 0.6, yoyo: true, repeat: 1, ease: 'sine.inOut' }, '+=0.15');
                                }
                            });
                            // cierre del loop: se desvanece y reinicia
                            tl.to(steps, { opacity: 0, y: 10, duration: 0.5, stagger: 0.04 }, '+=1.6');
                            tl.add(() => reset());
                        },
                    });
                }

                // Multi-divisa Animation (count-up de la tasa + pop del lock + flash del total MXN)
                const fxHero = document.getElementById('fxHero');
                if (fxHero) {
                    const rate = document.getElementById('fxRate');
                    const lock = document.getElementById('fxLock');
                    const mxn = document.getElementById('fxMxn');
                    gsap.set(lock, { opacity: 0, scale: 0.6 });
                    ScrollTrigger.create({
                        trigger: fxHero, start: 'top 78%', once: true,
                        onEnter: () => {
                            const obj = { v: 17.9 };
                            gsap.timeline({ delay: 0.5 })
                                .to(obj, { v: 18.50, duration: 1, ease: 'power2.out', onUpdate: () => { if (rate) rate.textContent = '$' + obj.v.toFixed(2) + ' MXN'; } })
                                .to(lock, { opacity: 1, scale: 1, duration: 0.45, ease: 'back.out(1.6)' }, '-=0.25')
                                .fromTo(mxn, { backgroundColor: 'rgba(16,185,129,0.18)' }, { backgroundColor: '#f8fafc', duration: 1.1, ease: 'power2.out' }, '-=0.1');
                        },
                    });
                }

                // Facturación internacional Animation (pill "Tasa blindada" + flash del total fiscal)
                const intlHero = document.getElementById('intlHero');
                if (intlHero) {
                    const fiscal = document.getElementById('intlFiscal');
                    const pill = document.getElementById('intlPill');
                    gsap.set(pill, { opacity: 0, scale: 0.6, y: -6 });
                    ScrollTrigger.create({
                        trigger: intlHero, start: 'top 78%', once: true,
                        onEnter: () => {
                            gsap.timeline({ delay: 0.5 })
                                .to(pill, { opacity: 1, scale: 1, y: 0, duration: 0.5, ease: 'back.out(1.6)' })
                                .fromTo(fiscal, { backgroundColor: 'rgba(16,185,129,0.2)' }, { backgroundColor: '#f8fafc', duration: 1.1, ease: 'power2.out' }, '-=0.1');
                        },
                    });
                }

                // Finanzas / CFO — count-up KPIs + barras que crecen + insight + pulso del pico
                const finHero = document.getElementById('finHero');
                if (finHero) {
                    const bars = finHero.querySelectorAll('.mk-fin-bar i');
                    const insight = document.getElementById('finInsight');
                    const k1 = document.getElementById('finK1');
                    const k2 = document.getElementById('finK2');
                    const hot = finHero.querySelector('.mk-fin-bar-hot i');
                    gsap.set(insight, { opacity: 0, y: 10 });
                    const countTo = (el, to) => { const o = { v: 0 }; return gsap.to(o, { v: to, duration: 1.1, ease: 'power2.out', onUpdate: () => { if (el) el.textContent = '$' + o.v.toFixed(2) + 'M'; } }); };
                    ScrollTrigger.create({
                        trigger: finHero, start: 'top 78%', once: true,
                        onEnter: () => {
                            const tl = gsap.timeline({ delay: 0.35 });
                            tl.to(bars, { scaleY: 1, duration: 0.85, stagger: 0.09, ease: 'power3.out' })
                              .add(countTo(k1, parseFloat(k1.dataset.to)), '<')
                              .add(countTo(k2, parseFloat(k2.dataset.to)), '<0.15')
                              .to(insight, { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '-=0.3');
                            if (hot) gsap.to(hot, { filter: 'brightness(1.12)', duration: 1.1, yoyo: true, repeat: -1, ease: 'sine.inOut', delay: 1.4 });
                        },
                    });
                }

                // Aprobaciones — el gauge llena a 18% (zona roja bajo el mínimo), alerta entra, botón pulsa
                const aprHero = document.getElementById('aprHero');
                if (aprHero) {
                    const fill = document.getElementById('aprFill');
                    const alert = document.getElementById('aprAlert');
                    const btn = document.getElementById('aprBtn');
                    const margin = document.getElementById('aprMargin');
                    gsap.set(alert, { opacity: 0, y: 8 });
                    gsap.set(margin, { scale: 0.6, opacity: 0 });
                    ScrollTrigger.create({
                        trigger: aprHero, start: 'top 78%', once: true,
                        onEnter: () => {
                            gsap.timeline({ delay: 0.4 })
                                .to(fill, { width: '18%', duration: 0.9, ease: 'power3.out' })
                                .to(margin, { scale: 1, opacity: 1, duration: 0.4, ease: 'back.out(1.6)' }, '-=0.4')
                                .to(alert, { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.15')
                                .fromTo(btn, { boxShadow: '0 0 0 0 rgba(15,23,42,0)' }, { boxShadow: '0 0 0 5px rgba(15,23,42,0.12)', duration: 0.7, yoyo: true, repeat: 3, ease: 'sine.inOut' }, '+=0.2');
                        },
                    });
                }

                // Equipo — filas entran en cascada + el botón invitar pulsa
                const teamHero = document.getElementById('teamHero');
                if (teamHero) {
                    const rows = teamHero.querySelectorAll('.team-item');
                    const invite = document.getElementById('teamInvite');
                    gsap.set(rows, { opacity: 0, x: -14 });
                    gsap.set(invite, { opacity: 0, y: 8 });
                    ScrollTrigger.create({
                        trigger: teamHero, start: 'top 78%', once: true,
                        onEnter: () => {
                            gsap.timeline({ delay: 0.35 })
                                .to(rows, { opacity: 1, x: 0, duration: 0.6, stagger: 0.11, ease: 'power2.out' })
                                .to(invite, { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.2');
                        },
                    });
                }

                // Presupuestos — count-up de los datos reales + pop de las pills vs. plan
                // (gated por reduced: sin animación, las pills quedan visibles en su estado final)
                const presuHero = document.getElementById('presuHero');
                if (presuHero && !reduced) {
                    const reals = presuHero.querySelectorAll('[data-presu-real]');
                    const pills = presuHero.querySelectorAll('.mk-presu-real');
                    const fmt = (n) => '$' + Math.round(n).toLocaleString('es-MX');
                    gsap.set(pills, { opacity: 0, y: 6, scale: 0.82 });
                    ScrollTrigger.create({
                        trigger: presuHero, start: 'top 78%', once: true,
                        onEnter: () => {
                            const tl = gsap.timeline({ delay: 0.4 });
                            pills.forEach((pill, i) => {
                                const real = reals[i];
                                const to = parseFloat(real.dataset.to);
                                const o = { v: 0 };
                                tl.to(pill, { opacity: 1, y: 0, scale: 1, duration: 0.5, ease: 'back.out(1.6)' }, i * 0.16)
                                  .to(o, { v: to, duration: 0.7, ease: 'power2.out', onUpdate: () => { real.textContent = fmt(o.v); } }, '<0.05');
                            });
                        },
                    });
                }

                // ── Ambient float sutil para TODOS los mockups del hero (toque Linear, sobrio) ──
                const heroMock = wrap.querySelector('.pp-mockup > *');
                if (heroMock) {
                    gsap.to(heroMock, { y: '-=7', duration: 4.6, ease: 'sine.inOut', yoyo: true, repeat: -1 });
                }

                // ── Burbujas de chat flotantes (link público): entrada + float suave ──
                const bubs = wrap.querySelectorAll('.pp-bub');
                if (bubs.length) {
                    gsap.set(bubs, { opacity: 0, y: 14, scale: 0.92 });
                    ScrollTrigger.create({
                        trigger: wrap, start: 'top 82%', once: true,
                        onEnter: () => {
                            gsap.to(bubs, { opacity: 1, y: 0, scale: 1, duration: 0.7, stagger: 0.2, ease: 'back.out(1.4)', delay: 0.5,
                                onComplete: () => {
                                    wrap.querySelectorAll('.pp-bub-in').forEach((el) => gsap.to(el, { y: '-=8', duration: 3.8, ease: 'sine.inOut', yoyo: true, repeat: -1 }));
                                    wrap.querySelectorAll('.pp-bub-out').forEach((el) => gsap.to(el, { y: '+=8', duration: 4.4, ease: 'sine.inOut', yoyo: true, repeat: -1 }));
                                },
                            });
                        },
                    });
                }
                // pulso del punto "Viendo ahora" (seguimiento)
                const liveDot = document.getElementById('satTrDot');
                if (liveDot) gsap.to(liveDot, { boxShadow: '0 0 0 6px rgba(16,185,129,0)', duration: 1.4, repeat: -1, ease: 'power1.out' });
            }

            // ───────────────────────── BLOCK MOCKUPS GSAP ─────────────────────────
            // Editor M0 (Discount Row & Cursor)
            const bEditor0 = document.querySelector('.bm-editor-m0');
            if (bEditor0) {
                const cursor = bEditor0.querySelector('.bm-fake-cursor');
                const row = bEditor0.querySelector('.bm-row-target');
                const chip = bEditor0.querySelector('.mk-chip');
                const price = bEditor0.querySelector('.price-val');
                const obj = { val: 191.48 };

                if (cursor && row && chip && price) {
                    ScrollTrigger.create({
                        trigger: bEditor0, start: 'top 85%',
                        onEnter: () => {
                            const tl = gsap.timeline({ repeat: -1, repeatDelay: 2.2 });
                            tl.set(cursor, { x: 210, y: 230, opacity: 0 })
                              .set(chip, { opacity: 0, scale: 0.5 })
                              .to(cursor, { opacity: 1, duration: 0.4 })
                              .to(cursor, { x: 330, y: 118, duration: 1, ease: 'power3.inOut' })
                              .to(cursor, { scale: 0.85, duration: 0.1, yoyo: true, repeat: 1 })
                              .to(row, { backgroundColor: 'rgba(16,185,129,0.12)', duration: 0.3 })
                              .to(chip, { opacity: 1, scale: 1, duration: 0.4, ease: 'back.out(1.5)' })
                              .to(row, { backgroundColor: 'transparent', duration: 0.3 })
                              .to(obj, { val: 168.50, duration: 0.8, onUpdate: () => price.textContent = `$${obj.val.toFixed(2)}` }, '-=0.3')
                              .to(cursor, { opacity: 0, y: '+=30', duration: 0.5 });
                        }
                    });
                }
            }

            // Editor M1 (catálogo — filas en cascada + caret que teclea)
            const bEditor1 = document.querySelector('.bm-editor-m1');
            if (bEditor1) {
                const rows = bEditor1.querySelectorAll('.cat-r');
                const caret = bEditor1.querySelector('.bm-search-caret');
                if (caret) gsap.to(caret, { opacity: 0, duration: 0.5, repeat: -1, yoyo: true, ease: 'steps(1)' });
                if (rows.length) {
                    ScrollTrigger.create({
                        trigger: bEditor1, start: 'top 85%', once: true,
                        onEnter: () => gsap.fromTo(rows, { opacity: 0, x: -10 }, { opacity: 1, x: 0, stagger: 0.1, duration: 0.55, ease: 'power2.out', delay: 0.3 }),
                    });
                }
            }

            // Editor M2 (resumen — filas de totales en cascada)
            const bEditor2 = document.querySelector('.bm-editor-m2');
            if (bEditor2) {
                const rows = bEditor2.querySelectorAll('.bm-stag-row');
                if (rows.length) {
                    ScrollTrigger.create({
                        trigger: bEditor2, start: 'top 85%', once: true,
                        onEnter: () => gsap.fromTo(rows, { opacity: 0, x: -10 }, { opacity: 1, x: 0, stagger: 0.14, duration: 0.6, ease: 'power2.out', delay: 0.3 }),
                    });
                }
            }

            // ── Ventanas completas del bento (bm-app): cascada de filas al entrar ──
            document.querySelectorAll('.pp-bcard-visual .bm-app').forEach((app) => {
                const stage = app.closest('.bm-stage');
                if (stage && /bm-editor-m/.test(stage.className || '')) return; // editor tiene su propia animación
                const rows = app.querySelectorAll('.bm-kv, .bm-step, .bm-cc-b, .bm-stat, .bm-tot-r, .bm-g:not(.bm-g-head)');
                if (!rows.length) return;
                gsap.set(rows, { opacity: 0, y: 10 });
                ScrollTrigger.create({
                    trigger: app, start: 'top 88%', once: true,
                    onEnter: () => gsap.to(rows, { opacity: 1, y: 0, duration: 0.5, stagger: 0.07, ease: 'power2.out', delay: 0.2, clearProps: 'transform' }),
                });
                const approve = app.querySelector('.bm-lp-approve');
                if (approve) gsap.to(approve, { boxShadow: '0 6px 16px -4px rgba(10,25,47,0.4), 0 0 0 5px rgba(10,25,47,0.12)', duration: 1, repeat: -1, yoyo: true, ease: 'sine.inOut' });
            });

        }
    });
</script>
