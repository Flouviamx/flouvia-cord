</style>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    // FAQ: acordeón (un solo abierto a la vez)
    document.addEventListener('DOMContentLoaded', () => {
        const items = Array.from(document.querySelectorAll<HTMLElement>('.pp-faq-item'));
        items.forEach((item) => {
            const btn = item.querySelector<HTMLButtonElement>('.pp-faq-q');
            if (!btn) return;
            btn.addEventListener('click', () => {
                const willOpen = !item.classList.contains('open');
                items.forEach((other) => {
                    other.classList.remove('open');
                    other.querySelector('.pp-faq-q')?.setAttribute('aria-expanded', 'false');
                });
                if (willOpen) {
                    item.classList.add('open');
                    btn.setAttribute('aria-expanded', 'true');
                }
            });
        });

        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (!reduced) {
            // Elegant 3D Entrance Animation for BlockMockups
            const blocks = document.querySelectorAll('.pp-block-visual');
            blocks.forEach((block) => {
                const stage = block.querySelector('.bm-stage');
                if (!stage) return;
                
                const internals = block.querySelectorAll('.bm-card, .bm-floating, .bm-search, .bm-timeline, .bm-board-col, .bm-stage > div');
                const glow = block.querySelector('.bm-glow');

                gsap.set(stage, { perspective: 1200 });
                gsap.set(internals, { y: 60, z: -80, rotationX: -10, opacity: 0, scale: 0.95 });
                if (glow) gsap.set(glow, { opacity: 0, scale: 0.5 });
                
                ScrollTrigger.create({
                    trigger: block,
                    start: 'top 85%',
                    once: true,
                    onEnter: () => {
                        gsap.to(internals, { 
                            y: 0, z: 0, rotationX: 0, opacity: 1, scale: 1, 
                            duration: 1.2, ease: 'power3.out', stagger: 0.08, clearProps: 'transform' 
                        });
                        if (glow) {
                            gsap.to(glow, { opacity: 1, scale: 1, duration: 2, ease: 'power3.out' });
                        }
                    }
                });
            });
            
            // ───────────────────────── HERO MOCKUP GSAP ─────────────────────────
            const wrap = document.querySelector('.pp-mockup-wrap');
            if (wrap) {
                // Parallax 3D settle + EXPLODED VIEW on scroll (Nivel Dios)
                gsap.set('.pp-mockup', { transformPerspective: 1600, transformStyle: 'preserve-3d', transformOrigin: 'center center' });
                
                // Set initial exploded state (floating layers)
                const floatingElements = wrap.querySelectorAll('.mk-public-card, .mk-window, .mk-toast, .mk-badge, .mk-approve, .mk-cfdi-front, .mk-tl');
                gsap.set(floatingElements, { z: 80, rotationX: 10, rotationY: -10, opacity: 0 });
                gsap.set('.pp-mockup', { rotationX: 25, rotationY: -15, scale: 0.9 });
                
                // Re-assemble (un-explode) on scroll scrub
                const assembleTl = gsap.timeline({
                    scrollTrigger: { trigger: wrap, start: 'top 95%', end: 'top 30%', scrub: 1 }
                });
                
                assembleTl.to('.pp-mockup', { rotationX: 0, rotationY: 0, scale: 1, ease: 'power2.out' }, 0);
                assembleTl.to(floatingElements, { z: 0, rotationX: 0, rotationY: 0, opacity: 1, stagger: 0.05, ease: 'back.out(1.2)' }, 0);
                
                // Particle emitter on mousemove over wrap
                wrap.addEventListener('mousemove', (e: Event) => {
                    const evt = e as MouseEvent;
                    const dot = document.createElement('div');
                    dot.className = 'mk-particle';
                    dot.style.left = evt.clientX + 'px';
                    dot.style.top = evt.clientY + 'px';
                    document.body.appendChild(dot);
                    gsap.to(dot, { y: -50, x: (Math.random()-0.5)*50, opacity: 0, scale: 0, duration: 1+Math.random(), onComplete: () => dot.remove() });
                });

                // Editor Animation
                const editorTarget = document.getElementById('editorTargetRow');
                if (editorTarget) {
                    const cursor = document.getElementById('editorCursor');
                    const chip = document.getElementById('editorChip');
                    const price = document.getElementById('editorPrice');
                    const imp = document.getElementById('editorImport');
                    const total = document.getElementById('editorTotal');
                    
                    const tl = gsap.timeline({ repeat: -1, repeatDelay: 3 });
                    tl.set(cursor, { x: 300, y: 250, opacity: 0 })
                      .set(chip, { scale: 0, opacity: 0 })
                      .to(cursor, { opacity: 1, duration: 0.5 })
                      .to(cursor, { x: 280, y: 155, duration: 1, ease: 'power3.inOut' })
                      .to(cursor, { scale: 0.8, duration: 0.1, yoyo: true, repeat: 1 }) // click
                      .to(editorTarget, { backgroundColor: 'rgba(16,185,129,0.16)', duration: 0.3 })
                      .to(chip, { scale: 1, opacity: 1, duration: 0.4, ease: 'back.out(1.5)' })
                      .to(editorTarget, { backgroundColor: 'rgba(16,185,129,0.04)', duration: 0.3 })
                      .to(cursor, { x: 100, y: 350, opacity: 0, duration: 1, ease: 'power2.inOut' }, '+=0.5')
                      .to([price, imp, total], { color: '#34d399', duration: 0.2 }, '-=1')
                      .to([price, imp, total], { color: '', duration: 0.4 }, '-=0.5');
                }

                // Public Link Animation
                const pubWrap = document.getElementById('publicWrap');
                if (pubWrap) {
                    const btn = document.getElementById('publicApproveBtn');
                    const glow = document.getElementById('publicGlow');
                    const card = document.getElementById('publicCard');
                    const success = document.getElementById('publicSuccess');
                    const ring = document.querySelector('.mk-success-ring');
                    const check = document.querySelector('.mk-success-check');
                    
                    const tl = gsap.timeline({ repeat: -1, repeatDelay: 2 });
                    tl.to(glow, { opacity: 0.8, duration: 0.8, yoyo: true, repeat: 3 })
                      .to(btn, { scale: 0.95, duration: 0.1 }) // click
                      .to(btn, { scale: 1, duration: 0.1 })
                      .to(card, { scale: 0.95, opacity: 0, duration: 0.4, ease: 'power2.in' })
                      .to(success, { opacity: 1, duration: 0.3 })
                      .fromTo(ring, { scale: 0.5, opacity: 1 }, { scale: 1.5, opacity: 0, duration: 0.8, ease: 'power2.out' }, '<')
                      .fromTo(check, { scale: 0, rotation: -45 }, { scale: 1, rotation: 0, duration: 0.6, ease: 'back.out(2)' }, '<0.1')
                      .to(success, { opacity: 0, duration: 0.5 }, '+=2')
                      .to(card, { scale: 1, opacity: 1, duration: 0.5 }, '<');
                }

                // Seguimiento Animation
                const trackItems = document.querySelectorAll('.track-item');
                if (trackItems.length) {
                    const toast = document.getElementById('trackToast');
                    gsap.to(trackItems, { 
                        opacity: 1, x: 0, duration: 0.8, stagger: 0.15, ease: 'power2.out',
                        scrollTrigger: { trigger: '.mk-track', start: 'top 80%', once: true }
                    });
                    gsap.to(toast, { 
                        opacity: 1, y: 0, duration: 0.6, ease: 'back.out(1.2)', delay: 0.8,
                        scrollTrigger: { trigger: '.mk-track', start: 'top 80%', once: true }
                    });
                }
                
                // CFDI Animation
                const cfdiStamp = document.getElementById('cfdiStamp');
                if (cfdiStamp) {
                    const check = cfdiStamp.querySelector('.mk-check');
                    const ring = cfdiStamp.querySelector('.mk-stamp-ring');
                    gsap.to(check, { 
                        scale: 1, duration: 0.6, ease: 'back.out(1.5)',
                        scrollTrigger: { trigger: '.mk-cfdi', start: 'top 80%', once: true }
                    });
                    gsap.fromTo(ring, { scale: 0.5, opacity: 1 }, { scale: 2, opacity: 0, duration: 1,
                        scrollTrigger: { trigger: '.mk-cfdi', start: 'top 80%', once: true }
                    });
                }
                
                // Clientes Animation
                const cliItems = document.querySelectorAll('.cli-item');
                if (cliItems.length) {
                    const bars = document.querySelectorAll('.mk-credit-bar i');
                    gsap.to(cliItems, {
                        opacity: 1, y: 0, duration: 0.6, stagger: 0.1, ease: 'power2.out',
                        scrollTrigger: { trigger: '.mk-cli', start: 'top 80%', once: true }
                    });
                    gsap.to(bars, {
                        scaleX: 1, duration: 1, stagger: 0.1, ease: 'power3.out', delay: 0.4,
                        scrollTrigger: { trigger: '.mk-cli', start: 'top 80%', once: true }
                    });
                }
            }

            // ───────────────────────── BLOCK MOCKUPS GSAP ─────────────────────────
            // Editor M0 (Discount Row & Cursor)
            const bEditor0 = document.querySelector('.bm-editor-m0');
            if (bEditor0) {
                const cursor = bEditor0.querySelector('.bm-fake-cursor');
                const row = bEditor0.querySelector('.bm-row-target');
                const chip = bEditor0.querySelector('.mk-chip');
                const price = bEditor0.querySelector('.price-val');
                const obj = { val: 191.48 };

                ScrollTrigger.create({
                    trigger: bEditor0, start: 'top 85%',
                    onEnter: () => {
                        const tl = gsap.timeline({ repeat: -1, repeatDelay: 2 });
                        tl.set(cursor, { x: 120, y: 150, opacity: 0 })
                          .set(chip, { opacity: 0, scale: 0.5 })
                          .to(cursor, { opacity: 1, duration: 0.4 })
                          .to(cursor, { x: 190, y: 40, duration: 1, ease: 'power3.inOut' })
                          .to(cursor, { scale: 0.85, duration: 0.1, yoyo: true, repeat: 1 })
                          .to(row, { backgroundColor: 'rgba(16,185,129,0.15)', duration: 0.3 })
                          .to(chip, { opacity: 1, scale: 1, duration: 0.4, ease: 'back.out(1.5)' })
                          .to(row, { backgroundColor: 'rgba(255,255,255,0.02)', duration: 0.3 })
                          .to(obj, { val: 168.50, duration: 0.8, onUpdate: () => price.textContent = `$${obj.val.toFixed(2)}` }, '-=0.3')
                          .to(cursor, { opacity: 0, y: '+=30', duration: 0.5 });
                    }
                });
                
                // 3D Tilt Effect on mousemove (Nivel Dios)
                bEditor0.addEventListener('mousemove', (e: Event) => {
                    const evt = e as MouseEvent;
                    const rect = bEditor0.getBoundingClientRect();
                    const x = (evt.clientX - rect.left) / rect.width - 0.5;
                    const y = (evt.clientY - rect.top) / rect.height - 0.5;
                    gsap.to(bEditor0.querySelector('.bm-card'), {
                        rotationY: x * 20, rotationX: -y * 20,
                        transformPerspective: 1000, ease: 'power1.out', duration: 0.5
                    });
                });
                bEditor0.addEventListener('mouseleave', () => {
                    gsap.to(bEditor0.querySelector('.bm-card'), { rotationY: 0, rotationX: 0, ease: 'power3.out', duration: 0.8 });
                });
            }

            // Editor M1 (Margin Bar)
            const bEditor1 = document.querySelector('.bm-editor-m1');
            if (bEditor1) {
                const fill = bEditor1.querySelector('.bm-margin-bar-fill');
                gsap.to(fill, {
                    width: '85%', ease: 'none',
                    scrollTrigger: { trigger: bEditor1, start: 'top 95%', end: 'top 40%', scrub: 1 }
                });
            }

            // Editor M2 (Staggered Taxes)
            const bEditor2 = document.querySelector('.bm-editor-m2');
            if (bEditor2) {
                const rows = bEditor2.querySelectorAll('.bm-stag-row');
                const stamp = bEditor2.querySelector('.bm-stamp-hide');
                ScrollTrigger.create({
                    trigger: bEditor2, start: 'top 85%', once: true,
                    onEnter: () => {
                        gsap.fromTo(rows, { opacity: 0, x: -10 }, { opacity: 1, x: 0, stagger: 0.15, duration: 0.6, ease: 'power2.out', delay: 0.3 });
                        gsap.fromTo(stamp, { opacity: 0, scale: 0 }, { opacity: 1, scale: 1, duration: 0.5, ease: 'back.out(1.5)', delay: 1 });
                    }
                });
            }

            // Public M0 (Chat)
            const bPub0 = document.querySelector('.bm-public-m0');
            if (bPub0) {
                const typing = bPub0.querySelector('.bm-msg-typing');
                const outMsg = bPub0.querySelector('.bm-msg-out');
                ScrollTrigger.create({
                    trigger: bPub0, start: 'top 85%',
                    onEnter: () => {
                        const tl = gsap.timeline({ repeat: -1, repeatDelay: 3 });
                        tl.set(outMsg, { display: 'none', opacity: 0, y: 10 })
                          .set(typing, { display: 'block', opacity: 0 })
                          .to(typing, { opacity: 1, duration: 0.3, delay: 0.5 })
                          .to(typing, { opacity: 0, duration: 0.3 }, '+=1.5')
                          .set(typing, { display: 'none' })
                          .set(outMsg, { display: 'block' })
                          .to(outMsg, { opacity: 1, y: 0, duration: 0.4, ease: 'back.out(1.2)' });
                    }
                });
            }

            // Public M1 (Branding Colors Scrub)
            const bPub1 = document.querySelector('.bm-public-m1');
            if (bPub1) {
                const card = bPub1.querySelector('.bm-brand-card');
                const logoPill = bPub1.querySelector('.bm-logo-pill');
                
                const tl = gsap.timeline({
                    scrollTrigger: { trigger: bPub1, start: 'top 95%', end: 'top 30%', scrub: 1 }
                });
                tl.to(card, { borderColor: '#10b981', boxShadow: '0 0 30px rgba(16,185,129,0.2)', ease: 'none' }, 0)
                  .to(logoPill, { background: '#10b981', ease: 'none' }, 0);
            }

            // Public M2 (Push Notif)
            const bPub2 = document.querySelector('.bm-public-m2');
            if (bPub2) {
                const push = bPub2.querySelector('.bm-push-notif');
                ScrollTrigger.create({
                    trigger: bPub2, start: 'top 85%',
                    onEnter: () => {
                        const tl = gsap.timeline({ repeat: -1, repeatDelay: 3 });
                        tl.set(push, { opacity: 0, y: -20, scale: 0.95 })
                          .to(push, { opacity: 1, y: 0, scale: 1, duration: 0.5, ease: 'back.out(1.5)' })
                          .to(push, { x: -3, duration: 0.05, yoyo: true, repeat: 3 }, '+=0.2') // vibrate
                          .to(push, { opacity: 0, y: -10, duration: 0.4 }, '+=2.5');
                    }
                });
            }

            // Seguimiento M0 (Timeline Fill)
            const bTrack0 = document.querySelector('.bm-track-m0');
            if (bTrack0) {
                const fill = bTrack0.querySelector('.bm-tl-fill');
                const node = bTrack0.querySelector('.bm-node-pending');
                ScrollTrigger.create({
                    trigger: bTrack0, start: 'top 85%', once: true,
                    onEnter: () => {
                        gsap.to(fill, { height: '80%', duration: 2, ease: 'power2.inOut', delay: 0.5 });
                        gsap.to(node, { opacity: 1, duration: 0.5, delay: 2.2 });
                    }
                });
            }

            // Seguimiento M1 (Kanban Drag SCRUB)
            const bTrack1 = document.querySelector('.bm-track-m1');
            if (bTrack1) {
                const card = bTrack1.querySelector('.bm-kanban-drag');
                const drop = bTrack1.querySelector('.bm-kanban-drop');
                
                const tl = gsap.timeline({
                    scrollTrigger: { trigger: bTrack1, start: 'top 95%', end: 'top 20%', scrub: 1 }
                });
                
                tl.to(card, { rotation: 5, scale: 1.05, boxShadow: '0 20px 40px rgba(0,0,0,0.5)', duration: 0.1 })
                  .to(drop, { opacity: 1, duration: 0.1 }, '<')
                  .to(card, { x: 120, y: 70, duration: 0.8, ease: 'none' })
                  .to(card, { rotation: 0, scale: 1, boxShadow: 'none', duration: 0.1 })
                  .to(drop, { opacity: 0, duration: 0.1 }, '<');
            }

            // Seguimiento M2 (Search)
            const bTrack2 = document.querySelector('.bm-track-m2');
            if (bTrack2) {
                const type = bTrack2.querySelector('.bm-search-type');
                const res1 = bTrack2.querySelector('.bm-s-res-1');
                const res2 = bTrack2.querySelector('.bm-s-res-2');
                ScrollTrigger.create({
                    trigger: bTrack2, start: 'top 85%',
                    onEnter: () => {
                        const tl = gsap.timeline({ repeat: -1, repeatDelay: 2 });
                        const text = 'varilla';
                        let curr = '';
                        tl.set([res1, res2], { opacity: 0, y: 10 });
                        
                        text.split('').forEach(char => {
                            tl.add(() => { curr += char; type.textContent = curr + '_'; }, '+=0.1');
                        });
                        tl.add(() => type.textContent = curr, '+=0.2')
                          .to([res1, res2], { opacity: 1, y: 0, duration: 0.4, stagger: 0.1 }, '+=0.2')
                          .to(type, { opacity: 0, duration: 0.1 }, '+=1.5')
                          .add(() => type.textContent = '_')
                          .to(type, { opacity: 1, duration: 0.1 });
                    }
                });
            }

            // CFDI M0 (XML Matrix Scramble)
            const bCfdi0 = document.querySelector('.bm-cfdi-m0');
            if (bCfdi0) {
                const matrix = bCfdi0.querySelector('.bm-matrix-text');
                const orig = matrix.innerHTML;
                const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&*';
                ScrollTrigger.create({
                    trigger: bCfdi0, start: 'top 85%', once: true,
                    onEnter: () => {
                        let iters = 0;
                        const interval = setInterval(() => {
                            matrix.innerHTML = orig.split('').map(c => {
                                if (c === '<' || c === '>' || c === ' ' || c === '\\n') return c;
                                return Math.random() > 0.5 ? chars[Math.floor(Math.random() * chars.length)] : c;
                            }).join('');
                            iters++;
                            if (iters > 15) { clearInterval(interval); matrix.innerHTML = orig; gsap.to(matrix, { opacity: 0.2, duration: 1 }); }
                        }, 50);
                    }
                });
            }

            // CFDI M1 (Terminal SCRUB)
            const bCfdi1 = document.querySelector('.bm-cfdi-m1');
            if (bCfdi1) {
                const lines = bCfdi1.querySelectorAll('.bm-term-line');
                const stamp = bCfdi1.querySelector('.bm-cert-stamp');
                
                const tl = gsap.timeline({
                    scrollTrigger: { trigger: bCfdi1, start: 'top 95%', end: 'top 40%', scrub: 1 }
                });
                
                gsap.set(stamp, { opacity: 0, scale: 0 });
                lines.forEach((l, i) => {
                    tl.to(l, { opacity: 1, duration: 0.1 }, i * 0.1);
                });
                tl.to(stamp, { opacity: 1, scale: 1, duration: 0.5, ease: 'back.out(1.5)' });
            }

            // CFDI M2 (Laser Barcode)
            const bCfdi2 = document.querySelector('.bm-cfdi-m2');
            if (bCfdi2) {
                const laser = bCfdi2.querySelector('.bm-laser');
                ScrollTrigger.create({
                    trigger: bCfdi2, start: 'top 85%',
                    onEnter: () => {
                        gsap.to(laser, { opacity: 1, duration: 0.2, repeat: -1, repeatDelay: 2, yoyo: true });
                        gsap.to(laser, { top: '100%', duration: 1, repeat: -1, repeatDelay: 1.2, ease: 'none' });
                    }
                });
            }

            // Credit M0 (Progress Bar SCRUB)
            const bCred0 = document.querySelector('.bm-credit-m0');
            if (bCred0) {
                const fill = bCred0.querySelector('.bm-credit-fill');
                const val = bCred0.querySelector('.bm-credit-val');
                const req = bCred0.querySelector('.bm-req-appr');
                const obj = { v: 0 };
                
                const tl = gsap.timeline({
                    scrollTrigger: { trigger: bCred0, start: 'top 95%', end: 'top 30%', scrub: 1 }
                });
                
                gsap.set(req, { opacity: 0, scale: 0 });
                tl.to(fill, { width: '85%', duration: 2, ease: 'none' }, 0)
                  .to(obj, { v: 425, duration: 2, ease: 'none', onUpdate: () => val.textContent = Math.round(obj.v).toString() }, 0)
                  .to(fill, { backgroundColor: '#f59e0b', duration: 0.5 }, 1.5)
                  .to(req, { opacity: 1, scale: 1, duration: 0.5, ease: 'back.out(1.5)' }, 1.8);
            }

            // Credit M1 (SPEI Payment)
            const bCred1 = document.querySelector('.bm-credit-m1');
            if (bCred1) {
                const status = bCred1.querySelector('.bm-spei-status');
                const toast = bCred1.querySelector('.bm-spei-toast');
                ScrollTrigger.create({
                    trigger: bCred1, start: 'top 85%',
                    onEnter: () => {
                        const tl = gsap.timeline({ repeat: -1, repeatDelay: 3 });
                        tl.set(toast, { opacity: 0, y: 10 })
                          .to(status, { opacity: 0.4, duration: 0.4, yoyo: true, repeat: 3 })
                          .to(toast, { opacity: 1, y: 0, duration: 0.5, ease: 'back.out(1.5)' })
                          .to(status, { color: '#34d399', onStart: () => status.textContent = 'Pagado' }, '<')
                          .to(toast, { opacity: 0, duration: 0.4 }, '+=2')
                          .set(status, { clearProps: 'all', textContent: 'Pendiente' });
                    }
                });
            }

            // Credit M2 (Bar Chart SCRUB)
            const bCred2 = document.querySelector('.bm-credit-m2');
            if (bCred2) {
                const cols = bCred2.querySelectorAll('.bm-chart-col-fill');
                const heights = ['40%', '70%', '50%', '90%', '60%'];
                
                const tl = gsap.timeline({
                    scrollTrigger: { trigger: bCred2, start: 'top 95%', end: 'top 30%', scrub: 1 }
                });
                
                cols.forEach((c, i) => {
                    tl.to(c, { height: heights[i], duration: 1, ease: 'none' }, i * 0.1);
                });
            }
        }
    });
</script>
