---
// Página de producto — una por feature (estilo Stripe: hero + mockup que vende,
// stats, bloques de detalle alternados, cross-links y CTA). Mismo lenguaje de
// animación que el index via PageAnims.astro.
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import PageAnims from '../../components/landing/PageAnims.astro';
import BlockMockup from '../../components/producto/BlockMockup.astro';
import ProductAccordion from '../../components/producto/ProductAccordion.jsx';
import FeatureShowcase from '../../components/producto/FeatureShowcase.astro';
import FaqAccordion from '../../components/landing/FaqAccordion.astro';
import { FEATURES } from '../../lib/producto';
import { FEATURES_EN } from '../../lib/producto.en';
import { getLangFromUrl } from '../../i18n/utils';

export function getStaticPaths() {
    return FEATURES.map((f) => ({ params: { slug: f.slug }, props: { feature: f } }));
}

const lang = getLangFromUrl(Astro.url);
const isEn = Astro.props.isEn || lang === 'en';
const currentFeature = Astro.props.feature || Astro.props.feature;
const feature = isEn && currentFeature ? FEATURES_EN.find((f) => f.slug === currentFeature.slug) || currentFeature : currentFeature;
const otros = (isEn ? FEATURES_EN : FEATURES).filter((f) => f.slug !== feature.slug);
const tituloPlano = feature.titulo.replace(/<br\s*\/?>/gi, ' ');

// ── Datos estructurados (JSON-LD) — FAQPage: lo que extraen los AI Overviews.
const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: feature.faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
};

// BreadcrumbList (jul 2026, auditoría SEO/AI-SEO — mismo criterio que /index
// y /precios): antes estas 12 páginas no tenían ninguna señal de jerarquía;
// esto le dice a Google/IA "esta es una feature DENTRO del producto Cord",
// ayuda a Google a mostrar el breadcrumb en el resultado de búsqueda y
// refuerza (junto con el metaTitle sin "by Flouvia") que Cord es el
// producto, no una sub-página de Flouvia.
const SITE = 'https://cordhq.app';
const base = isEn ? `${SITE}/en` : SITE;
// Solo 2 niveles: no existe un índice real de /producto que enlazar (mismo
// caso que /soluciones — ver docs/app-rutas.md), y un ListItem con URL
// duplicada no cumple las guías de datos estructurados de Google.
const breadcrumbSchema = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Cord', item: `${base}/` },
        { '@type': 'ListItem', position: 2, name: feature.nav, item: `${base}/producto/${feature.slug}` },
    ],
};
---

<Layout
    title={feature.metaTitle ?? `${feature.nav} — Cord`}
    description={feature.metaDescription ?? feature.sub}
>
    <script
        slot="head"
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify(faqSchema)}
    />
    <script
        slot="head"
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify(breadcrumbSchema)}
    />
    <Nav />
    <main>
        <!-- ── HERO ── -->
        <section class="pp-hero">
            <div class="pp-hero-mesh" aria-hidden="true"></div>
            <div class="pp-hero-inner">
                <div class="pp-hero-text">
                    <h1 class="pp-title masked-title" set:html={feature.titulo} />
                    <p class="pp-sub reveal">{feature.sub}</p>
                    <div class="pp-actions reveal">
                        <a href="/registro" class="pp-btn-primary">
                            <span>{isEn ? 'Start for free' : 'Empezar gratis'}</span>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </a>
                        <a href="/q/demo" class="pp-btn-ghost">{isEn ? 'See a real quote' : 'Ver una cotización real'}</a>
                    </div>
                    <p class="pp-plan reveal">{feature.plan}</p>
                </div>

                <!-- Mockup específico del feature -->
                <div class="pp-hero-visual">
                <div class="pp-mockup-wrap reveal-mockup">
                    <div class="pp-mesh-bg" aria-hidden="true"></div>
                    <div class="pp-glow" aria-hidden="true"></div>

                    <div class="pp-mockup">

                        {feature.slug === 'editor' && (
                            <div class="mk-window">
                                <div class="mk-bar">
                                    <span class="mk-bar-title">COT-0149 · {isEn ? 'El Zarco Distribution' : 'Distribuidora El Zarco'}</span>
                                    <div class="mk-bar-actions">
                                        <span class="mk-avatar-sm">RM</span>
                                        <span class="mk-badge mk-badge-draft">● {isEn ? 'Draft' : 'Borrador'}</span>
                                    </div>
                                </div>
                                <div class="mk-body">
                                    <div class="mk-sidebar">
                                        <div class="mk-sb-item mk-sb-active"><i><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path fill="currentColor" fill-opacity="0.12" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg></i> {isEn ? 'Current quote' : 'Cotización actual'}</div>
                                        <div class="mk-sb-item"><i><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path fill="currentColor" fill-opacity="0.12" d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4" fill="currentColor" fill-opacity="0.12"/></svg></i> {isEn ? 'Client details' : 'Datos del cliente'}</div>
                                        <div class="mk-sb-item"><i><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3" fill="currentColor" fill-opacity="0.15"/><path fill="currentColor" fill-opacity="0.08" d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></i> {isEn ? 'Settings' : 'Configuración'}</div>
                                    </div>
                                    <div class="mk-content">
                                        <div class="mk-rows">
                                            <div class="mk-row mk-row-head"><span>{isEn ? 'Product' : 'Producto'}</span><span>{isEn ? 'Qty' : 'Cant.'}</span><span>{isEn ? 'Price' : 'Precio'}</span><span>{isEn ? 'Amount' : 'Importe'}</span></div>
                                            <div class="mk-row"><span>{isEn ? 'Grey cement 50kg' : 'Cemento gris 50kg'}</span><span>120</span><span class="editorial">$182.00</span><span class="editorial">$21,840.00</span></div>
                                            <div class="mk-row mk-row-edit" id="editorTargetRow">
                                                <span>{isEn ? 'Rebar 3/8" × 12m' : 'Varilla 3/8" × 12m'}</span><span>340</span>
                                                <span class="editorial mk-green" id="editorPrice">$191.48 <i class="mk-chip" id="editorChip">−12%</i></span>
                                                <span class="editorial" id="editorImport">$65,103.20</span>
                                            </div>
                                            <div class="mk-row"><span>{isEn ? 'Hollow block 15×20×40' : 'Block hueco 15×20×40'}</span><span>2,400</span><span class="editorial">$14.20</span><span class="editorial">$34,080.00</span></div>
                                            <div class="mk-row"><span>{isEn ? 'Welded wire mesh 6×6' : 'Malla electrosoldada 6×6'}</span><span>180</span><span class="editorial">$312.00</span><span class="editorial">$56,160.00</span></div>
                                        </div>
                                        <div class="mk-totals">
                                            <div class="mk-tot-col"><span>{isEn ? 'Subtotal' : 'Subtotal'}</span><b class="editorial">$169,370.00</b></div>
                                            <div class="mk-tot-col"><span>{isEn ? 'Tax (16%)' : 'IVA 16%'}</span><b class="editorial">$27,099.20</b></div>
                                            <div class="mk-tot-col mk-tot-final"><span>{isEn ? 'Total' : 'Total'}</span><b class="editorial" id="editorTotal">$196,469.20</b></div>
                                        </div>
                                    </div>
                                </div>
                                <!-- Cursor GSAP -->
                                <div class="mk-cursor" id="editorCursor">
                                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M7 2l12 11.2-5.8.5 3.3 7.3-2.25 1-3.2-7.4-4.4 4.7z"/></svg>
                                </div>
                            </div>
                        )}

                        {feature.slug === 'link-publico' && (
                          <>
                            <div class="mk-public" id="publicWrap">
                                <div class="mk-public-card" id="publicCard">
                                    <div class="mk-public-head">
                                        <span class="mk-avatar">MV</span>
                                        <div>
                                            <b>{isEn ? 'Valle Materials' : 'Materiales del Valle'}</b>
                                            <i>{isEn ? 'sent you a quote' : 'te envió una cotización'}</i>
                                        </div>
                                        <span class="mk-badge mk-badge-sent">● COT-0148</span>
                                    </div>
                                    <div class="mk-public-total">
                                        <span>{isEn ? 'Total with tax' : 'Total con IVA'}</span>
                                        <b class="editorial">$196,469.20</b>
                                        <i>Net 30 · {isEn ? 'valid until Jun 24, 2026' : 'vigente al 24 jun 2026'}</i>
                                    </div>
                                    <div class="mk-public-actions">
                                        <div class="mk-btn-wrap" id="publicApproveBtn">
                                            <div class="mk-btn-glow" id="publicGlow"></div>
                                            <span class="mk-approve">{isEn ? 'Approve quote' : 'Aprobar cotización'}</span>
                                        </div>
                                        <span class="mk-reject">{isEn ? 'Reject' : 'Rechazar'}</span>
                                    </div>
                                    <span class="mk-via">vía <b>cord</b></span>
                                </div>
                                <div class="mk-success-overlay" id="publicSuccess">
                                    <div class="mk-success-ring"></div>
                                    <i class="mk-success-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></i>
                                    <b>¡{isEn ? 'Successfully approved!' : 'Aprobada exitosamente!'}</b>
                                </div>
                            </div>
                            <div class="pp-bub pp-bub-in pp-lp-bub" id="lpBub1" style="top: 6%; left: 1%;">
                                <span class="pp-bub-name">{isEn ? 'Client' : 'Cliente'}</span>
                                {isEn ? 'Any better price on the rebar?' : '¿Me mejoras el precio del acero?'}
                            </div>
                            <div class="pp-bub pp-bub-out pp-lp-bub" id="lpBub2" style="bottom: 20%; left: 6%;">
                                {isEn ? 'Done — updated the line ✓' : 'Listo — actualicé la línea ✓'}
                            </div>
                          </>
                        )}

                        {feature.slug === 'seguimiento' && (
                            <div class="mk-window mk-track2">
                                <div class="mk-track-topbar">
                                    <div class="mk-track-ti"><b>{isEn ? 'Activity' : 'Actividad'}</b><span>COT-0148 · {isEn ? 'El Zarco Distribution' : 'Distribuidora El Zarco'}</span></div>
                                    <span class="mk-live-pill"><i id="satTrDot"></i> {isEn ? 'Viewing now' : 'Viendo ahora'}</span>
                                </div>
                                <div class="mk-tl">
                                    <div class="mk-tl-row mk-on track-item"><i class="ok"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></i><div class="mk-tl-info"><b>{isEn ? 'Approved' : 'Aprobada'}</b><span>{isEn ? 'El Zarco approved the quote' : 'El Zarco aprobó la cotización'} · 12:36</span></div><span class="mk-avatar-sm">EZ</span></div>
                                    <div class="mk-tl-row mk-on track-item"><i class="warn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path fill="currentColor" fill-opacity="0.12" d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3" fill="currentColor" fill-opacity="0.2"/></svg></i><div class="mk-tl-info"><b>{isEn ? 'Viewed 3 times' : 'Vista 3 veces'}</b><span>{isEn ? 'Raúl opened the link' : 'Raúl Mendoza abrió el link'} · 12:31</span></div><span class="mk-avatar-sm">RM</span></div>
                                    <div class="mk-tl-row track-item"><i><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2" fill="currentColor" fill-opacity="0.12"/><polyline points="22,6 12,13 2,6"/></svg></i><div class="mk-tl-info"><b>{isEn ? 'Sent' : 'Enviada'}</b><span>{isEn ? 'By email and WhatsApp' : 'Por correo y WhatsApp'} · 11:02</span></div></div>
                                    <div class="mk-tl-row track-item"><i><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path fill="currentColor" fill-opacity="0.12" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></i><div class="mk-tl-info"><b>{isEn ? 'Created' : 'Creada'}</b><span>{isEn ? 'Draft' : 'Borrador'} COT-0148 · 10:41</span></div></div>
                                </div>
                            </div>
                        )}

                        {feature.slug === 'cfdi' && (
                            <div class="mk-cfdi">
                                <div class="mk-cfdi-bg-code">
                                    &lt;cfdi:Comprobante Version="4.0" Serie="A" Folio="1048" Fecha="2026-06-24T12:00:00"&gt;                                     &nbsp;&nbsp;&lt;cfdi:Emisor Rfc="MVA240611AB3" Nombre="{isEn ? 'Valle Materials' : 'Materiales del Valle'}" RegimenFiscal="601"/&gt;                                     &nbsp;&nbsp;&lt;cfdi:Receptor Rfc="DEZ981123QX1" Nombre="{isEn ? 'El Zarco Distribution' : 'Distribuidora El Zarco'}" UsoCFDI="G03"/&gt;                                     &nbsp;&nbsp;&lt;cfdi:Conceptos&gt;                                     &nbsp;&nbsp;&nbsp;&nbsp;&lt;cfdi:Concepto ClaveProdServ="30111500" Cantidad="120" ClaveUnidad="H87" Descripcion="{isEn ? 'Grey cement 50kg' : 'Cemento gris 50kg'}"/&gt;                                     &nbsp;&nbsp;&lt;/cfdi:Conceptos&gt;                                     &lt;/cfdi:Comprobante&gt;
                                </div>
                                <div class="mk-cfdi-front">
                                    <div class="mk-cfdi-head">
                                        <b>Factura CFDI 4.0</b>
                                        <span class="mk-badge mk-badge-ok">● Timbrada</span>
                                    </div>
                                    <div class="mk-cfdi-rows">
                                        <div><span>UUID</span><b class="editorial">a1b2c3d4-9f01-4e22-b7aa-3c5d8e2f11f9</b></div>
                                        <div><span>Emisor</span><b>{isEn ? 'Valle Materials' : 'Materiales del Valle'} · MVA240611AB3</b></div>
                                        <div><span>Receptor</span><b>{isEn ? 'El Zarco Distribution' : 'Distribuidora El Zarco'} · DEZ981123QX1</b></div>
                                        <div><span>{isEn ? 'Total' : 'Total'}</span><b class="editorial">$196,469.20 MXN</b></div>
                                    </div>
                                    <div class="mk-cfdi-stamp" id="cfdiStamp">
                                        <div class="mk-stamp-ring"></div>
                                        <span class="mk-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
                                        <span>{isEn ? 'Stamped with the SAT · from COT-0148' : 'Timbrada ante el SAT · desde COT-0148'}</span>
                                    </div>
                                </div>
                            </div>
                        )}

                        {feature.slug === 'clientes-credito' && (
                            <div class="mk-window mk-cliwin">
                              <div class="mk-bar">
                                <span class="mk-bar-title">Cord · {isEn ? 'Clients & credit' : 'Clientes y crédito'}</span>
                                <span class="mk-badge mk-badge-sent">3 {isEn ? 'clients' : 'clientes'}</span>
                              </div>
                              <div class="mk-cli">
                                <div class="mk-cli-row cli-item">
                                    <span class="mk-avatar mk-avatar-ez">EZ</span>
                                    <div class="mk-cli-info"><b>{isEn ? 'El Zarco Distribution' : 'Distribuidora El Zarco'}</b><i>Raúl Mendoza · DEZ981123QX1</i></div>
                                    <div class="mk-term-wrap"><span class="mk-term">Net 30</span></div>
                                    <div class="mk-credit">
                                        <div class="mk-credit-bar"><i style="width: 85%" class="warn-bar"></i></div>
                                        <span class="editorial">$425k / $500k</span>
                                    </div>
                                </div>
                                <div class="mk-cli-row cli-item">
                                    <span class="mk-avatar mk-avatar-cg">CG</span>
                                    <div class="mk-cli-info"><b>Constructora GAMA</b><i>Lucía Ferreira · CGA050617HJ8</i></div>
                                    <div class="mk-term-wrap"><span class="mk-term">Net 60</span></div>
                                    <div class="mk-credit">
                                        <div class="mk-credit-bar"><i style="width: 72%"></i></div>
                                        <span class="editorial">$612k / $850k</span>
                                    </div>
                                </div>
                                <div class="mk-cli-row cli-item">
                                    <span class="mk-avatar mk-avatar-gf">GF</span>
                                    <div class="mk-cli-info"><b>Grupo Ferrex</b><i>Marco Ruiz · GFE120304TR2</i></div>
                                    <div class="mk-term-wrap"><span class="mk-term mk-term-cash">Contado</span></div>
                                    <div class="mk-credit">
                                        <div class="mk-credit-bar"><i></i></div>
                                        <span class="editorial">{isEn ? 'No credit' : 'Sin crédito'}</span>
                                    </div>
                                </div>
                              </div>
                            </div>
                        )}

                        {feature.slug === 'cobranza-ia' && (
                            <div class="mk-chatfree" id="arFree">
                                <div class="cf-msg cf-in" data-cf="0">
                                    <span class="cf-name">{isEn ? 'Cord Agent' : 'Agente Cord'} <em class="cf-badge">IA</em></span>
                                    <div class="cf-bub cf-bub-in">{isEn ? 'Hi Raúl, your $412,300 balance is 47 days overdue. Can I help you clear it in 3 monthly payments, no surcharges?' : 'Hola Raúl, tu saldo de $412,300 venció hace 47 días. ¿Te ayudo a liquidarlo en 3 pagos mensuales, sin recargos?'}</div>
                                </div>
                                <div class="cf-msg cf-out" data-cf="1">
                                    <span class="cf-name">Raúl · El Zarco</span>
                                    <div class="cf-bub cf-bub-out">{isEn ? 'Yes, 3 parts works for me.' : 'Sí, me funciona en 3 partes.'}</div>
                                </div>
                                <div class="cf-msg cf-in" data-cf="2">
                                    <span class="cf-name">{isEn ? 'Cord Agent' : 'Agente Cord'} <em class="cf-badge">IA</em></span>
                                    <div class="cf-bub cf-bub-in">{isEn ? 'Done — here’s the plan:' : 'Listo — este es el plan:'}</div>
                                </div>
                                <div class="cf-plan" data-cf="3">
                                    <div class="cf-plan-head"><span>{isEn ? 'Payment plan' : 'Plan de pagos'}</span><b class="editorial">$412,300</b></div>
                                    <div class="cf-plan-rows">
                                        <div class="cf-cuota"><span>15 jul</span><b class="editorial">$137,433</b></div>
                                        <div class="cf-cuota"><span>15 ago</span><b class="editorial">$137,433</b></div>
                                        <div class="cf-cuota"><span>15 sep</span><b class="editorial">$137,434</b></div>
                                    </div>
                                    <div class="cf-approve" id="cfApprove">{isEn ? 'Approve plan' : 'Aprobar plan'}</div>
                                </div>
                                <div class="cf-msg cf-out" data-cf="4">
                                    <div class="cf-bub cf-bub-out cf-bub-ok"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> {isEn ? 'Approved' : 'Aprobado'}</div>
                                </div>
                            </div>
                        )}

                        {feature.slug === 'divisas' && (
                            <div class="mk-window mk-fx" id="fxHero">
                                <div class="mk-bar">
                                    <span class="mk-dots"><i></i><i></i><i></i></span>
                                    <span class="mk-bar-title">COT-0150 · Acme Imports</span>
                                    <span class="mk-badge mk-badge-sent">● USD</span>
                                </div>
                                <div class="mk-fx-body">
                                    <div class="mk-fx-controls">
                                        <div class="mk-fx-field">
                                            <label>Moneda de presentación</label>
                                            <div class="mk-fx-seg"><span class="on">USD</span><span>EUR</span><span>MXN</span></div>
                                        </div>
                                        <div class="mk-fx-field">
                                            <label>Cobertura (buffer)</label>
                                            <div class="mk-fx-buffer">2.0%</div>
                                        </div>
                                    </div>
                                    <div class="mk-fx-rate">
                                        <span class="mk-fx-rate-line">1 USD = <b class="editorial" id="fxRate">$18.50 MXN</b></span>
                                        <span class="mk-fx-lock" id="fxLock"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="9" rx="2" fill="currentColor" fill-opacity="0.12"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg> lock 30 días</span>
                                    </div>
                                    <div class="mk-fx-totals">
                                        <div class="mk-fx-total"><span>El cliente ve</span><b class="editorial">USD 10,620.50</b></div>
                                        <div class="mk-fx-total mk-fx-total-mxn" id="fxMxn"><span>Se factura</span><b class="editorial">$196,469.20 MXN</b></div>
                                    </div>
                                </div>
                            </div>
                        )}

                        {feature.slug === 'internacional' && (
                            <div class="mk-window mk-intl" id="intlHero">
