---
// Página de producto — una por feature (estilo Stripe: hero + mockup que vende,
// stats, bloques de detalle alternados, cross-links y CTA). Mismo lenguaje de
// animación que el index via PageAnims.astro.
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import PageAnims from '../../components/landing/PageAnims.astro';
import BlockMockup from '../../components/producto/BlockMockup.astro';
import { FEATURES } from '../../lib/producto';

export function getStaticPaths() {
    return FEATURES.map((f) => ({ params: { slug: f.slug }, props: { feature: f } }));
}

const { feature } = Astro.props;
const otros = FEATURES.filter((f) => f.slug !== feature.slug);
const tituloPlano = feature.titulo.replace(/<br\s*\/?>/gi, ' ');

// ── Datos estructurados (JSON-LD) — FAQPage: lo que extraen los AI Overviews.
const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: feature.faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
};
---

<Layout
    title={feature.metaTitle ?? `${feature.nav} — Cord`}
    description={feature.metaDescription ?? feature.sub}
>
    <script
        slot="head"
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify(faqSchema)}
    />
    <Nav />
    <main>
        <!-- ── HERO ── -->
        <section class="pp-hero">
            <div class="pp-hero-mesh" aria-hidden="true"></div>
            <div class="pp-hero-inner">
                <p class="pp-eyebrow reveal">{feature.eyebrow}</p>
                <h1 class="pp-title masked-title" set:html={feature.titulo} />
                <p class="pp-sub reveal">{feature.sub}</p>
                <div class="pp-actions reveal">
                    <a href="/registro" class="pp-btn-primary">
                        <span>Empezar gratis</span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </a>
                    <a href="/q/demo" class="pp-btn-ghost">Ver una cotización real</a>
                </div>
                <p class="pp-plan reveal">{feature.plan}</p>

                <!-- Mockup específico del feature -->
                <div class="pp-mockup-wrap reveal-mockup">
                    <div class="pp-mesh-bg" aria-hidden="true"></div>
                    <div class="pp-glow" aria-hidden="true"></div>

                    <div class="pp-mockup">

                        {feature.slug === 'editor' && (
                            <div class="mk-window">
                                <div class="mk-bar">
                                    <span class="mk-dots"><i></i><i></i><i></i></span>
                                    <span class="mk-bar-title">COT-0149 · Distribuidora El Zarco</span>
                                    <div class="mk-bar-actions">
                                        <span class="mk-avatar-sm">RM</span>
                                        <span class="mk-badge mk-badge-draft">● Borrador</span>
                                    </div>
                                </div>
                                <div class="mk-body">
                                    <div class="mk-sidebar">
                                        <div class="mk-sb-item mk-sb-active"><i>📄</i> Cotización actual</div>
                                        <div class="mk-sb-item"><i>👤</i> Datos del cliente</div>
                                        <div class="mk-sb-item"><i>⚙️</i> Configuración</div>
                                    </div>
                                    <div class="mk-content">
                                        <div class="mk-rows">
                                            <div class="mk-row mk-row-head"><span>Producto</span><span>Cant.</span><span>Precio</span><span>Importe</span></div>
                                            <div class="mk-row"><span>Cemento gris 50kg</span><span>120</span><span class="editorial">$182.00</span><span class="editorial">$21,840.00</span></div>
                                            <div class="mk-row mk-row-edit" id="editorTargetRow">
                                                <span>Varilla 3/8" × 12m</span><span>340</span>
                                                <span class="editorial mk-green" id="editorPrice">$191.48 <i class="mk-chip" id="editorChip">−12%</i></span>
                                                <span class="editorial" id="editorImport">$65,103.20</span>
                                            </div>
                                            <div class="mk-row"><span>Block hueco 15×20×40</span><span>2,400</span><span class="editorial">$14.20</span><span class="editorial">$34,080.00</span></div>
                                            <div class="mk-row"><span>Malla electrosoldada 6×6</span><span>180</span><span class="editorial">$312.00</span><span class="editorial">$56,160.00</span></div>
                                        </div>
                                        <div class="mk-totals">
                                            <div class="mk-tot-col"><span>Subtotal</span><b class="editorial">$169,370.00</b></div>
                                            <div class="mk-tot-col"><span>IVA 16%</span><b class="editorial">$27,099.20</b></div>
                                            <div class="mk-tot-col mk-tot-final"><span>Total</span><b class="editorial" id="editorTotal">$196,469.20</b></div>
                                        </div>
                                    </div>
                                </div>
                                <!-- Cursor GSAP -->
                                <div class="mk-cursor" id="editorCursor">
                                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M7 2l12 11.2-5.8.5 3.3 7.3-2.25 1-3.2-7.4-4.4 4.7z"/></svg>
                                </div>
                            </div>
                        )}

                        {feature.slug === 'link-publico' && (
                            <div class="mk-public" id="publicWrap">
                                <div class="mk-public-card" id="publicCard">
                                    <div class="mk-public-head">
                                        <span class="mk-avatar">MV</span>
                                        <div>
                                            <b>Materiales del Valle</b>
                                            <i>te envió una cotización</i>
                                        </div>
                                        <span class="mk-badge mk-badge-sent">● COT-0148</span>
                                    </div>
                                    <div class="mk-public-total">
                                        <span>Total con IVA</span>
                                        <b class="editorial">$196,469.20</b>
                                        <i>Net 30 · vigente al 24 jun 2026</i>
                                    </div>
                                    <div class="mk-public-actions">
                                        <div class="mk-btn-wrap" id="publicApproveBtn">
                                            <div class="mk-btn-glow" id="publicGlow"></div>
                                            <span class="mk-approve">Aprobar cotización</span>
                                        </div>
                                        <span class="mk-reject">Rechazar</span>
                                    </div>
                                    <span class="mk-via">vía <b>cord</b></span>
                                </div>
                                <div class="mk-success-overlay" id="publicSuccess">
                                    <div class="mk-success-ring"></div>
                                    <i class="mk-success-check">✓</i>
                                    <b>¡Aprobada exitosamente!</b>
                                </div>
                            </div>
                        )}

                        {feature.slug === 'seguimiento' && (
                            <div class="mk-track">
                                <div class="mk-track-head">
                                    <div class="mk-toast" id="trackToast">
                                        <span class="mk-toast-dot"></span>
                                        <div class="mk-toast-content">
                                            <b>Raúl Mendoza</b> abrió tu cotización
                                            <i>hace 3 min</i>
                                        </div>
                                    </div>
                                </div>
                                <div class="mk-tl">
                                    <div class="mk-tl-row mk-on track-item"><i class="ok">✓</i><div class="mk-tl-info"><b>Aprobada</b><span>El Zarco aprobó la cotización · hoy, 12:36</span></div><span class="mk-avatar-sm">EZ</span></div>
                                    <div class="mk-tl-row mk-on track-item"><i class="warn">👁</i><div class="mk-tl-info"><b>Vista (3 veces)</b><span>Raúl Mendoza abrió el link · hoy, 12:31</span></div><span class="mk-avatar-sm">RM</span></div>
                                    <div class="mk-tl-row track-item"><i>✉️</i><div class="mk-tl-info"><b>Enviada</b><span>Por correo y WhatsApp · hoy, 11:02</span></div></div>
                                    <div class="mk-tl-row track-item"><i>📄</i><div class="mk-tl-info"><b>Creada</b><span>Borrador COT-0148 · hoy, 10:41</span></div></div>
                                </div>
                            </div>
                        )}

                        {feature.slug === 'cfdi' && (
                            <div class="mk-cfdi">
                                <div class="mk-cfdi-bg-code">
                                    &lt;cfdi:Comprobante Version="4.0" Serie="A" Folio="1048" Fecha="2026-06-24T12:00:00"&gt;<br/>
                                    &nbsp;&nbsp;&lt;cfdi:Emisor Rfc="MVA240611AB3" Nombre="Materiales del Valle" RegimenFiscal="601"/&gt;<br/>
                                    &nbsp;&nbsp;&lt;cfdi:Receptor Rfc="DEZ981123QX1" Nombre="Distribuidora El Zarco" UsoCFDI="G03"/&gt;<br/>
                                    &nbsp;&nbsp;&lt;cfdi:Conceptos&gt;<br/>
                                    &nbsp;&nbsp;&nbsp;&nbsp;&lt;cfdi:Concepto ClaveProdServ="30111500" Cantidad="120" ClaveUnidad="H87" Descripcion="Cemento gris 50kg"/&gt;<br/>
                                    &nbsp;&nbsp;&lt;/cfdi:Conceptos&gt;<br/>
                                    &lt;/cfdi:Comprobante&gt;
                                </div>
                                <div class="mk-cfdi-front">
                                    <div class="mk-cfdi-head">
                                        <b>Factura CFDI 4.0</b>
                                        <span class="mk-badge mk-badge-ok">● Timbrada</span>
                                    </div>
                                    <div class="mk-cfdi-rows">
                                        <div><span>UUID</span><b class="editorial">a1b2c3d4-9f01-4e22-b7aa-3c5d8e2f11f9</b></div>
                                        <div><span>Emisor</span><b>Materiales del Valle · MVA240611AB3</b></div>
                                        <div><span>Receptor</span><b>Distribuidora El Zarco · DEZ981123QX1</b></div>
                                        <div><span>Total</span><b class="editorial">$196,469.20 MXN</b></div>
                                    </div>
                                    <div class="mk-cfdi-stamp" id="cfdiStamp">
                                        <div class="mk-stamp-ring"></div>
                                        <span class="mk-check">✓</span>
                                        <span>Timbrada ante el SAT · desde COT-0148</span>
                                    </div>
                                </div>
                            </div>
                        )}

                        {feature.slug === 'clientes-credito' && (
                            <div class="mk-cli">
                                <div class="mk-cli-row cli-item">
                                    <span class="mk-avatar mk-avatar-ez">EZ</span>
                                    <div class="mk-cli-info"><b>Distribuidora El Zarco</b><i>Raúl Mendoza · DEZ981123QX1</i></div>
                                    <div class="mk-term-wrap"><span class="mk-term">Net 30</span></div>
                                    <div class="mk-credit">
                                        <div class="mk-credit-bar"><i style="width: 85%" class="warn-bar"></i></div>
                                        <span class="editorial">$425k / $500k</span>
                                    </div>
                                </div>
                                <div class="mk-cli-row cli-item">
                                    <span class="mk-avatar mk-avatar-cg">CG</span>
                                    <div class="mk-cli-info"><b>Constructora GAMA</b><i>Lucía Ferreira · CGA050617HJ8</i></div>
                                    <div class="mk-term-wrap"><span class="mk-term">Net 60</span></div>
                                    <div class="mk-credit">
                                        <div class="mk-credit-bar"><i style="width: 72%"></i></div>
                                        <span class="editorial">$612k / $850k</span>
                                    </div>
                                </div>
                                <div class="mk-cli-row cli-item">
                                    <span class="mk-avatar mk-avatar-gf">GF</span>
                                    <div class="mk-cli-info"><b>Grupo Ferrex</b><i>Marco Ruiz · GFE120304TR2</i></div>
                                    <div class="mk-term-wrap"><span class="mk-term mk-term-cash">Contado</span></div>
                                    <div class="mk-credit">
                                        <div class="mk-credit-bar"><i></i></div>
                                        <span class="editorial">Sin crédito</span>
                                    </div>
                                </div>
                            </div>
                        )}

                    </div>
                </div>
            </div>
        </section>

        <!-- ── STATS ── -->
        <section class="pp-stats">
            {feature.stats.map((s) => (
                <div class="pp-stat reveal">
                    <span
                        class="pp-stat-num editorial"
                        data-countup={s.countup !== undefined ? String(s.countup) : undefined}
                        data-decimals={s.decimals !== undefined ? String(s.decimals) : undefined}
                        data-prefix={s.prefix}
                        data-suffix={s.suffix}
                    >{s.prefix ?? ''}{s.valor}{s.suffix ?? ''}</span>
                    <span class="pp-stat-label">{s.label}</span>
                </div>
            ))}
        </section>

        <!-- ── BLOQUES DE DETALLE ── -->
        <section class="pp-blocks">
            {feature.blocks.map((b, i) => (
                <article class:list={['pp-block', { 'pp-block-flip': i % 2 === 1 }]}>
                    <div class="pp-block-text">
                        <p class="pp-eyebrow reveal">{b.eyebrow}</p>
                        <h2 class="pp-h2 masked-title" set:html={b.titulo} />
                        <p class="pp-copy reveal">{b.copy}</p>
                        <ul class="pp-bullets">
                            {b.bullets.map((bl) => (
                                <li class="reveal">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                    <span>{bl}</span>
                                </li>
                            ))}
                        </ul>
                    </div>
                    <div class="pp-block-visual" style="align-items: center; justify-content: center; padding: 0;">
                        <BlockMockup slug={feature.slug} index={i} />
                    </div>
                </article>
            ))}
        </section>

        <!-- ── FAQ ── -->
        <section class="pp-faq">
            <div class="pp-faq-head">
                <p class="pp-eyebrow reveal">PREGUNTAS FRECUENTES</p>
                <h2 class="pp-h2 masked-title">Lo que más nos preguntan<br/>sobre {feature.nav.toLowerCase()}.</h2>
            </div>
            <div class="pp-faq-list">
                {feature.faqs.map((f, i) => (
                    <div class="pp-faq-item reveal">
                        <button class="pp-faq-q" aria-expanded="false" aria-controls={`pp-faq-panel-${i}`}>
                            <span>{f.q}</span>
                            <span class="pp-faq-icon" aria-hidden="true"></span>
                        </button>
                        <div class="pp-faq-panel" id={`pp-faq-panel-${i}`} role="region">
                            <p class="pp-faq-a">{f.a}</p>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <!-- ── CROSS-LINKS ── -->
        <section class="pp-more">
            <div class="pp-more-head">
                <p class="pp-eyebrow reveal">MÁS DE CORD</p>
                <h2 class="pp-h2 masked-title">Explora el resto<br/>del producto.</h2>
            </div>
            <div class="pp-more-grid">
                {otros.map((f) => (
                    <a href={`/producto/${f.slug}`} class="pp-more-card reveal">
                        <b>{f.nav}</b>
                        <span>{f.sub.split('.')[0]}.</span>
                        <i class="pp-more-arrow">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </i>
                    </a>
                ))}
            </div>
        </section>
    </main>

    <Footer ctaTitle={feature.cta.titulo.replace(/\. /, '.<br />')} ctaSub={feature.cta.sub} />
    <PageAnims />
</Layout>

<style>
    /* ════════ HERO ════════ */
    .pp-hero {
        position: relative;
        padding: 11.5rem 5% 5rem;
        text-align: center;
        overflow: clip;
        background: var(--color-bg);
    }
    .pp-hero-mesh {
        position: absolute; inset: -20% -10% auto;
        height: 80%;
        background:
            radial-gradient(ellipse 50% 60% at 28% 20%, rgba(10,25,47,0.05) 0%, transparent 60%),
            radial-gradient(ellipse 44% 54% at 76% 12%, rgba(10,25,47,0.04) 0%, transparent 60%);
        pointer-events: none;
    }
    .pp-hero-inner { position: relative; z-index: 1; max-width: 980px; margin: 0 auto; }

    .pp-eyebrow {
        font-size: 0.65rem; font-weight: 800; letter-spacing: 3px;
        text-transform: uppercase; color: #888; margin: 0 0 1.4rem;
    }
    .pp-title {
        font-size: clamp(2.4rem, 5.4vw, 4.4rem);
        font-weight: 800; line-height: 1.04; letter-spacing: -0.035em;
        color: var(--color-text); margin: 0 0 1.6rem;
    }
    .pp-sub {
        font-size: 1.12rem; line-height: 1.65; color: var(--color-text-muted);
        max-width: 640px; margin: 0 auto 2.2rem;
    }
    .pp-actions { display: flex; gap: 0.9rem; justify-content: center; align-items: center; flex-wrap: wrap; }
    .pp-btn-primary {
        display: inline-flex; align-items: center; gap: 10px;
        background: var(--color-blue-deep); color: #fff;
        text-decoration: none; font-size: 0.98rem; font-weight: 600;
        padding: 14px 28px; border-radius: 13px;
        box-shadow: 0 18px 44px -16px rgba(10,25,47,0.55);
        transition: transform 0.5s var(--ease-spring), box-shadow 0.5s var(--ease-spring);
    }
    .pp-btn-primary svg { width: 15px; height: 15px; transition: transform 0.5s var(--ease-spring); }
    .pp-btn-primary:hover { transform: translateY(-3px); box-shadow: 0 26px 56px -16px rgba(10,25,47,0.6); }
    .pp-btn-primary:hover svg { transform: translateX(4px); }
    .pp-btn-ghost {
        color: var(--color-text); text-decoration: none; font-weight: 600; font-size: 0.98rem;
        padding: 14px 10px;
        transition: color 0.3s;
    }
    .pp-btn-ghost:hover { color: var(--color-blue-deep); }
    .pp-plan { font-size: 0.78rem; color: #99a2af; margin: 1.3rem 0 0; font-weight: 600; }

    /* ── Mockup del hero (EXTREME MOTION GRAPHICS) ── */
    .pp-mockup-wrap { position: relative; max-width: 820px; margin: 4.5rem auto 0; perspective: 1400px; transform-style: preserve-3d; }
    
    .pp-mesh-bg {
        position: absolute;
        top: -100px; left: 50%;
        transform: translateX(-50%);
        width: 1400px; height: 900px;
        background:
            radial-gradient(ellipse 40% 50% at 20% 30%, rgba(59,130,246,0.10), transparent 60%),
            radial-gradient(ellipse 45% 45% at 80% 25%, rgba(16,185,129,0.07), transparent 60%),
            radial-gradient(ellipse 50% 55% at 50% 10%, rgba(10,25,47,0.10), transparent 55%);
        filter: blur(30px);
        pointer-events: none;
        opacity: 0.9;
    }
    
    .pp-glow {
        position: absolute; inset: -8% -4% 12%;
        background: radial-gradient(ellipse at center, rgba(10,25,47,0.18) 0%, transparent 70%);
        filter: blur(40px); z-index: 0;
        pointer-events: none;
    }

    .pp-mockup {
        position: relative;
        text-align: left;
        color: #fff;
        /* Removed background, padding, and backdrop-filter to prevent double-borders and clipping */
    }

    /* badges compartidos */
    .mk-badge {
        font-size: 0.6rem; font-weight: 800; letter-spacing: 0.8px;
        padding: 4px 10px; border-radius: 100px; white-space: nowrap; text-transform: uppercase;
    }
    .mk-badge-draft { color: rgba(255,255,255,0.7); background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15); }
    .mk-badge-sent  { color: #93c5fd; background: rgba(59,130,246,0.15); border: 1px solid rgba(59,130,246,0.3); }
    .mk-badge-ok    { color: #34d399; background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.3); }
    
    .mk-avatar {
        width: 38px; height: 38px; border-radius: 10px; flex-shrink: 0;
        background: linear-gradient(135deg, #3b82f6, #2563eb); color: #fff; 
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 4px 12px rgba(37,99,235,0.3);
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 0.85rem; font-weight: 800;
    }
    .mk-avatar-ez { background: linear-gradient(135deg, #f59e0b, #d97706); box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 4px 12px rgba(217,119,6,0.3); }
    .mk-avatar-cg { background: linear-gradient(135deg, #10b981, #059669); box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 4px 12px rgba(5,150,105,0.3); }
    .mk-avatar-gf { background: linear-gradient(135deg, #8b5cf6, #6d28d9); box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 4px 12px rgba(109,40,217,0.3); }
    
    .mk-avatar-sm {
        width: 20px; height: 20px; border-radius: 6px; flex-shrink: 0;
        background: #3b82f6; color: #fff;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 0.55rem; font-weight: 800;
    }

    /* ── EDITOR APP SIMULATION ── */
    .mk-window {
        background: #0a192f;
        border-radius: 14px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.5), inset 0 1px 1px rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.06);
        position: relative; overflow: hidden;
    }
    .mk-bar { 
        display: flex; align-items: center; justify-content: space-between; 
        padding: 12px 16px; border-bottom: 1px solid rgba(255,255,255,0.05); background: rgba(255,255,255,0.02);
    }
    .mk-dots { display: inline-flex; gap: 6px; }
    .mk-dots i { width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.2); }
    .mk-bar-title { font-size: 0.75rem; font-weight: 600; color: rgba(255,255,255,0.6); position: absolute; left: 50%; transform: translateX(-50%); }
    .mk-bar-actions { display: flex; align-items: center; gap: 10px; }
    
    .mk-body { display: flex; height: 320px; }
    .mk-sidebar { width: 180px; background: rgba(255,255,255,0.01); border-right: 1px solid rgba(255,255,255,0.03); padding: 12px; display: flex; flex-direction: column; gap: 4px; }
    .mk-sb-item { padding: 8px 10px; border-radius: 6px; font-size: 0.7rem; color: rgba(255,255,255,0.5); display: flex; align-items: center; gap: 8px; cursor: default; }
    .mk-sb-active { background: rgba(59,130,246,0.1); color: #93c5fd; font-weight: 500; }
    .mk-sb-item i { font-style: normal; opacity: 0.7; }
    
    .mk-content { flex: 1; padding: 1.5rem; display: flex; flex-direction: column; }
    .mk-rows { display: flex; flex-direction: column; gap: 4px; flex: 1; }
    .mk-row {
        display: grid; grid-template-columns: 2fr 0.5fr 1fr 1fr;
        gap: 8px; align-items: center;
        font-size: 0.75rem; color: rgba(255,255,255,0.8); font-weight: 500;
        padding: 8px 12px; border-radius: 8px;
        background: transparent; border: 1px solid transparent;
        transition: background 0.3s, border-color 0.3s;
    }
