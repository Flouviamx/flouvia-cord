    .pp-bcard-visual .bm-push-notif * { color: #374151 !important; }
    /* Re-apply semantic color overrides AFTER the blanket reset */
    .pp-bcard-visual .bm-bold,
    .pp-bcard-visual b { color: #050505 !important; }
    .pp-bcard-visual .editorial { color: #050505 !important; font-weight: 700; }
    .pp-bcard-visual .bm-head,
    .pp-bcard-visual .bm-head * { color: rgba(0,0,0,0.4) !important; }
    .pp-bcard-visual .bm-row span { color: #374151 !important; }
    .pp-bcard-visual i { color: rgba(0,0,0,0.38) !important; }
    .pp-bcard-visual .bm-divider { background: rgba(0,0,0,0.07) !important; }
    .pp-bcard-visual .bm-row { border-bottom-color: rgba(0,0,0,0.05) !important; }
    .pp-bcard-visual .bm-active { background: rgba(10,25,47,0.035) !important; }
    /* Semantic colors */
    .pp-bcard-visual .bm-green,
    .pp-bcard-visual .mk-green { color: #059669 !important; }
    .pp-bcard-visual .bm-orange { color: #d97706 !important; }
    /* Light pills */
    .pp-bcard-visual .bm-pill {
        background: #ffffff !important;
        border: 1px solid rgba(0,0,0,0.09) !important;
        box-shadow: 0 4px 14px rgba(0,0,0,0.11) !important;
    }
    .pp-bcard-visual .bm-pill * { color: #111827 !important; }
    /* Navy accent pill stays dark */
    .pp-bcard-visual .bm-pill-dark {
        background: #0a192f !important;
        border-color: transparent !important;
        box-shadow: 0 4px 14px rgba(10,25,47,0.3) !important;
    }
    .pp-bcard-visual .bm-pill-dark,
    .pp-bcard-visual .bm-pill-dark * { color: #ffffff !important; }
    /* Status dots */
    .pp-bcard-visual .bm-dot-blue { background: #3b82f6 !important; }
    .pp-bcard-visual .bm-dot-green { background: #10b981 !important; }
    /* Toast */
    .pp-bcard-visual .bm-toast {
