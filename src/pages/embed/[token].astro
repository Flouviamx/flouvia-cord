---
// CORD Elements — el cotizador embebido en el sitio de un tercero vía <iframe>.
// Reutiliza el MISMO QuoteCard que /q/[token]; la diferencia es el chrome mínimo
// (EmbedLayout, fondo transparente) y dos piezas propias del embed:
//   1) SEGURIDAD: header CSP `frame-ancestors` con la allowlist de la org
//      (orgs.embed_domains) → anti-clickjacking. Vacío = framing abierto (demo).
//   2) PUENTE con la página anfitriona: ResizeObserver → postMessage('cord:resize')
//      para auto-altura, y relay de los CustomEvents del QuoteCard al window padre.
export const prerender = false;

import EmbedLayout from '../../layouts/EmbedLayout.astro';
import QuoteCard from '../../components/q/QuoteCard.astro';
import { getCotizacionByToken, markViewed } from '../../lib/queries';

const { token } = Astro.params;
const result = await getCotizacionByToken(token ?? '');

if (!result) {
    return new Response('Cotización no encontrada', { status: 404 });
}

const { quote: q, org: ORG, conversacion } = result;

// Registra la apertura del cliente (igual que /q).
await markViewed(token ?? '');

// ── Appearance API ──
const appearanceParam = Astro.url.searchParams.get('appearance');
let appearanceCSS = '';
if (appearanceParam) {
    try {
        const parsed = JSON.parse(appearanceParam);
        // Sanitización estricta para evitar XSS reflejado:
        // Se rechazan caracteres como < > { } ; y eval/expression.
        const isSafe = (str: string) => typeof str === 'string' && !/[<>{};]|expression|javascript|vbscript/i.test(str);
        
        let vars = '';
        let fontImports = '';

        // Theme: paleta oscura por default para los tokens --cord-* que el
        // resto de este documento consume (QuoteCard hereda de :root). Las
        // `variables` del usuario SIEMPRE se emiten DESPUÉS en el mismo
        // selector `:root` → en CSS, entre reglas de igual especificidad,
        // gana la última declarada — así el usuario gana sin necesitar JS
        // ni selectores con más peso.
        const DARK_DEFAULTS = '--cord-color-text: #e5e7eb;\n--cord-color-background: #111827;\n';
        const theme = parsed.theme === 'dark' || parsed.theme === 'light' || parsed.theme === 'auto'
            ? parsed.theme : undefined;
        let themeCSS = '';
        let colorScheme = 'light';
        if (theme === 'dark') {
            themeCSS = `:root {\n${DARK_DEFAULTS}}\n`;
            colorScheme = 'dark';
        } else if (theme === 'auto') {
            // No hay info del cliente en el render server-side: la decisión
            // real la toma el navegador vía @media. Puesto ANTES del bloque
            // de variables del usuario por la misma razón de orden-de-cascada.
            themeCSS = `@media (prefers-color-scheme: dark) {\n:root {\n${DARK_DEFAULTS}}\n}\n`;
            colorScheme = 'light dark';
        }

        if (parsed.variables && typeof parsed.variables === 'object') {
            for (const [key, val] of Object.entries(parsed.variables)) {
                if (key !== 'fontFamily' && isSafe(val as string)) {
                    // Validar nombre de propiedad: solo letras y números
                    const safeKey = key.replace(/[^a-zA-Z0-9]/g, '');
                    const cssVar = `--cord-${safeKey.replace(/[A-Z]/g, m => '-' + m.toLowerCase())}`;
                    vars += `${cssVar}: ${val};\n`;
                }
            }
        }

        if (parsed.fonts && Array.isArray(parsed.fonts)) {
            // Allowlist de hosts de fuentes: sin esto, un @import podría cargar una
            // hoja de estilos externa arbitraria (redressing/UI-injection). Solo
            // proveedores de fuentes conocidos y de solo-fuentes.
            const FONT_HOSTS = ['https://fonts.googleapis.com/', 'https://fonts.bunny.net/'];
            parsed.fonts.forEach((f: any) => {
                if (f.cssSrc && isSafe(f.cssSrc) && FONT_HOSTS.some((h) => f.cssSrc.startsWith(h))) {
                    fontImports += `@import url('${f.cssSrc}');\n`;
                }
            });
            const fontFamily = parsed.variables?.fontFamily || parsed.fonts[0]?.cssSrc?.split('family=')[1]?.split('&')[0];
            if (fontFamily && isSafe(fontFamily)) {
                vars += `--cord-font-family: ${fontFamily.replace(/\+/g, ' ')};\n`;
            }
        }

        if (colorScheme !== 'light') {
            vars += `color-scheme: ${colorScheme};\n`;
        }

        // Se eliminó el soporte de `rules` (selectores CSS arbitrarios) por seguridad.
        appearanceCSS += themeCSS;
        if (vars) {
            appearanceCSS += `:root {\n${vars}}\n`;
        }
        appearanceCSS = fontImports + appearanceCSS;
    } catch (e) {}
}

// ── CSP: ¿quién puede embeber esta cotización? ──
// Lista separada por comas / saltos de línea en orgs.embed_domains. Cada entrada
// es un host-source de CSP ("cliente.com", "https://app.cliente.com", "*.cliente.com").
const dominios = (ORG.embedDomains || '')
    .split(/[\s,]+/)
    .map((d: string) => d.trim())
    .filter(Boolean);
const frameAncestors = dominios.length
    ? `frame-ancestors 'self' ${dominios.join(' ')}`
    : `frame-ancestors *`; // sin allowlist → abierto (modo demo / "Powered by Cord")
Astro.response.headers.set('Content-Security-Policy', frameAncestors);

// ── targetOrigin del postMessage saliente ──
// Antes SIEMPRE '*' (cualquier ventana en la cadena de frames podía leer los
// eventos). Si hay allowlist Y el `parentOrigin` que mandó el SDK matchea,
// usamos ESE origen exacto — mismo gate que ya protege frame-ancestors arriba.
// Sin match (o sin allowlist configurada) se queda en '*' — el SDK viejo o un
// <iframe> de terceros directo sin el parámetro siguen funcionando igual que
// antes (sin regresión), solo se AFINA cuando podemos validar.
const parentOriginParam = Astro.url.searchParams.get('parentOrigin') || '';
let targetOrigin = '*';
if (dominios.length > 0 && parentOriginParam) {
    try {
        const poHost = new URL(parentOriginParam).hostname;
        const matched = dominios.some((d: string) => d === poHost || poHost.endsWith('.' + d.replace(/^\*\./, '')));
        if (matched) targetOrigin = parentOriginParam;
    } catch { /* parentOrigin inválido → se queda en '*' */ }
}

const yaAprobada = ['approved', 'paid', 'invoiced'].includes(q.status);
const yaRechazada = q.status === 'rejected';
const pagoActivo = !!(import.meta.env.STRIPE_SECRET_KEY || process.env.STRIPE_SECRET_KEY);
// Términos de crédito: mismo gating que /q/[token] (ver getCotizacionByToken).
// Con cobros parciales mandan LOS COBROS; sin ellos, los términos de crédito.
const cobrosQ: any[] = Array.isArray((q as any).cobros) ? (q as any).cobros : [];
const hayCobroPagable = cobrosQ.some((co: any) => co.status === 'pendiente' && !co.venceEnFuturo);
// Con anticipo configurado, el anticipo es pagable en cuanto se aprueba.
const anticipoPagable = Number((q as any).anticipoPct) >= 1 && q.status !== 'paid';
const pagoDisponible = cobrosQ.length > 0
    ? hayCobroPagable
    : ((q as any).pagoDisponible !== false || anticipoPagable);
const puedePagar = pagoActivo && pagoDisponible && (
    ORG.aceptaTransferencia ||
    ((ORG.aceptaTarjeta || ORG.cobroSpeiAuto) && ORG.stripeAccountId && ORG.stripeChargesEnabled)
);
---

<EmbedLayout title={`Cotización ${q.folio}`}>
    <div class="embed-wrap">
        <QuoteCard
            quote={q}
            org={ORG}
            conversacion={conversacion}
            yaAprobada={yaAprobada}
            yaRechazada={yaRechazada}
            puedePagar={puedePagar}
        />
    </div>
    {appearanceCSS && <style set:html={appearanceCSS}></style>}
</EmbedLayout>

<script is:inline define:vars={{ targetOrigin }}>
    // JS puro (sin sintaxis TS) — este bloque es is:inline vía define:vars,
    // así que se manda VERBATIM al navegador. `targetOrigin` viaja
    // JSON-serializado por Astro (seguro contra inyección).
    window.__CORD_TARGET_ORIGIN__ = targetOrigin;
</script>
<script>
    // ── Puente iframe ↔ sitio anfitrión ──
    const post = (type: string, payload: Record<string, unknown> = {}) => {
        try {
            const to = (window as any).__CORD_TARGET_ORIGIN__ || '*';
            window.parent.postMessage({ source: 'cord', type, ...payload }, to);
        } catch {}
    };

    // 1) Auto-altura: mide el contenido y avisa al padre en cada cambio de tamaño.
    //    Usamos el alto del .q-card (no body) para no arrastrar el padding del wrap.
    const measure = () => {
        const card = document.querySelector('.embed-wrap');
        return Math.ceil((card ? card.scrollHeight : document.body.scrollHeight));
    };
    const reportHeight = () => post('cord:resize', { height: measure() });
    if ('ResizeObserver' in window) {
        new ResizeObserver(reportHeight).observe(document.body);
    } else {
        window.addEventListener('resize', reportHeight);
    }
    window.addEventListener('load', reportHeight);

    // 'ready' = contenido ya estilado (fuentes cargadas) → el padre revela el iframe.
    const ready = () => { reportHeight(); post('cord:ready'); post('cord:viewed'); };
    reportHeight();
    const fonts = (document as any).fonts?.ready;
    if (fonts) fonts.then(ready); else ready();
    window.addEventListener('load', ready);

    // 2) Relay: cada evento del QuoteCard → postMessage al padre.
    //    `cord:item_comment` faltaba aquí — QuoteCard SÍ lo emite (comentario
    //    por línea/partida), pero se perdía en silencio antes de llegar al SDK.
    for (const name of ['cord:approved', 'cord:rejected', 'cord:message', 'cord:pay', 'cord:signed', 'cord:item_comment'] as const) {
        window.addEventListener(name, (e) => {
            post(name, { detail: (e as CustomEvent).detail });
            // tras aprobar/rechazar la altura cambia (aparece el estado final)
            setTimeout(reportHeight, 50);
        });
    }
</script>

<style>
    /* En el embed la tarjeta llena el ancho del iframe; el host controla el tamaño. */
    .embed-wrap { padding: 4px; }
    .embed-wrap :global(.q-card) {
        max-width: none;
        box-shadow: 0 1px 3px rgba(10, 25, 47, 0.06);
    }
</style>
