---
import Layout from '../layouts/Layout.astro';
import CustomSignUp from '../components/auth/CustomSignUp';
---

<Layout title="Registro B2B - Cord">
    <div class="auth-page">
        <a href="/" class="auth-logo">
            <img src="/imgs/logo-cord-white.png" alt="Cord" height="26" />
        </a>

        <CustomSignUp client:only="react" />

        <p class="auth-page-footer">Hecho en México &nbsp;&middot;&nbsp; Datos cifrados</p>
    </div>
</Layout>

<style is:global>
    /* Auth pages own the viewport — hide any landing nav/footer */
    body:has(.auth-page) #navbar,
    body:has(.auth-page) footer { display: none !important; }

    .auth-page {
        min-height: 100vh;
        background:
            radial-gradient(ellipse 80% 60% at 50% -10%, rgba(30,72,140,0.22) 0%, transparent 60%),
            radial-gradient(ellipse at 50% 120%, #0c1f3d 0%, #0a192f 55%, #060f1f 100%);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2.25rem;
        padding: 2.5rem 1.5rem;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    }

    .auth-logo {
        display: block;
        opacity: 0.92;
        transition: opacity 0.2s ease;
    }
    .auth-logo:hover { opacity: 1; }
    .auth-logo img { display: block; }

    .auth-page-footer {
        font-size: 0.72rem;
        color: rgba(255,255,255,0.28);
        font-weight: 500;
        letter-spacing: 0.02em;
        margin: 0;
    }

    /* ---- Centered minimal form (rendered by Custom* components) ---- */
    .auth-card {
        width: 100%;
        max-width: 380px;
        background: transparent;
        border: none;
        box-shadow: none;
        padding: 0;
        animation: auth-fadein 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .auth-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .auth-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: #ffffff;
        margin: 0 0 0.4rem;
        letter-spacing: -0.025em;
    }

    .auth-subtitle {
        font-size: 0.9rem;
        color: rgba(255,255,255,0.45);
        margin: 0;
        font-weight: 400;
    }

    .auth-form {
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .label-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .form-group label {
        font-size: 0.78rem;
        font-weight: 500;
        color: rgba(255,255,255,0.6);
        letter-spacing: 0.01em;
    }

    .forgot-link {
        font-size: 0.76rem;
        color: rgba(255,255,255,0.55);
        text-decoration: none;
        font-weight: 500;
        transition: color 0.2s;
    }
    .forgot-link:hover { color: #ffffff; }

    .form-input {
        width: 100%;
        box-sizing: border-box;
        padding: 0.72rem 0.9rem;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px;
        font-size: 0.95rem;
        color: #ffffff;
        background: rgba(255,255,255,0.04);
        transition: all 0.18s cubic-bezier(0.16, 1, 0.3, 1);
        outline: none;
    }
    .form-input::placeholder { color: rgba(255,255,255,0.3); }
    .form-input:hover { border-color: rgba(255,255,255,0.18); }
    .form-input:focus {
        border-color: rgba(120,160,230,0.6);
        background: rgba(255,255,255,0.06);
        box-shadow: 0 0 0 3px rgba(80,130,220,0.15);
    }

    .btn-primary {
        width: 100%;
        margin-top: 0.6rem;
        background: #ffffff;
        color: #0a192f;
        border: none;
        padding: 0.78rem 1rem;
        border-radius: 10px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        letter-spacing: -0.01em;
        transition: all 0.18s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .btn-primary:hover:not(:disabled) {
        background: rgba(255,255,255,0.9);
        transform: translateY(-1px);
        box-shadow: 0 8px 24px -6px rgba(0,0,0,0.5);
    }
    .btn-primary:active:not(:disabled) { transform: translateY(0); box-shadow: none; }
    .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

    .auth-error {
        font-size: 0.82rem;
        color: #fca5a5;
        background: rgba(220,38,38,0.1);
        padding: 0.7rem 0.875rem;
        border-radius: 8px;
        border: 1px solid rgba(248,113,113,0.25);
    }

    .auth-divider {
        position: relative;
        text-align: center;
        margin: 1.5rem 0;
    }
    .auth-divider::before {
        content: '';
        position: absolute;
        top: 50%; left: 0; right: 0;
        height: 1px;
        background: rgba(255,255,255,0.1);
    }
    .auth-divider span {
        position: relative;
        background: #0a192f;
        padding: 0 0.875rem;
        color: rgba(255,255,255,0.4);
        font-size: 0.74rem;
        font-weight: 500;
    }

    .auth-social { display: flex; flex-direction: column; gap: 0.6rem; }

    .btn-social {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.7rem;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 0.72rem 1rem;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 500;
        color: rgba(255,255,255,0.92);
        cursor: pointer;
        transition: all 0.18s cubic-bezier(0.16, 1, 0.3, 1);
        width: 100%;
    }
    .btn-social:hover:not(:disabled) {
        border-color: rgba(255,255,255,0.22);
        background: rgba(255,255,255,0.07);
    }
    .btn-social:disabled { opacity: 0.5; cursor: not-allowed; }

    .auth-footer {
        margin-top: 1.75rem;
        text-align: center;
        font-size: 0.85rem;
        color: rgba(255,255,255,0.45);
    }
    .auth-footer a {
        color: #ffffff;
        font-weight: 500;
        text-decoration: none;
    }
    .auth-footer a:hover { text-decoration: underline; }

    @keyframes auth-fadein {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>
