                    if (!pill) return;
                    gsap.timeline({ repeat: -1, repeatDelay: 2.2 })
                      .call(() => { pill.textContent = 'sin acceso'; pill.classList.remove('dbm-gov-on'); pill.classList.add('dbm-gov-off'); })
                      .to({}, { duration: 1.4 })
                      .to(pill, { scale: 0.85, duration: 0.15, ease: 'power2.in' })
                      .call(() => { pill.textContent = 'permitido'; pill.classList.remove('dbm-gov-off'); pill.classList.add('dbm-gov-on'); })
                      .to(pill, { scale: 1, duration: 0.4, ease: 'back.out(1.8)' })
                      .to({}, { duration: 1.6 });
                } });
        }

        // FX 0 — el tipo de cambio parpadea vivo (Banxico FIX) + micro-movimiento del rate.
        const fxB0 = document.querySelector('.dbm-fx-m0');
        if (fxB0 && !reduced) {
            const rate = document.getElementById('fxRate');
            ScrollTrigger.create({ trigger: fxB0, start: 'top 88%', once: true,
