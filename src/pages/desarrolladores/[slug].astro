---
// Página para desarrolladores — una por tema (api, mcp). Mismo lenguaje visual y
// de animación que /producto/* (PageAnims, masked-title, reveal, editorial), pero
// con mockups de CÓDIGO/CHAT en vez de mockups de cotización. Copy en
// src/lib/desarrolladores.ts.
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import PageAnims from '../../components/landing/PageAnims.astro';
import DevBlockMockup from '../../components/desarrolladores/DevBlockMockup.astro';
import { DEV_PAGES } from '../../lib/desarrolladores';

export function getStaticPaths() {
    return DEV_PAGES.map((p) => ({ params: { slug: p.slug }, props: { page: p } }));
}

const { page } = Astro.props;
const otra = DEV_PAGES.find((p) => p.slug !== page.slug)!;
---

<Layout title={`${page.nav} — Cord`} description={page.sub}>
    <Nav />
    <main>
        <!-- ── HERO ── -->
        <section class="pp-hero">
            <div class="pp-hero-mesh" aria-hidden="true"></div>
            <div class="pp-hero-inner">
                <p class="pp-eyebrow reveal">{page.eyebrow}</p>
                <h1 class="pp-title masked-title" set:html={page.titulo} />
                <p class="pp-sub reveal">{page.sub}</p>
                <div class="pp-actions reveal">
                    <a href="/registro" class="pp-btn-primary">
                        <span>Empezar gratis</span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </a>
                    <a href="/precios" class="pp-btn-ghost">Ver planes</a>
                </div>
                <p class="pp-plan reveal">{page.plan}</p>

                <!-- Mockup del hero -->
                <div class="pp-mockup-wrap reveal-mockup">
                    <div class="pp-glow" aria-hidden="true"></div>
                    <div class="pp-mockup">
                        {page.slug === 'api' && (
                            <div class="dv-term">
                                <div class="dv-term-bar">
                                    <span class="dv-dots"><i></i><i></i><i></i></span>
                                    <span class="dv-term-title">cord · API v1</span>
                                    <span class="dv-pill">200 OK</span>
                                </div>
                                <pre class="dv-code"><code><span class="c-prompt">$</span> curl https://cord.flouvia.com/api/v1/cotizaciones \
  -H <span class="c-str">"Authorization: Bearer sk_live_xxxx"</span>

{`{`}
  <span class="c-key">"data"</span>: [
    {`{`} <span class="c-key">"folio"</span>: <span class="c-str">"COT-0149"</span>,
      <span class="c-key">"cliente"</span>: <span class="c-str">"Distribuidora El Zarco"</span>,
      <span class="c-key">"status"</span>: <span class="c-str">"sent"</span>,
      <span class="c-key">"total"</span>: <span class="c-num">196469.2</span> {`}`}
  ],
  <span class="c-key">"meta"</span>: {`{`} <span class="c-key">"total"</span>: <span class="c-num">1</span> {`}`}
{`}`}</code></pre>
                            </div>
                        )}
                        {page.slug === 'mcp' && (
                            <div class="dv-mcp">
                                <div class="dv-mcp-row">
                                    <div class="dv-node dv-node-ai">Claude · IA</div>
                                    <div class="dv-conn"><span class="dv-dot dv-dot-l" id="mcpDotL"></span></div>
                                    <div class="dv-node dv-node-cord">
                                        <img src="/imgs/logo-cord-white.png" alt="Cord" />
                                        <span class="dv-tool-chip" id="mcpTool">listar_cotizaciones</span>
                                    </div>
                                    <div class="dv-conn"><span class="dv-dot dv-dot-r" id="mcpDotR"></span><i class="dv-check" id="mcpCheck">✓</i></div>
                                    <div class="dv-node dv-node-ext">Tu CRM / ERP</div>
                                </div>
                                <div class="dv-mcp-legend">
                                    <span><b>Cord como servidor</b> · la IA consulta tus 7 herramientas</span>
                                    <span><b>Cord como cliente</b> · consulta tus sistemas, con permiso</span>
                                </div>
                            </div>
                        )}
                        {page.slug === 'elements' && (
                            <div class="dv-embed">
                                <div class="dv-embed-bar">
                                    <span class="dv-dots"><i></i><i></i><i></i></span>
                                    <span class="dv-embed-url">🔒 portal.tucliente.com/cotizacion</span>
                                </div>
                                <div class="dv-embed-site">
                                    <div class="dv-embed-sitehead">
                                        <span class="dv-embed-logo">ACME Industrial</span>
                                        <span class="dv-embed-nav"><i></i><i></i><i></i></span>
                                    </div>
                                    <p class="dv-embed-h">Tu cotización está lista</p>
                                    <div class="dv-embed-card">
                                        <div class="dv-embed-cardhead"><span class="dv-embed-brand">MV</span><b>Materiales del Valle</b><span class="dv-embed-badge" id="embedBadge">● Aprobada</span></div>
                                        <div class="dv-embed-line"><span>Cemento gris 50kg × 120</span><span class="editorial">$21,840.00</span></div>
                                        <div class="dv-embed-line"><span>Varilla 3/8" × 340</span><span class="editorial">$57,290.00</span></div>
                                        <div class="dv-embed-total"><span>Total con IVA</span><b class="editorial" id="embedTotal">$196,469.20</b></div>
                                    </div>
                                </div>
                            </div>
                        )}
                    </div>
                </div>
            </div>
        </section>

        <!-- ── STATS ── -->
        <section class="pp-stats">
            {page.stats.map((s) => (
                <div class="pp-stat reveal">
                    <span class="pp-stat-num editorial"
                        data-countup={s.countup !== undefined ? String(s.countup) : undefined}
                        data-decimals={s.decimals !== undefined ? String(s.decimals) : undefined}
                        data-prefix={s.prefix} data-suffix={s.suffix}
                    >{s.prefix ?? ''}{s.valor}{s.suffix ?? ''}</span>
                    <span class="pp-stat-label">{s.label}</span>
                </div>
            ))}
        </section>

        <!-- ── BLOQUES ── -->
        <section class="pp-blocks">
            {page.blocks.map((b, i) => (
                <article class:list={['pp-block', { 'pp-block-flip': i % 2 === 1 }]}>
                    <div class="pp-block-text">
                        <p class="pp-eyebrow reveal">{b.eyebrow}</p>
                        <h2 class="pp-h2 masked-title" set:html={b.titulo} />
                        <p class="pp-copy reveal">{b.copy}</p>
                        <ul class="pp-bullets">
                            {b.bullets.map((bl) => (
                                <li class="reveal">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                    <span set:html={bl} />
                                </li>
                            ))}
                        </ul>
                    </div>
                    <div class="pp-block-visual" style="align-items: center; justify-content: center; padding: 0;">
                        <DevBlockMockup slug={page.slug} index={i} />
                    </div>
                </article>
            ))}
        </section>

        <!-- ── CÓMO FUNCIONA (pasos) ── -->
        <section class="dv-steps">
            <div class="dv-steps-head">
                <p class="pp-eyebrow reveal">EN TRES PASOS</p>
                <h2 class="pp-h2 masked-title">Listo en minutos,<br/>no en semanas.</h2>
            </div>
            <div class="dv-steps-list">
                {page.steps.map((s, i) => (
                    <div class="dv-step reveal">
                        <span class="dv-step-n editorial">{i + 1}</span>
                        <div>
                            <b>{s.titulo}</b>
                            <span>{s.copy}</span>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <!-- ── CROSS-LINK (estilo lista, no cards) ── -->
        <section class="dv-more">
            <a href={`/desarrolladores/${otra.slug}`} class="dv-more-row reveal">
                <div>
                    <span class="dv-more-eyebrow">{otra.eyebrow}</span>
                    <b>{otra.nav}</b>
                    <i>{otra.sub.split('.')[0]}.</i>
                </div>
                <span class="dv-more-arrow">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
            </a>
        </section>
    </main>

    <Footer ctaTitle={page.cta.titulo.replace(/\. /, '.<br />')} ctaSub={page.cta.sub} />
    <PageAnims />
</Layout>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    window.addEventListener('load', () => {
        // GSAP Animations
        const stats = document.querySelectorAll('.pp-stat');
        if (stats.length) {
            gsap.fromTo(stats, 
                { opacity: 0, y: 20 },
                { opacity: 1, y: 0, duration: 0.6, stagger: 0.1, ease: 'power2.out', scrollTrigger: { trigger: '.pp-stats', start: 'top 85%', once: true } }
            );
        }

        // ───────────────────────── HERO MOCKUP ─────────────────────────
        // El "settle" del mockup del hero lo maneja PageAnims.astro, idéntico al index.
        // Aquí: micro-historia auto-reproducida dentro del mockup, según la página.
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // HERO MCP — diagrama bidireccional en loop (IA → Cord → CRM)
        const mcpHero = document.querySelector('.dv-mcp');
        if (mcpHero && !reduced) {
            const dotL = document.getElementById('mcpDotL');
            const dotR = document.getElementById('mcpDotR');
            const tool = document.getElementById('mcpTool');
            const check = document.getElementById('mcpCheck');
            const tools = ['listar_cotizaciones', 'cartera_vencida', 'crear_cotizacion_borrador'];
            let ti = 0;
            const tl = gsap.timeline({ repeat: -1 });
            tl.call(() => { if (tool) tool.textContent = tools[ti]; ti = (ti + 1) % tools.length; })
              .set([dotL, dotR], { left: '0%', opacity: 0 })
              .set([check, tool], { opacity: 0 })
              .to(dotL, { opacity: 1, duration: 0.2 })
              .to(dotL, { left: '100%', duration: 0.8, ease: 'power1.inOut' })
              .to(dotL, { opacity: 0, duration: 0.2 })
              .to(tool, { opacity: 1, duration: 0.3, ease: 'back.out(1.5)' }, '<')
              .to(dotR, { opacity: 1, duration: 0.2 }, '+=0.2')
              .to(dotR, { left: '100%', duration: 0.8, ease: 'power1.inOut' })
              .to(dotR, { opacity: 0, duration: 0.2 })
              .to(check, { opacity: 1, scale: 1, duration: 0.4, ease: 'back.out(1.6)' }, '<')
              .to([tool, check], { opacity: 0, duration: 0.4 }, '+=1.4');
        }

        // HERO ELEMENTS — el badge cicla estado + count-up del total
        const embedHero = document.querySelector('.dv-embed');
        if (embedHero && !reduced) {
            const badge = document.getElementById('embedBadge');
            const total = document.getElementById('embedTotal');
            ScrollTrigger.create({ trigger: embedHero, start: 'top 80%', once: true,
                onEnter: () => {
                    if (total) {
                        const obj = { v: 0 };
                        gsap.to(obj, { v: 196469.2, duration: 1.2, ease: 'power2.out', onUpdate: () => { total.textContent = '$' + obj.v.toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); } });
                    }
                    if (badge) {
                        const states = [{ t: '● Enviada', c: '#3b82f6', bg: 'rgba(59,130,246,0.14)' }, { t: '● Vista', c: '#d97706', bg: 'rgba(245,158,11,0.14)' }, { t: '● Aprobada', c: '#10b981', bg: 'rgba(16,185,129,0.12)' }];
                        let bi = 0;
                        gsap.timeline({ repeat: -1, repeatDelay: 1.1, delay: 1.2 }).call(() => {
                            const s = states[bi]; bi = (bi + 1) % states.length;
                            badge.textContent = s.t; badge.style.color = s.c; badge.style.background = s.bg;
                        }).to({}, { duration: 1.1 });
                    }
                } });
        }

        // ───────────────────────── BLOCK MOCKUPS GSAP ─────────────────────────

        // API M0
        const apiM0 = document.querySelector('.dbm-api-m0');
        if (apiM0) {
            const dot = apiM0.querySelector('.dbm-dot');
            gsap.to(dot, { left: '100%', ease: 'none', scrollTrigger: { trigger: apiM0, start: 'top 90%', end: 'top 20%', scrub: 1 } });
        }
        
        // API M1 — cursor parpadeante en la terminal (sin tilt con el mouse)
        const apiM1 = document.querySelector('.dbm-api-m1');
        if (apiM1) {
            const cursor = apiM1.querySelector('.dbm-cursor');
            gsap.to(cursor, { opacity: 0, duration: 0.4, repeat: -1, yoyo: true });
        }

        // API M2
        const apiM2 = document.querySelector('.dbm-api-m2');
        if (apiM2) {
            const hl = apiM2.querySelector('.dbm-hl-target');
            gsap.to(hl, { color: '#10b981', textShadow: '0 0 10px rgba(16,185,129,0.5)', ease: 'none', scrollTrigger: { trigger: apiM2, start: 'top 80%', end: 'top 40%', scrub: 1 } });
        }

        // MCP M0 — lista de las 7 tools entra escalonada
        const mcpM0 = document.querySelector('.dbm-mcp-m0');
        if (mcpM0) {
            const rows = mcpM0.querySelectorAll('.dbm-toolrow');
            gsap.set(rows, { opacity: 0, x: -10 });
            ScrollTrigger.create({ trigger: mcpM0, start: 'top 88%', once: true,
                onEnter: () => gsap.to(rows, { opacity: 1, x: 0, stagger: 0.12, duration: 0.5, ease: 'power2.out' }) });
        }

        // MCP M1 — Cord consulta el CRM: el dot cruza y el log se enciende (loop)
        const mcpM1 = document.querySelector('.dbm-mcp-m1');
        if (mcpM1) {
            const dot = mcpM1.querySelector('.dbm-dot');
            const logs = mcpM1.querySelectorAll('.dbm-mcp-log > div');
            ScrollTrigger.create({ trigger: mcpM1, start: 'top 85%', once: true,
                onEnter: () => {
                    if (reduced) { gsap.set(logs, { opacity: 1 }); return; }
                    gsap.timeline({ repeat: -1, repeatDelay: 1.6 })
                        .set(dot, { left: '0%', opacity: 0 })
                        .set(logs, { opacity: 0, y: 8 })
                        .to(dot, { opacity: 1, duration: 0.2 })
                        .to(dot, { left: '100%', duration: 0.9, ease: 'power1.inOut' })
                        .to(dot, { opacity: 0, duration: 0.2 })
                        .to(logs, { opacity: 1, y: 0, stagger: 0.3, duration: 0.4, ease: 'power2.out' }, '-=0.6')
                        .to({}, { duration: 1.4 });
                } });
        }

        // MCP M2 — gobernanza: el permiso del CRM pasa a "permitido"
        const mcpM2 = document.querySelector('.dbm-mcp-m2');
        if (mcpM2) {
            const pill = document.getElementById('govPill');
            ScrollTrigger.create({ trigger: mcpM2, start: 'top 85%', once: true,
                onEnter: () => {
                    if (!pill) return;
                    gsap.timeline({ delay: 0.6 })
                        .to(pill, { scale: 0.85, duration: 0.15, ease: 'power2.in' })
                        .call(() => { pill.textContent = 'permitido'; pill.classList.remove('dbm-gov-off'); pill.classList.add('dbm-gov-on'); })
                        .to(pill, { scale: 1, duration: 0.4, ease: 'back.out(1.8)' });
                } });
        }

        // Elements M0 — skeleton shimmer → tarjeta de cotización
        const elM0 = document.querySelector('.dbm-el-m0');
        if (elM0) {
            const skel = document.getElementById('elSkel');
            const mini = document.getElementById('elMini');
            ScrollTrigger.create({ trigger: elM0, start: 'top 85%', once: true,
                onEnter: () => {
                    if (reduced) { gsap.set([skel], { opacity: 0 }); gsap.set([mini], { opacity: 1 }); return; }
                    gsap.timeline()
                        .fromTo(skel, { backgroundPosition: '180% 0' }, { backgroundPosition: '-80% 0', duration: 1, ease: 'none', repeat: 1 })
                        .to(skel, { opacity: 0, duration: 0.3 })
                        .to(mini, { opacity: 1, duration: 0.4, ease: 'power2.out' }, '<');
                } });
        }

        // Elements M1 — pestañas que rotan + crossfade del snippet (loop)
        const elM1 = document.querySelector('.dbm-el-m1');
        if (elM1 && !reduced) {
            const tabs = elM1.querySelectorAll('.dbm-el-tabs span');
            const code = document.getElementById('elCode');
            const snippets = [
                '<span class="dbm-prompt">&lt;script src=</span><span class="dbm-str">"…/embed.js"</span><span class="dbm-prompt">&gt;</span>',
                '<span class="dbm-prompt">import</span> { CordCotizador } <span class="dbm-prompt">from</span> <span class="dbm-str">\'@flouviahq/elements/react\'</span>',
                '<span class="dbm-prompt">&lt;cord-cotizador</span> token=<span class="dbm-str">"…"</span><span class="dbm-prompt">&gt;</span>',
            ];
            let i = 0;
            ScrollTrigger.create({ trigger: elM1, start: 'top 85%', once: true,
                onEnter: () => {
                    gsap.timeline({ repeat: -1, repeatDelay: 1.4 }).call(() => {
                        tabs.forEach((t, k) => t.classList.toggle('dbm-seg-on', k === i));
                        if (code) { code.style.opacity = '0'; setTimeout(() => { code.innerHTML = snippets[i]; code.style.opacity = '1'; }, 180); }
                        i = (i + 1) % snippets.length;
                    }).to({}, { duration: 1.4 });
                } });
        }

        // Elements M2 — el cursor "clickea" Aprobar → estado "Aprobada" (loop)
        const elM2 = document.querySelector('.dbm-el-m2');
        if (elM2 && !reduced) {
            const cursor = document.getElementById('elCursor');
            const approve = document.getElementById('elApprove');
            const badge = document.getElementById('elBadge');
            ScrollTrigger.create({ trigger: elM2, start: 'top 85%', once: true,
                onEnter: () => {
                    gsap.timeline({ repeat: -1, repeatDelay: 1.8 })
                        .set(cursor, { x: 30, y: 20, opacity: 0 })
                        .call(() => { if (badge) { badge.textContent = 'Revisar'; badge.style.color = '#d97706'; badge.style.background = 'rgba(245,158,11,0.14)'; } })
                        .to(cursor, { opacity: 1, duration: 0.3 })
                        .to(cursor, { x: 0, y: 0, duration: 0.7, ease: 'power2.inOut' })
                        .to(approve, { scale: 0.95, duration: 0.1, yoyo: true, repeat: 1 })
                        .call(() => { if (badge) { badge.textContent = 'Aprobada'; badge.style.color = '#10b981'; badge.style.background = 'rgba(16,185,129,0.12)'; } })
                        .fromTo(approve, { boxShadow: '0 0 0 0 rgba(16,185,129,0.5)' }, { boxShadow: '0 0 0 8px rgba(16,185,129,0)', duration: 0.7 })
                        .to(cursor, { opacity: 0, duration: 0.3 }, '+=0.4');
                } });
        }
    });
</script>

<style>
    /* ════════ HERO (mismo sistema que /producto) ════════ */
    .pp-hero { position: relative; padding: 11.5rem 5% 5rem; text-align: center; overflow: clip; background: var(--color-bg); }
    .pp-hero-mesh {
        position: absolute; inset: -20% -10% auto; height: 80%;
        background:
            radial-gradient(ellipse 50% 60% at 28% 20%, rgba(10,25,47,0.05) 0%, transparent 60%),
            radial-gradient(ellipse 44% 54% at 76% 12%, rgba(10,25,47,0.04) 0%, transparent 60%);
        pointer-events: none;
    }
    .pp-hero-inner { position: relative; z-index: 1; max-width: 980px; margin: 0 auto; }
    .pp-eyebrow { font-size: 0.65rem; font-weight: 800; letter-spacing: 3px; text-transform: uppercase; color: #888; margin: 0 0 1.4rem; }
    .pp-title { font-size: clamp(2.4rem, 5.4vw, 4.4rem); font-weight: 800; line-height: 1.04; letter-spacing: -0.035em; color: var(--color-text); margin: 0 0 1.6rem; }
    .pp-sub { font-size: 1.12rem; line-height: 1.65; color: var(--color-text-muted); max-width: 660px; margin: 0 auto 2.2rem; }
    .pp-actions { display: flex; gap: 0.9rem; justify-content: center; align-items: center; flex-wrap: wrap; }
    .pp-btn-primary {
        display: inline-flex; align-items: center; gap: 10px;
        background: var(--color-blue-deep); color: #fff; text-decoration: none;
        font-size: 0.98rem; font-weight: 600; padding: 14px 28px; border-radius: 13px;
        box-shadow: 0 18px 44px -16px rgba(10,25,47,0.55);
        transition: transform 0.5s var(--ease-spring), box-shadow 0.5s var(--ease-spring);
    }
    .pp-btn-primary svg { width: 15px; height: 15px; transition: transform 0.5s var(--ease-spring); }
    .pp-btn-primary:hover { transform: translateY(-3px); box-shadow: 0 26px 56px -16px rgba(10,25,47,0.6); }
    .pp-btn-primary:hover svg { transform: translateX(4px); }
    .pp-btn-ghost { color: var(--color-text); text-decoration: none; font-weight: 600; font-size: 0.98rem; padding: 14px 10px; transition: color 0.3s; }
    .pp-btn-ghost:hover { color: var(--color-blue-deep); }
    .pp-plan { font-size: 0.78rem; color: #99a2af; margin: 1.3rem 0 0; font-weight: 600; }

    /* ── Mockup del hero ── */
    .pp-mockup-wrap { position: relative; max-width: 720px; margin: 4.5rem auto 0; }
    .pp-glow { position: absolute; inset: 12% -8% -18%; background: radial-gradient(ellipse at center, rgba(10,25,47,0.16) 0%, transparent 65%); filter: blur(30px); pointer-events: none; }
    .pp-mockup {
        position: relative;
        background: linear-gradient(165deg, #0e2240 0%, #0a192f 55%, #081424 100%);
        border-radius: 22px; padding: 1.4rem; text-align: left;
        box-shadow: 0 50px 100px -36px rgba(5,11,20,0.75), inset 0 0 0 0.5px rgba(255,255,255,0.08);
        color: #fff;
    }

    /* ════════ HERO MOCKUP ════════ */
    .dv-term {
        background: rgba(10,25,47,0.85); border-radius: 14px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.5), inset 0 1px 1px rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.06); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
        overflow: hidden; max-width: 520px; width: 100%; margin: 0 auto;
    }
    .dv-term-bar { display: flex; align-items: center; gap: 12px; padding: 0 0.3rem 1rem; }
    .dv-dots { display: inline-flex; gap: 5px; }
    .dv-dots i { width: 9px; height: 9px; border-radius: 50%; background: rgba(255,255,255,0.14); }
    .dv-term-title { font-size: 0.76rem; font-weight: 600; color: rgba(255,255,255,0.6); flex: 1; }
    .dv-pill { font-size: 0.6rem; font-weight: 800; letter-spacing: 0.4px; color: #4ade80; background: rgba(16,185,129,0.16); padding: 4px 9px; border-radius: 100px; }
    .dv-code { margin: 0; overflow-x: auto; }
    .dv-code code { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 0.76rem; line-height: 1.7; color: rgba(255,255,255,0.8); white-space: pre; }
    .c-prompt { color: #4ade80; font-weight: 700; }
