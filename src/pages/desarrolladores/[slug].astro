        const elB1 = document.querySelector('.dbm-el-m1');
        if (elB1 && !reduced) {
            const tabs = elB1.querySelectorAll('.dbm-el-tabs span');
            const code = document.getElementById('elCode');
            const snippets = [
                '<span class="dbm-jtag">&lt;script src=</span><span class="dbm-jstr">"…/embed.js"</span><span class="dbm-jtag">&gt;</span>',
                'import { CordCotizador } from <span class="dbm-jstr">\'@flouviahq/elements/react\'</span>',
                '<span class="dbm-jtag">&lt;cord-cotizador</span> token=<span class="dbm-jstr">"…"</span><span class="dbm-jtag">&gt;</span>',
            ];
            let i = 0;
            ScrollTrigger.create({ trigger: elB1, start: 'top 88%', once: true,
                onEnter: () => {
                    gsap.timeline({ repeat: -1, repeatDelay: 1.4 }).call(() => {
                        tabs.forEach((t, k) => t.classList.toggle('dbm-seg-on', k === i));
                        if (code) { code.style.opacity = '0'; setTimeout(() => { code.innerHTML = snippets[i]; code.style.opacity = '1'; }, 180); }
                        i = (i + 1) % snippets.length;
                    }).to({}, { duration: 1.4 });
                } });
        }
        const elB2 = document.querySelector('.dbm-el-m2');
        if (elB2 && !reduced) {
            const cursor = document.getElementById('elCursor');
            const approve = document.getElementById('elApprove');
            const badge = document.getElementById('elBadge');
            const evt = elB2.querySelector('.dbm-el2-event');
            ScrollTrigger.create({ trigger: elB2, start: 'top 88%', once: true,
                onEnter: () => {
                    gsap.timeline({ repeat: -1, repeatDelay: 1.8 })
                      .set(cursor, { x: 14, y: 16, opacity: 0 })
                      .set(evt, { opacity: 0.35 })
                      .call(() => { if (badge) { badge.textContent = isEn ? 'Review' : 'Revisar'; badge.style.color = ''; badge.style.background = ''; } })
                      .to(cursor, { opacity: 1, duration: 0.3 })
                      .to(cursor, { x: 0, y: 0, duration: 0.6, ease: 'power2.inOut' })
                      .to(approve, { scale: 0.95, duration: 0.1, yoyo: true, repeat: 1 })
                      .call(() => { if (badge) { badge.textContent = isEn ? 'Approved' : 'Aprobada'; badge.style.color = '#059669'; badge.style.background = 'rgba(16,185,129,0.12)'; } })
                      .fromTo(approve, { boxShadow: '0 0 0 0 rgba(16,185,129,0.5)' }, { boxShadow: '0 0 0 8px rgba(16,185,129,0)', duration: 0.7 })
                      .to(cursor, { opacity: 0, duration: 0.3 }, '<')
                      .to(evt, { opacity: 1, duration: 0.4 }, '-=0.2')
                      .to({}, { duration: 1.6 });
                } });
        }
    });
</script>

