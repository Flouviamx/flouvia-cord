                      .to({}, { duration: 1.6 })
                      .to(revoke, { scale: 0.9, duration: 0.12, yoyo: true, repeat: 1, ease: 'power2.in' })
                      .call(() => { if (key) key.classList.add('dbm-key-revoked'); if (keyTag) { keyTag.textContent = 'Revocada'; keyTag.className = 'dbm-tg dbm-tg-red'; } })
                      .to({}, { duration: 0.35 })
                      .call(() => { if (status) { status.textContent = '401 Unauthorized'; status.classList.add('dbm-status-fail'); } })
                      .fromTo(status, { scale: 0.85 }, { scale: 1, duration: 0.3, ease: 'back.out(1.8)' })
                      .to({}, { duration: 1.6 });
                } });
        }

        // API 2 — los endpoints en JSON: el cuerpo y el total cambian por pestaña (loop).
        const apiB2 = document.querySelector('.dbm-api-m2');
        if (apiB2 && !reduced) {
            const tabs = apiB2.querySelectorAll('.dbm-api-tabs span');
            const pre = document.getElementById('apiJson');
            const code = pre ? pre.querySelector('code') : null;
            const totalEl = document.getElementById('apiMetaTotal');
            const nameEl = document.getElementById('apiEndpointName');
            const snaps = [
                { name: 'cotizaciones', body: '{\n  <span class="dbm-jkey">"folio"</span>: <span class="dbm-jstr">"COT-0149"</span>,\n  <span class="dbm-jkey">"cliente"</span>: <span class="dbm-jstr">"Distribuidora El Zarco"</span>,\n  <span class="dbm-jkey">"status"</span>: <span class="dbm-jstr">"sent"</span>,\n  <span class="dbm-jkey">"total"</span>: <span class="dbm-jnum dbm-hl-target">196469.2</span>\n}', total: 'total 412' },
                { name: 'clientes', body: '{\n  <span class="dbm-jkey">"empresa"</span>: <span class="dbm-jstr">"Distribuidora El Zarco"</span>,\n  <span class="dbm-jkey">"rfc"</span>: <span class="dbm-jstr">"DEZ981123QX1"</span>,\n  <span class="dbm-jkey">"terminos"</span>: <span class="dbm-jstr">"net30"</span>,\n  <span class="dbm-jkey">"credito"</span>: <span class="dbm-jnum dbm-hl-target">500000</span>\n}', total: 'total 318' },
                { name: 'productos', body: '{\n  <span class="dbm-jkey">"sku"</span>: <span class="dbm-jstr">"CEM-050"</span>,\n  <span class="dbm-jkey">"nombre"</span>: <span class="dbm-jstr">"Cemento gris 50kg"</span>,\n  <span class="dbm-jkey">"precio"</span>: <span class="dbm-jnum dbm-hl-target">182</span>,\n  <span class="dbm-jkey">"costo"</span>: <span class="dbm-jnum">134</span>\n}', total: 'total 248' },
                { name: 'cobranza', body: '{\n  <span class="dbm-jkey">"vencido"</span>: <span class="dbm-jnum dbm-hl-target">412300</span>,\n  <span class="dbm-jkey">"dso"</span>: <span class="dbm-jnum">47</span>,\n  <span class="dbm-jkey">"exposicion"</span>: <span class="dbm-jstr">"alta"</span>\n}', total: 'aging 4' },
            ];
            let i = 0;
            ScrollTrigger.create({ trigger: apiB2, start: 'top 88%', once: true,
                onEnter: () => {
                    gsap.timeline({ repeat: -1, repeatDelay: 1.1 }).call(() => {
                        tabs.forEach((t, k) => t.classList.toggle('dbm-seg-on', k === i));
                        if (code) code.innerHTML = snaps[i].body;
                        if (totalEl) totalEl.textContent = snaps[i].total;
                        if (nameEl) nameEl.textContent = snaps[i].name;
                        const hl = pre ? pre.querySelector('.dbm-hl-target') : null;
                        if (hl) gsap.fromTo(hl, { color: '#b45309' }, { color: '#059669', duration: 0.5, yoyo: true, repeat: 1 });
                        i = (i + 1) % snaps.length;
                    }).to({}, { duration: 1.4 });
                } });
        }

        // MCP 0 — el transporte (HTTP ↔ SSE) alterna.
        const mcpB0 = document.querySelector('.dbm-mcp-m0');
        if (mcpB0 && !reduced) {
            const t0 = document.getElementById('mcpT0');
            const t1 = document.getElementById('mcpT1');
            ScrollTrigger.create({ trigger: mcpB0, start: 'top 88%', once: true,
                onEnter: () => {
                    let on = 0;
                    gsap.timeline({ repeat: -1, repeatDelay: 1.8, delay: 1 }).call(() => {
                        on = on ? 0 : 1;
                        if (t0) t0.classList.toggle('dbm-seg-on', on === 0);
                        if (t1) t1.classList.toggle('dbm-seg-on', on === 1);
                    }).to({}, { duration: 1.8 });
                } });
        }

        // MCP 1 — Cord consulta el CRM: el dot cruza y el log se enciende (loop).
        const mcpB1 = document.querySelector('.dbm-mcp-m1');
        if (mcpB1 && !reduced) {
            const dot = document.getElementById('mcpClientDot');
            const logs = document.querySelectorAll('#mcpClientLog > div');
            ScrollTrigger.create({ trigger: mcpB1, start: 'top 88%', once: true,
                onEnter: () => {
                    gsap.timeline({ repeat: -1, repeatDelay: 1.6 })
                        .set(dot, { left: '0%', opacity: 0 })
                        .set(logs, { opacity: 0, y: 6 })
                        .to(dot, { opacity: 1, duration: 0.2 })
                        .to(dot, { left: '100%', duration: 0.85, ease: 'power1.inOut' })
                        .to(dot, { opacity: 0, duration: 0.2 })
                        .to(logs, { opacity: 1, y: 0, stagger: 0.24, duration: 0.4, ease: 'power2.out' }, '-=0.5')
                        .to({}, { duration: 1.4 });
                } });
        }

        // MCP 2 — gobernanza: el permiso del CRM externo alterna sin acceso ↔ permitido (loop).
        const mcpB2 = document.querySelector('.dbm-mcp-m2');
        if (mcpB2 && !reduced) {
            const pill = document.getElementById('mcpGovPill');
            ScrollTrigger.create({ trigger: mcpB2, start: 'top 88%', once: true,
