                onEnter: () => {
                    gsap.timeline({ repeat: -1, repeatDelay: 1.4 })
                      .set(dr, { left: '0%', opacity: 0 })
                      .set(dl, { left: '100%', opacity: 0 })
                      .to(dr, { opacity: 1, duration: 0.2 })
                      .to(dr, { left: '100%', duration: 0.75, ease: 'power1.inOut' })
                      .to(dr, { opacity: 0, duration: 0.2 })
                      .to(dl, { opacity: 1, duration: 0.2 }, '+=0.35')
                      .to(dl, { left: '0%', duration: 0.75, ease: 'power1.inOut' })
                      .to(dl, { opacity: 0, duration: 0.2 })
                      .to({}, { duration: 1.2 });
                } });
        }

        // API 1 — una llave revocable: 200 OK → "Revocar" → 401 (loop).
        const apiB1 = document.querySelector('.dbm-api-m1');
        if (apiB1 && !reduced) {
            const key = document.getElementById('apiKey');
            const status = document.getElementById('apiAuthStatus');
            const revoke = document.getElementById('apiRevoke');
            const keyTag = document.getElementById('apiKeyTag');
            ScrollTrigger.create({ trigger: apiB1, start: 'top 88%', once: true,
                onEnter: () => {
                    gsap.timeline({ repeat: -1, repeatDelay: 1.6 })
