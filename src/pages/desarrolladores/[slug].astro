---
// Página para desarrolladores — una por tema (api, mcp). Mismo lenguaje visual y
// de animación que /producto/* (PageAnims, masked-title, reveal, editorial), pero
// con mockups de CÓDIGO/CHAT en vez de mockups de cotización. Copy en
// src/lib/desarrolladores.ts.
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import PageAnims from '../../components/landing/PageAnims.astro';
import DevBlockMockup from '../../components/desarrolladores/DevBlockMockup.astro';
import TrustGrid from '../../components/desarrolladores/TrustGrid.astro';
import FaqAccordion from '../../components/landing/FaqAccordion.astro';
import PriceAuroraBg from '../../components/landing/PriceAuroraBg.jsx';
import { DEV_PAGES } from '../../lib/desarrolladores';
import { DEV_PAGES_EN } from '../../lib/desarrolladores.en';
import { getLangFromUrl } from '../../i18n/utils';

export function getStaticPaths() {
    // 'elements' NO genera página aquí: se consolidó en /elements y esta ruta hace 301
    // (ver redirects en astro.config.mjs). El dato sigue en DEV_PAGES como fuente única.
    return DEV_PAGES.filter((p) => p.slug !== 'elements').map((p) => ({ params: { slug: p.slug }, props: { page: p } }));
}

const lang = getLangFromUrl(Astro.url);
const isEn = Astro.props.isEn || lang === 'en';
const currentPage = Astro.props.page || Astro.props.page;
const page = isEn && currentPage ? DEV_PAGES_EN.find((p) => p.slug === currentPage.slug) || currentPage : currentPage;
const otra = (isEn ? DEV_PAGES_EN : DEV_PAGES).find((p) => p.slug !== page.slug)!;

// Datos estructurados (jul 2026, auditoría SEO/AI-SEO — mismo criterio que
// /producto/*): esta plantilla no tenía metaTitle/metaDescription propios
// (título genérico `${nav} — Cord`), ni FAQPage, ni BreadcrumbList.
const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: page.faqs.map((f: { q: string; a: string }) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
};
const SITE = 'https://cordhq.app';
const base = isEn ? `${SITE}/en` : SITE;
const breadcrumbSchema = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Cord', item: `${base}/` },
        { '@type': 'ListItem', position: 2, name: page.nav, item: `${base}/desarrolladores/${page.slug}` },
    ],
};
---

<Layout title={page.metaTitle ?? `${page.nav} — Cord`} description={page.metaDescription ?? page.sub}>
    <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
    <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
    <Nav />
    <main>
        <!-- ── HERO ── -->
        <section class="pp-hero">
            <div class="pp-hero-mesh" aria-hidden="true"></div>
            <div class="pp-hero-inner">
                <div class="pp-hero-text">
                    <h1 class="pp-title masked-title" set:html={page.titulo} />
                    <p class="pp-sub reveal">{page.sub}</p>
                    <div class="pp-actions reveal">
                        <a href="/registro" class="pp-btn-primary">
                            <span>{isEn ? 'Start for free' : 'Empezar gratis'}</span>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </a>
                        <a href="/precios" class="pp-btn-ghost">{isEn ? 'View plans' : 'Ver planes'}</a>
                    </div>
                    <p class="pp-plan reveal">{page.plan}</p>
                </div>

                <!-- Mockup del hero (panel de código CLARO estilo Stripe/GitHub Docs — toolbar real, sin dots macOS) -->
                <div class="pp-hero-visual">
                <div class="pp-mockup-wrap reveal-mockup">
                    <div class="pp-glow" aria-hidden="true"></div>
                    <div class="pp-mockup">
                        {page.slug === 'api' && (
                            <div class="dv-term dv-api">
                                <div class="dv-term-bar">
                                    <span class="dv-term-title"><span class="dv-method">POST</span> /api/v1/cotizaciones</span>
                                    <span class="dv-term-stat" id="apiStat">{isEn ? 'sending…' : 'enviando…'}</span>
                                </div>
                                <div class="dv-term-body">
                                    <pre class="dv-req"><code><span class="dv-line"><span class="c-prompt">$</span> curl -X POST <span class="c-path">cordhq.app/api/v1/cotizaciones</span> \</span>
<span class="dv-line">  -H <span class="c-str">"Authorization: Bearer </span><span class="c-key2">sk_live_8f2a••••</span><span class="c-str">"</span> \</span>
<span class="dv-line">  -H <span class="c-str">"Content-Type: application/json"</span> \</span>
<span class="dv-line">  -d <span class="c-str">'{`{`} "cliente_id": "c_8f2a", "vigencia_dias": 15,</span></span>
<span class="dv-line">    <span class="c-str">"items": [{`{`} "sku": "CEM-050", "cantidad": 340 {`}`}] {`}`}'</span></span></code></pre>
                                    <div class="dv-req-div"><span class="dv-sending" id="apiSending">● {isEn ? 'sending' : 'enviando'}</span></div>
                                    <pre class="dv-res"><code><span class="dv-line">{`{`}</span>
<span class="dv-line">  <span class="c-key">"id"</span>: <span class="c-str">"q_19a4f…"</span>,</span>
<span class="dv-line">  <span class="c-key">"folio"</span>: <span class="c-str">"COT-0149"</span>,</span>
<span class="dv-line">  <span class="c-key">"cliente"</span>: <span class="c-str">"{isEn ? 'El Zarco Distribution' : 'Distribuidora El Zarco'}"</span>,</span>
<span class="dv-line">  <span class="c-key">"status"</span>: <span class="c-str">"sent"</span>,</span>
<span class="dv-line">  <span class="c-key">"vigencia"</span>: <span class="c-str">"2026-07-17"</span>,</span>
<span class="dv-line">  <span class="c-key">"link_publico"</span>: <span class="c-str">"cord.mx/q/8f2a"</span>,</span>
<span class="dv-line">  <span class="c-key">"subtotal"</span>: <span class="c-num">169370.0</span>,</span>
<span class="dv-line">  <span class="c-key">"iva"</span>: <span class="c-num">27099.2</span>,</span>
<span class="dv-line">  <span class="c-key">"total"</span>: <span class="c-num">196469.2</span></span>
<span class="dv-line">{`}`}</span></code></pre>
                                    <div class="dv-term-foot"><span id="apiLatency">142 ms · {isEn ? 'MX region' : 'región MX'}</span><span class="c-mut">~500 req/min · v1</span></div>
                                </div>
                            </div>
                        )}
                        {page.slug === 'mcp' && (
                            <div class="dv-term dv-mcp">
                                <div class="dv-term-bar">
                                    <span class="dv-term-title">tools/call · cordhq.app/api/mcp</span>
                                    <span class="dv-term-stat dv-stat-ok" id="mcpStat">JSON-RPC 2.0</span>
                                </div>
                                <div class="dv-term-body">
                                    <div class="dv-mcp-flow">
                                        <div class="dv-mcp-node dv-mcp-ai">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v3M12 18v3M3 12h3M18 12h3" fill="none"/><circle cx="12" cy="12" r="3.4" fill="currentColor" fill-opacity="0.2"/></svg>
                                            <span>Claude · IA</span>
                                        </div>
                                        <div class="dv-mcp-wire dv-wire-1"><span class="dv-mcp-dot" id="mcpD1"></span><span class="dv-mcp-chip" id="mcpChip1">cartera_vencida</span></div>
                                        <div class="dv-mcp-node dv-mcp-cord" id="mcpCord"><img src="/imgs/logo-cord-navy.png" alt="Cord" /></div>
                                        <div class="dv-mcp-wire dv-wire-2"><span class="dv-mcp-dot dv-dot-g" id="mcpD2"></span></div>
                                        <div class="dv-mcp-node dv-mcp-ext">{isEn ? 'Your CRM' : 'Tu CRM'}</div>
                                    </div>
                                    <pre class="dv-res dv-mcp-res"><code><span class="dv-line dv-mcp-l" data-mcp="0"><span class="c-mut">→</span> tools/call <span class="c-key">"cartera_vencida"</span></span>
<span class="dv-line dv-mcp-l" data-mcp="1"><span class="c-mut">→</span> get_saldo(<span class="c-str">"El Zarco"</span>) · <span class="c-mut">{isEn ? 'your CRM' : 'tu CRM'}</span></span>
<span class="dv-line dv-mcp-l" data-mcp="2"><span class="c-key">"vencido"</span>: <span class="c-num">412300</span>, <span class="c-key">"dso"</span>: <span class="c-num">47</span></span>
<span class="dv-line dv-mcp-l" data-mcp="3"><span class="c-ok">✓</span> {isEn ? 'the AI drafts the quote with full context' : 'la IA arma la cotización con contexto'}</span></code></pre>
                                    <div class="dv-term-foot"><span>{isEn ? 'bidirectional · with your permission' : 'bidireccional · con tu permiso'}</span><span class="c-mut">7 tools</span></div>
                                </div>
                            </div>
                        )}
                        {page.slug === 'elements' && (
                            <div class="dv-term dv-api">
                                <div class="dv-term-bar">
                                    <span class="dv-term-title">portal.tucliente.com</span>
                                    <span class="dv-term-stat dv-stat-ok">embed.js</span>
                                </div>
                                <div class="dv-term-body">
                                    <pre class="dv-req"><code><span class="dv-line"><span class="c-mut">// {isEn ? 'one line — mount it anywhere' : 'una línea — móntalo donde sea'}</span></span>
<span class="dv-line"><span class="c-tag">&lt;script src=</span><span class="c-str">"cord.mx/embed.js"</span><span class="c-tag">&gt;&lt;/script&gt;</span></span>
<span class="dv-line"><span class="c-tag">&lt;div</span> <span class="c-key">data-cord-token</span>=<span class="c-str">"8f2a…"</span><span class="c-tag">&gt;&lt;/div&gt;</span></span></code></pre>
                                    <div class="dv-req-div"></div>
                                    <pre class="dv-res"><code><span class="dv-line"><span class="c-mut">→</span> {`{`} <span class="c-key">"event"</span>: <span class="c-str">"ready"</span>, <span class="c-key">"height"</span>: <span class="c-num">412</span> {`}`}</span>
<span class="dv-line"><span class="c-mut">→</span> {`{`} <span class="c-key">"event"</span>: <span class="c-str">"viewed"</span>, <span class="c-key">"folio"</span>: <span class="c-str">"COT-0149"</span> {`}`}</span>
<span class="dv-line"><span class="c-mut">→</span> {`{`} <span class="c-key">"event"</span>: <span class="c-str">"approved"</span>, <span class="c-key">"total"</span>: <span class="c-num">196469.2</span> {`}`}</span></code></pre>
                                    <div class="dv-term-foot"><span>{isEn ? 'secure iframe · your brand' : 'iframe seguro · tu marca'}</span><span class="c-mut">frame-ancestors</span></div>
                                </div>
                            </div>
                        )}
                        {page.slug === 'fx' && (
                            <div class="dv-term dv-api dv-t-emerald">
                                <div class="dv-term-bar">
                                    <span class="dv-term-title"><span class="dv-method dv-m-get">GET</span> /api/v1/fx/rates?base=USD&target=MXN</span>
                                    <span class="dv-term-stat dv-stat-ok">200 OK</span>
                                </div>
                                <div class="dv-term-body">
                                    <pre class="dv-res"><code><span class="dv-line">{`{`}</span>
<span class="dv-line">  <span class="c-key">"source"</span>: <span class="c-str">"banxico_fix"</span>,</span>
<span class="dv-line">  <span class="c-key">"base"</span>: <span class="c-str">"USD"</span>, <span class="c-key">"target"</span>: <span class="c-str">"MXN"</span>,</span>
<span class="dv-line">  <span class="c-key">"spot"</span>: <span class="c-num">18.4520</span>,</span>
<span class="dv-line">  <span class="c-key">"buffer_pct"</span>: <span class="c-num">2.0</span>,</span>
<span class="dv-line">  <span class="c-key">"rate_locked"</span>: <span class="c-num">18.8210</span>,</span>
<span class="dv-line">  <span class="c-key">"lock_until"</span>: <span class="c-str">"2026-07-26"</span>,</span>
<span class="dv-line">  <span class="c-key">"timestamp"</span>: <span class="c-str">"2026-06-26T12:00:00Z"</span></span>
<span class="dv-line">{`}`}</span></code></pre>
                                    <div class="dv-term-foot"><span>{isEn ? 'rate frozen for 30 days' : 'tasa congelada 30 días'}</span><span class="c-mut">Banxico FIX</span></div>
                                </div>
                            </div>
                        )}
                        {page.slug === 'integraciones' && (
                            <div class="dv-term dv-api dv-t-emerald">
                                <div class="dv-term-bar">
                                    <span class="dv-term-title"><span class="dv-method">POST</span> tu-erp.com/webhooks/cord</span>
                                    <span class="dv-term-stat dv-stat-ok">200 OK</span>
                                </div>
                                <div class="dv-term-body">
                                    <pre class="dv-req"><code><span class="dv-line"><span class="c-key">X-Cord-Event</span>: <span class="c-str">quote.paid</span></span>
<span class="dv-line"><span class="c-key">X-Cord-Signature</span>: <span class="c-str">sha256=4f1ad8c…</span></span>
<span class="dv-line"><span class="c-key">Content-Type</span>: <span class="c-str">application/json</span></span></code></pre>
                                    <div class="dv-req-div"></div>
                                    <pre class="dv-res"><code><span class="dv-line">{`{`}</span>
<span class="dv-line">  <span class="c-key">"event"</span>: <span class="c-str">"quote.paid"</span>,</span>
<span class="dv-line">  <span class="c-key">"created_at"</span>: <span class="c-str">"2026-06-26T12:41Z"</span>,</span>
<span class="dv-line">  <span class="c-key">"data"</span>: {`{`}</span>
<span class="dv-line">    <span class="c-key">"folio"</span>: <span class="c-str">"COT-0149"</span>,</span>
<span class="dv-line">    <span class="c-key">"status"</span>: <span class="c-str">"paid"</span>,</span>
<span class="dv-line">    <span class="c-key">"total"</span>: <span class="c-num">196469.2</span>,</span>
<span class="dv-line">    <span class="c-key">"cliente"</span>: <span class="c-str">"{isEn ? 'El Zarco Distribution' : 'Distribuidora El Zarco'}"</span></span>
<span class="dv-line">  {`}`}</span>
<span class="dv-line">{`}`}</span></code></pre>
                                    <div class="dv-term-foot"><span>{isEn ? 'delivered · auto-retry on failure' : 'entregado · reintento auto si falla'}</span><span class="c-mut">HMAC-SHA256</span></div>
                                </div>
                            </div>
                        )}
                        {page.slug === 'fiscal' && (
                            <div class="dv-term dv-api dv-t-indigo">
                                <div class="dv-term-bar">
                                    <span class="dv-term-title"><span class="dv-method dv-m-indigo">POST</span> /api/v1/tax/calculate</span>
                                    <span class="dv-term-stat dv-stat-indigo">200 OK</span>
                                </div>
                                <div class="dv-term-body">
                                    <pre class="dv-res"><code><span class="dv-line">{`{`}</span>
<span class="dv-line">  <span class="c-key">"region"</span>: <span class="c-str">"MX-NLE"</span>,</span>
<span class="dv-line">  <span class="c-key">"receptor_rfc"</span>: <span class="c-str">"DEZ981123QX1"</span>,</span>
<span class="dv-line">  <span class="c-key">"subtotal"</span>: <span class="c-num">169370.00</span>,</span>
<span class="dv-line">  <span class="c-key">"taxes"</span>: [</span>
<span class="dv-line">    {`{`} <span class="c-key">"type"</span>: <span class="c-str">"IVA"</span>, <span class="c-key">"rate"</span>: <span class="c-num">0.16</span>, <span class="c-key">"amount"</span>: <span class="c-num">27099.20</span> {`}`},</span>
<span class="dv-line">    {`{`} <span class="c-key">"type"</span>: <span class="c-str">"RET_ISR"</span>, <span class="c-key">"rate"</span>: <span class="c-num">0.0125</span>, <span class="c-key">"amount"</span>: <span class="c-num">-2117.13</span> {`}`}</span>
<span class="dv-line">  ],</span>
<span class="dv-line">  <span class="c-key">"cfdi_use"</span>: <span class="c-str">"G03"</span>,</span>
<span class="dv-line">  <span class="c-key">"total"</span>: <span class="c-num">194352.07</span></span>
<span class="dv-line">{`}`}</span></code></pre>
                                    <div class="dv-term-foot"><span>{isEn ? 'local & global taxes' : 'impuestos locales, globales'}</span><span class="c-mut">CFDI 4.0</span></div>
                                </div>
                            </div>
                        )}
                    </div>
                </div>
                </div>{/* /pp-hero-visual */}
            </div>
        </section>

        <!-- ── BLOQUES (bento de tarjetas — mismo patrón que /producto) ── -->
        <section class="pp-bento">
            {page.blocks.map((b, i) => {
                const dark = i === 0;
                return (
                <article class={`pp-bcard pp-bcard-${i}${dark ? ' pp-bcard-dark' : ''}`}>
                    {dark && <PriceAuroraBg client:only="react" />}
                    <div class="pp-bcard-text">
                        <p class="pp-bcard-eyebrow">{b.eyebrow}</p>
                        <h2 class="pp-bcard-h2 masked-title" set:html={b.titulo} />
                        <p class="pp-bcard-copy reveal">{b.copy}</p>
                        <ul class="pp-bcard-bullets">
                            {b.bullets.map((bl) => (
                                <li class="reveal">
                                    <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
                                    <span set:html={bl} />
                                </li>
                            ))}
                        </ul>
                    </div>
                    <div class="pp-bcard-visual">
                        <DevBlockMockup slug={page.slug} index={i} />
                    </div>
                </article>
                );
            })}
        </section>

        {page.trust && <TrustGrid trust={page.trust} />}

        <FaqAccordion
            faqs={page.faqs}
            eyebrow={isEn ? 'FREQUENTLY ASKED QUESTIONS' : 'PREGUNTAS FRECUENTES'}
            title={isEn ? `What developers ask about ${page.nav}.` : `Lo que preguntan los developers sobre ${page.nav}.`}
            id={`dev-${page.slug}`}
            class="dv-faq-acc"
        />

        <!-- ── CROSS-LINK (estilo lista, no cards) — última sección antes del footer ── -->
        <section class="dv-more">
            <a href={`/desarrolladores/${otra.slug}`} class="dv-more-row reveal">
                <div>
                    <span class="dv-more-eyebrow">{otra.eyebrow}</span>
                    <b>{otra.nav}</b>
                    <i>{otra.sub.split('.')[0]}.</i>
                </div>
                <span class="dv-more-arrow">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
            </a>
        </section>
    </main>

    <Footer ctaTitle={page.cta.titulo.replace(/\. /, '.<br />')} ctaSub={page.cta.sub} />
    <PageAnims />
</Layout>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    window.addEventListener('load', () => {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const isEn = document.documentElement.lang === 'en';

        // ── Entrada limpia de los BlockMockups del bento: fade + rise (igual a /producto) ──
        if (!reduced) {
            document.querySelectorAll('.pp-bcard-visual').forEach((block) => {
                const win = block.querySelector('.dbm-app, .dbm-term');
                if (!win) return;
                gsap.set(win, { y: 26, opacity: 0 });
                ScrollTrigger.create({ trigger: block, start: 'top 88%', once: true,
                    onEnter: () => {
                        gsap.to(win, { y: 0, opacity: 1, duration: 0.9, ease: 'power3.out', clearProps: 'transform' });
                        // cascada de filas internas
                        const rows = win.querySelectorAll('.dbm-kv, .dbm-toolrow, .dbm-scope, .dbm-log > div:not([style]), .dbm-sync-row');
                        gsap.from(rows, { opacity: 0, y: 8, duration: 0.5, stagger: 0.05, delay: 0.15, ease: 'power2.out' });
                    } });
            });
        }

        // ════════════════════════════ HERO ════════════════════════════

        // HERO API — request → response: la respuesta JSON entra en streaming y el status salta a 200 OK.
        const apiHero = document.querySelector('.pp-mockup .dv-api');
        if (apiHero && !reduced && document.querySelector('.dv-mcp') === null) {
            const stat = document.getElementById('apiStat');
            const sending = document.getElementById('apiSending');
            const foot = apiHero.querySelector('.dv-term-foot');
            const lines = apiHero.querySelectorAll('.dv-res .dv-line');
            const isDynamic = !!(stat && sending && lines.length);
            if (isDynamic) {
                ScrollTrigger.create({ trigger: apiHero, start: 'top 82%', once: true,
                    onEnter: () => {
                        const tl = gsap.timeline({ repeat: -1, repeatDelay: 2.2 });
                        tl.call(() => { if (stat) { stat.textContent = isEn ? 'sending…' : 'enviando…'; stat.classList.remove('dv-stat-ok'); } })
                          .set(lines, { opacity: 0 })
                          .set(sending, { opacity: 1 })
                          .set(foot, { opacity: 0, y: 4 })
                          .to(sending, { opacity: 0.3, duration: 0.4, yoyo: true, repeat: 2, ease: 'sine.inOut' })
                          .to(lines, { opacity: 1, duration: 0.3, stagger: 0.09, ease: 'power1.out' })
                          .to(sending, { opacity: 0, duration: 0.25 }, '<')
                          .call(() => { if (stat) { stat.textContent = '200 OK'; stat.classList.add('dv-stat-ok'); } })
                          .fromTo(stat, { scale: 0.82 }, { scale: 1, duration: 0.4, ease: 'back.out(1.8)' })
                          .to(foot, { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' }, '<')
                          .to({}, { duration: 2 });
                    } });
            }
        }

        // HERO MCP — loop bidireccional: la IA invoca, Cord consulta el CRM, el contexto regresa (log en vivo).
        const mcpHero = document.querySelector('.dv-mcp');
        if (mcpHero && !reduced) {
            const d1 = document.getElementById('mcpD1');
            const d2 = document.getElementById('mcpD2');
            const chip = document.getElementById('mcpChip1');
            const cord = document.getElementById('mcpCord');
            const logs = mcpHero.querySelectorAll('.dv-mcp-l');
