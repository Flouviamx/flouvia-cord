                      .to(d1, { left: '100%', duration: 0.7, ease: 'power1.inOut' })
                      .to(d1, { opacity: 0, duration: 0.2 })
                      .call(() => { if (cord) cord.classList.add('dv-mcp-active'); })
                      .to(logs[1], { opacity: 1, x: 0, duration: 0.35 })
                      .to(d2, { opacity: 1, duration: 0.2 }, '+=0.1')
                      .to(d2, { left: '100%', duration: 0.7, ease: 'power1.inOut' })
                      .to(d2, { opacity: 0, duration: 0.2 })
                      .to(logs[2], { opacity: 1, x: 0, duration: 0.35 })
                      .call(() => { if (cord) cord.classList.remove('dv-mcp-active'); }, undefined, '+=0.3')
                      .to(logs[3], { opacity: 1, x: 0, duration: 0.4, ease: 'back.out(1.4)' })
                      .to({}, { duration: 1.8 })
                      .to([chip], { opacity: 0, duration: 0.4 });
                } });
        }
        // (Los heroes de fx/fiscal/integraciones/elements son screenshots estáticos — no requieren JS.)

        // ═══════════════════════ BLOCK MOCKUPS (motion en loop) ═══════════════════════

        // API 0 — sync ERP ↔ Cord: el dot entrante viaja a la derecha, el saliente regresa.
        const apiB0 = document.querySelector('.dbm-api-m0');
        if (apiB0 && !reduced) {
            const dr = document.getElementById('apiSyncR');
            const dl = document.getElementById('apiSyncL');
