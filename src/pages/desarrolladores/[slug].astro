                    const rates = ['1 USD = $18.4520', '1 USD = $18.4488', '1 USD = $18.4531', '1 USD = $18.4506'];
                    let i = 0;
                    gsap.timeline({ repeat: -1, repeatDelay: 1.6 }).call(() => {
                        if (rate) { rate.textContent = rates[i % rates.length]; gsap.fromTo(rate, { color: '#34d399' }, { color: '#94a3b8', duration: 0.8 }); }
                        i++;
                    }).to({}, { duration: 1.6 });
                } });
        }

        // ELEMENTS 0/1/2 — animación de los bloques de /desarrolladores/elements.
        const elB0 = document.querySelector('.dbm-el-m0');
        if (elB0 && !reduced) {
            const skel = document.getElementById('elSkel');
            const mini = document.getElementById('elMini');
            if (skel) gsap.to(skel, { backgroundPosition: '-200% 0', duration: 1.2, ease: 'none', repeat: -1 });
            ScrollTrigger.create({ trigger: elB0, start: 'top 88%', once: true,
                onEnter: () => {
                    gsap.timeline({ repeat: -1, repeatDelay: 1.6 })
                      .set(skel, { opacity: 1 }).set(mini, { opacity: 0 })
                      .to({}, { duration: 1.1 })
                      .to(skel, { opacity: 0, duration: 0.3 })
                      .to(mini, { opacity: 1, duration: 0.4, ease: 'power2.out' }, '<')
                      .to({}, { duration: 1.4 });
                } });
