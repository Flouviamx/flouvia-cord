---
// Blog — Layout Editorial tipo Stripe / Linear
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/landing/Nav.astro';
import Footer from '../components/landing/Footer.astro';
import PageAnims from '../components/landing/PageAnims.astro';

const FEATURED_POST = {
    id: 'error-pdf-ventas-b2b',
    title: 'Por qué enviar cotizaciones en PDF te está costando cierres en el sector corporativo',
    excerpt: 'Analizamos más de 10,000 transacciones B2B y descubrimos cómo la fricción de descargar, imprimir y firmar PDFs retrasa las ventas. Las cotizaciones interactivas aumentan la conversión en un 32%.',
    category: 'Ventas B2B',
    date: '18 Jun 2026',
    author: {
        name: 'André Valle',
        avatar: 'https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?ixlib=rb-4.0.3&auto=format&fit=crop&w=150&q=80'
    },
    img: 'https://images.unsplash.com/photo-1556761175-5973dc0f32e7?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80'
};

const POSTS = [
    {
        id: 'guia-cfdi-4-0-2026',
        title: 'Guía Definitiva: CFDI 4.0 para mayoristas',
        category: 'Fiscal',
        date: '12 Jun 2026',
        img: 'https://images.unsplash.com/photo-1450101499163-c8848c66ca85?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'
    },
    {
        id: 'credito-b2b-net30',
        title: 'Cómo ofrecer crédito (Net 30) sin quebrar',
        category: 'Finanzas',
        date: '05 Jun 2026',
        img: 'https://images.unsplash.com/photo-1554224155-8d04cb21cd6c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'
    },
    {
        id: 'ia-en-ventas',
        title: 'La IA en cobranza B2B: tu nuevo agente',
        category: 'Tecnología',
        date: '28 May 2026',
        img: 'https://images.unsplash.com/photo-1485827404703-89b55fcc595e?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'
    },
    {
        id: 'listas-de-precios-b2b',
        title: 'Manejo de listas de precios: de Excel a Cord',
        category: 'Operaciones',
        date: '15 May 2026',
        img: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'
    },
    {
        id: 'mcp-agentes-ia',
        title: 'Por qué conectamos Cord a Claude vía MCP',
        category: 'Tecnología',
        date: '02 May 2026',
        img: 'https://images.unsplash.com/photo-1518770660439-4636190af475?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'
    }
];

const CATEGORIES = ['Todos', 'Ventas B2B', 'Finanzas', 'Operaciones', 'Tecnología', 'Fiscal'];
---

<Layout
    title="Blog | Cord"
    description="Artículos, guías y estrategias sobre ventas B2B, facturación, y cómo acelerar tu flujo de ingresos."
>
    <Nav />
    
    <main class="editorial-main">
        <!-- Encabezado Ultra Minimalista -->
        <header class="editorial-header reveal">
            <h1 class="editorial-title">Cord Blog</h1>
            
            <!-- Tabs en lugar de Pills -->
            <nav class="editorial-tabs" id="blog-filters">
                {CATEGORIES.map((cat, i) => (
                    <button class={`editorial-tab ${i === 0 ? 'active' : ''}`} data-filter={cat === 'Todos' ? 'all' : cat}>
                        {cat}
                    </button>
                ))}
            </nav>
        </header>

        <!-- Bento Grid Editorial -->
        <section class="editorial-bento-grid" id="blog-grid">
            
            <!-- HERO: Toma 2 columnas en desktop -->
            <article class="bento-cell hero-cell reveal" data-category={FEATURED_POST.category}>
                <a href={`/blog/${FEATURED_POST.id}`} class="bento-link">
                    <div class="bento-image-wrapper">
                        <img src={FEATURED_POST.img} alt={FEATURED_POST.title} fetchpriority="high" />
                        <div class="bento-tag">{FEATURED_POST.category}</div>
                    </div>
                    <div class="bento-content">
                        <time class="bento-date">{FEATURED_POST.date}</time>
                        <h2 class="hero-post-title">{FEATURED_POST.title}</h2>
                        <p class="hero-post-excerpt">{FEATURED_POST.excerpt}</p>
                        <div class="hero-post-author">
                            <img src={FEATURED_POST.author.avatar} alt={FEATURED_POST.author.name} />
                            <span>Por <strong>{FEATURED_POST.author.name}</strong></span>
                            
                            <div class="editorial-arrow">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            </div>
                        </div>
                    </div>
                </a>
            </article>

            <!-- POSTS SECUNDARIOS -->
            {POSTS.map((post, i) => (
                <article class="bento-cell standard-cell reveal" data-category={post.category} style={`transition-delay: ${(i % 4) * 50}ms`}>
                    <a href={`/blog/${post.id}`} class="bento-link">
                        <div class="bento-image-wrapper">
                            <img src={post.img} alt={post.title} loading="lazy" />
                            <div class="bento-tag">{post.category}</div>
                        </div>
                        <div class="bento-content">
                            <time class="bento-date">{post.date}</time>
                            <h3 class="standard-post-title">{post.title}</h3>
                            <div class="editorial-arrow inline-arrow">
                                <span>Leer</span>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            </div>
                        </div>
                    </a>
                </article>
            ))}
        </section>
    </main>

    <Footer 
        ctaTitle="¿Listo para acelerar tus cierres?"
        ctaSub="Empieza gratis hoy — 5 cotizaciones activas al mes, sin tarjeta."
    />
    <PageAnims />
</Layout>

<script>
    // Filtrado de categorías
    document.addEventListener('DOMContentLoaded', () => {
        const filters = document.querySelectorAll('.editorial-tab');
        const grid = document.getElementById('blog-grid');
        const cards = document.querySelectorAll('.bento-cell');

        if (!filters.length || !grid || !cards.length) return;

        filters.forEach(btn => {
            btn.addEventListener('click', () => {
                filters.forEach(f => f.classList.remove('active'));
                btn.classList.add('active');

                const targetCat = btn.getAttribute('data-filter');

                grid.classList.add('filtering');
                
                setTimeout(() => {
                    cards.forEach(card => {
                        const cat = card.getAttribute('data-category');
                        if (targetCat === 'all' || targetCat === cat) {
                            card.style.display = 'flex';
                        } else {
                            card.style.display = 'none';
                        }
                    });

                    void grid.offsetWidth;
                    grid.classList.remove('filtering');
                }, 300);
            });
        });
    });
</script>

<style>
    /* ==========================================================
       RESET Y BASE EDITORIAL
       ========================================================== */
    .editorial-main {
        background: #fff;
        color: #0a2540; /* Stripe Navy */
        min-height: 100vh;
        padding-top: 6rem;
        font-family: 'Inter', sans-serif;
    }
    :global(html[data-theme="dark"]) .editorial-main {
        background: #000; color: #fff;
    }

    /* ==========================================================
       HEADER MINIMALISTA
       ========================================================== */
    .editorial-header {
        max-width: 1400px;
        margin: 0 auto;
        padding: 4rem 5% 2rem;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }
    @media (min-width: 768px) {
        .editorial-header {
            flex-direction: row;
            justify-content: space-between;
            align-items: flex-end;
            padding: 6rem 5% 3rem;
        }
    }

    .editorial-title {
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 500;
        letter-spacing: -0.04em;
        margin: 0;
        line-height: 1;
        color: #111827;
    }
    :global(html[data-theme="dark"]) .editorial-title { color: #fff; }

    /* TABS (No Pills, raw text with underline) */
    .editorial-tabs {
        display: flex;
        gap: 1.5rem;
        overflow-x: auto;
        scrollbar-width: none;
        border-bottom: 1px solid rgba(0,0,0,0.1);
        padding-bottom: 1rem;
    }
    .editorial-tabs::-webkit-scrollbar { display: none; }
    :global(html[data-theme="dark"]) .editorial-tabs { border-bottom: 1px solid rgba(255,255,255,0.1); }

    .editorial-tab {
        background: transparent;
        border: none;
        padding: 0;
        font-size: 0.9rem;
        font-weight: 500;
        color: #6b7280;
        cursor: pointer;
        white-space: nowrap;
        position: relative;
        transition: color 0.3s;
    }
    :global(html[data-theme="dark"]) .editorial-tab { color: #9ca3af; }

    .editorial-tab:hover { color: #111827; }
    :global(html[data-theme="dark"]) .editorial-tab:hover { color: #fff; }

    .editorial-tab.active {
        color: #111827;
    }
    :global(html[data-theme="dark"]) .editorial-tab.active { color: #fff; }

    .editorial-tab.active::after {
        content: '';
        position: absolute;
        bottom: -1rem; /* match padding-bottom of parent */
        left: 0; right: 0;
        height: 2px;
        background: #111827;
    }
    :global(html[data-theme="dark"]) .editorial-tab.active::after { background: #fff; }

    /* ==========================================================
       BENTO GRID EDITORIAL (Hairline grid lines)
       ========================================================== */
    .editorial-bento-grid {
        max-width: 1400px;
        margin: 0 auto 8rem;
        padding: 0 5%;
        display: grid;
        grid-template-columns: 1fr;
        /* El secreto de este layout: gap 1px y color de fondo para crear las líneas */
        gap: 1px;
        background: rgba(0,0,0,0.1); /* Color de las líneas del grid */
        border: 1px solid rgba(0,0,0,0.1);
        transition: opacity 0.3s;
    }
    :global(html[data-theme="dark"]) .editorial-bento-grid {
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.1);
    }
    
    .editorial-bento-grid.filtering { opacity: 0; }

    @media (min-width: 768px) {
        .editorial-bento-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (min-width: 1100px) {
        .editorial-bento-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    /* ==========================================================
       CELDAS BENTO
       ========================================================== */
    .bento-cell {
        background: #fff;
        display: flex;
        flex-direction: column;
        transition: background 0.4s;
    }
    :global(html[data-theme="dark"]) .bento-cell { background: #050505; }

    .bento-cell:hover {
        background: #f8fafc;
    }
    :global(html[data-theme="dark"]) .bento-cell:hover { background: #0a0a0a; }

    .hero-cell {
        grid-column: 1 / -1;
    }
    @media (min-width: 1100px) {
        .hero-cell {
            grid-column: span 2;
        }
    }

    .bento-link {
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 1.5rem;
    }
    @media (min-width: 768px) {
        .bento-link { padding: 2.5rem; }
    }

    .hero-cell .bento-link {
        flex-direction: column;
    }
    @media (min-width: 768px) {
        .hero-cell .bento-link {
            flex-direction: row;
            gap: 3rem;
            align-items: stretch;
        }
    }

    /* Imagen */
    .bento-image-wrapper {
        position: relative;
        width: 100%;
        aspect-ratio: 16/10;
        overflow: hidden;
        margin-bottom: 2rem;
        background: #f3f4f6;
    }
    :global(html[data-theme="dark"]) .bento-image-wrapper { background: #1f2937; }

    @media (min-width: 768px) {
        .hero-cell .bento-image-wrapper {
            width: 55%;
            margin-bottom: 0;
            height: 100%;
            min-height: 400px;
        }
    }

    .bento-image-wrapper img {
        width: 100%; height: 100%; object-fit: cover;
        transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .bento-cell:hover .bento-image-wrapper img {
        transform: scale(1.04);
    }

    .bento-tag {
        position: absolute;
        top: 1rem; left: 1rem;
        background: #fff;
        color: #000;
        font-size: 0.7rem;
        font-weight: 600;
        padding: 4px 10px;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        border: 1px solid rgba(0,0,0,0.1);
    }

    /* Contenido */
    .bento-content {
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }
    @media (min-width: 768px) {
        .hero-cell .bento-content {
            width: 45%;
            justify-content: center;
        }
    }

    .bento-date {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.75rem;
        color: #6b7280;
        margin-bottom: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    :global(html[data-theme="dark"]) .bento-date { color: #9ca3af; }

    .hero-post-title {
        font-size: clamp(2rem, 3vw, 2.5rem);
        font-weight: 600;
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin: 0 0 1rem;
        color: #111827;
        transition: color 0.3s;
    }
    :global(html[data-theme="dark"]) .hero-post-title { color: #fff; }

    .standard-post-title {
        font-size: 1.5rem;
        font-weight: 500;
        letter-spacing: -0.02em;
        line-height: 1.2;
        margin: 0 0 1rem;
        color: #111827;
    }
    :global(html[data-theme="dark"]) .standard-post-title { color: #fff; }

    .hero-post-excerpt {
        font-size: 1.1rem;
        color: #4b5563;
        line-height: 1.6;
        margin: 0 0 2rem;
    }
    :global(html[data-theme="dark"]) .hero-post-excerpt { color: #9ca3af; }

    /* Meta del Hero */
    .hero-post-author {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-top: auto;
    }
    .hero-post-author img {
        width: 36px; height: 36px;
        border-radius: 50%;
    }
    .hero-post-author span {
        font-size: 0.9rem;
        color: #6b7280;
    }
    .hero-post-author strong { color: #111827; font-weight: 600; }
    :global(html[data-theme="dark"]) .hero-post-author strong { color: #fff; }

    /* Flecha Minimalista Editorial */
    .editorial-arrow {
        margin-left: auto;
        width: 40px; height: 40px;
        display: flex; align-items: center; justify-content: flex-end;
        color: #111827;
    }
    :global(html[data-theme="dark"]) .editorial-arrow { color: #fff; }
    
    .editorial-arrow svg {
        width: 20px; height: 20px;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .bento-cell:hover .editorial-arrow svg {
        transform: translateX(6px);
    }

    .inline-arrow {
        margin-top: auto;
        margin-left: 0;
        justify-content: flex-start;
        gap: 0.5rem;
        width: auto;
        opacity: 0.6;
        transition: opacity 0.3s;
    }
    .inline-arrow span {
        font-size: 0.9rem;
        font-weight: 500;
    }
    .bento-cell:hover .inline-arrow {
        opacity: 1;
        color: var(--color-blue-deep);
    }
    :global(html[data-theme="dark"]) .bento-cell:hover .inline-arrow { color: #60a5fa; }
</style>
