---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/landing/Nav.astro';
import Footer from '../components/landing/Footer.astro';
import PageAnims from '../components/landing/PageAnims.astro';
import BlogCTA from '../components/blog/BlogCTA.astro';
import BlogCover from '../components/blog/BlogCover.jsx';

import { getCollection } from 'astro:content';
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isEn = Astro.props.isEn || lang === 'en';
const collectionDir = isEn ? 'en/' : 'es/';
const allPosts = (await getCollection('blog')).filter(p => p.id.startsWith(collectionDir));

const FEATURED_POST = allPosts.find(p => p.data.featured)?.data || allPosts[0]?.data;
const featuredPostId = allPosts.find(p => p.data.featured)?.id || allPosts[0]?.id;

const POSTS = allPosts.filter(p => p.id !== featuredPostId).map(p => ({
    id: p.id,
    ...p.data
}));

const CATEGORIES = [isEn ? 'All' : 'Todos', ...new Set(allPosts.map(p => p.data.category))];

const featuredAuthorName = FEATURED_POST?.authorName || (isEn ? 'Cord Team' : 'Equipo Cord');
const featuredAuthorRole = FEATURED_POST?.authorRole || (isEn ? 'Editorial' : 'Redacción');

const featuredHref = isEn
    ? `/en/blog/${featuredPostId?.replace('en/', '')}`
    : `/blog/${featuredPostId?.replace('es/', '')}`;

// BreadcrumbList (jul 2026, auditoría SEO/AI-SEO)
const SITE = 'https://cordhq.app';
const base = isEn ? `${SITE}/en` : SITE;
const breadcrumbSchema = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Cord', item: `${base}/` },
        { '@type': 'ListItem', position: 2, name: 'Blog', item: `${base}/blog` },
    ],
};
---

<Layout
    title={isEn ? "Blog | Cord" : "Blog de Cord — Ventas B2B, Facturación y CFDI en México"}
    description={isEn ? "Articles, guides, and strategies on B2B sales, billing, and how to accelerate your revenue." : "Artículos, guías y estrategias sobre ventas B2B, facturación, CFDI y cómo acelerar tu flujo de ingresos. Para cualquier negocio B2B en México."}
>
    <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
    <Nav />

    <main class="cord-blog-main">

        <!-- Page Header (ElevenLabs-style: clean H1 + social link) -->
        <header class="blog-header reveal">
            <div class="blog-container">
                <h1 class="blog-headline">{isEn ? 'Cord Blog' : 'Blog de Cord'}</h1>
                <a href="https://linkedin.com/company/flouviamx" target="_blank" rel="noopener" class="blog-social-link">
                    {isEn ? 'Cord on LinkedIn' : 'Cord en LinkedIn'}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
            </div>
        </header>

        <!-- Featured Post — full-width tall card, title inside the shader -->
        <section class="blog-featured reveal">
            <div class="blog-container">
                <a href={featuredHref} class="fc-card">
                    <!-- Shader image takes full top, title is rendered inside BlogCover -->
                    <div class="fc-cover">
                        <BlogCover
                            client:only="react"
                            category={FEATURED_POST?.category || 'featured'}
                            featured={true}
                            title={FEATURED_POST?.title || ''}
                        />
                    </div>
                    <!-- Compact bottom metadata bar -->
                    <div class="fc-bar">
                        <div class="fc-bar-left">
                            <span class="fc-cat">{FEATURED_POST?.category}</span>
                            <span class="fc-sep">·</span>
                            <span class="fc-date">{FEATURED_POST?.date}</span>
                            {FEATURED_POST?.readTime && (
                                <>
                                    <span class="fc-sep">·</span>
                                    <span class="fc-date">{FEATURED_POST.readTime}</span>
                                </>
                            )}
                        </div>
                        <div class="fc-bar-right">
                            <div class="fc-avatar">{featuredAuthorName.charAt(0).toUpperCase()}</div>
                            <strong class="fc-author-name">{featuredAuthorName}</strong>
                        </div>
                    </div>
                </a>
            </div>
        </section>

        <!-- Inline Filters — no sticky, just flows naturally -->
        <div class="blog-filters-bar reveal">
            <div class="blog-container">
                <div class="blog-filters" id="blog-filters">
                    {CATEGORIES.map((cat, i) => (
                        <button
                            class={`filter-btn ${i === 0 ? 'active' : ''}`}
                            data-filter={cat === 'Todos' || cat === 'All' ? 'all' : cat}
                        >
                            {cat}
                        </button>
                    ))}
                </div>
            </div>
        </div>

        <!-- Article Grid -->
        <section class="blog-grid-section">
            <div class="blog-container">
                <div class="blog-grid" id="blog-grid">
                    {POSTS.map((post, i) => (
                        <article
                            class="blog-card reveal"
                            data-category={post.category}
                            style={`transition-delay: ${(i % 3) * 40}ms`}
                        >
                            <a
                                href={isEn ? `/en/blog/${post.id.replace('en/', '')}` : `/blog/${post.id.replace('es/', '')}`}
                                class="blog-card-link"
                            >
                                <div class="blog-img-wrap">
                                    <BlogCover
                                        client:only="react"
                                        category={post.category}
                                        title={post.title}
                                    />
                                    <span class="blog-cat-badge">{post.category}</span>
                                </div>
                                <div class="blog-card-body">
                                    <div class="blog-card-meta">
                                        <span>{post.date}</span>
                                        {post.readTime && (
                                            <>
                                                <span>·</span>
                                                <span>{post.readTime}</span>
                                            </>
                                        )}
                                    </div>
                                    <h3 class="blog-card-title">{post.title}</h3>
                                    <span class="blog-read-link">
                                        {isEn ? 'Read' : 'Leer'}
                                    </span>
                                </div>
                            </a>
                        </article>
                    ))}
                </div>
            </div>
        </section>

        <BlogCTA isEn={isEn} />

    </main>

    <Footer
        ctaTitle={isEn ? "Ready to accelerate your deals?" : "¿Listo para acelerar tus cierres?"}
        ctaSub={isEn ? "Start for free today — 5 active quotes per month, no credit card." : "Empieza gratis hoy — 5 cotizaciones activas al mes, sin tarjeta."}
        isEn={isEn}
    />
    <PageAnims />
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const filters = document.querySelectorAll('.filter-btn');
        const grid = document.getElementById('blog-grid');
        const cards = document.querySelectorAll('.blog-card');

        if (!filters.length || !grid || !cards.length) return;

        filters.forEach(btn => {
            btn.addEventListener('click', () => {
                filters.forEach(f => f.classList.remove('active'));
                btn.classList.add('active');

                const targetCat = btn.getAttribute('data-filter');
                grid.classList.add('filtering');

                setTimeout(() => {
                    cards.forEach(card => {
                        const cat = card.getAttribute('data-category');
                        card.style.display = (targetCat === 'all' || targetCat === cat) ? 'flex' : 'none';
                    });
                    void grid.offsetWidth;
                    grid.classList.remove('filtering');
                }, 260);
            });
        });
    });
</script>

<style>
    /* ── Reset & base ───────────────────────────────────────────── */
    .cord-blog-main {
        background: #fdfdfd;
        color: #111827;
        min-height: 100vh;
        font-family: 'Inter', sans-serif;
    }
    :global(html[data-theme="dark"]) .cord-blog-main { background: #050505; color: #fff; }

    /* Shared container */
    .blog-container {
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 5%;
    }

    /* ── Page Header ────────────────────────────────────────────── */
    .blog-header {
        padding: 7rem 0 2.5rem;
    }
    .blog-header .blog-container {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 2rem;
        border-bottom: 1px solid rgba(0,0,0,0.07);
        padding-bottom: 2rem;
    }
    :global(html[data-theme="dark"]) .blog-header .blog-container {
        border-bottom-color: rgba(255,255,255,0.07);
    }

    .blog-headline {
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 1;
        color: #050505;
        margin: 0;
    }
    :global(html[data-theme="dark"]) .blog-headline { color: #fff; }

    .blog-social-link {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 0.9rem;
        font-weight: 600;
        color: #6b7280;
        text-decoration: none;
        white-space: nowrap;
        transition: color 0.2s;
        flex-shrink: 0;
    }
    :global(html[data-theme="dark"]) .blog-social-link { color: #9ca3af; }
    .blog-social-link:hover { color: #0a192f; }
    :global(html[data-theme="dark"]) .blog-social-link:hover { color: #fff; }
    .blog-social-link svg { width: 13px; height: 13px; }

    /* ── Featured Card ──────────────────────────────────────────── */
    .blog-featured { padding: 2.5rem 0 0; }

    .fc-card {
        display: block;
        text-decoration: none;
        color: inherit;
        border-radius: 18px;
        overflow: hidden;
        box-shadow:
            inset 0 0 0 0.5px rgba(0,0,0,0.08),
            0 2px 8px rgba(0,0,0,0.04),
            0 24px 60px -16px rgba(0,0,0,0.1);
        transition: transform 0.55s cubic-bezier(0.16, 1, 0.3, 1),
                    box-shadow 0.55s cubic-bezier(0.16, 1, 0.3, 1);
        background: #fff;
    }
    :global(html[data-theme="dark"]) .fc-card {
        background: #0d0d0d;
        box-shadow:
            inset 0 0 0 0.5px rgba(255,255,255,0.07),
            0 24px 60px -16px rgba(0,0,0,0.5);
    }
    .fc-card:hover {
        transform: translateY(-3px);
        box-shadow:
            inset 0 0 0 0.5px rgba(0,0,0,0.1),
            0 2px 8px rgba(0,0,0,0.04),
            0 32px 72px -16px rgba(10,25,47,0.14);
    }
    :global(html[data-theme="dark"]) .fc-card:hover {
        box-shadow:
            inset 0 0 0 0.5px rgba(255,255,255,0.1),
            0 32px 72px -16px rgba(0,0,0,0.7);
    }

    /* Shader image area — tall, full-width */
    .fc-cover {
        position: relative;
        width: 100%;
        aspect-ratio: 21 / 9;
        overflow: hidden;
        background: #0a192f;
    }
    @media (max-width: 700px) {
        .fc-cover { aspect-ratio: 4 / 3; }
    }

    /* Bottom metadata bar */
    .fc-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.1rem 1.4rem;
        gap: 1rem;
        border-top: 1px solid rgba(0,0,0,0.06);
    }
    :global(html[data-theme="dark"]) .fc-bar {
        border-top-color: rgba(255,255,255,0.07);
    }
    .fc-bar-left {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        flex-wrap: wrap;
    }
    .fc-cat {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: #0a192f;
        background: rgba(10,25,47,0.07);
        padding: 3px 10px;
        border-radius: 100px;
    }
    :global(html[data-theme="dark"]) .fc-cat {
        color: #93c5fd;
        background: rgba(147,197,253,0.12);
    }
    .fc-sep {
        color: #d1d5db;
        font-size: 0.8rem;
    }
    .fc-date {
        font-size: 0.8rem;
        color: #6b7280;
        font-variant-numeric: tabular-nums;
    }
    :global(html[data-theme="dark"]) .fc-date { color: #9ca3af; }

    .fc-bar-right {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        flex-shrink: 0;
    }
    .fc-avatar {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: linear-gradient(135deg, #0a2540 0%, #3b82f6 100%);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.75rem;
        flex-shrink: 0;
    }
    .fc-author-name {
        font-size: 0.85rem;
        font-weight: 600;
        color: #374151;
    }
    :global(html[data-theme="dark"]) .fc-author-name { color: #d1d5db; }


    /* ── Filters Bar ────────────────────────────────────────────── */
    .blog-filters-bar {
        padding: 2.5rem 0 1.5rem;
    }
    .blog-filters {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        flex-wrap: wrap;
    }

    .filter-btn {
        background: transparent;
        border: none;
        padding: 7px 16px;
        border-radius: 100px;
        font-size: 0.85rem;
        font-weight: 600;
        color: #6b7280;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        white-space: nowrap;
    }
    :global(html[data-theme="dark"]) .filter-btn { color: #9ca3af; }
    .filter-btn:hover {
        color: #111827;
        background: rgba(0,0,0,0.05);
    }
    :global(html[data-theme="dark"]) .filter-btn:hover {
        color: #fff;
        background: rgba(255,255,255,0.08);
    }
    .filter-btn.active {
        background: #111827;
        color: #fff;
    }
    :global(html[data-theme="dark"]) .filter-btn.active {
        background: #fff;
        color: #111827;
    }

    /* ── Article Grid ───────────────────────────────────────────── */
    .blog-grid-section {
        padding: 0 0 7rem;
    }

    .blog-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 2rem 1.75rem;
        transition: opacity 0.26s ease, transform 0.26s ease;
    }
    .blog-grid.filtering { opacity: 0; transform: translateY(8px); }

    .blog-card {
        display: flex;
        flex-direction: column;
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow:
            inset 0 0 0 0.5px rgba(0,0,0,0.07),
            0 2px 8px rgba(0,0,0,0.03);
        transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1),
                    box-shadow 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    }
    :global(html[data-theme="dark"]) .blog-card {
        background: #0d0d0d;
        box-shadow: inset 0 0 0 0.5px rgba(255,255,255,0.07);
    }
    .blog-card:hover {
        transform: translateY(-3px);
        box-shadow:
            inset 0 0 0 0.5px rgba(0,0,0,0.09),
            0 16px 40px -12px rgba(10,25,47,0.1);
    }
    :global(html[data-theme="dark"]) .blog-card:hover {
        box-shadow:
            inset 0 0 0 0.5px rgba(255,255,255,0.1),
            0 16px 40px -12px rgba(0,0,0,0.4);
    }

    .blog-card-link {
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    /* Image wrap — shader fills this */
    .blog-img-wrap {
        position: relative;
        width: 100%;
        aspect-ratio: 3 / 2;
        overflow: hidden;
        background: #0d1b3e;
        flex-shrink: 0;
    }

    .blog-cat-badge {
        position: absolute;
        top: 0.85rem;
        left: 0.85rem;
        background: rgba(255,255,255,0.88);
        backdrop-filter: blur(8px);
        color: #111827;
        font-size: 0.6rem;
        font-weight: 700;
        padding: 3px 9px;
        border-radius: 100px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        pointer-events: none;
    }
    :global(html[data-theme="dark"]) .blog-cat-badge {
        background: rgba(0,0,0,0.65);
        color: #fff;
    }

    /* Card text body — compact */
    .blog-card-body {
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        padding: 1.1rem 1.2rem 1.15rem;
        gap: 0.5rem;
    }

    .blog-card-meta {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.72rem;
        font-weight: 600;
        color: #9ca3af;
        letter-spacing: 0.01em;
        font-variant-numeric: tabular-nums;
    }

    .blog-card-title {
        font-size: 1rem;
        font-weight: 700;
        line-height: 1.35;
        letter-spacing: -0.018em;
        color: #111827;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        transition: color 0.2s;
    }
    :global(html[data-theme="dark"]) .blog-card-title { color: #fff; }
    .blog-card-link:hover .blog-card-title { color: #0a192f; }
    :global(html[data-theme="dark"]) .blog-card-link:hover .blog-card-title { color: #93c5fd; }

    .blog-read-link {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 0.82rem;
        font-weight: 700;
        color: #6b7280;
        margin-top: auto;
        padding-top: 0.4rem;
        transition: gap 0.35s cubic-bezier(0.16, 1, 0.3, 1), color 0.2s;
    }
    :global(html[data-theme="dark"]) .blog-read-link { color: #9ca3af; }
    .blog-card-link:hover .blog-read-link { color: #0a192f; }
    :global(html[data-theme="dark"]) .blog-card-link:hover .blog-read-link { color: #fff; }

    /* ── Responsive ─────────────────────────────────────────────── */
    @media (max-width: 900px) {
        .blog-header { padding: 6rem 0 2rem; }
        .blog-grid { grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
    }
    @media (max-width: 600px) {
        .blog-header .blog-container { flex-direction: column; gap: 0.75rem; align-items: flex-start; }
        .blog-headline { font-size: 1.75rem; }
        .fc-bar { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
        .blog-grid { grid-template-columns: 1fr; }
    }
</style>
