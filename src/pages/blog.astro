---
// Blog — Aesthetic Cord inspirado en Stripe Hero (Floating Card + Gradient Canvas)
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/landing/Nav.astro';
import Footer from '../components/landing/Footer.astro';
import PageAnims from '../components/landing/PageAnims.astro';

const FEATURED_POST = {
    id: 'error-pdf-ventas-b2b',
    title: 'Por qué enviar cotizaciones en PDF te está costando cierres',
    excerpt: 'Analizamos más de 10,000 transacciones B2B y descubrimos cómo la fricción de descargar, imprimir y firmar PDFs retrasa las ventas. Las cotizaciones interactivas aumentan la conversión en un 32%.',
    category: 'Ventas B2B',
    date: '18 Jun 2026',
    author: {
        name: 'André Valle',
        role: 'Product Manager, Cord',
        avatar: 'https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?ixlib=rb-4.0.3&auto=format&fit=crop&w=150&q=80'
    },
    img: 'https://images.unsplash.com/photo-1556761175-5973dc0f32e7?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80'
};

const POSTS = [
    {
        id: 'guia-cfdi-4-0-2026',
        title: 'Guía Definitiva: CFDI 4.0 para mayoristas y distribuidores',
        excerpt: 'Todo lo que necesitas saber sobre complementos de pago y carta porte.',
        category: 'Fiscal',
        date: '12 Jun 2026',
        img: 'https://images.unsplash.com/photo-1450101499163-c8848c66ca85?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'
    },
    {
        id: 'credito-b2b-net30',
        title: 'Cómo ofrecer crédito (Net 30) sin quebrar en el intento',
        excerpt: 'Dar crédito es obligatorio en B2B. Aprende a fijar límites dinámicos.',
        category: 'Finanzas',
        date: '05 Jun 2026',
        img: 'https://images.unsplash.com/photo-1554224155-8d04cb21cd6c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'
    },
    {
        id: 'ia-en-ventas',
        title: 'La IA en cobranza B2B: tu nuevo agente implacable',
        excerpt: 'La automatización del seguimiento y la negociación de deuda.',
        category: 'Tecnología',
        date: '28 May 2026',
        img: 'https://images.unsplash.com/photo-1485827404703-89b55fcc595e?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'
    },
    {
        id: 'listas-de-precios-b2b',
        title: 'Manejo de listas de precios: de Excel al caos, y del caos a Cord',
        excerpt: 'Venderle a 200 clientes a 200 precios distintos es una pesadilla.',
        category: 'Operaciones',
        date: '15 May 2026',
        img: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'
    },
    {
        id: 'mcp-agentes-ia',
        title: 'Por qué conectamos Cord a Claude vía MCP',
        excerpt: 'Así funciona nuestra arquitectura bidireccional de agentes.',
        category: 'Tecnología',
        date: '02 May 2026',
        img: 'https://images.unsplash.com/photo-1518770660439-4636190af475?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'
    },
    {
        id: 'tasas-cierre-b2b',
        title: 'Anatomía de una cotización que cierra',
        excerpt: 'Patrones visuales y de interacción para conversiones altas.',
        category: 'Ventas B2B',
        date: '20 Abr 2026',
        img: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'
    }
];

const CATEGORIES = ['Todos', 'Ventas B2B', 'Finanzas', 'Operaciones', 'Tecnología', 'Fiscal'];
---

<Layout
    title="Blog | Cord"
    description="Artículos, guías y estrategias sobre ventas B2B, facturación, y cómo acelerar tu flujo de ingresos."
>
    <Nav />
    
    <main class="stripe-blog-main">
        
        <!-- HERO CANVAS (Gradient + Guide Lines + Floating Card) -->
        <section class="hero-canvas">
            <!-- Background Gradients tipo Cord -->
            <div class="hero-canvas-bg" aria-hidden="true">
                <div class="blob blob-1"></div>
                <div class="blob blob-2"></div>
                <div class="blob blob-3"></div>
            </div>

            <!-- Guide Lines -->
            <div class="hero-guides" aria-hidden="true">
                <div class="guide-container">
                    <div class="guide-line"></div>
                    <div class="guide-line"></div>
                    <div class="guide-line"></div>
                    <div class="guide-line"></div>
                    <div class="guide-line"></div>
                </div>
            </div>

            <!-- Hero Content -->
            <div class="hero-canvas-content">
                <!-- Top Links -->
                <div class="hero-top-links reveal">
                    <span class="blog-brand">Blog</span>
                    <a href="https://linkedin.com/company/cord" target="_blank" class="social-link">
                        Cord en LinkedIn <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                </div>

                <!-- Floating Featured Card -->
                <div class="floating-card-wrapper reveal">
                    <a href={`/blog/${FEATURED_POST.id}`} class="floating-card">
                        <!-- Left: Text -->
                        <div class="fc-text">
                            <span class="fc-category">{FEATURED_POST.category}</span>
                            <h1 class="fc-title">{FEATURED_POST.title}</h1>
                            
                            <div class="fc-author">
                                <img src={FEATURED_POST.author.avatar} alt={FEATURED_POST.author.name} />
                                <div class="fc-author-info">
                                    <strong>{FEATURED_POST.author.name}</strong>
                                    <span>{FEATURED_POST.author.role}</span>
                                </div>
                            </div>
                            
                            <p class="fc-excerpt">{FEATURED_POST.excerpt}</p>
                            
                            <div class="fc-readmore">
                                Leer artículo <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            </div>
                        </div>
                        
                        <!-- Right: Image/Graphic -->
                        <div class="fc-image">
                            <img src={FEATURED_POST.img} alt={FEATURED_POST.title} fetchpriority="high" />
                        </div>
                    </a>
                </div>
            </div>
        </section>

        <!-- Filtros Flotantes (Pill) -->
        <div class="blog-sticky-nav reveal">
            <div class="blog-filters-glass" id="blog-filters">
                {CATEGORIES.map((cat, i) => (
                    <button class={`filter-btn ${i === 0 ? 'active' : ''}`} data-filter={cat === 'Todos' ? 'all' : cat}>
                        {cat}
                    </button>
                ))}
            </div>
        </div>

        <!-- Grid de Artículos Recientes -->
        <section class="blog-grid-section">
            <div class="blog-grid" id="blog-grid">
                {POSTS.map((post, i) => (
                    <article class="blog-card hairline-border reveal" data-category={post.category} style={`transition-delay: ${(i % 3) * 50}ms`}>
                        <a href={`/blog/${post.id}`} class="blog-card-link">
                            <div class="blog-img-wrap">
                                <img src={post.img} alt={post.title} loading="lazy" />
                            </div>
                            <div class="blog-content">
                                <span class="card-category">{post.category}</span>
                                <h3 class="blog-title">{post.title}</h3>
                                <p class="blog-excerpt">{post.excerpt}</p>
                                <div class="blog-read-more">
                                    Leer artículo
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                                </div>
                            </div>
                        </a>
                    </article>
                ))}
            </div>
        </section>
    </main>

    <Footer 
        ctaTitle="¿Listo para acelerar tus cierres?"
        ctaSub="Empieza gratis hoy — 5 cotizaciones activas al mes, sin tarjeta."
    />
    <PageAnims />
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const filters = document.querySelectorAll('.filter-btn');
        const grid = document.getElementById('blog-grid');
        const cards = document.querySelectorAll('.blog-card');

        if (!filters.length || !grid || !cards.length) return;

        filters.forEach(btn => {
            btn.addEventListener('click', () => {
                filters.forEach(f => f.classList.remove('active'));
                btn.classList.add('active');

                const targetCat = btn.getAttribute('data-filter');

                grid.classList.add('filtering');
                
                setTimeout(() => {
                    cards.forEach(card => {
                        const cat = card.getAttribute('data-category');
                        if (targetCat === 'all' || targetCat === cat) {
                            card.style.display = 'flex';
                        } else {
                            card.style.display = 'none';
                        }
                    });

                    void grid.offsetWidth;
                    grid.classList.remove('filtering');
                }, 300);
            });
        });
    });
</script>

<style>
    /* ==========================================================
       RESET Y BASE
       ========================================================== */
    .stripe-blog-main {
        background: #fff;
        color: #111827;
        min-height: 100vh;
        overflow-x: hidden;
        font-family: 'Inter', sans-serif;
    }
    :global(html[data-theme="dark"]) .stripe-blog-main { background: #000; color: #fff; }

    /* ==========================================================
       HERO CANVAS (Background gradients & guides)
       ========================================================== */
    .hero-canvas {
        position: relative;
        width: 100%;
        padding-top: 80px; /* Space for Nav */
        padding-bottom: 6rem;
        min-height: 800px;
        display: flex;
        flex-direction: column;
        align-items: center;
        background-color: #f8f9fa; /* Base light gray */
        overflow: hidden;
    }
    :global(html[data-theme="dark"]) .hero-canvas { background-color: #050505; }

    /* Cord Custom Gradient Blobs */
    .hero-canvas-bg {
        position: absolute; inset: 0; z-index: 0;
        overflow: hidden; pointer-events: none;
    }
    .blob {
        position: absolute;
        filter: blur(80px);
        opacity: 0.7;
        border-radius: 50%;
        animation: float 20s infinite ease-in-out alternate;
    }
    .blob-1 {
        top: 20%; left: -10%; width: 800px; height: 800px;
        background: radial-gradient(circle, rgba(10,37,218,0.3) 0%, transparent 70%);
        animation-delay: 0s;
    }
    .blob-2 {
        bottom: -20%; right: -10%; width: 900px; height: 900px;
        background: radial-gradient(circle, rgba(14,165,233,0.25) 0%, transparent 70%);
        animation-delay: -5s;
    }
    .blob-3 {
        top: 40%; left: 40%; width: 600px; height: 600px;
        background: radial-gradient(circle, rgba(139,92,246,0.15) 0%, transparent 70%);
        animation-delay: -10s;
    }
    @keyframes float {
        0% { transform: translate(0, 0) scale(1); }
        100% { transform: translate(50px, 50px) scale(1.1); }
    }
    :global(html[data-theme="dark"]) .blob { opacity: 0.4; filter: blur(100px); }

    /* Guide Lines */
    .hero-guides {
        position: absolute; inset: 0; z-index: 1;
        pointer-events: none;
        display: flex; justify-content: center;
    }
    .guide-container {
        width: 100%; max-width: 1200px;
        display: flex; justify-content: space-between;
        padding: 0 5%;
    }
    .guide-line {
        width: 1px; height: 100%;
        background: repeating-linear-gradient(to bottom, transparent, transparent 4px, rgba(0,0,0,0.06) 4px, rgba(0,0,0,0.06) 8px);
    }
    :global(html[data-theme="dark"]) .guide-line {
        background: repeating-linear-gradient(to bottom, transparent, transparent 4px, rgba(255,255,255,0.04) 4px, rgba(255,255,255,0.04) 8px);
    }

    .hero-canvas-content {
        position: relative; z-index: 2;
        width: 100%; max-width: 1200px;
        padding: 0 5%;
        display: flex; flex-direction: column;
        flex-grow: 1;
    }

    /* Top Links (Blog | Stripe on X) */
    .hero-top-links {
        display: flex; justify-content: space-between; align-items: center;
        padding: 2rem 0; margin-bottom: 2rem;
    }
    .blog-brand {
        font-size: 1.25rem; font-weight: 500; color: var(--color-blue-deep);
        letter-spacing: -0.02em;
    }
    :global(html[data-theme="dark"]) .blog-brand { color: #60a5fa; }

    .social-link {
        display: inline-flex; align-items: center; gap: 4px;
        font-size: 0.95rem; font-weight: 500; color: var(--color-blue-deep);
        text-decoration: none; transition: opacity 0.2s;
    }
    :global(html[data-theme="dark"]) .social-link { color: #60a5fa; }
    .social-link:hover { opacity: 0.7; }
    .social-link svg { width: 14px; height: 14px; }

    /* ==========================================================
       FLOATING FEATURED CARD (The Stripe Hero)
       ========================================================== */
    .floating-card-wrapper {
        width: 100%;
        margin-bottom: -10rem; /* Pulls the grid below upwards slightly */
    }

    .floating-card {
        display: flex; flex-direction: column;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 50px 100px -20px rgba(50,50,93,0.15), 0 30px 60px -30px rgba(0,0,0,0.1), inset 0 0 0 1px rgba(0,0,0,0.02);
        overflow: hidden; text-decoration: none; color: inherit;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s;
    }
    :global(html[data-theme="dark"]) .floating-card {
        background: #0f172a;
        box-shadow: 0 50px 100px -20px rgba(0,0,0,0.5), inset 0 0 0 1px rgba(255,255,255,0.05);
    }

    .floating-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 50px 100px -20px rgba(10,37,218,0.2), 0 30px 60px -30px rgba(0,0,0,0.15), inset 0 0 0 1px rgba(0,0,0,0.02);
    }
    :global(html[data-theme="dark"]) .floating-card:hover {
        box-shadow: 0 50px 100px -20px rgba(0,0,0,0.8), inset 0 0 0 1px rgba(255,255,255,0.1);
    }

    @media (min-width: 992px) {
        .floating-card { flex-direction: row; min-height: 480px; }
    }

    /* Left Text Side */
    .fc-text {
        flex: 1; padding: 3rem 2.5rem;
        display: flex; flex-direction: column; justify-content: center;
    }
    @media (min-width: 992px) { .fc-text { padding: 4rem; } }

    .fc-category {
        font-size: 0.9rem; font-weight: 600; color: var(--color-blue-deep);
        margin-bottom: 1.5rem; letter-spacing: -0.01em;
    }
    :global(html[data-theme="dark"]) .fc-category { color: #60a5fa; }

    .fc-title {
        font-size: clamp(2rem, 3vw, 2.75rem); font-weight: 600; line-height: 1.1;
        letter-spacing: -0.03em; color: #111827; margin: 0 0 2rem;
    }
    :global(html[data-theme="dark"]) .fc-title { color: #fff; }

    .fc-author {
        display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;
    }
    .fc-author img { width: 40px; height: 40px; border-radius: 50%; }
    .fc-author-info { display: flex; flex-direction: column; }
    .fc-author-info strong { font-size: 0.95rem; font-weight: 600; color: #111827; }
    :global(html[data-theme="dark"]) .fc-author-info strong { color: #fff; }
    .fc-author-info span { font-size: 0.85rem; color: #6b7280; }

    .fc-excerpt {
        font-size: 1.1rem; color: #4b5563; line-height: 1.6; margin: 0 0 2.5rem;
    }
    :global(html[data-theme="dark"]) .fc-excerpt { color: #9ca3af; }

    .fc-readmore {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 0.95rem; font-weight: 600; color: var(--color-blue-deep);
        margin-top: auto; transition: gap 0.3s;
    }
    :global(html[data-theme="dark"]) .fc-readmore { color: #60a5fa; }
    .fc-readmore svg { width: 16px; height: 16px; transition: transform 0.3s; }
    .floating-card:hover .fc-readmore { gap: 10px; }

    /* Right Image Side */
    .fc-image {
        flex: 1; background: #f6f9fc; position: relative; overflow: hidden;
        min-height: 300px;
    }
    :global(html[data-theme="dark"]) .fc-image { background: #1e293b; }
    .fc-image img {
        width: 100%; height: 100%; object-fit: cover;
        transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .floating-card:hover .fc-image img { transform: scale(1.03); }

    /* ==========================================================
       FILTROS (GLASS PILL)
       ========================================================== */
    .blog-sticky-nav {
        position: sticky; top: 1.5rem; z-index: 50;
        display: flex; justify-content: center;
        margin-top: 12rem; /* Pushes it down below the floating card overhang */
        margin-bottom: 4rem; padding: 0 5%;
        pointer-events: none;
    }
    .blog-filters-glass {
        pointer-events: auto; display: inline-flex; gap: 0.2rem;
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
        padding: 6px; border-radius: 100px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.06), inset 0 0 0 1px rgba(0,0,0,0.05);
        overflow-x: auto; scrollbar-width: none;
    }
    .blog-filters-glass::-webkit-scrollbar { display: none; }
    :global(html[data-theme="dark"]) .blog-filters-glass {
        background: rgba(15, 23, 42, 0.6); box-shadow: 0 4px 20px rgba(0,0,0,0.4), inset 0 0 0 1px rgba(255,255,255,0.1);
    }

    .filter-btn {
        background: transparent; border: none;
        padding: 8px 16px; border-radius: 100px;
        font-size: 0.85rem; font-weight: 500; color: #4b5563;
        cursor: pointer; transition: all 0.2s; white-space: nowrap;
    }
    :global(html[data-theme="dark"]) .filter-btn { color: #9ca3af; }
    .filter-btn:hover { color: #111827; background: rgba(0,0,0,0.04); }
    :global(html[data-theme="dark"]) .filter-btn:hover { color: #fff; background: rgba(255,255,255,0.08); }
    .filter-btn.active { background: #111827; color: #fff; box-shadow: 0 2px 8px rgba(0,0,0,0.15); }
    :global(html[data-theme="dark"]) .filter-btn.active { background: #fff; color: #000; }

    /* ==========================================================
       GRID DE ARTÍCULOS RECIENTES
       ========================================================== */
    .blog-grid-section { padding: 0 5% 8rem; max-width: 1200px; margin: 0 auto; }

    .blog-grid {
        display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 3rem 2rem; transition: opacity 0.3s, transform 0.3s;
    }
    .blog-grid.filtering { opacity: 0; transform: translateY(10px); }

    .blog-card {
        display: flex; flex-direction: column;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .blog-card:hover { transform: translateY(-4px); }

    .blog-card-link { text-decoration: none; color: inherit; display: flex; flex-direction: column; height: 100%; }

    .blog-img-wrap {
        width: 100%; aspect-ratio: 16/10;
        border-radius: 8px; overflow: hidden; margin-bottom: 1.5rem;
        background: #f3f4f6;
    }
    :global(html[data-theme="dark"]) .blog-img-wrap { background: #1f2937; }
    .blog-img-wrap img {
        width: 100%; height: 100%; object-fit: cover;
        transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .blog-card-link:hover .blog-img-wrap img { transform: scale(1.04); }

    .blog-content { display: flex; flex-direction: column; flex-grow: 1; }

    .card-category {
        font-size: 0.85rem; font-weight: 500; color: var(--color-blue-deep);
        margin-bottom: 0.8rem;
    }
    :global(html[data-theme="dark"]) .card-category { color: #60a5fa; }

    .blog-title {
        font-size: 1.25rem; font-weight: 600; line-height: 1.3; letter-spacing: -0.02em;
        color: #111827; margin: 0 0 0.8rem; transition: color 0.2s;
    }
    :global(html[data-theme="dark"]) .blog-title { color: #fff; }

    .blog-excerpt {
        font-size: 1rem; color: #4b5563; line-height: 1.6; margin: 0 0 1.5rem;
        display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
    }
    :global(html[data-theme="dark"]) .blog-excerpt { color: #9ca3af; }

    .blog-read-more {
        display: inline-flex; align-items: center; gap: 4px;
        font-size: 0.95rem; font-weight: 600; color: var(--color-blue-deep);
        margin-top: auto; transition: gap 0.3s;
    }
    :global(html[data-theme="dark"]) .blog-read-more { color: #60a5fa; }
    .blog-read-more svg { width: 16px; height: 16px; transition: transform 0.3s; }
    .blog-card-link:hover .blog-read-more { gap: 8px; }

</style>
