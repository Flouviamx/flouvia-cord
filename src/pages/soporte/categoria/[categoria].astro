---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/landing/Nav.astro';
import Footer from '../../../components/landing/Footer.astro';

export const prerender = true;

export async function getStaticPaths() {
  const categories = [
    { slug: 'pagos', name: 'Pagos y Depósitos', desc: 'Todo sobre recepción de fondos, tiempos de liquidación y comisiones.', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>' },
    { slug: 'cotizaciones', name: 'Cotizaciones', desc: 'Guías para enviar y gestionar cotizaciones interactivas.', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><line x1="10" x2="8" y1="9" y2="9"/></svg>' },
    { slug: 'facturacion', name: 'Facturación y CFDI', desc: 'Configura la facturación automática 4.0 al instante.', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>' },
    { slug: 'cuenta', name: 'Cuenta y Equipo', desc: 'Administra accesos, roles y configuraciones de tu organización.', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>' },
    { slug: 'desarrolladores', name: 'Desarrolladores', desc: 'Documentación para APIs, Webhooks y CORD Elements.', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>' },
    { slug: 'seguridad', name: 'Seguridad y Privacidad', desc: 'Información sobre cumplimiento PCI-DSS y protección de datos.', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>' },
  ];
  return categories.map(cat => ({
    params: { categoria: cat.slug },
    props: { name: cat.name, desc: cat.desc, icon: cat.icon },
  }));
}

const isEn = Astro.props.isEn || false;
const categoria = Astro.props.categoria || Astro.params.categoria;
const { name, desc, icon } = Astro.props;
const allArticles = await getCollection('support');
// We map and filter to find articles for this category.
const langPrefix = isEn ? 'en/' : 'es/';
const categoryArticles = allArticles.filter(a => a.id.startsWith(langPrefix) && a.data.category === name);

// If there are few articles, we'll populate the UI with 'coming soon' or just show the real ones.
const hasArticles = categoryArticles.length > 0;
---

<Layout title={`${name} - ${isEn ? 'Cord Help Center' : 'Centro de Ayuda Cord'}`} description={isEn ? `Help articles about ${name}` : `Artículos de ayuda sobre ${name}`}>
    <Nav />
    <main class="cat-page-layout">
        <div class="pr-mesh" aria-hidden="true"></div>
        <div class="cat-container">
            <a href={isEn ? "/en/support" : "/soporte"} class="back-link reveal">{isEn ? '← Back to Help Center' : '← Volver al Centro de Ayuda'}</a>
            
            <div class="cat-header reveal">
                <div class="cat-icon-wrapper">
                    <div class="cat-icon-svg" set:html={icon} />
                </div>
                <h1 class="cat-title masked-title">{name}</h1>
                <p class="cat-desc">{desc}</p>
            </div>
            
            <div class="cat-content reveal">
                {hasArticles ? (
                    <div class="articles-list">
                        {categoryArticles.map(article => (
                            <a href={isEn ? `/en/support/${article.id.replace('en/', '')}` : `/soporte/${article.id.replace('es/', '')}`} class="article-row">
                                <div class="row-content">
                                    <h3>{article.data.title}</h3>
                                    <p>{article.data.description}</p>
                                </div>
                                <svg class="row-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                    <polyline points="12 5 19 12 12 19"></polyline>
                                </svg>
                            </a>
                        ))}
                    </div>
                ) : (
                        <div class="premium-empty-state">
                        <div class="empty-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                <polyline points="14 2 14 8 20 8"></polyline>
                                <line x1="16" y1="13" x2="8" y2="13"></line>
                                <line x1="16" y1="17" x2="8" y2="17"></line>
                                <polyline points="10 9 9 9 8 9"></polyline>
                            </svg>
                        </div>
                        <h2>{isEn ? 'We are preparing these guides' : 'Estamos preparando estas guías'}</h2>
                        <p>{isEn ? `Our team is documenting the best processes for ` : `Nuestro equipo está documentando los mejores procesos para `}<strong>{name}</strong>. {isEn ? 'You will find detailed articles here soon.' : 'Pronto encontrarás artículos detallados aquí.'}</p>
                        <a href="mailto:soporte@flouvia.com" class="empty-cta">{isEn ? 'Ask Support directly' : 'Pregúntale a Soporte directamente'}</a>
                    </div>
                )}
            </div>

            <!-- Contact CTA (similar to main page to keep the flow) -->
            <div class="contact-cta reveal">
                <div class="cta-content">
                    <h2>{isEn ? 'Still have questions?' : '¿Aún tienes dudas?'}</h2>
                    <p>{isEn ? 'Don\'t worry, our expert team is an email away to solve any issue.' : 'No te preocupes, nuestro equipo de expertos está a un correo de distancia para resolver cualquier problema.'}</p>
                </div>
                <a href="mailto:soporte@flouvia.com" class="cta-button">{isEn ? 'Write to Support' : 'Escribir a soporte'}</a>
            </div>
        </div>
    </main>
    <Footer 
        ctaTitle={isEn ? "Ready to accelerate your sales?" : "¿Listo para acelerar tus ventas?"} 
        ctaSub={isEn ? "Join the companies that already quote like professionals with Cord." : "Únete a las empresas que ya cotizan como profesionales con Cord."} 
        isEn={isEn}
    />
</Layout>

<style>
    .cat-page-layout {
        position: relative;
        padding: 130px 5% 100px;
        background-color: var(--color-bg);
        min-height: 80vh;
        overflow: hidden;
    }
    .pr-mesh {
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 600px;
        background: radial-gradient(ellipse 60% 60% at 50% -10%, rgba(10,25,47,0.04) 0%, transparent 70%);
        pointer-events: none;
    }
    .cat-container {
        max-width: 960px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
    }
    
    .back-link {
        display: inline-flex;
        align-items: center;
        margin-bottom: 3rem;
        color: var(--color-text-muted);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        transition: color 0.2s, transform 0.2s;
    }
    .back-link:hover {
        color: var(--color-blue-deep);
        transform: translateX(-4px);
    }

    /* Header */
    .cat-header {
        text-align: center;
        margin-bottom: 5rem;
    }
    .cat-icon-wrapper {
        width: 72px;
        height: 72px;
        margin: 0 auto 1.5rem;
        background: #ffffff;
        border: 1px solid var(--color-border);
        box-shadow: 0 10px 30px -10px rgba(10,25,47,0.08);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        transform: rotate(-3deg);
        transition: transform 0.4s var(--ease-spring);
    }
    .cat-header:hover .cat-icon-wrapper {
        transform: rotate(0deg) scale(1.05);
    }
    .cat-icon-svg {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-blue-deep);
    }
    .cat-title {
        font-size: clamp(2.6rem, 5vw, 3.8rem);
        font-weight: 800;
        color: var(--color-text);
        margin-bottom: 1rem;
        letter-spacing: -0.035em;
        line-height: 1.1;
    }
    .cat-desc {
        font-size: 1.25rem;
        color: var(--color-text-muted);
        max-width: 600px;
        margin: 0 auto;
        line-height: 1.5;
    }
    
    /* Articles List (Minimalist) */
    .articles-list {
        display: flex;
        flex-direction: column;
        border-top: 1px solid var(--color-border);
        margin-bottom: 6rem;
    }
    .article-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 2rem 0;
        border-bottom: 1px solid var(--color-border);
        text-decoration: none;
        transition: all 0.3s ease;
    }
    .article-row:hover {
        background-color: transparent;
    }
    .row-content h3 {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--color-text);
        margin: 0 0 0.5rem 0;
        transition: color 0.2s ease;
    }
    .row-content p {
        font-size: 1rem;
        color: var(--color-text-muted);
        margin: 0;
        line-height: 1.5;
        max-width: 80%;
    }
    .article-row:hover .row-content h3 {
        color: var(--color-blue-deep);
    }
    .row-arrow {
        width: 24px;
        height: 24px;
        color: var(--color-text-muted);
        transition: transform 0.3s var(--ease-spring), color 0.2s ease;
        flex-shrink: 0;
    }
    .article-row:hover .row-arrow {
        transform: translateX(6px);
        color: var(--color-blue-deep);
    }
    
    /* Premium Empty State */
    .premium-empty-state {
        text-align: center;
        padding: 5rem 2rem;
        background: var(--color-bg-soft);
        border: 1px dashed rgba(10,25,47,0.15);
        border-radius: 24px;
        margin-bottom: 6rem;
    }
    .empty-icon {
        width: 64px;
        height: 64px;
        margin: 0 auto 1.5rem;
        background: #ffffff;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-text-muted);
        box-shadow: 0 8px 20px rgba(10,25,47,0.04);
    }
    .empty-icon svg { width: 32px; height: 32px; stroke-width: 1.5px; }
    .premium-empty-state h2 {
        font-size: 1.6rem;
        font-weight: 700;
        margin-bottom: 0.75rem;
        color: var(--color-text);
    }
    .premium-empty-state p {
        font-size: 1.1rem;
        color: var(--color-text-muted);
        max-width: 500px;
        margin: 0 auto 2rem;
        line-height: 1.5;
    }
    .empty-cta {
        display: inline-block;
        padding: 12px 24px;
        background: var(--color-blue-deep);
        color: #ffffff;
        font-weight: 600;
        border-radius: 12px;
        text-decoration: none;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .empty-cta:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(10,25,47,0.15);
    }

    /* Contact CTA (Copied from SupportCards to match style) */
    .contact-cta {
        padding: 4rem;
        background: radial-gradient(ellipse at 50% 0%, #112240 0%, #0a192f 80%);
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        color: #ffffff;
        position: relative;
        overflow: hidden;
        box-shadow: 0 30px 60px -20px rgba(10,25,47,0.5);
    }
    .contact-cta::after {
        content: '';
        position: absolute;
        top: -50%; right: -10%;
        width: 500px; height: 500px;
        background: radial-gradient(circle, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0) 70%);
        border-radius: 50%;
        pointer-events: none;
    }
    .cta-content h2 {
        font-size: 2.2rem;
        font-weight: 800;
        margin: 0 0 16px 0;
        letter-spacing: -0.03em;
        line-height: 1.1;
    }
    .cta-content p {
        font-size: 1.1rem;
        color: rgba(255,255,255,0.7);
        margin: 0;
        max-width: 480px;
        line-height: 1.6;
    }
    .cta-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 16px 32px;
        background: #ffffff;
        color: var(--color-blue-deep);
        font-weight: 700;
        font-size: 1rem;
        border-radius: 12px;
        text-decoration: none;
        transition: all 0.4s var(--ease-spring);
        white-space: nowrap;
        margin-left: 32px;
        box-shadow: 0 12px 28px -10px rgba(0,0,0,0.3);
        position: relative;
        z-index: 1;
    }
    .cta-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 20px 40px -15px rgba(0,0,0,0.4);
    }

    @media (max-width: 768px) {
        .articles-grid {
            grid-template-columns: 1fr;
        }
        .contact-cta {
            flex-direction: column;
            text-align: center;
            padding: 3rem 2rem;
        }
        .cta-content p { margin: 0 auto; }
        .cta-button {
            margin-left: 0;
            margin-top: 32px;
            width: 100%;
        }
    }
</style>
