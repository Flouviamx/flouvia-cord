<script is:inline>
    (function () {
        const input = document.getElementById('searchClientes');
        const clearBtn = document.getElementById('searchClearCli');
        const countEl = document.getElementById('dirCount');
        if (!input) return;

        const rows = Array.from(document.querySelectorAll('.dir .t-row'));
        const total = rows.length;
        let noResults = document.querySelector('.search-no-results');
        if (!noResults) {
            noResults = document.createElement('div');
            noResults.className = 'search-no-results';
            noResults.textContent = 'Sin resultados para esta búsqueda.';
            document.querySelector('.dir').appendChild(noResults);
        }

        function filter() {
            const q = input.value.trim().toLowerCase();
            clearBtn.style.display = q ? 'flex' : 'none';
            let visible = 0;
            rows.forEach(row => {
                const empresa = (row.dataset.empresa || '').toLowerCase();
                const contacto = (row.dataset.contacto || '').toLowerCase();
                const email = (row.dataset.email || '').toLowerCase();
                const rfc = (row.dataset.rfc || '').toLowerCase();
                const match = !q || empresa.includes(q) || contacto.includes(q) || email.includes(q) || rfc.includes(q);
                row.hidden = !match;
                if (match) visible++;
            });
            noResults.style.display = visible === 0 && q ? 'block' : 'none';
            if (countEl) {
                if (q) countEl.textContent = `${visible} de ${total} ${total === 1 ? 'cliente' : 'clientes'}`;
                else countEl.textContent = `${total} ${total === 1 ? 'cliente' : 'clientes'}`;
            }
        }

        input.addEventListener('input', filter);
        clearBtn.addEventListener('click', () => { input.value = ''; filter(); input.focus(); });
    })();
</script>
