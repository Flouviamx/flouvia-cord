---
// Dashboard de Cobros (Apple-style / Borderless)
import AppLayout from '../../layouts/AppLayout.astro';
import { getCobros, getMyMembership, money, getOrg } from '../../lib/queries';
import { getBalance, listPayouts } from '../../lib/billing';
import { memberCan } from '../../lib/permissions';

const ME = await getMyMembership();
const hasAccess = memberCan(ME, 'cobranza');
const C = hasAccess ? await getCobros() : null;
const hay = (C?.recent.length ?? 0) > 0;

let balance = null;
let payouts = null;

if (hasAccess) {
    try {
        const ORG = await getOrg();
        if (ORG.stripeAccountId && ORG.stripeChargesEnabled) {
            balance = await getBalance(ORG.stripeAccountId);
            payouts = await listPayouts(ORG.stripeAccountId);
        }
    } catch (e) {
        console.error('Error fetching Stripe balance', e);
    }
}

const formatDate = (ts: number) => {
    return new Date(ts * 1000).toLocaleDateString('es-MX', { day: '2-digit', month: 'short' });
};
const translateStatus = (s: string) => {
    if (s === 'paid') return 'Depositado';
    if (s === 'in_transit') return 'En camino';
    return 'Programado';
};

// Utilidad para color por método
const methodColor = (method: string) => {
    switch(method) {
        case 'tarjeta': return '#6366f1'; // Indigo
        case 'spei': return '#10b981'; // Emerald
        default: return '#94a3b8'; // Slate
    }
};

const methodLabel = (method: string) => {
    switch(method) {
        case 'tarjeta': return 'Tarjeta de crédito/débito';
        case 'spei': return 'Transferencia SPEI (Stripe)';
        default: return 'Transferencia (Manual)';
    }
};
---

<AppLayout title="Dinero Cobrado — Cord" page="cobros" heading="Cobros">
    {!hasAccess && (
        <div class="cb-denied">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <h3>Sin acceso</h3>
            <p>Tu rol actual no tiene permiso para ver los cobros. Contacta al administrador de tu organización.</p>
        </div>
    )}

    {hasAccess && !hay && (
        <section class="empty">
            <h2>Aún no has cobrado nada en línea</h2>
            <p>Conecta tu cuenta bancaria y empieza a cobrar por tarjeta o SPEI de forma automatizada.</p>
            <a href="/app/ajustes/cobros" class="empty-cta">Configurar cobros</a>
        </section>
    )}

    {hasAccess && hay && C && (
        <>
            <div class="two-col-flat" style="padding-top: 2rem; border-bottom: 1px solid var(--color-border); margin-bottom: 2rem; padding-bottom: 2rem;">
                <section class="kpis-section" style="display: flex; flex-direction: column; gap: 2rem; justify-content: center;">
                    <div class="kpi">
                        <span class="kpi-label">TOTAL COBRADO</span>
                        <span class="editorial kpi-num">{money(C.totalCobrado, 0)}</span>
                    </div>
                    {balance && (
                        <div style="display: flex; gap: 3rem;">
                            <div class="kpi">
                                <span class="kpi-label">SALDO DISPONIBLE</span>
                                <span class="editorial kpi-num" style="font-size: 1.8rem;">{money((balance.available[0]?.amount || 0) / 100, 0)}</span>
                            </div>
                            <div class="kpi">
                                <span class="kpi-label">EN CAMINO</span>
                                <span class="editorial kpi-num" style="font-size: 1.8rem; color: var(--color-text-muted);">{money((balance.pending[0]?.amount || 0) / 100, 0)}</span>
                            </div>
                        </div>
                    )}
                </section>

                {payouts && payouts.data && payouts.data.length > 0 && (
                    <section class="list-section">
                        <div class="sec-head" style="margin-bottom: 0;"><h2 class="sec-title">Depósitos</h2></div>
                        <div class="method-list">
                            {payouts.data.slice(0, 4).map((p: any) => (
                                <div class="method-row">
                                    <div class="m-info">
                                        <span class="m-dot" style={`background:${p.status === 'paid' ? '#10b981' : p.status === 'in_transit' ? '#3b82f6' : '#f59e0b'}`}></span>
                                        <div class="m-text">
                                            <span class="m-name">{translateStatus(p.status)}</span>
                                            <span class="m-sub">Llegada: {formatDate(p.arrival_date)}</span>
                                        </div>
                                    </div>
                                    <span class="editorial m-amount">{money(p.amount / 100, 0)}</span>
                                </div>
                            ))}
                        </div>
                    </section>
                )}
            </div>

            <div class="two-col-flat">
                <section class="list-section">
                    <div class="sec-head"><h2 class="sec-title">Desglose por método</h2></div>
                    <div class="method-list">
                        {C.methods.map((m) => (
                            <div class="method-row">
                                <div class="m-info">
                                    <span class="m-dot" style={`background:${methodColor(m.method)}`}></span>
                                    <div class="m-text">
                                        <span class="m-name">{methodLabel(m.method)}</span>
                                        <span class="m-sub">{m.txs} transacción{m.txs !== 1 ? 'es' : ''}</span>
                                    </div>
                                </div>
                                <span class="editorial m-amount">{money(m.monto, 0)}</span>
                            </div>
                        ))}
                    </div>
                </section>

                <section class="list-section">
                    <div class="sec-head"><h2 class="sec-title">Volumen mensual</h2></div>
                    <div class="monthly-list">
                        {C.monthly.map((m) => (
                            <div class="monthly-row">
                                <span class="m-name">{m.ym}</span>
                                <span class="editorial m-amount">{money(m.monto, 0)}</span>
                            </div>
                        ))}
                    </div>
                </section>
            </div>

            <section class="table-flat">
                <div class="sec-head"><h2 class="sec-title">Cobros recientes</h2></div>
                <div class="t-head">
                    <span>Folio</span>
                    <span>Cliente</span>
                    <span>Método</span>
                    <span>Fecha</span>
                    <span class="t-right">Monto</span>
                </div>
                <div class="t-body">
                    {C.recent.map((r) => (
                        <div class="t-row">
                            <a class="t-folio" href={`/app/cotizaciones/${r.id}`}>{r.folio}</a>
                            <span class="t-client">{r.empresa}</span>
                            <span class="t-method">
                                <span class="m-dot" style={`background:${methodColor(r.method)}`}></span>
                                {methodLabel(r.method)}
                            </span>
                            <span class="t-date">{r.paidAt}</span>
                            <span class="editorial t-amount t-right">{money(r.total, 0)}</span>
                        </div>
                    ))}
                </div>
            </section>
        </>
    )}
</AppLayout>

<style>
    /* Estilo Apple/Hairline (sin cards, sin box-shadow) */
    
    .kpi {
        display: flex; flex-direction: column; gap: 0.5rem;
    }
    .kpi-label { font-size: 0.65rem; font-weight: 800; letter-spacing: 1.5px; color: var(--color-text-muted); }
    .kpi-num { font-size: 2.5rem; color: var(--color-text); line-height: 1; font-variant-numeric: tabular-nums; }

    .two-col-flat {
        display: grid; grid-template-columns: 1fr 1fr; gap: 4rem;
        margin-bottom: 3rem;
    }
    .sec-head {
        padding-bottom: 0.8rem;
        border-bottom: 1px solid var(--color-border);
        margin-bottom: 1rem;
    }
    .sec-title {
        font-size: 0.9rem; font-weight: 600; margin: 0; color: var(--color-text);
    }

    /* Listas hairline */
    .method-row, .monthly-row {
        display: flex; justify-content: space-between; align-items: center;
        padding: 0.8rem 0;
        border-bottom: 1px solid var(--color-border);
    }
    .method-row:last-child, .monthly-row:last-child {
        border-bottom: none;
    }
    .m-info {
        display: flex; align-items: center; gap: 12px;
    }
    .m-dot {
        width: 10px; height: 10px; border-radius: 50%; display: inline-block;
    }
    .m-text {
        display: flex; flex-direction: column; gap: 2px;
    }
    .m-name { font-size: 0.88rem; font-weight: 500; color: var(--color-text); }
    .m-sub { font-size: 0.75rem; color: var(--color-text-muted); }
    .m-amount { font-size: 0.95rem; font-weight: 500; color: var(--color-text); }

    /* Tabla plana */
    .table-flat { margin-bottom: 3rem; }
    .t-head, .t-row {
        display: grid; grid-template-columns: 1fr 2fr 1.5fr 1fr 1fr;
        gap: 1rem; align-items: center;
        padding: 0.8rem 0;
    }
    .t-head {
        font-size: 0.65rem; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;
        color: var(--color-text-muted); border-bottom: 1px solid var(--color-border);
    }
    .t-row {
        border-bottom: 1px solid var(--color-border);
    }
    .t-folio { font-size: 0.85rem; font-weight: 600; color: var(--color-text); text-decoration: none; }
    .t-folio:hover { text-decoration: underline; color: var(--color-blue-deep); }
    .t-client { font-size: 0.85rem; color: var(--color-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .t-method { display: inline-flex; align-items: center; gap: 8px; font-size: 0.8rem; color: var(--color-text-muted); }
    .t-date { font-size: 0.8rem; color: var(--color-text-muted); }
    .t-right { text-align: right; }
    .t-amount { font-size: 0.95rem; color: var(--color-text); }

    .empty { padding: 4rem 0; }
    .empty h2 { font-size: 1.2rem; font-weight: 600; margin: 0 0 0.5rem; color: var(--color-text); }
    .empty p { font-size: 0.9rem; color: var(--color-text-muted); max-width: 460px; margin: 0 0 1.5rem; line-height: 1.5; }
    .empty-cta { display: inline-block; background: var(--color-text); color: var(--color-bg); text-decoration: none; font-size: 0.85rem; font-weight: 500; padding: 10px 18px; border-radius: 8px; }

    .cb-denied { display: flex; flex-direction: column; gap: 0.6rem; padding: 2rem 0; }
    .cb-denied svg { width: 32px; height: 32px; color: #c9d2de; }
    .cb-denied h3 { font-size: 1rem; font-weight: 700; margin: 0; }
    .cb-denied p { font-size: 0.84rem; color: var(--color-text-muted); margin: 0; line-height: 1.55; }

    @media (max-width: 800px) {
        .two-col-flat { grid-template-columns: 1fr; gap: 2rem; }
        .t-head { display: none; }
        .t-row { grid-template-columns: 1fr 1fr; gap: 0.5rem; padding: 1rem 0; }
        .t-method, .t-date { display: none; }
        .t-client { text-align: right; }
    }
</style>
