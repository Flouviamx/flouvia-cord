---
// Presupuestos — índice de Cédulas Presupuestales (planeación financiera).
// Herramienta de PLANEACIÓN: cascada Ventas → Producción → Compras de MP →
// Cobranza → Efectivo. El inventario inicial/final es un SUPUESTO tecleado, no
// un saldo rastreado en vivo — ver docs/historial.md.
//
// FREEMIUM (jul 2026): todos los planes crean cédulas con límite de cantidad
// (free 1 · starter 3 · pro+ ilimitadas). El wizard "Plan financiero completo"
// y Presupuesto vs. Real son Pro+ — el server (api/cedulas) es la autoridad.
import AppLayout from '../../../layouts/AppLayout.astro';
import { getMyMembership, getOrg } from '../../../lib/queries';
import { memberCan, planTienePresupuestos } from '../../../lib/permissions';

const ME = await getMyMembership();
const ORG = await getOrg();
const hasPerm = memberCan(ME, 'analitica');
const isPro = planTienePresupuestos(ORG.plan_raw);
---

<AppLayout title="Presupuestos — Cord" page="presupuestos" heading="Presupuestos">
    <div slot="topbar-actions">
        {hasPerm && <button class="btn-primary" id="btnNueva">+ Nuevo presupuesto</button>}
    </div>
    <div slot="page-sub">Planea tus ventas, costos y flujo de efectivo — y compáralo contra lo que realmente pasó.</div>
    {hasPerm && (
        <div slot="page-tabs">
            <a href="/app/presupuestos" class="ph-tab active">Cédulas</a>
            <a href="/app/presupuestos/herramientas" class="ph-tab">Herramientas</a>
        </div>
    )}

    {!hasPerm && (
        <div class="pr-denied">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <h3>Sin acceso</h3>
            <p>Tu rol actual no tiene permiso para ver presupuestos. Contacta al administrador de tu organización.</p>
        </div>
    )}

    {hasPerm && (
        <section id="listWrap">
            {!isPro && (
                <div class="pr-plan-note" id="planNote" hidden>
                    <span id="planNoteTxt"></span>
                    <a href="/app/ajustes/plan">Desbloquear con Profesional →</a>
                </div>
            )}
            <div class="skeleton-wrap" id="skel">
                <div class="skeleton skeleton-line" style="width:100%;height:52px;margin-bottom:8px"></div>
                <div class="skeleton skeleton-line" style="width:100%;height:52px;margin-bottom:8px"></div>
                <div class="skeleton skeleton-line" style="width:100%;height:52px"></div>
            </div>
            <div id="emptyState" class="empty" hidden>
                <h2>Planea el dinero de tu negocio en minutos</h2>
                <p>Arma tu presupuesto de ventas, cobranza y efectivo — Cord lo conecta con tus ventas reales para decirte cada mes si vas arriba o abajo del plan.</p>
                <button class="empty-cta" id="emptyCta">+ Crear mi primer presupuesto</button>
            </div>
            <div id="rows" class="pr-list" hidden></div>
        </section>
    )}

    {hasPerm && <dialog class="modal modal-lg" id="newModal">
        <form method="dialog" class="modal-card">
            <header>
                <h3 id="mTitle">¿Qué quieres planear?</h3>
                <button type="button" class="mclose" id="mClose" aria-label="Cerrar">&times;</button>
            </header>

            <!-- ── Paso 1: elegir tipo (lista hairline, lenguaje humano) ── -->
            <div class="modal-body" id="step1">
                <div class="tpl-list" role="listbox" aria-label="Tipo de presupuesto">
                    <button type="button" class="tpl-row tpl-featured is-selected" data-tipo="plan_completo" data-nombre="">
                        <span class="tpl-ico">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h16v4H4z" fill="currentColor" fill-opacity="0.12"/><path d="M4 5h16v4H4zM4 15h16v4H4z"/><path d="M8 9v3m8-3v3m-8 3v0"/><path d="M8 12h8v3H8z" fill="currentColor" fill-opacity="0.12"/><path d="M8 12h8v3H8z"/></svg>
                        </span>
                        <span class="tpl-txt">
                            <span class="tpl-name">Plan financiero completo <em class="tpl-chip">Recomendado</em>{!isPro && <em class="tpl-chip tpl-chip-pro">Pro</em>}</span>
                            <span class="tpl-desc">Ventas → Cobranza → Efectivo, ya conectados entre sí, sembrados con tu historial real y comparados mes a mes contra lo que de verdad vendas y cobres.</span>
                        </span>
                        <span class="tpl-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
                    </button>

                    <button type="button" class="tpl-row" data-tipo="ventas" data-nombre="Presupuesto de Ventas">
                        <span class="tpl-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17l6-6 4 4 7-7" /><path d="M14 8h6v6" /><path d="M3 17l6-6 4 4 7-7v13H3z" fill="currentColor" fill-opacity="0.12" stroke="none"/></svg></span>
                        <span class="tpl-txt"><span class="tpl-name">Ventas</span><span class="tpl-desc">¿Cuánto voy a vender cada mes? La base de todo lo demás.</span></span>
                        <span class="tpl-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
                    </button>
                    <button type="button" class="tpl-row" data-tipo="ventas_factores" data-nombre="Presupuesto de Ventas con factores de ajuste">
                        <span class="tpl-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2" fill="currentColor" fill-opacity="0.12"/><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 9h4M7 13h7M7 17h5"/><circle cx="16.5" cy="9" r="1.4"/></svg></span>
                        <span class="tpl-txt"><span class="tpl-name">Ventas con factores de ajuste</span><span class="tpl-desc">Parte del año pasado y aplica ajustes y factores % encadenados.</span></span>
                        <span class="tpl-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
                    </button>
                    <button type="button" class="tpl-row" data-tipo="produccion" data-nombre="Presupuesto de Producción">
                        <span class="tpl-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" fill="currentColor" fill-opacity="0.12"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><path d="M3.3 7 12 12l8.7-5M12 22V12"/></svg></span>
                        <span class="tpl-txt"><span class="tpl-name">Producción</span><span class="tpl-desc">¿Cuánto debo producir? Ventas + inventario deseado − inventario inicial, calculado solo.</span></span>
                        <span class="tpl-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
                    </button>
                    <button type="button" class="tpl-row" data-tipo="compras_mp" data-nombre="Presupuesto de Compras de Materia Prima">
                        <span class="tpl-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="20" r="1.4"/><circle cx="18" cy="20" r="1.4"/><path d="M2 3h3l2.6 12.4A2 2 0 0 0 9.6 17H18a2 2 0 0 0 2-1.6L21.6 8H6" fill="currentColor" fill-opacity="0.12"/><path d="M2 3h3l2.6 12.4A2 2 0 0 0 9.6 17H18a2 2 0 0 0 2-1.6L21.6 8H6"/></svg></span>
                        <span class="tpl-txt"><span class="tpl-name">Compras de materia prima</span><span class="tpl-desc">¿Cuánto material necesito comprar para cumplir el plan de producción?</span></span>
                        <span class="tpl-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
                    </button>
                    <button type="button" class="tpl-row" data-tipo="mano_obra" data-nombre="Presupuesto de Mano de Obra y CIF">
                        <span class="tpl-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.5" fill="currentColor" fill-opacity="0.12"/><circle cx="9" cy="8" r="3.5"/><path d="M2.5 20c.8-3.2 3.4-5 6.5-5s5.7 1.8 6.5 5"/><path d="M17.5 8.5 19 7m0 0 1.5-1.5M19 7l1.5 1.5M19 7l-1.5-1.5"/></svg></span>
                        <span class="tpl-txt"><span class="tpl-name">Mano de obra y CIF</span><span class="tpl-desc">¿Cuánto me cuesta producir? Horas, costo por hora y gastos indirectos.</span></span>
                        <span class="tpl-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
                    </button>
                    <button type="button" class="tpl-row" data-tipo="cobranza" data-nombre="Presupuesto de Cobranza">
                        <span class="tpl-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="16" rx="2" fill="currentColor" fill-opacity="0.12"/><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M8 3v4m8-4v4M3 10h18"/><path d="M12 13v5m0 0 2-2m-2 2-2-2"/></svg></span>
                        <span class="tpl-txt"><span class="tpl-name">Cobranza</span><span class="tpl-desc">¿Cuándo me pagan de verdad? Distribuye tus ventas a crédito por mes de cobro.</span></span>
                        <span class="tpl-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
                    </button>
                    <button type="button" class="tpl-row" data-tipo="efectivo" data-nombre="Presupuesto de Efectivo">
                        <span class="tpl-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2" fill="currentColor" fill-opacity="0.12"/><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2.6"/><path d="M5.5 9.5v0m13 5v0"/></svg></span>
                        <span class="tpl-txt"><span class="tpl-name">Efectivo</span><span class="tpl-desc">¿Me alcanza la caja? Entradas, salidas y saldo mes a mes.</span></span>
                        <span class="tpl-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
                    </button>
                    <button type="button" class="tpl-row" data-tipo="custom" data-nombre="">
                        <span class="tpl-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3" fill="currentColor" fill-opacity="0.12"/><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M12 8v8M8 12h8"/></svg></span>
                        <span class="tpl-txt"><span class="tpl-name">Empezar en blanco</span><span class="tpl-desc">Arma tu propia cédula fila por fila, con tus fórmulas.</span></span>
                        <span class="tpl-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
                    </button>
                </div>
            </div>

            <!-- ── Paso 2: nombre + periodos ── -->
            <div class="modal-body" id="step2" hidden>
                <label class="fld" id="fldNombre">
                    <span>Nombre</span>
                    <input type="text" id="fNombre" placeholder="Ej. Producción 2026" maxlength="120" />
                </label>
                <label class="fld">
                    <span>Meses a planear</span>
                    <div class="periodo-presets">
                        <button type="button" class="ppreset" data-n="3">Trimestre</button>
                        <button type="button" class="ppreset is-active" data-n="6">6 meses</button>
                        <button type="button" class="ppreset" data-n="12">Año completo</button>
                    </div>
                    <input type="text" id="fPeriodos" placeholder="Ene 2026, Feb 2026, Mar 2026…" />
                    <span class="m-hint">Separados por coma. Usa "Mes Año" (ej. Ene 2026) para que Cord pueda comparar cada columna contra tus ventas y cobranza reales de ese mes.</span>
                </label>
                <label class="tpl-toggle" id="fldProduccion" hidden>
                    <input type="checkbox" id="fProduccion" />
                    <span class="tpl-toggle-box"></span>
                    <span class="tpl-toggle-txt">Mi negocio produce o maneja inventario — agrega también Producción y Compras de MP</span>
                </label>
                <p class="m-err" id="fErr" hidden></p>
                <p class="m-err-plan" id="fErrPlan" hidden><a href="/app/ajustes/plan">Ver planes →</a></p>
            </div>

            <footer>
                <button type="button" id="mBack" class="btn-ghost" hidden>← Atrás</button>
                <span class="mfoot-spacer"></span>
                <button type="button" id="mCancel" class="btn-ghost">Cancelar</button>
                <button type="button" id="mNext" class="btn-primary">Continuar</button>
                <button type="button" id="mSave" class="btn-primary" hidden>Crear</button>
            </footer>
        </form>
    </dialog>}

    {hasPerm && <dialog class="modal" id="dupModal">
        <form method="dialog" class="modal-card">
            <header>
                <h3>Duplicar cédula</h3>
                <button type="button" class="mclose" id="dmClose" aria-label="Cerrar">&times;</button>
            </header>
            <div class="modal-body">
                <div class="dup-opts">
                    <label class="dup-opt">
                        <input type="radio" name="dupMode" value="0" checked />
                        <span class="dup-opt-txt"><strong>Mismos periodos</strong><span>Una copia idéntica — para probar otro escenario del mismo año.</span></span>
                    </label>
                    <label class="dup-opt">
                        <input type="radio" name="dupMode" value="1" />
                        <span class="dup-opt-txt"><strong>Recorrer al año siguiente</strong><span>Ene 2026 → Ene 2027 — para arrancar el plan del próximo año con esta base.</span></span>
                    </label>
                </div>
                <p class="m-err" id="dmErr" hidden></p>
            </div>
            <footer>
                <span class="mfoot-spacer"></span>
                <button type="button" id="dmCancel" class="btn-ghost">Cancelar</button>
                <button type="button" id="dmSave" class="btn-primary">Duplicar</button>
            </footer>
        </form>
    </dialog>}
</AppLayout>

<style is:global>
    .pr-denied { display:flex; flex-direction:column; align-items:center; text-align:center; gap:.75rem; padding:5rem 1rem; color:var(--color-text-muted); }
    .pr-denied svg { width:40px; height:40px; opacity:.5; }
    .pr-denied h3 { color:var(--color-text); font-size:1.05rem; }
    .pr-denied p { max-width:460px; font-size:.88rem; line-height:1.6; }

    /* Nota de plan (freemium) — hairline, sin card */
    .pr-plan-note { display:flex; align-items:center; justify-content:space-between; gap:1rem; padding:.7rem 0; margin-bottom:.5rem; border-bottom:1px solid var(--color-border); font-size:.82rem; color:var(--color-text-muted); }
    .pr-plan-note[hidden] { display:none; }
    .pr-plan-note a { color:var(--color-blue-deep); font-weight:600; text-decoration:none; white-space:nowrap; }
    html[data-theme="dark"] .pr-plan-note a { color:#7ea8ff; }

    .pr-list { display:flex; flex-direction:column; }
    .pr-list[hidden] { display:none; }
    .pr-row { display:grid; grid-template-columns: 1fr auto auto auto 28px; align-items:center; gap:1rem; padding:1rem 0; border-bottom:1px solid var(--color-border); cursor:pointer; }
    .pr-row:hover { background:var(--row-hover, var(--color-bg-soft)); }
    .pr-row:last-child { border-bottom:none; }
    .pr-name { font-weight:600; color:var(--color-text); }
    .pr-tipo { font-size:.78rem; color:var(--color-text-muted); }
    .pr-badge { font-size:.68rem; font-weight:700; letter-spacing:.02em; padding:.2rem .55rem; border-radius:999px; background:var(--color-bg-soft); color:var(--color-text-muted); white-space:nowrap; }
    .pr-badge-real { background:rgba(16,185,129,0.12); color:#047857; }
    html[data-theme="dark"] .pr-badge-real { color:#34d399; }
    .pr-updated { font-size:.78rem; color:var(--color-text-muted); white-space:nowrap; }
    .pr-del, .pr-dup { all:unset; box-sizing:border-box; display:inline-flex; cursor:pointer; opacity:.35; padding:4px; border-radius:6px; }
    .pr-dup:hover { opacity:1; color:var(--color-text); background:var(--color-bg-soft); }
    .pr-del:hover { opacity:1; color:var(--color-danger); background:var(--color-bg-soft); }

    .fld { display:flex; flex-direction:column; gap:.35rem; margin-bottom:1.1rem; }
    .fld[hidden] { display:none; }
    .fld span:first-child { font-size:.82rem; font-weight:600; color:var(--color-text); }
    .fld select, .fld input[type="text"] { background:var(--color-bg-soft); border:1px solid transparent; border-radius:10px; padding:.6rem .75rem; font-size:.9rem; color:var(--color-text); }
    .fld select:focus, .fld input:focus { outline:none; border-color:rgba(10,25,47,0.15); }
    .m-hint { font-size:.72rem; color:var(--color-text-muted); }
    .m-err { color:var(--color-danger); font-size:.82rem; margin:0; }
    .m-err-plan { margin:.35rem 0 0; font-size:.82rem; }
    .m-err-plan[hidden] { display:none; }
    .m-err-plan a { color:var(--color-blue-deep); font-weight:600; text-decoration:none; }
    .periodo-presets { display:flex; gap:.4rem; margin-bottom:.35rem; }
    .ppreset { all:unset; box-sizing:border-box; cursor:pointer; font-size:.72rem; padding:.3rem .6rem; border-radius:999px; background:var(--color-bg-soft); color:var(--color-text-muted); }
    .ppreset:hover { color:var(--color-text); }
    .ppreset.is-active { background:var(--color-blue-deep); color:#fff; }

    /* ── Selector de tipo (paso 1): filas hairline con ícono duotone ── */
    .tpl-list { display:flex; flex-direction:column; }
    .tpl-row { all:unset; box-sizing:border-box; display:grid; grid-template-columns: 40px 1fr 22px; align-items:center; gap:.9rem; padding:.85rem .5rem; border-radius:12px; cursor:pointer; border-bottom:1px solid var(--color-border); }
    .tpl-row:last-child { border-bottom:none; }
    .tpl-row:hover { background:var(--color-bg-soft); }
    .tpl-row.is-selected { background:var(--color-bg-soft); }
    .tpl-ico { display:flex; align-items:center; justify-content:center; width:40px; height:40px; border-radius:12px; background:rgba(10,25,47,0.05); color:var(--color-blue-deep); flex-shrink:0; }
    html[data-theme="dark"] .tpl-ico { background:rgba(255,255,255,0.07); color:#9db8e8; }
    .tpl-ico svg { width:21px; height:21px; }
    .tpl-txt { display:flex; flex-direction:column; gap:.15rem; min-width:0; }
    .tpl-name { font-size:.9rem; font-weight:600; color:var(--color-text); display:flex; align-items:center; gap:.45rem; flex-wrap:wrap; }
    .tpl-desc { font-size:.76rem; color:var(--color-text-muted); line-height:1.45; }
    .tpl-chip { font-style:normal; font-size:.6rem; font-weight:700; letter-spacing:.03em; text-transform:uppercase; padding:.14rem .5rem; border-radius:999px; background:rgba(16,185,129,0.12); color:#047857; }
    html[data-theme="dark"] .tpl-chip { color:#34d399; }
    .tpl-chip-pro { background:rgba(10,25,47,0.08); color:var(--color-blue-deep); }
    html[data-theme="dark"] .tpl-chip-pro { background:rgba(255,255,255,0.1); color:#9db8e8; }
    .tpl-check { display:flex; align-items:center; justify-content:center; width:22px; height:22px; border-radius:50%; color:#fff; background:var(--color-blue-deep); opacity:0; transform:scale(.6); transition: opacity .18s var(--ease-spring), transform .18s var(--ease-spring); }
    .tpl-check svg { width:12px; height:12px; }
    .tpl-row.is-selected .tpl-check { opacity:1; transform:scale(1); }
    .tpl-featured { border:1px solid rgba(10,25,47,0.12); border-radius:14px; margin-bottom:.6rem; background:var(--color-bg-soft); }
    html[data-theme="dark"] .tpl-featured { border-color:rgba(255,255,255,0.12); }
    .tpl-featured .tpl-ico { background:var(--color-blue-deep); color:#fff; }

    /* Opciones de duplicado (radios hairline) */
    .dup-opts { display:flex; flex-direction:column; }
    .dup-opt { display:flex; align-items:flex-start; gap:.7rem; padding:.8rem .35rem; border-bottom:1px solid var(--color-border); cursor:pointer; border-radius:10px; }
    .dup-opt:last-child { border-bottom:none; }
    .dup-opt:hover { background:var(--color-bg-soft); }
    .dup-opt input { margin-top:3px; accent-color: var(--color-blue-deep); }
    .dup-opt-txt { display:flex; flex-direction:column; gap:.12rem; }
    .dup-opt-txt strong { font-size:.88rem; font-weight:600; color:var(--color-text); }
    .dup-opt-txt span { font-size:.76rem; color:var(--color-text-muted); line-height:1.45; }

    /* Toggle "incluye producción" (checkbox estilizado simple) */
    .tpl-toggle { display:flex; align-items:flex-start; gap:.6rem; cursor:pointer; margin-bottom:1.1rem; }
    .tpl-toggle[hidden] { display:none; }
    .tpl-toggle input { position:absolute; opacity:0; pointer-events:none; }
    .tpl-toggle-box { flex-shrink:0; width:18px; height:18px; margin-top:1px; border-radius:6px; border:1.5px solid rgba(10,25,47,0.25); background:var(--color-bg); position:relative; transition: background .15s, border-color .15s; }
    html[data-theme="dark"] .tpl-toggle-box { border-color:rgba(255,255,255,0.3); }
    .tpl-toggle input:checked + .tpl-toggle-box { background:var(--color-blue-deep); border-color:var(--color-blue-deep); }
    .tpl-toggle input:checked + .tpl-toggle-box::after { content:''; position:absolute; left:5px; top:2px; width:4.5px; height:8.5px; border:solid #fff; border-width:0 2px 2px 0; transform:rotate(45deg); }
    .tpl-toggle-txt { font-size:.82rem; color:var(--color-text); line-height:1.45; }

    /* ── Estado vacío (mismo patrón que analítica/cobranza) ── */
    .empty { padding:4.5rem 2rem; text-align:center; }
    .empty h2 { font-size:1.1rem; font-weight:700; margin:0 0 .5rem; color:var(--color-text); }
    .empty p { font-size:.88rem; color:var(--color-text-muted); max-width:500px; margin:0 auto 1.4rem; line-height:1.6; }
    .empty-cta { all:unset; box-sizing:border-box; display:inline-block; cursor:pointer; background:var(--color-blue-deep); color:#fff; font-size:.86rem; font-weight:600; padding:11px 20px; border-radius:10px; transition: transform .15s var(--ease-spring), box-shadow .15s; }
    .empty-cta:hover { transform:translateY(-1px); box-shadow:0 10px 22px -10px rgba(10,25,47,0.5); }

    /* ── Modal (dialog nativo, mismo lenguaje que clientes/productos) ── */
    .modal {
        border:none; border-radius:20px; padding:0; color:var(--color-text);
        width:min(480px, calc(100vw - 2rem));
        background:var(--surface);
        box-shadow:0 40px 90px -30px rgba(10,25,47,0.45);
    }
    .modal-lg { width:min(620px, calc(100vw - 2rem)); }
    .modal::backdrop { background:rgba(10,25,47,0.38); backdrop-filter:blur(4px); }
    .modal[open] { animation: modIn .22s var(--ease-spring); }
    @keyframes modIn { from { opacity:0; transform:scale(.97) translateY(10px); } to { opacity:1; transform:scale(1) translateY(0); } }
    .modal-card { display:flex; flex-direction:column; }
    .modal-card header { display:flex; align-items:center; justify-content:space-between; padding:1.35rem 1.5rem; border-bottom:1px solid var(--color-border); }
    .modal-card header h3 { margin:0; font-size:1.05rem; font-weight:700; letter-spacing:-0.01em; color:var(--color-text); }
    .mclose { all:unset; box-sizing:border-box; cursor:pointer; width:28px; height:28px; display:flex; align-items:center; justify-content:center; border-radius:8px; color:var(--color-text-muted); font-size:1.2rem; line-height:1; }
    .mclose:hover { background:var(--color-bg-soft); color:var(--color-text); }
    .modal-body { padding:1.25rem 1.5rem; max-height:65vh; overflow-y:auto; }
    .modal-body[hidden] { display:none; }
    .modal-card footer { display:flex; align-items:center; gap:.6rem; padding:1.1rem 1.5rem; border-top:1px solid var(--color-border); }
    .mfoot-spacer { flex:1; }
    .modal-card footer .btn-ghost[hidden], .modal-card footer .btn-primary[hidden] { display:none; }

    .btn-primary { font-family:var(--font-sans); font-size:.85rem; font-weight:600; background:var(--color-blue-deep); color:#fff; border:none; border-radius:10px; padding:.6rem 1.15rem; cursor:pointer; box-shadow:0 6px 18px -8px rgba(10,25,47,0.5); transition: transform .15s var(--ease-spring), box-shadow .15s; }
    .btn-primary:hover { transform:translateY(-1px); box-shadow:0 10px 22px -8px rgba(10,25,47,0.55); }
    .btn-primary:active { transform:scale(.97); }
    .btn-primary:disabled { opacity:.6; cursor:default; transform:none; }
    .btn-ghost { font-family:var(--font-sans); font-size:.85rem; font-weight:600; background:var(--color-bg-soft); color:var(--color-text); border:1px solid var(--color-border); border-radius:10px; padding:.6rem 1.15rem; cursor:pointer; }
    .btn-ghost:hover { background:var(--color-border); }

    /* En móvil el modal se vuelve un "bottom sheet" (mismo patrón que clientes/productos) */
    @media (max-width: 560px) {
        .modal {
            width:100%; max-width:100%;
            margin:0; top:auto; bottom:0; left:0; right:0;
            border-radius:20px 20px 0 0;
            max-height:92dvh;
            animation: sheet-up .32s var(--ease-spring);
        }
        .modal-body { max-height: calc(92dvh - 150px); }
    }
    @keyframes sheet-up { from { transform: translateY(100%); } to { transform: translateY(0); } }
    @media (prefers-reduced-motion: reduce) { .modal, .modal[open] { animation:none; } }
</style>

<script>
    const TIPO_LABEL: Record<string, string> = {
        ventas: 'Ventas', ventas_factores: 'Ventas con factores', produccion: 'Producción', compras_mp: 'Compras de MP',
        mano_obra: 'Mano de obra y CIF', cif: 'CIF', cobranza: 'Cobranza', efectivo: 'Efectivo', custom: 'Personalizada',
    };

    const rowsEl = document.getElementById('rows')!;
    const emptyEl = document.getElementById('emptyState')!;
    const skelEl = document.getElementById('skel')!;

    async function load() {
        const res = await fetch('/api/cedulas');
        if (!res.ok) return;
        const data = await res.json();
        skelEl.setAttribute('hidden', '');
        const cedulas = data.cedulas || [];

        // Nota freemium: "1 de 1 cédulas de tu plan" (solo planes con límite).
        const note = document.getElementById('planNote');
        if (note && data.plan && data.plan.limit != null) {
            (document.getElementById('planNoteTxt') as HTMLElement).textContent =
                `Tu plan ${data.plan.label} incluye ${data.plan.limit} cédula${data.plan.limit === 1 ? '' : 's'} (usas ${cedulas.length}). Profesional desbloquea cédulas ilimitadas, el plan completo en un clic y la comparación contra tus ventas reales.`;
            note.removeAttribute('hidden');
        }

        if (!cedulas.length) { emptyEl.removeAttribute('hidden'); rowsEl.setAttribute('hidden', ''); return; }
        emptyEl.setAttribute('hidden', '');
        rowsEl.removeAttribute('hidden');
        rowsEl.innerHTML = cedulas.map((c: any) => `
            <div class="pr-row" data-id="${c.id}">
                <div>
                    <div class="pr-name">${escapeHtml(c.nombre)}</div>
                    <div class="pr-tipo">${TIPO_LABEL[c.tipo] || c.tipo}</div>
                </div>
                <span class="pr-badge">${c.periodos} periodo${c.periodos === 1 ? '' : 's'}</span>
                <span class="pr-updated">${new Date(c.updatedAt).toLocaleDateString('es-MX', { day: 'numeric', month: 'short' })}</span>
                <button class="pr-dup" data-dup="${c.id}" title="Duplicar (ej. copiar a otro año)" type="button">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="9" y="9" width="12" height="12" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                </button>
                <button class="pr-del" data-del="${c.id}" title="Eliminar" type="button">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                </button>
            </div>
        `).join('');
        rowsEl.querySelectorAll('.pr-row').forEach((el) => {
            el.addEventListener('click', (e) => {
                if ((e.target as HTMLElement).closest('[data-del],[data-dup]')) return;
                window.location.href = `/app/presupuestos/${(el as HTMLElement).dataset.id}`;
            });
        });
        rowsEl.querySelectorAll('[data-dup]').forEach((btn) => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                openDupModal((btn as HTMLElement).dataset.dup!);
            });
        });
        rowsEl.querySelectorAll('[data-del]').forEach((btn) => {
            btn.addEventListener('click', async (e) => {
                e.stopPropagation();
                const id = (btn as HTMLElement).dataset.del;
                if (!await (window as any).cordConfirm({ title: 'Eliminar cédula', body: 'Se borrarán todas sus filas y valores. Esta acción no se puede deshacer.', danger: true, confirmText: 'Eliminar' })) return;
                const r = await fetch(`/api/cedulas/${id}`, { method: 'DELETE' });
                if (r.ok) { (window as any).cordToast?.('Cédula eliminada', 'ok'); load(); }
                else (window as any).cordToast?.('No se pudo eliminar', 'error');
            });
        });
    }
    function escapeHtml(s: string) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

    // ── Modal de duplicado (mismos periodos vs. año siguiente) ───────
    const dupModal = document.getElementById('dupModal') as HTMLDialogElement | null;
    let dupId: string | null = null;
    function openDupModal(id: string) {
        if (!dupModal) return;
        dupId = id;
        (document.getElementById('dmErr') as HTMLElement).setAttribute('hidden', '');
        (dupModal.querySelector('input[name="dupMode"][value="0"]') as HTMLInputElement).checked = true;
        dupModal.showModal();
    }
    document.getElementById('dmClose')?.addEventListener('click', () => dupModal?.close());
    document.getElementById('dmCancel')?.addEventListener('click', () => dupModal?.close());
    document.getElementById('dmSave')?.addEventListener('click', async () => {
        if (!dupId) return;
        const shift = Number((dupModal!.querySelector('input[name="dupMode"]:checked') as HTMLInputElement)?.value) || 0;
        const btn = document.getElementById('dmSave') as HTMLButtonElement;
        btn.disabled = true;
        const r = await fetch('/api/cedulas', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ duplicar_de: dupId, shift_years: shift }),
        });
        const d = await r.json();
        btn.disabled = false;
        if (r.ok) {
            dupModal!.close();
            (window as any).cordToast?.(shift ? 'Cédula duplicada con los periodos recorridos un año' : 'Cédula duplicada', 'ok');
            window.location.href = `/app/presupuestos/${d.id}`;
        } else {
            const errEl = document.getElementById('dmErr') as HTMLElement;
            errEl.textContent = d.error || 'No se pudo duplicar';
            errEl.removeAttribute('hidden');
        }
    });

    // ── Modal de creación (2 pasos) ──────────────────────────────────
    const modal = document.getElementById('newModal') as HTMLDialogElement | null;
    const step1 = document.getElementById('step1')!;
    const step2 = document.getElementById('step2')!;
    const mTitle = document.getElementById('mTitle')!;
    const mNext = document.getElementById('mNext')!;
    const mSave = document.getElementById('mSave')!;
    const mBack = document.getElementById('mBack')!;
    let selTipo = 'plan_completo';

    function gotoStep(n: 1 | 2) {
        step1.toggleAttribute('hidden', n !== 1);
        step2.toggleAttribute('hidden', n !== 2);
        mNext.toggleAttribute('hidden', n !== 1);
        mSave.toggleAttribute('hidden', n !== 2);
        mBack.toggleAttribute('hidden', n !== 2);
        mTitle.textContent = n === 1 ? '¿Qué quieres planear?'
            : (selTipo === 'plan_completo' ? 'Tu plan financiero completo' : 'Detalles del presupuesto');
        if (n === 2) {
            // El wizard nombra sus cédulas solo; los tipos individuales piden nombre.
            document.getElementById('fldNombre')!.toggleAttribute('hidden', selTipo === 'plan_completo');
            document.getElementById('fldProduccion')!.toggleAttribute('hidden', selTipo !== 'plan_completo');
        }
    }

    const openModal = () => {
        if (!modal) return;
        (document.getElementById('fErr') as HTMLElement).setAttribute('hidden', '');
        (document.getElementById('fErrPlan') as HTMLElement).setAttribute('hidden', '');
        const nombreInput = document.getElementById('fNombre') as HTMLInputElement;
        nombreInput.value = '';
        nombreInput.dataset.touched = '';
        (document.getElementById('fProduccion') as HTMLInputElement).checked = false;
        // Default: 6 meses desde el mes actual (pre-llenado — un campo menos que pensar).
        applyPreset(6);
        document.querySelectorAll('.ppreset').forEach((b) => b.classList.toggle('is-active', (b as HTMLElement).dataset.n === '6'));
        gotoStep(1);
        modal.showModal();
    };
    document.getElementById('btnNueva')?.addEventListener('click', openModal);
    document.getElementById('emptyCta')?.addEventListener('click', openModal);
    document.getElementById('mClose')?.addEventListener('click', () => modal?.close());
    document.getElementById('mCancel')?.addEventListener('click', () => modal?.close());
    mBack.addEventListener('click', () => gotoStep(1));
    mNext.addEventListener('click', () => gotoStep(2));

    document.querySelectorAll('.tpl-row').forEach((row) => {
        row.addEventListener('click', () => {
            document.querySelectorAll('.tpl-row').forEach((r) => r.classList.remove('is-selected'));
            row.classList.add('is-selected');
            selTipo = (row as HTMLElement).dataset.tipo || 'custom';
            const nombreInput = document.getElementById('fNombre') as HTMLInputElement;
            if (nombreInput.dataset.touched !== '1') nombreInput.value = (row as HTMLElement).dataset.nombre || '';
        });
        // Doble clic / segundo clic en el ya seleccionado avanza — flujo de un gesto.
        row.addEventListener('dblclick', () => gotoStep(2));
    });
    document.getElementById('fNombre')?.addEventListener('input', (e) => {
        const t = e.target as HTMLInputElement;
        t.dataset.touched = t.value.trim() ? '1' : '';
    });

    const MESES = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];
    function applyPreset(n: number) {
        const now = new Date();
        const labels: string[] = [];
        for (let i = 0; i < n; i++) {
            const d = new Date(now.getFullYear(), now.getMonth() + i, 1);
            labels.push(`${MESES[d.getMonth()]} ${d.getFullYear()}`);
        }
        (document.getElementById('fPeriodos') as HTMLInputElement).value = labels.join(', ');
    }
    document.querySelectorAll('.ppreset').forEach((btn) => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.ppreset').forEach((b) => b.classList.remove('is-active'));
            btn.classList.add('is-active');
            applyPreset(Number((btn as HTMLElement).dataset.n) || 6);
        });
    });

    mSave.addEventListener('click', async () => {
        const periodos = (document.getElementById('fPeriodos') as HTMLInputElement).value
            .split(',').map((s) => s.trim()).filter(Boolean);
        const errEl = document.getElementById('fErr') as HTMLElement;
        const errPlan = document.getElementById('fErrPlan') as HTMLElement;
        errEl.setAttribute('hidden', ''); errPlan.setAttribute('hidden', '');
        if (!periodos.length) { errEl.textContent = 'Agrega al menos un periodo (ej. Ene 2026, Feb 2026).'; errEl.removeAttribute('hidden'); return; }

        const body: any = selTipo === 'plan_completo'
            ? { plan_completo: true, periodos, incluirProduccion: (document.getElementById('fProduccion') as HTMLInputElement).checked }
            : { tipo: selTipo, nombre: (document.getElementById('fNombre') as HTMLInputElement).value.trim(), periodos };

        (mSave as HTMLButtonElement).disabled = true;
        const res = await fetch('/api/cedulas', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
        });
        const data = await res.json();
        (mSave as HTMLButtonElement).disabled = false;
        if (!res.ok) {
            errEl.textContent = data.error || 'No se pudo crear.';
            errEl.removeAttribute('hidden');
            if (res.status === 402) errPlan.removeAttribute('hidden');
            return;
        }
        if (data.ids && data.ids.length > 1) (window as any).cordToast?.(`Se crearon ${data.ids.length} cédulas conectadas`, 'ok');
        window.location.href = `/app/presupuestos/${data.id}`;
    });

    load();
</script>
