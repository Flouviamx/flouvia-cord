---
// Editor de una Cédula Presupuestal — grid de filas (insumo o fórmula) ×
// periodos. Las filas 'input' se teclean; las 'formula' se calculan en el
// servidor (src/lib/cedulas.ts) contra otras filas, propias o de otra cédula.
import AppLayout from '../../../layouts/AppLayout.astro';
import { getMyMembership } from '../../../lib/queries';
import { memberCan } from '../../../lib/permissions';

const ME = await getMyMembership();
const hasAccess = memberCan(ME, 'analitica');
const cedulaId = Astro.params.id;
---

<AppLayout title="Cédula — Cord" page="presupuestos" heading="Cédula" crumbs={[{ label: 'Presupuestos', href: '/app/presupuestos' }]}>
    <div slot="topbar-actions">
        {hasAccess && <button class="btn-ghost" id="btnAddFila">+ Agregar fila</button>}
    </div>

    {!hasAccess && (
        <div class="pr-denied">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <h3>Sin acceso</h3>
            <p>Tu rol actual no tiene permiso para ver presupuestos. Contacta al administrador de tu organización.</p>
        </div>
    )}

    {hasAccess && <>
        <div class="pr-toolbar">
            <button type="button" id="btnRename" class="pr-name-wrap" title="Clic para renombrar">
                <span id="cName" class="pr-cedula-name">Cargando…</span>
                <svg class="pr-pencil" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>
            </button>
            <input id="cNameInput" class="pr-cedula-name-input" type="text" maxlength="120" hidden />
            <span id="cTipo" class="pr-badge"></span>
        </div>

        <div class="pr-grid-wrap" id="gridWrap">
            <div class="skeleton-wrap" id="skel">
                <div class="skeleton skeleton-line" style="width:100%;height:44px;margin-bottom:8px"></div>
                <div class="skeleton skeleton-line" style="width:100%;height:44px;margin-bottom:8px"></div>
                <div class="skeleton skeleton-line" style="width:100%;height:44px"></div>
            </div>
            <table class="pr-grid" id="grid" hidden></table>
            <div class="pr-empty-grid" id="emptyGrid" hidden>
                <p>Esta cédula todavía no tiene filas.</p>
                <button type="button" class="empty-cta" id="emptyGridCta">+ Agregar la primera fila</button>
            </div>
        </div>
        <p class="pr-legend">Las filas en gris claro son <strong>calculadas</strong> — se recalculan solas cuando cambias un insumo del que dependen.</p>

        <dialog class="modal modal-lg" id="filaModal">
            <form method="dialog" class="modal-card">
                <header>
                    <h3>Agregar fila</h3>
                    <button type="button" class="mclose" id="fmClose" aria-label="Cerrar">&times;</button>
                </header>
                <div class="modal-body">
                    <label class="fld">
                        <span>Concepto</span>
                        <input type="text" id="fmConcepto" placeholder="Ej. Consumo de acero por unidad" maxlength="160" />
                    </label>
                    <div class="fld">
                        <span>Tipo de fila</span>
                        <div class="pr-type-toggle">
                            <button type="button" class="pr-type-opt is-active" data-tipo="input">Insumo (lo tecleas)</button>
                            <button type="button" class="pr-type-opt" data-tipo="formula">Fórmula (se calcula)</button>
                        </div>
                    </div>
                    <div id="formulaBuilder" hidden>
                        <p class="m-hint">Los términos se aplican en el orden en que los agregas: "Suma/resta" acumula un valor (positivo o negativo); "% de otra fila" aplica un porcentaje de cambio sobre lo acumulado hasta ese punto (ej. +1% económico, luego +3% de distribución); "× otra fila" multiplica lo acumulado por otra fila completa (ej. unidades × precio). El campo <strong>Atrás</strong> toma el valor de un periodo anterior (0 = mismo periodo, 1 = el periodo pasado) — útil para cobranza escalonada.</p>
                        <div class="pr-term-head">
                            <span>Operación</span>
                            <span>Cédula</span>
                            <span>Fila</span>
                            <span class="pr-th-c">Coef.</span>
                            <span class="pr-th-c">Atrás</span>
                            <span></span>
                        </div>
                        <div id="terms"></div>
                        <button type="button" id="btnAddTerm" class="pr-add-term">+ Agregar término</button>
                    </div>
                    <p class="m-err" id="fmErr" hidden></p>
                </div>
                <footer>
                    <button type="button" id="fmCancel" class="btn-ghost">Cancelar</button>
                    <button type="button" id="fmSave" class="btn-primary">Agregar fila</button>
                </footer>
            </form>
        </dialog>
    </>}
</AppLayout>

<style is:global>
    .pr-denied { display:flex; flex-direction:column; align-items:center; text-align:center; gap:.75rem; padding:5rem 1rem; color:var(--color-text-muted); }
    .pr-denied svg { width:40px; height:40px; opacity:.5; }
    .pr-denied h3 { color:var(--color-text); font-size:1.05rem; }

    .pr-toolbar { display:flex; align-items:center; gap:.75rem; margin-bottom:1.25rem; }
    .pr-name-wrap { all:unset; box-sizing:border-box; cursor:pointer; display:flex; align-items:center; gap:.4rem; padding:.2rem .4rem; margin:-.2rem -.4rem; border-radius:8px; }
    .pr-name-wrap[hidden] { display:none; }
    .pr-name-wrap:hover { background:var(--color-bg-soft); }
    .pr-name-wrap:hover .pr-pencil { opacity:.5; }
    .pr-cedula-name { font-size:1.15rem; font-weight:600; color:var(--color-text); letter-spacing:-0.01em; }
    .pr-pencil { opacity:0; color:var(--color-text-muted); transition:opacity .15s; }
    .pr-cedula-name-input { font-size:1.15rem; font-weight:600; color:var(--color-text); letter-spacing:-0.01em; background:var(--color-bg-soft); border:1px solid rgba(10,25,47,0.15); border-radius:8px; padding:.15rem .5rem; font-family:inherit; }
    .pr-cedula-name-input:focus { outline:none; border-color:rgba(10,25,47,0.3); }
    .pr-badge { font-size:.7rem; font-weight:700; letter-spacing:.02em; padding:.22rem .6rem; border-radius:999px; background:var(--color-bg-soft); color:var(--color-text-muted); }

    .pr-grid-wrap { overflow-x:auto; border:1px solid var(--color-border); border-radius:14px; position:relative; }
    table.pr-grid { border-collapse:collapse; width:100%; font-size:.86rem; }
    .pr-grid th, .pr-grid td { padding:.7rem .9rem; text-align:right; white-space:nowrap; border-bottom:1px solid var(--color-border); }
    .pr-grid th { font-size:.68rem; text-transform:uppercase; letter-spacing:.04em; color:var(--color-text-muted); font-weight:700; background:var(--color-bg-soft); }
    .pr-grid tr:last-child td { border-bottom:none; }
    .pr-grid tbody tr:hover td { background:var(--row-hover, var(--color-bg-soft)); }
    .pr-grid tbody tr.pr-row-formula:hover td { background:var(--color-bg-soft); }
    .pr-row-head { text-align:left !important; position:sticky; left:0; background:var(--surface, #fff); min-width:240px; z-index:1; transition:box-shadow .15s; }
    .pr-grid th.pr-row-head { background:var(--color-bg-soft); z-index:2; }
    .pr-grid-wrap.is-scrolled .pr-row-head { box-shadow:6px 0 10px -6px rgba(10,25,47,0.16); }
    .pr-concepto-cell { display:flex; align-items:flex-start; justify-content:space-between; gap:.5rem; }
    .pr-concepto-main { min-width:0; }
    .pr-concepto-txt { font-weight:500; color:var(--color-text); display:block; white-space:normal; }
    .pr-concepto-formula { font-size:.72rem; color:var(--color-text-muted); font-variant-numeric:tabular-nums; margin-top:.15rem; white-space:normal; }
    .pr-row-formula .pr-row-head, .pr-row-formula td.pr-cell { background:var(--color-bg-soft); }
    .pr-row-formula .pr-concepto-txt { color:var(--color-text); }
    .pr-cell input { width:96px; text-align:right; background:transparent; border:1px solid transparent; border-radius:8px; padding:.3rem .4rem; font:inherit; color:var(--color-text); font-variant-numeric:tabular-nums; }
    .pr-cell input:hover { border-color:var(--color-border); }
    .pr-cell input:focus { outline:none; border-color:rgba(10,25,47,0.2); background:var(--color-bg); }
    .pr-cell-computed { font-variant-numeric:tabular-nums; font-weight:600; color:var(--color-text); border-radius:6px; transition:background-color .15s; }
    .pr-cell-computed.pr-flash { background-color:rgba(10,25,47,0.09); }
    .pr-del-fila { all:unset; box-sizing:border-box; cursor:pointer; display:inline-flex; opacity:.3; padding:3px; border-radius:5px; flex-shrink:0; margin-top:2px; }
    .pr-del-fila:hover { opacity:1; color:var(--color-danger); background:var(--color-bg-soft); }
    .pr-legend { font-size:.78rem; color:var(--color-text-muted); margin-top:.75rem; }
    .pr-empty-grid { display:flex; flex-direction:column; align-items:center; gap:.75rem; padding:3.5rem 1rem; text-align:center; color:var(--color-text-muted); }
    .pr-empty-grid[hidden] { display:none; }
    table.pr-grid[hidden] { display:none; }

    .fld { display:flex; flex-direction:column; gap:.35rem; margin-bottom:1.1rem; }
    .fld span:first-child { font-size:.82rem; font-weight:600; color:var(--color-text); }
    .fld input[type="text"] { background:var(--color-bg-soft); border:1px solid transparent; border-radius:10px; padding:.6rem .75rem; font-size:.9rem; color:var(--color-text); }
    .fld input:focus { outline:none; border-color:rgba(10,25,47,0.15); }
    .m-hint { font-size:.72rem; color:var(--color-text-muted); margin:0 0 .5rem; }
    .m-err { color:var(--color-danger); font-size:.82rem; margin:0; }

    .pr-type-toggle { display:flex; gap:.4rem; }
    .pr-type-opt { all:unset; box-sizing:border-box; cursor:pointer; text-align:center; flex:1; font-size:.82rem; padding:.5rem; border-radius:10px; background:var(--color-bg-soft); color:var(--color-text-muted); border:1px solid transparent; }
    .pr-type-opt.is-active { background:var(--color-blue-deep); color:#fff; }

    .pr-term-head { display:grid; grid-template-columns: 122px 1.1fr 1.1fr 54px 54px 28px; gap:.35rem; margin-bottom:.45rem; padding:0 .1rem; }
    .pr-term-head span { font-size:.6rem; font-weight:700; text-transform:uppercase; letter-spacing:.04em; color:var(--color-text-muted); }
    .pr-term-head .pr-th-c { text-align:center; }
    .pr-term-row { display:grid; grid-template-columns: 122px 1.1fr 1.1fr 54px 54px 28px; gap:.35rem; align-items:center; margin-bottom:.5rem; }
    .pr-term-row[data-kind="pct"] .term-coef, .pr-term-row[data-kind="producto"] .term-coef { visibility:hidden; }
    .term-offset { text-align:center; }
    .pr-term-row select, .pr-term-row input { background:var(--color-bg-soft); border:1px solid transparent; border-radius:8px; padding:.4rem .5rem; font-size:.8rem; color:var(--color-text); }
    .pr-term-row select:focus, .pr-term-row input:focus { outline:none; border-color:rgba(10,25,47,0.15); }
    .pr-term-del { all:unset; box-sizing:border-box; cursor:pointer; display:inline-flex; opacity:.4; padding:2px; }
    .pr-term-del:hover { opacity:1; color:var(--color-danger); }
    .pr-add-term { all:unset; box-sizing:border-box; cursor:pointer; font-size:.78rem; color:var(--color-blue-deep); font-weight:600; }

    /* ── Estado vacío del grid (mismo botón que el resto de la app) ── */
    .empty-cta { all:unset; box-sizing:border-box; display:inline-block; cursor:pointer; background:var(--color-blue-deep); color:#fff; font-size:.86rem; font-weight:600; padding:11px 20px; border-radius:10px; transition: transform .15s var(--ease-spring), box-shadow .15s; }
    .empty-cta:hover { transform:translateY(-1px); box-shadow:0 10px 22px -10px rgba(10,25,47,0.5); }

    /* ── Modal (dialog nativo, mismo lenguaje que clientes/productos) ── */
    .modal {
        border:none; border-radius:20px; padding:0; color:var(--color-text);
        width:min(480px, calc(100vw - 2rem));
        background:var(--surface);
        box-shadow:0 40px 90px -30px rgba(10,25,47,0.45);
    }
    .modal-lg { width:min(700px, calc(100vw - 2rem)); }
    .modal::backdrop { background:rgba(10,25,47,0.38); backdrop-filter:blur(4px); }
    .modal[open] { animation: modIn .22s var(--ease-spring); }
    @keyframes modIn { from { opacity:0; transform:scale(.97) translateY(10px); } to { opacity:1; transform:scale(1) translateY(0); } }
    .modal-card { display:flex; flex-direction:column; }
    .modal-card header { display:flex; align-items:center; justify-content:space-between; padding:1.35rem 1.5rem; border-bottom:1px solid var(--color-border); }
    .modal-card header h3 { margin:0; font-size:1.05rem; font-weight:700; letter-spacing:-0.01em; color:var(--color-text); }
    .mclose { all:unset; box-sizing:border-box; cursor:pointer; width:28px; height:28px; display:flex; align-items:center; justify-content:center; border-radius:8px; color:var(--color-text-muted); font-size:1.2rem; line-height:1; }
    .mclose:hover { background:var(--color-bg-soft); color:var(--color-text); }
    .modal-body { padding:1.5rem; max-height:70vh; overflow-y:auto; }
    .modal-card footer { display:flex; align-items:center; justify-content:flex-end; gap:.6rem; padding:1.1rem 1.5rem; border-top:1px solid var(--color-border); }

    .btn-primary { font-family:var(--font-sans); font-size:.85rem; font-weight:600; background:var(--color-blue-deep); color:#fff; border:none; border-radius:10px; padding:.6rem 1.15rem; cursor:pointer; box-shadow:0 6px 18px -8px rgba(10,25,47,0.5); transition: transform .15s var(--ease-spring), box-shadow .15s; }
    .btn-primary:hover { transform:translateY(-1px); box-shadow:0 10px 22px -8px rgba(10,25,47,0.55); }
    .btn-primary:active { transform:scale(.97); }
    .btn-ghost { font-family:var(--font-sans); font-size:.85rem; font-weight:600; background:var(--color-bg-soft); color:var(--color-text); border:1px solid var(--color-border); border-radius:10px; padding:.6rem 1.15rem; cursor:pointer; }
    .btn-ghost:hover { background:var(--color-border); }

    /* En móvil el modal se vuelve un "bottom sheet" (mismo patrón que clientes/productos) */
    @media (max-width: 560px) {
        .modal {
            width:100%; max-width:100%;
            margin:0; top:auto; bottom:0; left:0; right:0;
            border-radius:20px 20px 0 0;
            max-height:92dvh;
            animation: sheet-up .32s var(--ease-spring);
        }
        .modal-body { max-height: calc(92dvh - 130px); }
    }
    @keyframes sheet-up { from { transform: translateY(100%); } to { transform: translateY(0); } }
    @media (prefers-reduced-motion: reduce) { .modal, .modal[open] { animation:none; } }
</style>

<script define:vars={{ cedulaId }}>
    let STATE = null; // última respuesta de GET /api/cedulas/[id]

    const money = (n) => Number(n || 0).toLocaleString('es-MX', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
    function escapeHtml(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

    // Nombre de una fila por id, cruzando la cédula propia + todas las "otras"
    // (para que la descripción de una fórmula muestre nombres, no ids).
    function filaNombre(filaId, cedulaIdRef) {
        if (!cedulaIdRef || cedulaIdRef === STATE.cedula.id) {
            const f = STATE.cedula.filas.find((x) => x.id === filaId);
            return f ? f.concepto : '(fila eliminada)';
        }
        const otra = STATE.otras.find((o) => o.id === cedulaIdRef);
        const f = otra && otra.filas.find((x) => x.id === filaId);
        if (!f) return '(fila eliminada)';
        return `${f.concepto} · ${otra.nombre}`;
    }

    // "= Ventas + Inv. final deseado − Inv. inicial" o "= Ventas × (1 + Factor1 %) × Precio"
    // o "= 0.4× Ventas + 0.3× Ventas (t−1) + 0.3× Ventas (t−2)" según el kind/offset de cada
    // término — legible, sin ids.
    function describeFormula(formula) {
        if (!formula || !Array.isArray(formula.terms) || !formula.terms.length) return '';
        return '= ' + formula.terms.map((t, i) => {
            const kind = t.kind || 'suma';
            const nombre = filaNombre(t.fila_id, t.cedula_id);
            const offset = Number(t.offset) || 0;
            const desfase = offset ? ` (t−${offset})` : '';
            if (kind === 'pct') return (i === 0 ? '' : ' ') + `× (1 + ${nombre}${desfase} %)`;
            if (kind === 'producto') return (i === 0 ? '' : ' ') + `× ${nombre}${desfase}`;
            const coef = Number(t.coef) || 0;
            const abs = Math.abs(coef);
            const factor = abs !== 1 ? `${abs}× ` : '';
            const sign = coef < 0 ? '−' : '+';
            return (i === 0 ? (coef < 0 ? '−' : '') : ` ${sign} `) + factor + nombre + desfase;
        }).join('');
    }

    async function load() {
        const res = await fetch(`/api/cedulas/${cedulaId}`);
        if (!res.ok) { document.getElementById('cName').textContent = 'Cédula no encontrada'; return; }
        STATE = await res.json();
        document.title = `${STATE.cedula.nombre} — Cord`;
        document.getElementById('cName').textContent = STATE.cedula.nombre;
        document.getElementById('cTipo').textContent = STATE.cedula.periodos.length + ' periodos';
        renderGrid();
    }

    function renderGrid() {
        const skel = document.getElementById('skel');
        const grid = document.getElementById('grid');
        const emptyGrid = document.getElementById('emptyGrid');
        skel.setAttribute('hidden', '');

        if (!STATE.cedula.filas.length) {
            grid.setAttribute('hidden', '');
            emptyGrid.removeAttribute('hidden');
            return;
        }
        emptyGrid.setAttribute('hidden', '');
        grid.removeAttribute('hidden');

        const periodos = STATE.cedula.periodos;
        const filas = STATE.cedula.filas;

        let thead = '<thead><tr><th class="pr-row-head">Concepto</th>' + periodos.map((p) => `<th>${escapeHtml(p)}</th>`).join('') + '</tr></thead>';
        let tbody = '<tbody>' + filas.map((f) => {
            const vals = STATE.valores[f.id] || [];
            const cells = periodos.map((_, i) => {
                if (f.tipo === 'input') {
                    return `<td class="pr-cell"><input class="editorial" type="number" step="any" inputmode="decimal" data-fila="${f.id}" data-idx="${i}" value="${vals[i] ?? 0}" /></td>`;
                }
                return `<td class="pr-cell pr-cell-computed editorial" data-computed-fila="${f.id}" data-computed-idx="${i}">${money(vals[i] ?? 0)}</td>`;
            }).join('');
            const formulaTxt = f.tipo === 'formula' ? describeFormula(f.formula) : '';
            return `<tr class="${f.tipo === 'formula' ? 'pr-row-formula' : ''}">
                <td class="pr-row-head">
                    <div class="pr-concepto-cell">
                        <div class="pr-concepto-main">
                            <span class="pr-concepto-txt">${escapeHtml(f.concepto)}</span>
                            ${formulaTxt ? `<span class="pr-concepto-formula">${escapeHtml(formulaTxt)}</span>` : ''}
                        </div>
                        <button class="pr-del-fila" data-del-fila="${f.id}" title="Eliminar fila" type="button">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                        </button>
                    </div>
                </td>
                ${cells}
            </tr>`;
        }).join('') + '</tbody>';

        grid.innerHTML = thead + tbody;
        wireGridEvents(grid);
    }

    function wireGridEvents(grid) {
        grid.querySelectorAll('input[data-fila]').forEach((inp) => {
            inp.addEventListener('change', async () => {
                const filaId = inp.dataset.fila;
                const idx = Number(inp.dataset.idx);
                const valor = Number(inp.value) || 0;
                const r = await fetch(`/api/cedulas/${cedulaId}`, {
                    method: 'PATCH', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: 'set_valor', fila_id: filaId, periodo_idx: idx, valor }),
                });
                if (r.ok) refreshValues(); else window.cordToast?.('No se pudo guardar el valor', 'error');
            });
        });
        grid.querySelectorAll('[data-del-fila]').forEach((btn) => {
            btn.addEventListener('click', async () => {
                const filaId = btn.dataset.delFila;
                if (!await window.cordConfirm({ title: 'Eliminar fila', body: 'Se borrarán sus valores. Si otra fórmula la referencia, esa fórmula pasará a calcular 0 para esta fila.', danger: true, confirmText: 'Eliminar' })) return;
                const r = await fetch(`/api/cedulas/${cedulaId}`, {
                    method: 'PATCH', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: 'delete_fila', fila_id: filaId }),
                });
                if (r.ok) load(); else window.cordToast?.('No se pudo eliminar la fila', 'error');
            });
        });
    }

    // Tras editar un insumo: refresca solo los VALORES (sin reconstruir el DOM
    // ni robar el foco de otra celda donde el usuario ya esté escribiendo) y
    // marca con un flash breve las celdas calculadas que cambiaron.
    async function refreshValues() {
        const prevValores = STATE ? JSON.parse(JSON.stringify(STATE.valores)) : {};
        const res = await fetch(`/api/cedulas/${cedulaId}`);
        if (!res.ok) return;
        STATE = await res.json();
        const grid = document.getElementById('grid');
        STATE.cedula.filas.forEach((f) => {
            const vals = STATE.valores[f.id] || [];
            const prevVals = prevValores[f.id] || [];
            STATE.cedula.periodos.forEach((_, i) => {
                const v = Number(vals[i] ?? 0);
                if (f.tipo === 'input') {
                    const inp = grid.querySelector(`input[data-fila="${f.id}"][data-idx="${i}"]`);
                    if (inp && document.activeElement !== inp) inp.value = v;
                    return;
                }
                const cell = grid.querySelector(`[data-computed-fila="${f.id}"][data-computed-idx="${i}"]`);
                if (!cell) return;
                const pv = Number(prevVals[i] ?? 0);
                cell.textContent = money(v);
                if (Math.abs(v - pv) > 0.004) {
                    cell.classList.remove('pr-flash');
                    void cell.offsetWidth; // fuerza reflow para reiniciar la transición
                    cell.classList.add('pr-flash');
                    setTimeout(() => cell.classList.remove('pr-flash'), 700);
                }
            });
        });
    }

    // ── Renombrar (inline, sin prompt() nativo) ───────────────────────
    const nameBtn = document.getElementById('btnRename');
    const nameInput = document.getElementById('cNameInput');
    function startRename() {
        if (!STATE) return;
        nameInput.value = STATE.cedula.nombre;
        nameBtn.setAttribute('hidden', '');
        nameInput.removeAttribute('hidden');
        nameInput.focus();
        nameInput.select();
    }
    async function commitRename() {
        nameInput.setAttribute('hidden', '');
        nameBtn.removeAttribute('hidden');
        const nombre = nameInput.value.trim();
        if (!nombre || nombre === STATE.cedula.nombre) return;
        document.getElementById('cName').textContent = nombre; // optimista
        const r = await fetch(`/api/cedulas/${cedulaId}`, {
            method: 'PATCH', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'rename', nombre }),
        });
        if (r.ok) { STATE.cedula.nombre = nombre; document.title = `${nombre} — Cord`; }
        else { document.getElementById('cName').textContent = STATE.cedula.nombre; window.cordToast?.('No se pudo renombrar', 'error'); }
    }
    nameBtn?.addEventListener('click', startRename);
    nameInput?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') nameInput.blur();
        if (e.key === 'Escape') { nameInput.value = STATE.cedula.nombre; nameInput.blur(); }
    });
    nameInput?.addEventListener('blur', commitRename);

    // ── Sombra de la columna fija al hacer scroll horizontal ──────────
    const gridWrap = document.getElementById('gridWrap');
    gridWrap?.addEventListener('scroll', () => {
        gridWrap.classList.toggle('is-scrolled', gridWrap.scrollLeft > 2);
    });

    // ── Modal "Agregar fila" ─────────────────────────────────────────
    const filaModal = document.getElementById('filaModal');
    const builder = document.getElementById('formulaBuilder');
    const termsWrap = document.getElementById('terms');
    let currentTipo = 'input';

    function openFilaModal() {
        document.getElementById('fmConcepto').value = '';
        document.getElementById('fmErr').setAttribute('hidden', '');
        termsWrap.innerHTML = '';
        setTipo('input');
        filaModal.showModal();
    }
    document.getElementById('btnAddFila')?.addEventListener('click', openFilaModal);
    document.getElementById('emptyGridCta')?.addEventListener('click', openFilaModal);
    document.getElementById('fmClose')?.addEventListener('click', () => filaModal.close());
    document.getElementById('fmCancel')?.addEventListener('click', () => filaModal.close());

    function setTipo(tipo) {
        currentTipo = tipo;
        document.querySelectorAll('.pr-type-opt').forEach((b) => b.classList.toggle('is-active', b.dataset.tipo === tipo));
        if (tipo === 'formula') { builder.removeAttribute('hidden'); if (!termsWrap.children.length) addTermRow(); }
        else builder.setAttribute('hidden', '');
    }
    document.querySelectorAll('.pr-type-opt').forEach((b) => b.addEventListener('click', () => setTipo(b.dataset.tipo)));

    function cedulaOptionsHtml() {
        if (!STATE) return '';
        let opts = `<option value="">${escapeHtml(STATE.cedula.nombre)} (esta cédula)</option>`;
        for (const o of STATE.otras) opts += `<option value="${o.id}">${escapeHtml(o.nombre)}</option>`;
        return opts;
    }
    function filaOptionsHtml(cedulaSel) {
        const filas = !cedulaSel ? STATE.cedula.filas : (STATE.otras.find((o) => o.id === cedulaSel)?.filas || []);
        return filas.map((f) => `<option value="${f.id}">${escapeHtml(f.concepto)}</option>`).join('');
    }
    function addTermRow() {
        const row = document.createElement('div');
        row.className = 'pr-term-row';
        row.dataset.kind = 'suma';
        row.innerHTML = `
            <select class="term-kind" title="Tipo de término">
                <option value="suma">Suma / resta</option>
                <option value="pct">% de otra fila</option>
                <option value="producto">× otra fila</option>
            </select>
            <select class="term-cedula">${cedulaOptionsHtml()}</select>
            <select class="term-fila"></select>
            <input type="number" class="term-coef" value="1" step="any" title="Coeficiente" />
            <input type="number" class="term-offset" value="0" step="1" min="0" title="Periodos atrás (0 = mismo periodo, 1 = un periodo antes…)" />
            <button type="button" class="pr-term-del" title="Quitar">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M18 6 6 18M6 6l12 12"/></svg>
            </button>`;
        termsWrap.appendChild(row);
        const kindSel = row.querySelector('.term-kind');
        const cedulaSel = row.querySelector('.term-cedula');
        const filaSel = row.querySelector('.term-fila');
        const refresh = () => { filaSel.innerHTML = filaOptionsHtml(cedulaSel.value); };
        cedulaSel.addEventListener('change', refresh);
        kindSel.addEventListener('change', () => { row.dataset.kind = kindSel.value; });
        refresh();
        row.querySelector('.pr-term-del').addEventListener('click', () => row.remove());
    }
    document.getElementById('btnAddTerm')?.addEventListener('click', addTermRow);

    document.getElementById('fmSave')?.addEventListener('click', async () => {
        const concepto = document.getElementById('fmConcepto').value.trim();
        const errEl = document.getElementById('fmErr');
        if (!concepto) { errEl.textContent = 'Escribe un concepto.'; errEl.removeAttribute('hidden'); return; }
        const body = { action: 'add_fila', concepto, tipo: currentTipo };
        if (currentTipo === 'formula') {
            const terms = Array.from(termsWrap.querySelectorAll('.pr-term-row')).map((row) => {
                const kind = row.querySelector('.term-kind').value;
                return {
                    kind,
                    cedula_id: row.querySelector('.term-cedula').value || null,
                    fila_id: row.querySelector('.term-fila').value,
                    coef: Number(row.querySelector('.term-coef').value) || 0,
                    offset: Number(row.querySelector('.term-offset').value) || 0,
                };
            }).filter((t) => t.fila_id && (t.kind !== 'suma' || t.coef !== 0));
            if (!terms.length) { errEl.textContent = 'Agrega al menos un término válido (suma con coeficiente distinto de 0, o una referencia de % / ×).'; errEl.removeAttribute('hidden'); return; }
            body.formula = { terms };
        }
        const r = await fetch(`/api/cedulas/${cedulaId}`, {
            method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
        });
        const data = await r.json();
        if (!r.ok) { errEl.textContent = data.error || 'No se pudo agregar la fila.'; errEl.removeAttribute('hidden'); return; }
        filaModal.close();
        load();
    });

    load();
</script>
