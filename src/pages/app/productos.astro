---
// Productos — catálogo con precios de lista. CRUD real (Neon).
import AppLayout from '../../layouts/AppLayout.astro';
import { getProductos, getMyMembership, money } from '../../lib/queries';
import { memberCan } from '../../lib/permissions';

const [PRODUCTOS, ME] = await Promise.all([getProductos(), getMyMembership()]);
const canEdit = memberCan(ME, 'productos');
---

<AppLayout title="Productos — Cord" page="productos" heading="Productos">
    <div slot="topbar-actions" class="topbar-btns">
        <div class="ph-search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input id="searchProductos" type="search" placeholder="Buscar productos…" autocomplete="off" spellcheck="false" />
            <button class="ph-search-clear" id="searchClear" aria-label="Limpiar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        {canEdit && <button class="btn-import" id="btnImport">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            Importar CSV
        </button>}
        {canEdit && <button class="btn-new" id="btnNew">+ Nuevo producto</button>}
    </div>

    <section class="catalogo">
        <div class="section-head">
            <h2>Catálogo</h2>
            <span class="cat-count" id="catCount">{PRODUCTOS.length} producto{PRODUCTOS.length === 1 ? '' : 's'}</span>
        </div>
        <div class="t-head">
            <span>SKU</span><span>Producto</span><span>Unidad</span><span class="t-right">Precio de lista</span><span>Estado</span>
        </div>
        {PRODUCTOS.map((p) => (
            <button
                class="t-row"
                data-id={p.id}
                data-sku={p.sku}
                data-nombre={p.nombre}
                data-unidad={p.unidad}
                data-precio={String(p.precio)}
                data-costo={String(p.costo)}
                data-activo={p.activo ? '1' : ''}
                data-volumen={JSON.stringify(p.preciosVolumen)}
            >
                <span class="t-sku">{p.sku}</span>
                <span class="t-name">{p.nombre}</span>
                <span class="t-muted">{p.unidad}</span>
                <span class="editorial t-amount t-right">{money(p.precio)}</span>
                <span class:list={['t-state', p.activo ? 'on' : 'off']}>{p.activo ? '● Activo' : '○ Inactivo'}</span>
            </button>
        ))}
        {PRODUCTOS.length === 0 && (
            <div class="t-empty">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                <p><b>Tu catálogo está vacío</b> Agrega tu primer producto o impórtalos en lote desde un CSV.</p>
                {canEdit && (
                    <div class="t-empty-cta">
                        <button class="btn-new" id="btnNewEmpty">+ Nuevo producto</button>
                        <button class="btn-import" id="btnImportEmpty">Importar CSV</button>
                    </div>
                )}
            </div>
        )}
    </section>

    <!-- Modal alta / edición (solo si tiene permiso de edición) -->
    {canEdit && <dialog class="modal" id="prodModal">
        <form method="dialog" class="m-form" id="prodForm">
            <div class="m-head">
                <h2 id="mTitle">Nuevo producto</h2>
                <button type="button" class="m-close" id="mClose" aria-label="Cerrar">✕</button>
            </div>

            <div class="m-field">
                <label for="fNombre">Nombre *</label>
                <input class="m-input" id="fNombre" required placeholder="Cemento gris 50kg" />
            </div>
            <div class="m-row">
                <div class="m-field">
                    <label for="fSku">SKU</label>
                    <input class="m-input" id="fSku" placeholder="CEM-50" maxlength="24" />
                </div>
                <div class="m-field">
                    <label for="fUnidad">Unidad</label>
                    <input class="m-input" id="fUnidad" placeholder="saco, pieza, m³…" />
                </div>
            </div>
            <div class="m-row">
                <div class="m-field">
                    <label for="fPrecio">Precio de venta (MXN) *</label>
                    <input class="m-input" id="fPrecio" type="number" min="0" step="0.01" required placeholder="198.00" />
                </div>
                <div class="m-field">
                    <label for="fCosto">¿Cuánto te cuesta? (MXN)</label>
                    <input class="m-input" id="fCosto" type="number" min="0" step="0.01" placeholder="0.00" />
                    <span class="m-hint">Opcional. Nos deja mostrarte tu ganancia.</span>
                </div>
            </div>
            <div class="margin-strip" id="marginStrip" hidden>
                <div class="ms-bar"><span class="ms-fill" id="msFill"></span></div>
                <div class="ms-text" id="msText"></div>
            </div>

            <!-- Precios por volumen (opcional) -->
            <div class="m-field vol-field">
                <label>Precios por volumen <span class="m-optlbl">opcional</span></label>
                <span class="m-hint">Aplica un precio más bajo automáticamente cuando la cantidad en la cotización alcanza cada nivel. Ideal para ventas al mayoreo.</span>
                <div class="vol-list" id="volList"></div>
                <button type="button" class="vol-add" id="volAdd">
                    <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Agregar nivel de volumen
                </button>
            </div>

            <div class="m-row">
                <div class="m-field" style="flex:0 0 auto">
                    <label>Estado</label>
                    <div class="m-chips" id="fActivo">
                        <button type="button" class="chip active" data-v="1">Activo</button>
                        <button type="button" class="chip" data-v="">Inactivo</button>
                    </div>
                </div>
            </div>

            <p class="m-error" id="mError"></p>

            <div class="m-actions">
                {canEdit && <button type="button" class="m-delete" id="mDelete">Eliminar</button>}
                <span class="m-spacer"></span>
                <button type="button" class="m-cancel" id="mCancel">Cancelar</button>
                <button type="submit" class="m-save" id="mSave">Guardar producto</button>
            </div>
        </form>
    </dialog>}

    <!-- Modal de importación CSV (solo si tiene permiso de edición) -->
    {canEdit && <dialog class="modal modal-lg" id="importModal">
        <div class="m-form">
            <div class="m-head">
                <h2 id="impTitle">Importar productos por CSV</h2>
                <button type="button" class="m-close" id="impClose" aria-label="Cerrar">✕</button>
            </div>

            <div class="imp-steps" id="impSteps">
                <span class="imp-stepdot active" data-s="file"><i>1</i> Archivo</span>
                <span class="imp-stepdot" data-s="map"><i>2</i> Columnas</span>
                <span class="imp-stepdot" data-s="prev"><i>3</i> Revisar</span>
            </div>

            <!-- Paso 1: archivo -->
            <div class="imp-step" id="impStepFile">
                <label class="imp-drop" id="impDrop">
                    <input type="file" id="impFile" accept=".csv,text/csv" hidden />
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="M12 18v-6"/><path d="m9 15 3-3 3 3"/></svg>
                    <b>Arrastra tu archivo CSV o haz clic para elegirlo</b>
                    <span>Columnas sugeridas: SKU, nombre, unidad, precio, activo</span>
                </label>
                <button type="button" class="imp-tpl" id="impTpl">↓ Descargar plantilla de ejemplo</button>
            </div>

            <!-- Paso 2: mapeo de columnas -->
            <div class="imp-step" id="impStepMap" hidden>
                <p class="imp-lead">Empareja las columnas de tu archivo con los campos de Cord.</p>
                <label class="imp-check"><input type="checkbox" id="impHeader" checked /> La primera fila son encabezados</label>
                <div class="imp-maps" id="impMaps"></div>
            </div>

            <!-- Paso 3: preview -->
            <div class="imp-step" id="impStepPrev" hidden>
                <div class="imp-summary" id="impSummary"></div>
                <label class="imp-check"><input type="checkbox" id="impUpsert" checked /> Actualizar productos existentes con el mismo SKU</label>
                <div class="imp-prev-wrap"><table class="imp-prev"><thead id="impPrevHead"></thead><tbody id="impPrevBody"></tbody></table></div>
            </div>

            <p class="m-error" id="impError"></p>

            <div class="m-actions">
                <button type="button" class="m-cancel" id="impBack" hidden>← Atrás</button>
                <span class="m-spacer"></span>
                <button type="button" class="m-cancel" id="impCancel">Cancelar</button>
                <button type="button" class="m-save" id="impNext" disabled>Continuar</button>
            </div>
        </div>
    </dialog>}
</AppLayout>

<style>
    .btn-new {
        font-family: var(--font-sans);
        background: var(--color-blue-deep); color: #fff;
        font-size: 0.82rem; font-weight: 600; border: none; cursor: pointer;
        padding: 9px 16px; border-radius: 9px;
        box-shadow: 0 6px 18px -8px rgba(10,25,47,0.5);
        transition: transform 0.4s var(--ease-spring);
    }
    .btn-new:hover { transform: translateY(-2px); }
    .topbar-btns { display: flex; gap: 0.6rem; align-items: center; }
    .btn-import {
        font-family: var(--font-sans); display: inline-flex; align-items: center; gap: 7px;
        background: var(--color-bg-soft); color: var(--color-text);
        font-size: 0.82rem; font-weight: 600; border: 1px solid var(--color-border); cursor: pointer;
        padding: 8px 14px; border-radius: 9px; transition: border-color 0.25s, transform 0.4s var(--ease-spring);
    }
    .btn-import svg { width: 14px; height: 14px; }
    .btn-import:hover { transform: translateY(-2px); border-color: rgba(10,25,47,0.25); }

    /* ── Modal importación ── */
    .modal-lg { width: min(680px, calc(100vw - 2rem)); }
    .imp-steps { display: flex; align-items: center; gap: 0.4rem; margin: -0.2rem 0 0.2rem; }
    .imp-stepdot { display: inline-flex; align-items: center; gap: 6px; font-size: 0.74rem; font-weight: 600; color: var(--color-text-muted); }
    .imp-stepdot i { display: inline-flex; align-items: center; justify-content: center; width: 19px; height: 19px; border-radius: 50%; border: 1px solid var(--color-border); font-size: 0.66rem; font-style: normal; font-weight: 700; transition: all 0.25s; }
    .imp-stepdot:not(:last-child)::after { content: ''; width: 18px; height: 1px; background: var(--color-border); margin-left: 0.4rem; }
    .imp-stepdot.active { color: var(--color-blue-deep); }
    .imp-stepdot.active i { border-color: var(--color-blue-deep); background: var(--color-blue-deep); color: #fff; }
    .imp-stepdot.done { color: #059669; }
    .imp-stepdot.done i { border-color: #10b981; background: #10b981; color: #fff; }
    .imp-step { display: flex; flex-direction: column; gap: 0.9rem; }
    .imp-lead { font-size: 0.84rem; color: var(--color-text-muted); margin: 0; }
    .imp-drop {
        display: flex; flex-direction: column; align-items: center; gap: 0.5rem; text-align: center;
        border: 1.5px dashed var(--color-border); border-radius: 14px; padding: 2.4rem 1.5rem; cursor: pointer;
        background: var(--color-bg-soft); transition: border-color 0.25s, background 0.25s;
    }
    .imp-drop.drag, .imp-drop:hover { border-color: var(--color-blue-deep); background: rgba(10,25,47,0.03); }
    .imp-drop svg { width: 32px; height: 32px; color: var(--color-blue-deep); }
    .imp-drop b { font-size: 0.9rem; font-weight: 700; color: var(--color-text); }
    .imp-drop span { font-size: 0.76rem; color: var(--color-text-muted); }
    .imp-tpl {
        align-self: center; background: none; border: none; cursor: pointer;
        font-family: var(--font-sans); font-size: 0.8rem; font-weight: 600; color: var(--color-blue-deep);
    }
    .imp-tpl:hover { text-decoration: underline; }

    .imp-check { display: flex; align-items: center; gap: 8px; font-size: 0.82rem; color: var(--color-text); cursor: pointer; }
    .imp-maps { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; }
    .imp-map { display: flex; flex-direction: column; gap: 0.35rem; }
    .imp-map label { font-size: 0.62rem; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; color: #99a2af; }
    .imp-map label .req { color: var(--color-danger); }
    .imp-map select {
        font-family: var(--font-sans); font-size: 0.84rem; color: var(--color-text);
        background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: 9px; padding: 9px 10px;
    }
    .imp-map select:focus { outline: none; border-color: var(--color-blue-deep); }

    .imp-summary {
        display: flex; gap: 1.4rem; flex-wrap: wrap;
        background: var(--color-bg-soft); border: 1px solid var(--color-border);
        border-radius: 11px; padding: 0.9rem 1.1rem;
    }
    .imp-summary .is-num { font-size: 1.3rem; font-weight: 700; color: var(--color-blue-deep); letter-spacing: -0.5px; }
    .imp-summary .is-num.warn { color: var(--color-warn); }
    .imp-summary div { display: flex; flex-direction: column; }
    .imp-summary small { font-size: 0.68rem; color: var(--color-text-muted); }
    .imp-prev-wrap { max-height: 230px; overflow: auto; border: 1px solid var(--color-border); border-radius: 11px; }
    .imp-prev { width: 100%; border-collapse: collapse; font-size: 0.76rem; }
    .imp-prev th { position: sticky; top: 0; background: var(--color-bg-soft); text-align: left; font-size: 0.6rem; font-weight: 800; letter-spacing: 0.6px; text-transform: uppercase; color: #99a2af; padding: 8px 10px; border-bottom: 1px solid var(--color-border); }
    .imp-prev td { padding: 7px 10px; border-bottom: 1px solid var(--color-border); color: var(--color-text); white-space: nowrap; }
    .imp-prev td.n { text-align: right; font-variant-numeric: tabular-nums; }
    .imp-prev tr.bad td { background: rgba(239,68,68,0.05); color: var(--color-text-muted); }

    /* ── Encabezado de sección (eyebrow + hairline, idéntico al dashboard) ── */
    .catalogo { margin-bottom: 2.6rem; }
    .section-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 1.2rem; padding-bottom: 0.7rem; border-bottom: 1px solid var(--color-border); }
    .section-head h2 { font-size: 0.7rem; font-weight: 800; letter-spacing: 1.6px; text-transform: uppercase; color: #99a2af; margin: 0; }
    .cat-count { font-size: 0.78rem; font-weight: 600; color: var(--color-text-muted); }

    /* ── Tabla plana: a todo lo ancho, sin caja envolvente ── */
    .t-head, .t-row {
        display: grid;
        grid-template-columns: 100px 1.8fr 0.8fr 1fr 110px;
        gap: 1rem; align-items: center;
        padding: 0.8rem 0.6rem;
    }
    .t-head {
        font-size: 0.65rem; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;
        color: var(--color-text-muted); border-bottom: 1px solid var(--color-border);
    }
    .t-head > span:first-child, .t-row > :first-child { padding-left: 0; }
    .t-head > span:last-child, .t-row > :last-child { padding-right: 0; }
    .t-row {
        width: 100%; text-align: left;
        font-family: var(--font-sans); background: none; border: none; cursor: pointer;
        border-bottom: 1px solid var(--color-border);
        transition: background 0.2s var(--ease-ios);
    }
    .t-row:hover { background: var(--color-bg-soft); }

    .t-sku { font-size: 0.74rem; font-weight: 700; color: var(--color-text-muted); letter-spacing: 0.4px; }
    .t-name { font-size: 0.86rem; font-weight: 600; color: var(--color-text); }
    .t-muted { font-size: 0.8rem; color: var(--color-text-muted); }
    .t-amount { font-size: 0.95rem; color: var(--color-blue-deep); }
    .t-right { text-align: right; }
    .t-state { font-size: 0.72rem; font-weight: 700; }
    .t-state.on { color: #059669; }
    .t-state.off { color: #99a2af; }
    .t-empty { display: flex; flex-direction: column; align-items: center; gap: 0.7rem; padding: 3rem 0.6rem; font-size: 0.85rem; color: var(--color-text-muted); margin: 0; text-align: center; line-height: 1.5; }
    .t-empty svg { width: 34px; height: 34px; color: #cbd5e1; }
    .t-empty b { color: var(--color-text); font-weight: 600; }
    .t-empty-cta { display: flex; gap: 0.6rem; margin-top: 0.3rem; }

    /* Medidor de margen en vivo dentro del modal de producto */
    .margin-strip { display: flex; flex-direction: column; gap: 0.4rem; margin-top: -0.2rem; }
    .margin-strip[hidden] { display: none; }
    .ms-bar { height: 6px; border-radius: 100px; background: var(--color-bg-soft); overflow: hidden; border: 1px solid var(--color-border); }
    .ms-fill { display: block; height: 100%; border-radius: 100px; transition: width 0.35s var(--ease-spring), background 0.3s; }
    .ms-fill.good { background: #10b981; }
    .ms-fill.warn { background: #f59e0b; }
    .ms-fill.bad { background: #ef4444; }
    .ms-text { font-size: 0.78rem; color: var(--color-text-muted); }
    .ms-text b { font-weight: 700; color: var(--color-text); }
    .ms-text.good b { color: #059669; }
    .ms-text.warn b { color: #b45309; }
    .ms-text.bad b { color: #dc2626; }

    /* ── Precios por volumen (matriz por producto) ── */
    .vol-field { gap: 0.6rem; }
    .m-optlbl { font-size: 0.58rem; font-weight: 700; letter-spacing: 0.6px; color: #b3bcc9; }
    .m-hint { font-size: 0.75rem; color: var(--color-text-muted); line-height: 1.4; margin-top: -0.1rem; }
</style>
<style is:global>
    .vol-list { display: flex; flex-direction: column; gap: 0.55rem; }
    .vol-list:empty { display: none; }
    .vol-row { display: grid; grid-template-columns: 1fr auto 1fr 34px; gap: 0.6rem; align-items: center; }
    .vol-cell { 
        display: flex; align-items: center; gap: 6px; 
        background: var(--color-bg-soft); border: 1px solid var(--color-border); 
        border-radius: 9px; padding: 0 10px; transition: border-color 0.25s, box-shadow 0.25s, background 0.25s; 
    }
    .vol-cell:focus-within { border-color: var(--color-blue-deep); box-shadow: 0 0 0 3px rgba(10,25,47,0.08); background: #fff; }
    .vol-cell .vc-pre { font-size: 0.75rem; font-weight: 600; color: var(--color-text-muted); white-space: nowrap; user-select: none; }
    .vol-cell input { 
        font-family: var(--font-sans); font-size: 0.88rem; font-weight: 500; 
        color: var(--color-text); background: transparent; border: none; outline: none; 
        padding: 9px 0; width: 100%; -moz-appearance: textfield; 
    }
    .vol-cell input::-webkit-outer-spin-button,
    .vol-cell input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
    .vol-cell input::placeholder { color: #bbb; font-weight: 400; }
    .vol-arrow { font-size: 0.9rem; color: #a1a1aa; padding: 0 2px; }
    .vol-del { 
        background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: 9px; 
        width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; 
        cursor: pointer; color: #94a3b8; transition: color 0.2s, border-color 0.2s, background 0.2s; 
    }
    .vol-del:hover { color: #ef4444; border-color: #fca5a5; background: rgba(239,68,68,0.08); }
</style>
<style>
    .vol-add {
        align-self: flex-start; display: inline-flex; align-items: center; gap: 6px;
        font-family: var(--font-sans); font-size: 0.78rem; font-weight: 600; cursor: pointer;
        color: var(--color-text); background: var(--color-bg-soft);
        border: 1px dashed var(--color-border); border-radius: 9px; padding: 7px 12px;
        transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    }
    .vol-add:hover { border-color: var(--color-blue-deep); box-shadow: 0 2px 6px rgba(10,25,47,0.06); background: #fff; }
    .vol-add svg { color: var(--color-text-muted); }

    /* ── Modal (mismo lenguaje que clientes) ── */
    .modal {
        border: none; border-radius: 18px; padding: 0;
        width: min(520px, calc(100vw - 2rem));
        box-shadow: 0 40px 90px -30px rgba(10,25,47,0.45);
    }
    .modal::backdrop { background: rgba(10,25,47,0.38); backdrop-filter: blur(4px); }
    .m-form { display: flex; flex-direction: column; gap: 0.95rem; padding: 1.5rem 1.6rem 1.4rem; }
    .m-head { display: flex; align-items: center; justify-content: space-between; }
    .m-head h2 { font-size: 1.05rem; font-weight: 700; margin: 0; letter-spacing: -0.3px; }
    .m-close {
        background: var(--color-bg-soft); border: 1px solid var(--color-border);
        width: 30px; height: 30px; border-radius: 9px; cursor: pointer;
        font-size: 0.8rem; color: var(--color-text-muted);
    }
    .m-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.95rem; }
    .m-field { display: flex; flex-direction: column; gap: 0.4rem; }
    .m-field label { font-size: 0.62rem; font-weight: 800; letter-spacing: 1.2px; text-transform: uppercase; color: #99a2af; }
    .m-input {
        font-family: var(--font-sans); font-size: 0.88rem; font-weight: 500;
        color: var(--color-text); background: var(--color-bg-soft);
        border: 1px solid var(--color-border); border-radius: 9px;
        padding: 10px 12px; transition: border-color 0.25s;
    }
    .m-input:focus { outline: none; border-color: var(--color-blue-deep); }

    .m-chips { display: flex; gap: 0.5rem; }
    .chip {
        font-family: var(--font-sans); font-size: 0.78rem; font-weight: 600;
        color: var(--color-text-muted); background: var(--color-bg-soft);
        border: 1px solid var(--color-border); border-radius: 100px;
        padding: 7px 16px; cursor: pointer;
        transition: all 0.25s var(--ease-ios);
    }
    .chip.active { background: var(--color-blue-deep); color: #fff; border-color: var(--color-blue-deep); }

    .m-error { font-size: 0.78rem; color: var(--color-danger); margin: 0; min-height: 1em; }

    .m-actions { display: flex; align-items: center; gap: 0.6rem; }
    .m-spacer { flex: 1; }
    .m-delete {
        font-family: var(--font-sans); font-size: 0.8rem; font-weight: 600;
        color: var(--color-danger); background: none; border: none; cursor: pointer;
        padding: 9px 4px;
    }
    .m-delete[hidden] { display: none; }
    .m-cancel {
        font-family: var(--font-sans); font-size: 0.82rem; font-weight: 600;
        color: var(--color-text); background: var(--color-bg-soft);
        border: 1px solid var(--color-border); border-radius: 9px;
        padding: 9px 16px; cursor: pointer;
    }
    .m-save {
        font-family: var(--font-sans); font-size: 0.82rem; font-weight: 600;
        background: var(--color-blue-deep); color: #fff;
        border: none; border-radius: 9px; padding: 9px 18px; cursor: pointer;
        box-shadow: 0 6px 18px -8px rgba(10,25,47,0.5);
    }
    .m-save:disabled { opacity: 0.6; cursor: wait; }

    @media (max-width: 720px) {
        .t-head { display: none; }
        /* Fila tipo lista: nombre arriba, SKU debajo, precio a la derecha */
        .t-row {
            grid-template-columns: 1fr auto;
            grid-template-areas: "name price" "sku price";
            gap: 0.15rem 1rem; align-items: center; padding: 0.75rem 0.3rem;
        }
        .t-name { grid-area: name; }
        .t-sku { grid-area: sku; display: block; }
        .t-amount { grid-area: price; align-self: center; }
        .t-muted, .t-state { display: none; }
        .m-row { grid-template-columns: 1fr; }
    }

    /* En móvil el modal se vuelve un "bottom sheet" que sube desde abajo (nativo). */
    @media (max-width: 560px) {
        .modal, .modal-lg {
            width: 100%; max-width: 100%;
            margin: 0; top: auto; bottom: 0; left: 0; right: 0;
            border-radius: 20px 20px 0 0;
            max-height: 92dvh;
            animation: sheet-up 0.32s var(--ease-spring);
        }
        .m-form {
            padding: 1.3rem 1.2rem;
            padding-bottom: calc(1.3rem + env(safe-area-inset-bottom));
            max-height: 92dvh; overflow-y: auto; -webkit-overflow-scrolling: touch;
        }
    }
    @keyframes sheet-up { from { transform: translateY(100%); } to { transform: translateY(0); } }
    @media (prefers-reduced-motion: reduce) { .modal, .modal-lg { animation: none; } }
</style>

<script>
    // CRUD de productos contra /api/productos. Click en fila = editar.
    document.addEventListener('DOMContentLoaded', () => {
        const modal = document.getElementById('prodModal') as HTMLDialogElement;
        if (!modal) return; // sin permiso de edición, el modal no existe
        const form = document.getElementById('prodForm') as HTMLFormElement;
        const title = document.getElementById('mTitle')!;
        const errorEl = document.getElementById('mError')!;
        const btnDelete = document.getElementById('mDelete') as HTMLButtonElement;
        const btnSave = document.getElementById('mSave') as HTMLButtonElement;
        const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('#fActivo .chip'));

        let editId: string | null = null;
        let activo = true;

        const input = (id: string) => document.getElementById(id) as HTMLInputElement;
        const setActivo = (v: boolean) => {
            activo = v;
            chips.forEach(c => c.classList.toggle('active', Boolean(c.dataset.v) === v));
        };

        // Medidor de margen en vivo: traduce precio − costo en pesos ganados + %.
        const moneyFmt = (n: number) => '$' + new Intl.NumberFormat('es-MX', { minimumFractionDigits: 2 }).format(n);
        const updateMargin = () => {
            const precio = parseFloat(input('fPrecio').value) || 0;
            const costo = parseFloat(input('fCosto').value) || 0;
            const strip = document.getElementById('marginStrip')!;
            const fill = document.getElementById('msFill')!;
            const text = document.getElementById('msText')!;
            if (costo <= 0 || precio <= 0) { strip.hidden = true; return; }
            strip.hidden = false;
            const ganancia = precio - costo;
            const m = (ganancia / precio) * 100;
            const cls = m < 15 ? 'bad' : m < 30 ? 'warn' : 'good';
            fill.style.width = Math.max(0, Math.min(100, m)) + '%';
            fill.className = 'ms-fill ' + cls;
            text.className = 'ms-text ' + cls;
            text.innerHTML = ganancia < 0
                ? `Pierdes <b>${moneyFmt(Math.abs(ganancia))}</b> por unidad — tu costo supera el precio`
                : `Ganas <b>${moneyFmt(ganancia)}</b> por unidad · margen <b>${Math.round(m)}%</b>`;
        };
        input('fPrecio').addEventListener('input', updateMargin);
        input('fCosto').addEventListener('input', updateMargin);

        // ── Precios por volumen: editor de niveles {min, precio} ──
        const volList = document.getElementById('volList')!;
        let volTiers: { min: number | string; precio: number | string }[] = [];
        const renderVol = () => {
            volList.innerHTML = volTiers.map((t, i) => `
                <div class="vol-row" data-i="${i}">
                    <div class="vol-cell"><span class="vc-pre">Desde</span><input type="number" min="1" step="1" data-vk="min" value="${t.min ?? ''}" placeholder="500" /><span class="vc-pre">pz</span></div>
                    <span class="vol-arrow">→</span>
                    <div class="vol-cell"><span class="vc-pre">$</span><input type="number" min="0" step="0.01" data-vk="precio" value="${t.precio ?? ''}" placeholder="90.00" /></div>
                    <button type="button" class="vol-del" data-vdel="${i}" aria-label="Quitar nivel">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>`).join('');
        };
        volList.addEventListener('input', (e) => {
            const t = e.target as HTMLInputElement;
            if (!t.dataset.vk) return;
            const i = parseInt((t.closest('.vol-row') as HTMLElement).dataset.i!, 10);
            (volTiers[i] as any)[t.dataset.vk] = t.value;
        });
        volList.addEventListener('click', (e) => {
            const btn = (e.target as HTMLElement).closest<HTMLElement>('.vol-del');
            if (!btn) return;
            volTiers.splice(parseInt(btn.dataset.vdel!, 10), 1);
            renderVol();
        });
        document.getElementById('volAdd')?.addEventListener('click', () => {
            volTiers.push({ min: '', precio: '' });
            renderVol();
            (volList.querySelector('.vol-row:last-child input') as HTMLInputElement)?.focus();
        });

        const open = (data?: DOMStringMap) => {
            errorEl.textContent = '';
            editId = data?.id ?? null;
            title.textContent = editId ? 'Editar producto' : 'Nuevo producto';
            btnDelete.hidden = !editId;
            input('fNombre').value = data?.nombre ?? '';
            input('fSku').value = data?.sku ?? '';
            input('fUnidad').value = data?.unidad ?? '';
            input('fPrecio').value = data?.precio ?? '';
            input('fCosto').value = data?.costo && data.costo !== '0' ? data.costo : '';
            setActivo(data ? Boolean(data.activo) : true);
            try { volTiers = JSON.parse(data?.volumen || '[]'); } catch { volTiers = []; }
            if (!Array.isArray(volTiers)) volTiers = [];
            renderVol();
            updateMargin();
            modal.showModal();
        };

        document.getElementById('btnNew')?.addEventListener('click', () => open());
        document.getElementById('btnNewEmpty')?.addEventListener('click', () => open());
        document.querySelectorAll<HTMLElement>('.t-row[data-id]').forEach(row =>
            row.addEventListener('click', () => open(row.dataset)));
        // Auto-abrir el modal de alta cuando se llega con ?nuevo=1 (botón "+" del drawer móvil)
        if (new URLSearchParams(location.search).get('nuevo')) {
            open();
            history.replaceState(null, '', location.pathname);
        }
        document.getElementById('mClose')?.addEventListener('click', () => modal.close());
        document.getElementById('mCancel')?.addEventListener('click', () => modal.close());
        chips.forEach(c => c.addEventListener('click', () => setActivo(Boolean(c.dataset.v))));

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            btnSave.disabled = true;
            errorEl.textContent = '';
            const payload = {
                id: editId ?? undefined,
                nombre: input('fNombre').value,
                sku: input('fSku').value,
                unidad: input('fUnidad').value,
                precio: input('fPrecio').value,
                costo: input('fCosto').value || '0',
                activo,
                precios_volumen: volTiers
                    .map(t => ({ min: Math.floor(Number(t.min) || 0), precio: Math.max(0, Number(t.precio) || 0) }))
                    .filter(t => t.min > 0 && t.precio > 0)
                    .sort((a, b) => a.min - b.min),
            };
            try {
                const res = await fetch('/api/productos', {
                    method: editId ? 'PATCH' : 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload),
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'No se pudo guardar');
                location.reload();
            } catch (err: any) {
                errorEl.textContent = err.message;
                btnSave.disabled = false;
            }
        });

        btnDelete.addEventListener('click', async () => {
            if (!editId) return;
            if (!await (window as any).cordConfirm({ title: 'Eliminar producto', body: '¿Eliminar este producto del catálogo? Esta acción no se puede deshacer.', danger: true, confirmText: 'Eliminar' })) return;
            const delId = editId;
            const res = await fetch('/api/productos', {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: delId }),
            });
            if (res.ok) {
                // Optimista: quita la fila en sitio y cierra el modal (sin recargar).
                document.querySelector(`.t-row[data-id="${delId}"]`)?.remove();
                modal.close();
            } else errorEl.textContent = (await res.json()).error || 'No se pudo eliminar';
        });
    });
</script>

<script>
    // Importador CSV: archivo → mapeo de columnas → preview → carga masiva.
    document.addEventListener('DOMContentLoaded', () => {
        const modal = document.getElementById('importModal') as HTMLDialogElement | null;
        if (!modal) return;
        const $ = (id: string) => document.getElementById(id)!;
        const fileInput = $('impFile') as HTMLInputElement;
        const drop = $('impDrop');
        const stepFile = $('impStepFile'), stepMap = $('impStepMap'), stepPrev = $('impStepPrev');
        const headerChk = $('impHeader') as HTMLInputElement;
        const upsertChk = $('impUpsert') as HTMLInputElement;
        const mapsEl = $('impMaps');
        const errorEl = $('impError');
        const btnNext = $('impNext') as HTMLButtonElement;
        const btnBack = $('impBack') as HTMLButtonElement;

        const FIELDS = [
            { key: 'nombre', label: 'Nombre', req: true, guess: ['nombre', 'producto', 'descripcion', 'description', 'name', 'concepto', 'articulo'] },
            { key: 'sku', label: 'SKU / Clave', req: false, guess: ['sku', 'clave', 'codigo', 'code'] },
            { key: 'unidad', label: 'Unidad', req: false, guess: ['unidad', 'unit', 'medida', 'um'] },
            { key: 'precio', label: 'Precio de lista', req: false, guess: ['precio', 'price', 'lista', 'costo', 'importe', 'monto'] },
            { key: 'activo', label: 'Activo', req: false, guess: ['activo', 'active', 'estatus', 'status', 'estado'] },
        ];

        let grid: string[][] = [];
        let step: 'file' | 'map' | 'prev' = 'file';
        let prepared: any[] = [];

        const norm = (s: string) => s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').trim();
        const parseNum = (v: string) => Number(String(v ?? '').replace(/[^0-9.\-]/g, '')) || 0;
        const FALSY = new Set(['0', 'no', 'false', 'inactivo', 'inactive', 'off', '']);
        const parseBool = (v: string) => !FALSY.has(norm(v ?? ''));

        function parseCSV(text: string): string[][] {
            const first = text.split(/\r?\n/)[0] || '';
            const counts: Record<string, number> = {
                ',': (first.match(/,/g) || []).length,
                ';': (first.match(/;/g) || []).length,
                '\t': (first.match(/\t/g) || []).length,
            };
            const delim = Object.entries(counts).sort((a, b) => b[1] - a[1])[0][0] || ',';
            const rows: string[][] = []; let row: string[] = []; let field = ''; let q = false; let i = 0;
            while (i < text.length) {
                const c = text[i];
                if (q) {
                    if (c === '"') { if (text[i + 1] === '"') { field += '"'; i += 2; continue; } q = false; i++; continue; }
                    field += c; i++; continue;
                }
                if (c === '"') { q = true; i++; continue; }
                if (c === delim) { row.push(field); field = ''; i++; continue; }
                if (c === '\n') { row.push(field); rows.push(row); row = []; field = ''; i++; continue; }
                if (c === '\r') { i++; continue; }
                field += c; i++;
            }
            if (field.length || row.length) { row.push(field); rows.push(row); }
            return rows.filter(r => r.some(c => c.trim() !== ''));
        }

        const showStep = (s: 'file' | 'map' | 'prev') => {
            step = s;
            stepFile.hidden = s !== 'file';
            stepMap.hidden = s !== 'map';
            stepPrev.hidden = s !== 'prev';
            btnBack.hidden = s === 'file';
            errorEl.textContent = '';
            if (s === 'file') { btnNext.disabled = true; btnNext.textContent = 'Continuar'; }
            if (s === 'map') { btnNext.disabled = false; btnNext.textContent = 'Continuar'; }
            const order: Record<string, number> = { file: 0, map: 1, prev: 2 };
            document.querySelectorAll<HTMLElement>('#impSteps .imp-stepdot').forEach((d) => {
                const di = order[d.dataset.s || 'file']; const ci = order[s];
                d.classList.toggle('active', di === ci);
                d.classList.toggle('done', di < ci);
            });
        };

        const ncols = () => grid.reduce((m, r) => Math.max(m, r.length), 0);

        function buildMaps() {
            const useHeader = headerChk.checked;
            const headers = useHeader ? (grid[0] || []) : [];
            const n = ncols();
            mapsEl.innerHTML = FIELDS.map(f => {
                let guessed = -1;
                if (useHeader) {
                    guessed = headers.findIndex(h => f.guess.some(g => norm(h).includes(g)));
                }
                const opts = ['<option value="-1">— ninguna —</option>'];
                for (let i = 0; i < n; i++) {
                    const label = useHeader && headers[i] ? headers[i] : `Columna ${i + 1}`;
                    opts.push(`<option value="${i}" ${i === guessed ? 'selected' : ''}>${label.replace(/</g, '&lt;')}</option>`);
                }
                return `<div class="imp-map"><label>${f.label}${f.req ? ' <span class="req">*</span>' : ''}</label><select data-field="${f.key}">${opts.join('')}</select></div>`;
            }).join('');
        }

        const readMap = () => {
            const m: Record<string, number> = {};
            mapsEl.querySelectorAll<HTMLSelectElement>('select[data-field]').forEach(s => { m[s.dataset.field!] = parseInt(s.value, 10); });
            return m;
        };

        function buildPreview() {
            const m = readMap();
            if ((m.nombre ?? -1) < 0) { errorEl.textContent = 'Elige qué columna tiene el nombre del producto.'; return false; }
            const dataRows = headerChk.checked ? grid.slice(1) : grid;
            prepared = dataRows.map(r => ({
                nombre: (r[m.nombre] ?? '').trim(),
                sku: m.sku >= 0 ? (r[m.sku] ?? '').trim() : '',
                unidad: m.unidad >= 0 ? (r[m.unidad] ?? '').trim() : '',
                precio: m.precio >= 0 ? parseNum(r[m.precio]) : 0,
                activo: m.activo >= 0 ? parseBool(r[m.activo]) : true,
            }));
            const valid = prepared.filter(p => p.nombre);
            const skipped = prepared.length - valid.length;
            const money = (n: number) => '$' + new Intl.NumberFormat('es-MX', { minimumFractionDigits: 2 }).format(n);

            $('impSummary').innerHTML =
                `<div><span class="is-num">${valid.length}</span><small>productos a importar</small></div>` +
                (skipped > 0 ? `<div><span class="is-num warn">${skipped}</span><small>filas omitidas (sin nombre)</small></div>` : '');

            $('impPrevHead').innerHTML = '<tr><th>SKU</th><th>Nombre</th><th>Unidad</th><th class="n">Precio</th><th>Activo</th></tr>';
            $('impPrevBody').innerHTML = prepared.slice(0, 8).map(p => {
                const bad = !p.nombre;
                return `<tr class="${bad ? 'bad' : ''}"><td>${esc(p.sku)}</td><td>${esc(p.nombre || '—')}</td><td>${esc(p.unidad || 'pieza')}</td><td class="n">${money(p.precio)}</td><td>${p.activo ? 'Sí' : 'No'}</td></tr>`;
            }).join('');

            btnNext.textContent = `Importar ${valid.length} producto${valid.length === 1 ? '' : 's'}`;
            btnNext.disabled = valid.length === 0;
            return true;
        }
        const esc = (s: string) => String(s ?? '').replace(/</g, '&lt;');

        async function doImport() {
            const valid = prepared.filter(p => p.nombre);
            if (!valid.length) return;
            btnNext.disabled = true; btnNext.textContent = 'Importando…';
            try {
                const res = await fetch('/api/productos/import', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ rows: valid, upsert: upsertChk.checked }),
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'No se pudo importar');
                location.reload();
            } catch (err: any) {
                errorEl.textContent = err.message;
                btnNext.disabled = false; btnNext.textContent = `Importar ${valid.length} productos`;
            }
        }

        const loadFile = (file: File) => {
            const reader = new FileReader();
            reader.onload = () => {
                grid = parseCSV(String(reader.result));
                if (!grid.length) { errorEl.textContent = 'El archivo está vacío o no se pudo leer.'; return; }
                buildMaps();
                showStep('map');
            };
            reader.readAsText(file, 'utf-8');
        };

        // ── Eventos ──
        document.getElementById('btnImport')?.addEventListener('click', () => { showStep('file'); modal.showModal(); });
        document.getElementById('btnImportEmpty')?.addEventListener('click', () => { showStep('file'); modal.showModal(); });
        $('impClose').addEventListener('click', () => modal.close());
        $('impCancel').addEventListener('click', () => modal.close());
        fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) loadFile(fileInput.files[0]); });
        headerChk.addEventListener('change', buildMaps);

        drop.addEventListener('dragover', (e) => { e.preventDefault(); drop.classList.add('drag'); });
        drop.addEventListener('dragleave', () => drop.classList.remove('drag'));
        drop.addEventListener('drop', (e) => {
            e.preventDefault(); drop.classList.remove('drag');
            const f = (e as DragEvent).dataTransfer?.files?.[0];
            if (f) loadFile(f);
        });

        btnNext.addEventListener('click', () => {
            if (step === 'map') { if (buildPreview()) showStep('prev'); }
            else if (step === 'prev') doImport();
        });
        btnBack.addEventListener('click', () => {
            if (step === 'prev') { showStep('map'); btnNext.textContent = 'Continuar'; }
            else if (step === 'map') showStep('file');
        });

        // Plantilla CSV de ejemplo
        $('impTpl').addEventListener('click', () => {
            const csv = 'sku,nombre,unidad,precio,activo\nCEM-50,Cemento gris 50kg,saco,198.00,1\nVAR-38,Varilla 3/8 x 12m,pieza,189.00,1\nBLK-152,Block hueco 15x20x40,pieza,16.50,1\n';
            const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = 'plantilla-productos-cord.csv';
            a.click();
            URL.revokeObjectURL(a.href);
        });
    });
</script>

