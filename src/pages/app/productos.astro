<script is:inline>
    (function () {
        const input = document.getElementById('searchProductos');
        const clearBtn = document.getElementById('searchClear');
        const countEl = document.getElementById('catCount');
        if (!input) return;

        const rows = Array.from(document.querySelectorAll('.catalogo .t-row'));
        const total = rows.length;
        let noResults = document.querySelector('.search-no-results');
        if (!noResults) {
            noResults = document.createElement('div');
            noResults.className = 'search-no-results';
            noResults.textContent = 'Sin resultados para esta búsqueda.';
            document.querySelector('.catalogo').appendChild(noResults);
        }

        function filter() {
            const q = input.value.trim().toLowerCase();
            clearBtn.style.display = q ? 'flex' : 'none';
            let visible = 0;
            rows.forEach(row => {
                const sku = (row.dataset.sku || '').toLowerCase();
                const nombre = (row.dataset.nombre || '').toLowerCase();
                const unidad = (row.dataset.unidad || '').toLowerCase();
                const match = !q || sku.includes(q) || nombre.includes(q) || unidad.includes(q);
                row.hidden = !match;
                if (match) visible++;
            });
            noResults.style.display = visible === 0 && q ? 'block' : 'none';
            if (countEl) {
                if (q) countEl.textContent = `${visible} de ${total} producto${total === 1 ? '' : 's'}`;
                else countEl.textContent = `${total} producto${total === 1 ? '' : 's'}`;
            }
        }

        input.addEventListener('input', filter);
        clearBtn.addEventListener('click', () => { input.value = ''; filter(); input.focus(); });
    })();
</script>
