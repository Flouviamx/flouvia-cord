---
// Desempeño del equipo — ranking de cierre/cobro por vendedor.
// Atribución vía cotizaciones.creado_por (clerk_user_id de quien crea/duplica la
// cotización); ver "Desempeño por vendedor" en docs/historial.md.
import AppLayout from '../../layouts/AppLayout.astro';
import { getDesempeno, getMyMembership, money } from '../../lib/queries';
import { memberCan, ROL_LABEL } from '../../lib/permissions';

const ME = await getMyMembership();
const hasAccess = memberCan(ME, 'analitica');
const D = hasAccess ? await getDesempeno() : null;

const maxCerrado = Math.max(1, ...(D?.vendedores ?? []).map((v) => v.cerradoTotal), D?.sinAsignar.cerradoTotal ?? 0);
const top = D?.vendedores.find((v) => v.cerradoTotal > 0) ?? null;
const tasaEquipo = D && D.vendedores.length
    ? Math.round(D.vendedores.reduce((s, v) => s + v.tasaCierre, 0) / D.vendedores.length)
    : 0;
const mostrarSinAsignar = !!D && (D.sinAsignar.n > 0 || D.sinAsignar.cerradoTotal > 0);
---

<AppLayout title="Desempeño del equipo — Cord" page="desempeno" heading="Desempeño">
    <div slot="page-tabs">
        <a href="/app/cfo" class="ph-tab">Finanzas</a>
        <a href="/app/analitica" class="ph-tab">Analítica</a>
        <a href="/app/desempeno" class="ph-tab active">Equipo</a>
    </div>

    {!hasAccess && (
        <div class="an-denied">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <h3>Sin acceso</h3>
            <p>Tu rol actual no tiene permiso para ver el desempeño del equipo. Contacta al administrador de tu organización.</p>
        </div>
    )}

    {hasAccess && D && !D.hayDatos && (
        <section class="empty">
            <h2>Aún no hay cotizaciones para medir</h2>
            <p>En cuanto tu equipo empiece a crear y cerrar cotizaciones, aquí verás quién cierra más y quién cobra más rápido.</p>
            <a href="/app/cotizaciones/nueva" class="empty-cta">+ Crear una cotización</a>
        </section>
    )}

    {hasAccess && D && D.hayDatos && (
        <>
        <section class="kpis">
            <div class="kpi">
                <span class="kpi-label">CERRADO POR EL EQUIPO</span>
                <span class="editorial kpi-num kpi-ok">{money(D.totalCerrado, 0)}</span>
                <span class="kpi-sub">aprobadas, pagadas y facturadas</span>
            </div>
            <div class="kpi">
                <span class="kpi-label">TASA DE CIERRE PROMEDIO</span>
                <span class="editorial kpi-num">{tasaEquipo}<span class="kpi-pct">%</span></span>
                <span class="kpi-sub">de lo enviado por vendedor</span>
            </div>
            <div class="kpi">
                <span class="kpi-label">LÍDER DEL PERIODO</span>
                <span class="editorial kpi-num kpi-lead" title={top?.nombre}>{top ? top.nombre : '—'}</span>
                <span class="kpi-sub">{top ? money(top.cerradoTotal, 0) + ' cerrado' : 'sin cierres todavía'}</span>
            </div>
            <div class="kpi">
                <span class="kpi-label">VENDEDORES ACTIVOS</span>
                <span class="editorial kpi-num">{D.vendedores.length}</span>
                <span class="kpi-sub">con cuenta activa en el equipo</span>
            </div>
        </section>

        <section class="rank-card lb-card">
            <div class="sec-head"><h2 class="sec-title">Ranking por vendedor</h2><span class="rank-sub">por monto cerrado</span></div>

            <div class="lb-head">
                <span class="lb-col-name">Vendedor</span>
                <span class="lb-col-n">Cotiz.</span>
                <span class="lb-col-n">Cierre</span>
                <span class="lb-col-bar">Cerrado</span>
                <span class="lb-col-amt">Cobrado</span>
                <span class="lb-col-amt">Ticket</span>
                <span class="lb-col-n">Días</span>
            </div>

            {D.vendedores.map((v, i) => (
                <div class:list={['lb-row', v.esYo && 'is-me']}>
                    <div class="lb-name">
                        <span class="lb-rank">{i + 1}</span>
                        <span class="lb-avatar">{v.inicial}</span>
                        <span class="lb-nm">
                            <span class="lb-nm-main">{v.nombre}{v.esYo && <span class="lb-tag">Tú</span>}</span>
                            {v.rol !== 'vendedor' && <span class="lb-role">{ROL_LABEL[v.rol] ?? v.rol}</span>}
                        </span>
                    </div>
                    <span class="lb-n">{v.creadas}</span>
                    <span class="lb-n">{v.tasaCierre}%</span>
                    <div class="lb-barwrap">
                        <span class="lb-bar" style={`width:${Math.round((v.cerradoTotal / maxCerrado) * 100)}%`}></span>
                    </div>
                    <span class="editorial lb-amt">{money(v.cerradoTotal, 0)}</span>
                    <span class="editorial lb-amt lb-amt-muted">{money(v.cobradoTotal, 0)}</span>
                    <span class="editorial lb-amt lb-amt-small">{v.ticketPromedio ? money(v.ticketPromedio, 0) : '—'}</span>
                </div>
            ))}

            {mostrarSinAsignar && (
                <div class="lb-row lb-row-unassigned">
                    <div class="lb-name">
                        <span class="lb-rank">—</span>
                        <span class="lb-avatar lb-avatar-muted">?</span>
                        <span class="lb-nm"><span class="lb-nm-main">Sin asignar</span><span class="lb-role">de antes de este reporte o vía API</span></span>
                    </div>
                    <span class="lb-n">{D.sinAsignar.n}</span>
                    <span class="lb-n">—</span>
                    <div class="lb-barwrap">
                        <span class="lb-bar lb-bar-muted" style={`width:${Math.round((D.sinAsignar.cerradoTotal / maxCerrado) * 100)}%`}></span>
                    </div>
                    <span class="editorial lb-amt">{money(D.sinAsignar.cerradoTotal, 0)}</span>
                    <span class="editorial lb-amt lb-amt-muted">{money(D.sinAsignar.cobradoTotal, 0)}</span>
                    <span class="lb-amt lb-amt-small">—</span>
                </div>
            )}
        </section>
        </>
    )}
</AppLayout>

<style>
    /* KPIs — misma tira que /app/analitica */
    .kpis {
        display: grid; grid-template-columns: repeat(4, 1fr); gap: 0;
        margin-bottom: 2.6rem;
        border-top: 1px solid var(--color-border);
        border-bottom: 1px solid var(--color-border);
    }
    .kpi { padding: 1.5rem 1.7rem; display: flex; flex-direction: column; gap: 0.45rem; border-left: 1px solid var(--color-border); min-width: 0; }
    .kpi:first-child { border-left: none; padding-left: 0; }
    .kpi-label { font-size: 0.6rem; font-weight: 800; letter-spacing: 1.6px; color: #99a2af; }
    .kpi-num { font-size: 2.1rem; color: var(--color-blue-deep); line-height: 1; font-variant-numeric: tabular-nums; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .kpi-lead { font-size: 1.4rem; }
    .kpi-ok { color: #059669; }
    .kpi-pct { font-size: 1.1rem; }
    .kpi-sub { font-size: 0.78rem; color: var(--color-text-muted); }

    .rank-sub { font-size: 0.72rem; color: var(--color-text-muted); }
    .lb-card { display: flex; flex-direction: column; gap: 0; }

    .lb-head, .lb-row {
        display: grid;
        grid-template-columns: 2.1fr 0.55fr 0.6fr 1.2fr 0.95fr 0.85fr 0.5fr;
        align-items: center; gap: 0.9rem;
    }
    .lb-head { padding: 0.6rem 0; border-bottom: 1px solid var(--color-border); margin-top: 1rem; }
    .lb-head span { font-size: 0.62rem; font-weight: 800; letter-spacing: 1.2px; color: #99a2af; text-transform: uppercase; }
    .lb-col-name { text-align: left; } .lb-col-n, .lb-col-amt { text-align: right; } .lb-col-bar { text-align: left; }

    .lb-row { padding: 0.85rem 0; border-bottom: 1px solid var(--color-border); }
    .lb-row:last-child { border-bottom: none; }
    .lb-row.is-me { background: var(--color-bg-soft); margin: 0 -1rem; padding-left: 1rem; padding-right: 1rem; border-radius: 10px; }

    .lb-name { display: flex; align-items: center; gap: 0.7rem; min-width: 0; }
    .lb-rank { font-size: 0.74rem; font-weight: 700; color: var(--color-text-muted); width: 1.1rem; flex-shrink: 0; }
    .lb-avatar {
        width: 30px; height: 30px; border-radius: 999px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        background: var(--color-blue-deep); color: #fff;
        font-size: 0.72rem; font-weight: 700;
    }
    .lb-avatar-muted { background: var(--color-bg-soft); color: var(--color-text-muted); border: 1px solid var(--color-border); }
    .lb-nm { display: flex; flex-direction: column; min-width: 0; gap: 1px; }
    .lb-nm-main { font-size: 0.86rem; font-weight: 600; color: var(--color-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: flex; align-items: center; gap: 6px; }
    .lb-tag { font-size: 0.6rem; font-weight: 700; color: var(--color-blue-deep); background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: 100px; padding: 1px 7px; }
    .lb-role { font-size: 0.68rem; color: var(--color-text-muted); }

    .lb-n { text-align: right; font-size: 0.82rem; color: var(--color-text); font-variant-numeric: tabular-nums; }
    .lb-barwrap { height: 8px; background: var(--chart-track); border-radius: 100px; overflow: hidden; border: 1px solid var(--color-border); }
    .lb-bar { display: block; height: 100%; background: var(--chart-fill); border-radius: 100px; min-width: 3px; transition: width 0.7s var(--ease-spring); }
    .lb-bar-muted { background: #c6d0dd; }
    .lb-amt { text-align: right; font-size: 0.88rem; color: var(--color-blue-deep); white-space: nowrap; }
    .lb-amt-muted { color: #059669; font-size: 0.82rem; }
    .lb-amt-small { font-size: 0.78rem; color: var(--color-text-muted); }
    .lb-row-unassigned { opacity: 0.65; }

    .empty { padding: 4.5rem 2rem; text-align: center; }
    .empty h2 { font-size: 1.1rem; font-weight: 700; margin: 0 0 0.5rem; }
    .empty p { font-size: 0.88rem; color: var(--color-text-muted); max-width: 460px; margin: 0 auto 1.4rem; line-height: 1.6; }
    .empty-cta { display: inline-block; background: var(--color-blue-deep); color: #fff; text-decoration: none; font-size: 0.86rem; font-weight: 600; padding: 11px 20px; border-radius: 10px; }

    .an-denied { display: flex; flex-direction: column; gap: 0.6rem; padding: 2rem 0; }
    .an-denied svg { width: 32px; height: 32px; color: #c9d2de; }
    .an-denied h3 { font-size: 1rem; font-weight: 700; margin: 0; }
    .an-denied p { font-size: 0.84rem; color: var(--color-text-muted); margin: 0; line-height: 1.55; }

    @media (max-width: 1080px) {
        .kpis { grid-template-columns: repeat(2, 1fr); }
        .kpi:nth-child(odd) { border-left: none; padding-left: 0; }
        .kpi:nth-child(3), .kpi:nth-child(4) { border-top: 1px solid var(--color-border); }
        .lb-head, .lb-row { grid-template-columns: 1.6fr 0.5fr 1fr 0.8fr; }
        .lb-col-bar, .lb-amt-small, .lb-n:nth-child(3) { display: none; }
    }
    @media (max-width: 640px) {
        .kpis { grid-template-columns: 1fr; }
        .kpi { border-left: none; padding-left: 0; border-top: 1px solid var(--color-border); }
        .kpi:first-child { border-top: none; }
        .lb-head, .lb-row { grid-template-columns: 1.8fr 0.6fr 0.9fr; }
    }
</style>
