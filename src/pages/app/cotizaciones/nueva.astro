---
// Editor de cotizaciones — LA pantalla crítica. Interactivo, datos reales (Neon):
// agregas productos del catálogo, negocias precio por línea, el total se recalcula
// en vivo con IVA, y al enviar hace POST a /api/cotizaciones (inserta en Neon).
import AppLayout from '../../../layouts/AppLayout.astro';
import { getProductos, getClientes, getOrg, getCotizacion, getKitsForEditor } from '../../../lib/queries';
import { REGIMENES_FISCALES, USOS_CFDI } from '../../../lib/sat';

const draftId = Astro.url.searchParams.get('draft');
let draftQuote = null;
if (draftId) {
    draftQuote = await getCotizacion(draftId);
    if (!draftQuote || draftQuote.status !== 'draft') {
        return Astro.redirect('/app/cotizaciones/nueva');
    }
}

const [productos, CLIENTES, ORG, kits] = await Promise.all([getProductos(), getClientes(), getOrg(), getKitsForEditor()]);
const catalogo = productos.filter(p => p.activo);

// Defaults reales desde Ajustes › Cotizaciones e impuestos.
const TERM_DEFAULT_LABEL = draftQuote ? draftQuote.terminos : (({ contado: 'Contado', net30: 'Net 30', net60: 'Net 60' } as Record<string, string>)[ORG.terminosDefault] ?? 'Contado');
// Moneda inicial del editor: la del borrador si se está editando; si no, la
// moneda default de la org (Ajustes → General). FIX jul 2026: antes MXN estaba
// hardcodeado y el ajuste "moneda" era placebo.
const DEFAULT_CURRENCY = ((draftQuote as any)?.baseCurrency ?? (draftQuote as any)?.base_currency ?? ORG.moneda ?? 'MXN') as string;
// Vigencia pre-seleccionada: los días RESTANTES del borrador (vigenciaDias) o el
// default de la org. Si el valor del borrador no es una opción estándar, se agrega.
const DRAFT_VIG = draftQuote?.vigenciaDias ?? null;
const SELECTED_VIG = DRAFT_VIG ?? ORG.vigenciaDefaultDias;
const VIGENCIAS = [...new Set([15, 30, 60, ORG.vigenciaDefaultDias, ...(DRAFT_VIG ? [DRAFT_VIG] : [])])].sort((a, b) => a - b);
// Anticipo pre-llenado: el del borrador si se está editando; si no, el default
// del negocio (Ajustes › Cotizaciones). 0/null = sin anticipo.
const DEFAULT_ANTICIPO = Number((draftQuote as any)?.anticipoPct ?? ORG.anticipoDefaultPct) || 0;
const DEFAULT_RECURRENTE = Boolean((draftQuote as any)?.esRecurrente);

---

<AppLayout title={draftQuote ? "Editar borrador" : "Nueva cotización"} page="cotizaciones" heading={draftQuote ? "Editar borrador" : "Nueva cotización"} crumbs={[{ label: 'Cotizaciones', href: '/app/cotizaciones' }]}>
    <span slot="topbar-actions" class="draft-tag">Borrador</span>

    <div class="editor-grid">
        <!-- ── Columna principal ── -->
        <div class="ed-main">
            <!-- Armar con IA — la forma rápida (puerta de entrada) -->
            <section class="ed-block ai-block">
                <h2 class="ai-title">Arma la cotización con IA</h2>
                <p class="ai-sub">Pega el pedido del cliente o adjunta la foto/PDF de su orden de compra.</p>
                <div class="ai-textarea-wrap">
                    <textarea id="aiText" class="ed-textarea ai-textarea" rows="3" placeholder="Ej. Hola, necesito 200 sacos de cemento gris, 50 varillas de 3/8 y 2 m³ de arena. ¿Me pasas precio?"></textarea>
                    <input type="file" id="aiFile" accept="application/pdf,image/jpeg,image/png,image/webp" hidden />
                    <button type="button" class="ai-attach-btn" id="aiAttachBtn" aria-label="Adjuntar foto o PDF de una orden de compra" title="Adjuntar foto o PDF">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
                    </button>
                </div>
                <div class="ai-file-chip" id="aiFileChip" hidden>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
                    <span id="aiFileName"></span>
                    <button type="button" id="aiFileRemove" aria-label="Quitar archivo">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    </button>
                </div>
                <div class="ai-actions">
                    <button class="ai-btn" id="aiBtn"><span class="ai-btn-label">Armar cotización con IA</span></button>
                    <span class="ai-status" id="aiStatus"></span>
                </div>
            </section>

            <div class="ed-or"><span>o créala manualmente</span></div>

            <!-- Cliente -->
            <section class="ed-block">
                <div class="section-head step-head">
                    <span class="step-num">1</span>
                    <div class="step-text">
                        <h2>¿A quién le cotizas?</h2>
                        <p class="step-hint">Elige el cliente y cómo te paga. Si tiene un nivel con descuento, se aplica solo a los precios.</p>
                    </div>
                </div>
                <div class="client-row">
                    <select class="ed-select" id="clientSelect">
                        <option value="" disabled selected>— Selecciona un cliente —</option>
                        {CLIENTES.map((c) => (
                            <option value={c.id} data-desc={String(c.descuentoPct)} data-nivel={c.nivel} data-term={c.terminos}>{c.empresa}{c.contacto ? ` — ${c.contacto}` : ''}</option>
                        ))}
                        <option value="__NEW__" class="opt-action">+ Crear nuevo cliente…</option>
                    </select>
                    <div class="term-chips" id="termChips">
                        {['Contado', 'Net 30', 'Net 60'].map((t) => (
                            <button class:list={['chip', { active: t === TERM_DEFAULT_LABEL }]} data-term={t}>{t}</button>
                        ))}
                    </div>
                </div>
                <p class="desc-note" id="descNote" hidden></p>
            </section>

            <!-- Productos -->
            <section class="ed-block">
                <div class="section-head step-head">
                    <span class="step-num">2</span>
                    <div class="step-text">
                        <h2>¿Qué le vas a cotizar?</h2>
                        <p class="step-hint">Agrega productos de tu catálogo o una línea libre. Baja el precio en <b>Negociado</b> sin tocar tu lista.</p>
                    </div>
                </div>

                <div class="lines-head">
                    <span>Producto</span><span>Cant.</span><span>Lista</span><span>Negociado</span><span class="lh-right">Importe</span><span class="lh-margen">Margen <span class="lh-i" title="Tu ganancia sobre el precio negociado, ya descontando el costo. Verde = sano · rojo = por debajo de tu mínimo.">?</span></span><span></span>
                </div>
                <div id="lines"></div>

                <div class="lines-empty" id="linesEmpty">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h18v4H3z"/><path d="M3 7v14h18V7"/><path d="M9 12h6"/></svg>
                    <p><b>Aún no agregas productos</b> Búscalos en tu catálogo aquí abajo o agrega una línea libre.</p>
                </div>

                <div class="add-actions">
                    <div class="prod-search">
                        <svg class="prod-search-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/></svg>
                        <input type="text" class="prod-input" id="prodInput" placeholder="Busca un producto de tu catálogo… (nombre o SKU)" autocomplete="off" role="combobox" aria-expanded="false" aria-controls="prodDrop" />
                        <div class="prod-drop" id="prodDrop" hidden role="listbox"></div>
                    </div>
                    <button class="btn-free-line" id="btnFreeLine">+ Línea libre</button>
                    {kits.length > 0 && (
                        <div class="kit-insert-wrap">
                            <button type="button" class="btn-free-line" id="btnKitInsert" aria-expanded="false" aria-controls="kitInsertDrop">+ Insertar kit</button>
                            <div class="kit-insert-drop" id="kitInsertDrop" hidden>
                                {kits.map((k) => (
                                    <div class="kit-insert-row" data-kid={k.id}>
                                        <span class="kit-insert-name">{k.nombre}<small>{k.items.length} línea{k.items.length === 1 ? '' : 's'}</small></span>
                                        <input type="number" class="kit-insert-qty" min="1" step="1" value="1" aria-label={`Cuántas veces insertar ${k.nombre}`} />
                                        <button type="button" class="kit-insert-add" data-kid-add={k.id}>Agregar</button>
                                    </div>
                                ))}
                            </div>
                        </div>
                    )}
                </div>
                <p class="add-hint">Escribe para buscar y presiona <kbd>Enter</kbd> para agregar. Puedes agregar varios seguidos.</p>
            </section>

            <!-- Notas -->
            <section class="ed-block">
                <div class="section-head"><h2>Notas para el cliente <span class="opt">(opcional)</span></h2></div>
                <textarea id="notasText" class="ed-textarea" rows="2" placeholder="Ej. Precio especial por volumen — entrega en obra incluida.">{draftQuote?.notas || ''}</textarea>
            </section>
        </div>

        <!-- ── Sidebar resumen ── -->
        <aside class="ed-side">
            <section class="ed-summary">
                <div class="section-head"><h2>Revisa y envía</h2></div>
                <div class="sum-count" id="sumCount">Agrega productos para ver el total</div>
                <div class="sum-line"><span>Subtotal</span><span class="editorial" id="sumSubtotal">$0.00</span></div>
                <div class="sum-line sum-save" id="sumSaveLine" hidden><span>Le descontaste</span><span class="editorial" id="sumSave">$0.00</span></div>
                <div class="sum-field" style="flex-direction: row; align-items: center; justify-content: space-between; margin-top: 0.5rem; margin-bottom: -0.5rem;">
                    <label for="ivaIncluido" style="margin:0; cursor: pointer; color: var(--color-text);">Precios ya incluyen IVA</label>
                    <label class="s-toggle" title="Precios incluyen IVA">
                        <input type="checkbox" id="ivaIncluido" checked={draftQuote ? draftQuote.iva_incluido : ORG.ivaIncluidoDefecto} />
                        <span class="s-toggle-track"><span class="s-toggle-thumb"></span></span>
                    </label>
                </div>
                <div class="sum-line"><span>IVA {ORG.ivaPct}%</span><span class="editorial" id="sumIva">$0.00</span></div>
                <input type="hidden" id="cfgIva" value={ORG.ivaPct} />
                <div class="sum-divider"></div>
                <div class="sum-line sum-total"><span>Total</span><span class="editorial" id="sumTotal">$0.00</span></div>

                <div class="sum-field">
                    <label>Vigencia</label>
                    <select class="ed-select" id="vigSelect">
                        {VIGENCIAS.map((n) => <option value={n} selected={n === SELECTED_VIG}>{n} días</option>)}
                    </select>
                </div>

                <!-- Iguala recurrente: cobro automático mensual. Solo con términos de
                     contado; excluyente con anticipo. -->
                <div class="sum-field" id="recurrenteField" style="flex-direction: row; align-items: center; justify-content: space-between;">
                    <label for="esRecurrente" style="margin:0; cursor: pointer; color: var(--color-text);">Cobro recurrente mensual <span class="opt">(iguala)</span></label>
                    <label class="s-toggle" title="Cobra el total automáticamente cada mes">
                        <input type="checkbox" id="esRecurrente" checked={DEFAULT_RECURRENTE} />
                        <span class="s-toggle-track"><span class="s-toggle-thumb"></span></span>
                    </label>
                </div>
                <p class="sum-anticipo-note" id="recurrenteNote" hidden></p>

                <div class="sum-field" id="anticipoField">
                    <label>Anticipo (%) <span class="opt">(opcional)</span></label>
                    <input class="ed-select" id="anticipoPct" type="number" min="0" max="99" step="1" placeholder="0" value={DEFAULT_ANTICIPO || ''} />
                    <p class="sum-anticipo-note" id="anticipoNote" hidden></p>
                </div>

                <div class="sum-field">
                    <label>¿En qué moneda le cotizas?</label>
                    <select class="ed-select" id="fxBase">
                        <option value="MXN" selected={DEFAULT_CURRENCY === 'MXN'}>🇲🇽 Pesos mexicanos (MXN)</option>
                        <option value="USD" selected={DEFAULT_CURRENCY === 'USD'}>🇺🇸 Dólares (USD)</option>
                        <option value="EUR" selected={DEFAULT_CURRENCY === 'EUR'}>🇪🇺 Euros (EUR)</option>
                    </select>
                </div>

                <div class="fx-cover" id="fxCover" hidden>
                    <p class="fx-explain">Le muestras precios en <b id="fxBaseLbl2">USD</b>, pero tu factura sale en pesos 🇲🇽. Congelamos el tipo de cambio de hoy para que un peso volátil no te coma el margen si tarda en pagarte.</p>

                    <div class="fx-stepper">
                        <div class="fx-step">
                            <span class="fx-step-lbl">Tipo de cambio hoy</span>
                            <span class="fx-step-val editorial" id="fxSpot">—</span>
                        </div>
                        <span class="fx-arrow" aria-hidden="true">→</span>
                        <div class="fx-step fx-step-on">
                            <span class="fx-step-lbl">Tu tasa protegida <span id="fxBufLbl">+2%</span></span>
                            <span class="fx-step-val editorial" id="fxApplied">—</span>
                        </div>
                    </div>

                    <label class="fx-cushion-lbl">¿Qué tan cauto quieres ser?</label>
                    <div class="fx-cushion" id="fxCushion">
                        <button type="button" class="fx-cush-chip" data-buf="1"><b>Poco</b><small>+1%</small></button>
                        <button type="button" class="fx-cush-chip active" data-buf="2"><b>Normal</b><small>+2%</small></button>
                        <button type="button" class="fx-cush-chip" data-buf="5"><b>Cauto</b><small>+5%</small></button>
                    </div>
                    <input type="hidden" id="fxBuffer" value="2" />

                    <p class="fx-client-sees" id="fxPreview">Tu cliente verá ≈ <b>US$—</b></p>
                    <div class="fx-lock-row"><span class="fx-lock-ic">🔒</span> Tasa congelada 30 días — tú decides el colchón</div>
                </div>

                <button class="btn-send" id="btnSend">
                    <span>{draftQuote ? 'Guardar y enviar' : 'Crear y enviar'}</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </button>
                <button class="btn-draft" id="btnDraft">{draftQuote ? 'Guardar cambios' : 'Guardar borrador'}</button>
                <p class="sum-note">{draftQuote ? 'Los cambios se guardan sobre este borrador; al enviar se crea el link público.' : 'Al enviar se generará la V1 y se creará el link público.'}</p>
                <p class="sum-kbd"><kbd>⌘</kbd><kbd>Enter</kbd> para enviar</p>
            </section>
        </aside>
    </div>

    <!-- Modal Cliente Nuevo -->
    <dialog class="modal" id="clientModal">
        <form method="dialog" class="m-form" id="clientForm">
            <div class="m-head">
                <h2 id="mTitle">Nuevo cliente</h2>
                <button type="button" class="m-close" id="mClose" aria-label="Cerrar">✕</button>
            </div>

            <div class="m-field">
                <label for="fEmpresa">Empresa *</label>
                <input class="m-input" id="fEmpresa" name="empresa" required placeholder="Distribuidora El Zarco" />
            </div>
            <div class="m-row">
                <div class="m-field">
                    <label for="fContacto">Contacto</label>
                    <input class="m-input" id="fContacto" name="contacto" placeholder="Raúl Mendoza" />
                </div>
                <div class="m-field">
                    <label for="fEmail">Correo</label>
                    <input class="m-input" id="fEmail" name="email" type="email" placeholder="compras@elzarco.mx" />
                </div>
            </div>
            <div class="m-row">
                <div class="m-field">
                    <label for="fRfc">RFC</label>
                    <input class="m-input" id="fRfc" name="rfc" placeholder="DEZ981123QX1" maxlength="13" />
                </div>
                <div class="m-field">
                    <label for="fLimite">Límite de crédito (MXN)</label>
                    <input class="m-input" id="fLimite" name="limite" type="number" min="0" step="1000" placeholder="500000" />
                </div>
            </div>
            <div class="m-field">
                <label>Nivel de precio</label>
                <div class="m-chips m-tiers" id="fTiers">
                    <button type="button" class="chip tier active" data-v="estandar" data-sug="0">Estándar</button>
                    <button type="button" class="chip tier" data-v="plata" data-sug="5">Plata</button>
                    <button type="button" class="chip tier" data-v="oro" data-sug="10">Oro</button>
                    <button type="button" class="chip tier" data-v="distribuidor" data-sug="15">Distribuidor</button>
                </div>
                <input type="hidden" id="fNivel" value="estandar" />
            </div>
            <div class="m-field">
                <label for="fDescuento">Descuento automático en sus precios</label>
                <div class="disc-row">
                    <div class="disc-input">
                        <input class="m-input" id="fDescuento" type="number" min="0" max="100" step="1" placeholder="0" />
                        <span class="disc-suffix">%</span>
                    </div>
                    <span class="disc-preview" id="discPreview">Sin descuento</span>
                </div>
                <span class="m-hint">Cada vez que le cotices, sus precios bajan este % solos. Ej. <b>Oro = −10%</b>: un producto de $1,000 le sale en $900.</span>
            </div>
            <div class="m-field">
                <label>Términos de pago</label>
                <div class="m-chips" id="fTerminos">
                    <button type="button" class="chip active" data-v="contado">Contado</button>
                    <button type="button" class="chip" data-v="net30">Net 30</button>
                    <button type="button" class="chip" data-v="net60">Net 60</button>
                </div>
            </div>

            <details class="m-fiscal">
                <summary>Datos fiscales para CFDI (opcional)</summary>
                <p class="m-hint" style="margin: 0 0 0.75rem 0;">Si los capturas, al facturar timbramos el CFDI 4.0 a nombre de este cliente. Si los dejas vacíos, usamos "público en general".</p>
                <div class="m-row">
                    <div class="m-field">
                        <label for="fRegimen">Régimen fiscal</label>
                        <select class="m-input" id="fRegimen">
                            <option value="">— Sin especificar —</option>
                            {REGIMENES_FISCALES.map((r) => <option value={r.codigo}>{r.nombre}</option>)}
                        </select>
                    </div>
                    <div class="m-field">
                        <label for="fCp">Código postal (domicilio fiscal)</label>
                        <input class="m-input" id="fCp" inputmode="numeric" maxlength="5" placeholder="06600" />
                    </div>
                </div>
                <div class="m-field">
                    <label for="fUso">Uso del CFDI</label>
                    <select class="m-input" id="fUso">
                        <option value="">— Sin especificar (G03) —</option>
                        {USOS_CFDI.map((u) => <option value={u.codigo}>{u.nombre}</option>)}
                    </select>
                </div>
            </details>

            <p class="m-error" id="mError"></p>

            <div class="m-actions">
                <span class="m-spacer"></span>
                <button type="button" class="m-cancel" id="mCancel">Cancelar</button>
                <button type="submit" class="m-save" id="mSave">Crear y seleccionar</button>
            </div>
        </form>
    </dialog>

    <!-- Toast -->
    <div class="toast" id="toast" hidden>
        <span class="toast-dot"></span>
        <span id="toastMsg">Cotización enviada</span>
    </div>
</AppLayout>

<script is:inline define:vars={{ catalogo, kits, aprobMargenMin: ORG.aprobMargenMin, draftQuote }}>
    const lines = [];
    const catMap = Object.fromEntries(catalogo.map(p => [p.id, p]));
    const volUnit = (l) => {
        if (!l.id || !Array.isArray(l.vol) || !l.vol.length) return l.baseLista ?? l.lista;
        let price = l.baseLista ?? l.lista;
        for (const t of l.vol) { if (l.cantidad >= t.min) price = t.precio; }
        return price;
    };

    if (draftQuote) {
        draftQuote.items.forEach(it => {
            const cat = it.producto_id ? catMap[it.producto_id] : null;
            const l = {
                id: it.producto_id || null,
                nombre: it.descripcion,
                unidad: it.unidad || 'pieza',
                baseLista: cat ? cat.precio : it.precioLista,
                lista: cat ? cat.precio : it.precioLista, // se ajustará con volUnit
                vol: cat ? (cat.preciosVolumen || []) : [],
                costo: cat ? (cat.costo || 0) : 0,
                negociado: it.precioNegociado,
                cantidad: it.cantidad,
                negoTouched: it.precioNegociado !== null
            };
            if (l.id) l.lista = volUnit(l);
            lines.push(l);
        });
    }
    const $lines = document.getElementById('lines');
    const $empty = document.getElementById('linesEmpty');
    const fmt = (n) => '$' + new Intl.NumberFormat('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    const fmtPct = (n) => Number.isFinite(n) ? Math.round(n) + '%' : '—';
    const margenPct = (costo, precio) => (costo > 0 && precio > 0) ? (precio - costo) / precio * 100 : null;


    // ── Precios por volumen (matriz por producto) ──
    // Dada la cantidad de la línea, devuelve el precio del nivel más alto cuyo
    // mínimo se alcanza; si ninguno aplica, el precio de lista base. `l.vol` viene

    // Mínimo del nivel de volumen activo (0 = ninguno).
    const volMin = (l) => {
        if (!l.id || !Array.isArray(l.vol)) return 0;
        let m = 0; for (const t of l.vol) { if (l.cantidad >= t.min) m = t.min; } return m;
    };
    // HTML del sub-texto del nombre (unidad + nota de volumen + precio sugerido).
    const nameNote = (l, idx) => {
        const vm = volMin(l);
        let html = l.unidad + (vm ? ` · <b class="lr-volnote">precio x volumen (${vm}+)</b>` : '');
        html += pricingNoteHtml(l, idx);
        return html;
    };

    // ── Precio sugerido por historial real (win-rate por banda de descuento) ──
    function pricingNoteHtml(l, idx) {
        const p = l.pricing;
        if (!p || p.suggestedPrice === null || typeof idx !== 'number') return '';
        const precioFinal = l.negociado ?? l.lista;
        if (Math.abs(precioFinal - p.suggestedPrice) < 0.01) return ''; // ya está en el precio sugerido
        const band = p.bands.find(b => b.band === p.suggestedDiscountPct);
        const pctCierre = band ? Math.round(band.winRate * 100) : null;
        const label = pctCierre !== null ? `Sugerido: ${fmt(p.suggestedPrice)} (${pctCierre}% cierra)` : `Sugerido: ${fmt(p.suggestedPrice)}`;
        return ` · <button type="button" class="lr-pricing-hint" data-apply-price="${idx}" title="Basado en tu historial real de cotizaciones decididas">${label}</button>`;
    }

    function loadPricing(idx) {
        const l = lines[idx];
        if (!l || !l.id) return;
        const clienteVal = $client && $client.value ? $client.value : '';
        const qs = new URLSearchParams({ producto_id: l.id, precio_lista: String(l.lista) });
        if (clienteVal) qs.set('cliente_id', clienteVal);
        fetch('/api/pricing/suggest?' + qs.toString())
            .then((r) => (r.ok ? r.json() : null))
            .then((data) => {
                if (!data || lines[idx] !== l) return; // la línea pudo cambiar/eliminarse mientras tanto
                l.pricing = data;
                const row = $lines.querySelector('[data-row="' + idx + '"]');
                const small = row ? row.querySelector('.lr-name small') : null;
                if (small) small.innerHTML = nameNote(l, idx);
            })
            .catch(() => {});
    }

    // ── Descuento por nivel de cliente (price tiers) ──
    const $client = document.getElementById('clientSelect');
    let lastClientVal = $client ? $client.value : '';
    const $descNote = document.getElementById('descNote');
    const currentDesc = () => { const o = $client && $client.options[$client.selectedIndex]; return o && !o.disabled ? (parseFloat(o.dataset.desc) || 0) : 0; };
    const applyDesc = (lista) => { const d = currentDesc(); return d > 0 ? Math.round(lista * (1 - d / 100) * 100) / 100 : null; };
    const reflectDesc = () => {
        const d = currentDesc();
        if ($descNote) { $descNote.textContent = d > 0 ? `Nivel del cliente: −${d}% aplicado automáticamente a los precios de lista.` : ''; $descNote.hidden = d <= 0; }
    };

    let lastTotal = 0;
    const currentTotal = () => lastTotal;
    function recalc() {
        const ivaPct = (Number((document.getElementById('cfgIva') || {}).value) || 0) / 100;
        const ivaIncluido = document.getElementById('ivaIncluido') ? document.getElementById('ivaIncluido').checked : false;
        const subtotal = lines.reduce((s, l) => s + (l.negociado ?? l.lista) * l.cantidad, 0);

        const iva = ivaIncluido ? subtotal - (subtotal / (1 + ivaPct)) : subtotal * ivaPct;
        const realSubtotal = ivaIncluido ? subtotal / (1 + ivaPct) : subtotal;
        const total = ivaIncluido ? subtotal : subtotal + iva;
        lastTotal = total;

        document.getElementById('sumSubtotal').textContent = fmt(realSubtotal);
        document.getElementById('sumIva').textContent = fmt(iva);
        document.getElementById('sumTotal').textContent = fmt(total);

        // Conteo de líneas/piezas + cuánto le descontaste al cliente (lista vs negociado)
        const nLines = lines.length;
        const pieces = lines.reduce((s, l) => s + l.cantidad, 0);
        const saved = lines.reduce((s, l) => {
            const neg = l.negociado ?? l.lista;
            return s + (l.lista > neg ? (l.lista - neg) * l.cantidad : 0);
        }, 0);
        const $cnt = document.getElementById('sumCount');
        if ($cnt) $cnt.textContent = nLines === 0
            ? 'Agrega productos para ver el total'
            : `${nLines} ${nLines === 1 ? 'línea' : 'líneas'} · ${pieces} ${pieces === 1 ? 'pieza' : 'piezas'}`;
        const $save = document.getElementById('sumSaveLine');
        const $saveV = document.getElementById('sumSave');
        if ($save && $saveV) { $save.hidden = saved <= 0; $saveV.textContent = '−' + fmt(saved); }

        // Anticipo: preview en pesos de cuánto paga el cliente al aprobar.
        const antEl = document.getElementById('anticipoPct');
        const antNote = document.getElementById('anticipoNote');
        if (antEl && antNote) {
            const pct = Math.min(99, Math.max(0, parseInt(antEl.value, 10) || 0));
            if (pct >= 1 && total > 0) {
                const ant = Math.round(total * pct) / 100;
                antNote.textContent = `Al aprobar, tu cliente paga ${fmt(ant)} de anticipo y el resto (${fmt(total - ant)}) según los términos.`;
                antNote.hidden = false;
            } else {
                antNote.hidden = true;
            }
        }

        // Iguala recurrente: refrescar el preview del monto mensual.
        if (typeof syncRecurrenteUI === 'function') syncRecurrenteUI();

        // Si cotiza en divisa extranjera, el monto cambió → refrescar el FX
        const cov = document.getElementById('fxCover');
        if (cov && !cov.hidden) scheduleFx();
    }

    function margenBadge(costo, precio) {
        const m = margenPct(costo, precio);
        if (m === null) return '<span class="lr-margen lr-margen-na">—</span>';
        const low = aprobMargenMin > 0 && m < aprobMargenMin;
        return `<span class="lr-margen ${low ? 'lr-margen-low' : ''}" title="Margen bruto">${fmtPct(m)}</span>`;
    }

    function render() {
        $empty.hidden = lines.length > 0;
        $lines.innerHTML = '';
        lines.forEach((l, idx) => {
            const precioFinal = l.negociado ?? l.lista;
            const importe = precioFinal * l.cantidad;
            const row = document.createElement('div');
            row.className = 'line-row';
            row.dataset.row = String(idx);

            // Si es línea libre, el nombre es editable.
            const nameHtml = l.id
                ? `<span class="lr-name">${l.nombre}<small>${nameNote(l, idx)}</small></span>`
                : `<input type="text" class="lr-input lr-desc-input" value="${l.nombre}" data-idx="${idx}" data-field="nombre" placeholder="Descripción de la línea..." />`;

            row.innerHTML = `
                ${nameHtml}
                <input type="number" min="1" value="${l.cantidad}" class="lr-input" data-idx="${idx}" data-field="cantidad" />
                <span class="lr-lista">${l.id ? fmt(l.lista) : '—'}</span>
                <input type="number" min="0" step="0.01" value="${precioFinal.toFixed(2)}" class="lr-input lr-nego ${l.negociado !== null && l.negociado < l.lista ? 'is-deal' : ''}" data-idx="${idx}" data-field="negociado" />
                <span class="editorial lr-importe">${fmt(importe)}</span>
                ${margenBadge(l.costo, precioFinal)}
                <button class="lr-del" data-del="${idx}" aria-label="Quitar">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            `;
            $lines.appendChild(row);
        });
        recalc();
    }

    // ── Buscador de productos (combobox con teclado) ──
    const $prodInput = document.getElementById('prodInput');
    const $prodDrop = document.getElementById('prodDrop');
    let prodResults = [];
    let prodActive = -1;

    function addProduct(p) {
        lines.push({ id: p.id, nombre: p.nombre, unidad: p.unidad, baseLista: p.precio, lista: p.precio, vol: p.preciosVolumen || [], costo: p.costo || 0, negociado: applyDesc(p.precio), cantidad: 1, negoTouched: false });
        render();
        // Micro-feedback: la fila nueva parpadea suave para ubicarla.
        const rows = $lines.querySelectorAll('.line-row');
        const last = rows[rows.length - 1];
        if (last) { last.classList.add('line-added'); setTimeout(() => last.classList.remove('line-added'), 900); }
        loadPricing(lines.length - 1);
    }

    const norm = (s) => String(s || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    function searchProds(q) {
        const n = norm(q);
        const pool = catalogo;
        if (!n) return pool.slice(0, 8);
        return pool.filter(p => norm(p.nombre).includes(n) || norm(p.sku).includes(n)).slice(0, 8);
    }

    function renderDrop() {
        if (!$prodDrop) return;
        if (!prodResults.length) {
            $prodDrop.innerHTML = '<div class="prod-empty">No hay coincidencias en tu catálogo.<br/><small>Usa "+ Línea libre" para cotizar algo fuera del catálogo.</small></div>';
        } else {
            $prodDrop.innerHTML = prodResults.map((p, i) => `
                <button type="button" class="prod-item ${i === prodActive ? 'is-active' : ''}" data-pid="${p.id}" role="option">
                    <span class="prod-item-name">${p.nombre}${p.sku ? `<small>${p.sku}</small>` : ''}</span>
                    <span class="prod-item-price editorial">${fmt(p.precio)} <small>/ ${p.unidad}</small></span>
                </button>`).join('');
        }
        $prodDrop.hidden = false;
        if ($prodInput) $prodInput.setAttribute('aria-expanded', 'true');
    }

    function closeDrop() {
        if ($prodDrop) $prodDrop.hidden = true;
        prodActive = -1;
        if ($prodInput) $prodInput.setAttribute('aria-expanded', 'false');
    }

    function pickProd(idx) {
        const p = prodResults[idx];
        if (!p) return;
        addProduct(p);
        if ($prodInput) { $prodInput.value = ''; $prodInput.focus(); }
        prodResults = searchProds('');
        prodActive = -1;
        renderDrop();
    }

    if ($prodInput && $prodDrop) {
        $prodInput.addEventListener('input', () => { prodResults = searchProds($prodInput.value); prodActive = prodResults.length ? 0 : -1; renderDrop(); });
        $prodInput.addEventListener('focus', () => { prodResults = searchProds($prodInput.value); prodActive = prodResults.length ? 0 : -1; renderDrop(); });
        $prodInput.addEventListener('keydown', (e) => {
            if ($prodDrop.hidden && (e.key === 'ArrowDown' || e.key === 'Enter')) { prodResults = searchProds($prodInput.value); renderDrop(); }
            if (e.key === 'ArrowDown') { e.preventDefault(); prodActive = Math.min(prodActive + 1, prodResults.length - 1); renderDrop(); }
            else if (e.key === 'ArrowUp') { e.preventDefault(); prodActive = Math.max(prodActive - 1, 0); renderDrop(); }
            else if (e.key === 'Enter') { e.preventDefault(); if (prodActive >= 0) pickProd(prodActive); }
            else if (e.key === 'Escape') { closeDrop(); $prodInput.blur(); }
        });
        $prodDrop.addEventListener('mousedown', (e) => {
            const btn = e.target.closest('.prod-item');
            if (!btn) return;
            e.preventDefault(); // no perder el foco del input
            const idx = prodResults.findIndex(p => p.id === btn.dataset.pid);
            if (idx >= 0) pickProd(idx);
        });
        document.addEventListener('click', (e) => {
            if (!e.target.closest('.prod-search')) closeDrop();
        });
    }

    document.getElementById('btnFreeLine')?.addEventListener('click', () => {
        lines.push({ id: null, nombre: '', unidad: 'pieza', baseLista: 0, lista: 0, vol: [], costo: 0, negociado: 0, cantidad: 1, negoTouched: false });
        render();
        // Foco directo a la descripción de la línea recién creada.
        const inputs = $lines.querySelectorAll('.lr-desc-input');
        const lastInput = inputs[inputs.length - 1];
        if (lastInput) lastInput.focus();
    });

    // ── Insertar kit: agrega TODAS las líneas de un kit de un clic, multiplicando
    // la cantidad de cada renglón por el multiplicador que elija el vendedor.
    // Reutiliza catMap/applyDesc — los renglones heredan gratis precio por
    // volumen, descuento por cliente, badge de margen y precio sugerido. ──
    const kitMap = Object.fromEntries((kits || []).map(k => [k.id, k]));
    const $kitBtn = document.getElementById('btnKitInsert');
    const $kitDrop = document.getElementById('kitInsertDrop');

    function closeKitDrop() {
        if ($kitDrop) $kitDrop.hidden = true;
        $kitBtn?.setAttribute('aria-expanded', 'false');
    }
    $kitBtn?.addEventListener('click', () => {
        const willOpen = $kitDrop.hidden;
        closeDrop(); // no dos dropdowns abiertos a la vez
        $kitDrop.hidden = !willOpen;
        $kitBtn.setAttribute('aria-expanded', String(willOpen));
    });
    document.addEventListener('click', (e) => {
        if (!e.target.closest('.kit-insert-wrap')) closeKitDrop();
    });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeKitDrop(); });

    $kitDrop?.addEventListener('click', (e) => {
        const btn = e.target.closest('[data-kid-add]');
        if (!btn) return;
        const kit = kitMap[btn.dataset.kidAdd];
        if (!kit || !kit.items.length) return;
        const row = btn.closest('.kit-insert-row');
        const mult = Math.max(1, Math.floor(Number(row?.querySelector('.kit-insert-qty')?.value) || 1));

        const startLen = lines.length;
        kit.items.forEach((it) => {
            const qty = (Number(it.cantidad) || 1) * mult;
            const p = it.productoId ? catMap[it.productoId] : null;
            if (p) {
                lines.push({ id: p.id, nombre: p.nombre, unidad: p.unidad, baseLista: p.precio, lista: p.precio, vol: p.preciosVolumen || [], costo: p.costo || 0, negociado: applyDesc(p.precio), cantidad: qty, negoTouched: false });
            } else {
                lines.push({ id: null, nombre: it.descripcion, unidad: 'pieza', baseLista: 0, lista: 0, vol: [], costo: 0, negociado: 0, cantidad: qty, negoTouched: false });
            }
        });
        render();
        // Flash de las líneas recién insertadas + precio sugerido por línea de catálogo.
        const rows = $lines.querySelectorAll('.line-row');
        for (let i = startLen; i < lines.length; i++) {
            rows[i]?.classList.add('line-added');
            if (lines[i].id) loadPricing(i);
        }
        setTimeout(() => rows.forEach(r => r.classList.remove('line-added')), 900);
        if (window.cordToast) window.cordToast(`Kit "${kit.nombre}" insertado — ${kit.items.length} línea${kit.items.length === 1 ? '' : 's'}`, 'ok');
        closeKitDrop();
    });

    // Activa el chip de términos que coincida con la etiqueta ("Contado"/"Net 30"/"Net 60").
    function setTermChip(label) {
        if (!label) return;
        const chips = Array.from(document.querySelectorAll('#termChips .chip'));
        if (!chips.some(c => c.dataset.term === label)) return;
        chips.forEach(c => c.classList.toggle('active', c.dataset.term === label));
    }

    // Al cambiar de cliente, reaplica el descuento a las líneas del catálogo
    // (sobre el precio de volumen vigente), reactiva el auto-tracking y
    // pre-selecciona los términos de pago default de ese cliente.
    $client?.addEventListener('change', () => {
        if ($client.value === '__NEW__') {
            $client.value = lastClientVal; // Revertir visualmente temporalmente
            openClientModal();
            return;
        }
        lastClientVal = $client.value;
        const d = currentDesc();
        lines.forEach((l) => {
            if (l.id) { // Solo aplica a items del catálogo
                l.negoTouched = false;
                l.negociado = d > 0 ? Math.round(l.lista * (1 - d / 100) * 100) / 100 : null;
            }
        });
        const opt = $client.options[$client.selectedIndex];
        if (opt && !opt.disabled) setTermChip(opt.dataset.term);
        reflectDesc();
        render();
    });

    $lines.addEventListener('input', (e) => {
        const t = e.target;
        if (!(t instanceof HTMLInputElement)) return;
        const idx = parseInt(t.dataset.idx, 10);
        
        if (t.dataset.field === 'nombre') {
            lines[idx].nombre = t.value;
            return; // No necesita recalcular
        }

        const val = parseFloat(t.value) || 0;
        const row = t.closest('.line-row');
        const l = lines[idx];

        if (t.dataset.field === 'cantidad') {
            l.cantidad = Math.max(1, Math.round(val));
            // Precio por volumen: la cantidad puede cambiar el precio de lista vigente.
            if (l.id) {
                const newLista = volUnit(l);
                if (newLista !== l.lista) {
                    l.lista = newLista;
                    if (!l.negoTouched) l.negociado = applyDesc(l.lista);
                }
                // Actualiza in-place lista, negociado (si auto) y la nota de volumen.
                const listaEl = row.querySelector('.lr-lista'); if (listaEl) listaEl.textContent = fmt(l.lista);
                const small = row.querySelector('.lr-name small'); if (small) small.innerHTML = nameNote(l, idx);
                if (!l.negoTouched) {
                    const negoEl = row.querySelector('.lr-nego');
                    const pf = l.negociado ?? l.lista;
                    if (negoEl) { negoEl.value = pf.toFixed(2); negoEl.classList.toggle('is-deal', l.negociado !== null && l.negociado < l.lista); }
                }
            }
        }
        if (t.dataset.field === 'negociado') {
            l.negociado = val;
            l.negoTouched = true; // el usuario fijó un precio manual → no auto-ajustar
            if (l.id) t.classList.toggle('is-deal', val < l.lista);
        }

        // recalcula visualmente la fila actual sin perder el foco
        const precioFinal = l.negociado ?? l.lista;
        row.querySelector('.lr-importe').textContent = fmt(precioFinal * l.cantidad);
        const badge = row.querySelector('.lr-margen');
        if (badge) badge.outerHTML = margenBadge(l.costo, precioFinal);

        recalc();
    });

    $lines.addEventListener('click', (e) => {
        const delBtn = e.target.closest('.lr-del');
        if (delBtn) {
            lines.splice(parseInt(delBtn.dataset.del, 10), 1);
            render();
            return;
        }
        const applyBtn = e.target.closest('[data-apply-price]');
        if (applyBtn) {
            const idx = parseInt(applyBtn.dataset.applyPrice, 10);
            const l = lines[idx];
            if (l && l.pricing && l.pricing.suggestedPrice !== null) {
                l.negociado = l.pricing.suggestedPrice;
                l.negoTouched = true;
                render();
            }
        }
    });

    // Chips de términos
    document.querySelectorAll('#termChips .chip').forEach((chip) => {
        chip.addEventListener('click', () => {
            document.querySelectorAll('#termChips .chip').forEach(c => c.classList.remove('active'));
            chip.classList.add('active');
            syncRecurrenteUI();
        });
    });

    // Iguala recurrente ⇄ anticipo/términos: son excluyentes. La iguala solo
    // aplica a contado; al activarla se oculta el anticipo, y solo se muestra el
    // toggle si el término es contado.
    function syncRecurrenteUI() {
        const recEl = document.getElementById('esRecurrente');
        const recField = document.getElementById('recurrenteField');
        const recNote = document.getElementById('recurrenteNote');
        const antField = document.getElementById('anticipoField');
        const activeTerm = document.querySelector('#termChips .chip.active');
        const esContado = !activeTerm || activeTerm.dataset.term === 'Contado';
        if (!recEl) return;
        if (!esContado) { recEl.checked = false; if (recField) recField.hidden = true; }
        else if (recField) recField.hidden = false;
        const on = !!recEl.checked;
        if (antField) antField.hidden = on;
        if (recNote) {
            if (on) {
                const total = currentTotal();
                recNote.textContent = total > 0
                    ? `Al autorizar, tu cliente paga ${fmt(total)} hoy y se le cobra ese monto automáticamente cada mes con su tarjeta, hasta que se cancele.`
                    : 'Se cobra el total automáticamente cada mes con tarjeta (requiere cuenta de cobros conectada).';
                recNote.hidden = false;
            } else {
                recNote.hidden = true;
            }
        }
    }
    document.getElementById('esRecurrente')?.addEventListener('change', syncRecurrenteUI);
    syncRecurrenteUI();

    // ── Guardado real (POST /api/cotizaciones → Neon) ──
    const toast = document.getElementById('toast');
    const toastMsg = document.getElementById('toastMsg');
    const TERM_MAP = { 'Contado': 'contado', 'Net 30': 'net30', 'Net 60': 'net60' };
    const showToast = (msg, hide = 0) => {
        toastMsg.textContent = msg; toast.hidden = false;
        if (hide) setTimeout(() => { toast.hidden = true; }, hide);
    };

    function buildPayload(send) {
        const clientSel = document.getElementById('clientSelect');
        const activeChip = document.querySelector('#termChips .chip.active');
        const vigSel = document.getElementById('vigSelect');
        const notas = document.getElementById('notasText');
        
        // Validación del cliente
        const cliente_id = clientSel && clientSel.value !== "" ? clientSel.value : null;

        // Multi-divisa: si la moneda elegida no es MXN, se factura en MXN con cobertura.
        const fxBaseSel = document.getElementById('fxBase');
        const fxBufferEl = document.getElementById('fxBuffer');
        const base_currency = fxBaseSel ? fxBaseSel.value : 'MXN';
        const fiscal_currency = base_currency === 'MXN' ? 'MXN' : 'MXN';
        const fx_buffer_pct = base_currency === 'MXN' ? 0 : (fxBufferEl ? parseFloat(fxBufferEl.value) || 0 : 0);

        // Iguala recurrente: cobra el total automáticamente cada mes (solo contado;
        // excluyente con anticipo).
        const recEl = document.getElementById('esRecurrente');
        const es_recurrente = !!(recEl && recEl.checked);
        // Anticipo: % que el cliente paga de inmediato al aprobar (0 = sin anticipo).
        const antEl = document.getElementById('anticipoPct');
        const anticipo_pct = antEl ? Math.min(99, Math.max(0, parseInt(antEl.value, 10) || 0)) : 0;
        const terminos = es_recurrente ? 'contado' : (TERM_MAP[activeChip ? activeChip.dataset.term : 'Contado'] || 'contado');

        return {
            send,
            cliente_id,
            terminos,
            vigencia_dias: vigSel ? parseInt(vigSel.value, 10) || 30 : 30,
            es_recurrente,
            anticipo_pct: (!es_recurrente && anticipo_pct >= 1) ? anticipo_pct : null,
            notas: notas ? notas.value.trim() : '',
            base_currency,
            fiscal_currency,
            fx_buffer_pct,
            iva_incluido: document.getElementById('ivaIncluido') ? document.getElementById('ivaIncluido').checked : false,
            items: lines.map(l => ({
                producto_id: l.id || null,
                descripcion: l.nombre || 'Línea libre',
                cantidad: l.cantidad,
                precio_unitario: l.lista,
                precio_negociado: l.negociado,
                costo_unitario: l.costo || 0,
            })),
        };
    }

    async function save(send, btn) {
        if (!lines.length) {
            showToast('Agrega al menos un producto en el paso 2', 2600);
            if ($prodInput) $prodInput.focus();
            return;
        }
        // Líneas libres sin descripción: pedir que se completen antes de guardar.
        const emptyFree = lines.findIndex(l => !l.id && !(l.nombre || '').trim());
        if (emptyFree >= 0) {
            showToast('Describe la línea libre (o quítala) antes de continuar', 2800);
            const inputs = $lines.querySelectorAll('.lr-desc-input');
            if (inputs[0]) inputs[0].focus();
            return;
        }
        // Para ENVIAR se necesita un cliente (el link y el correo van dirigidos a él).
        if (send && (!$client || !$client.value || $client.value === '__NEW__')) {
            showToast('Elige un cliente en el paso 1 para poder enviar', 2800);
            if ($client) {
                $client.scrollIntoView({ behavior: 'smooth', block: 'center' });
                setTimeout(() => $client.focus(), 350);
            }
            return;
        }
        const original = btn.innerHTML;
        btn.disabled = true; btn.style.opacity = '0.7';
        showToast(send ? 'Enviando…' : 'Guardando…');
        
        try {
            if (draftQuote) {
                // If it's a draft, update it instead of creating a new one
                const payload = buildPayload(send);
                payload.action = send ? 'send' : 'update_draft';
                const res = await fetch(`/api/cotizaciones/${draftQuote.id}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload),
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'Error al guardar');
                showToast(send ? 'Enviada con éxito ✓' : 'Borrador guardado ✓');
                setTimeout(() => { window.location.href = `/app/cotizaciones/${draftQuote.id}`; }, 1100);
            } else {
                // Normal creation
                const res = await fetch('/api/cotizaciones', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(buildPayload(send)),
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'Error al guardar');
                if (data.needsApproval) showToast(`Aprobación solicitada — ${data.folio}. Espera el visto bueno de gerencia.`);
                else showToast(send ? `Enviada — ${data.folio} ✓` : `Borrador ${data.folio} guardado ✓`);
                setTimeout(() => { window.location.href = `/app/cotizaciones/${data.id}`; }, 1100);
            }
        } catch (err) {
            btn.disabled = false; btn.style.opacity = '1'; btn.innerHTML = original;
            showToast(err.message || 'Error de red', 2600);
        }
    }

    document.getElementById('btnSend')?.addEventListener('click', (e) => save(true, e.currentTarget));
    document.getElementById('btnDraft')?.addEventListener('click', (e) => save(false, e.currentTarget));

    // ⌘/Ctrl + Enter = enviar (fluido con teclado, estándar de composers).
    // No aplica con el modal de cliente abierto (ahí Enter pertenece al form).
    document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
            const modal = document.getElementById('clientModal');
            if (modal && modal.open) return;
            const b = document.getElementById('btnSend');
            if (b && !b.disabled) { e.preventDefault(); b.click(); }
        }
    });

    // ── Multi-divisa: tipo de cambio en lenguaje simple + colchón visual ──
    const $fxBase = document.getElementById('fxBase');
    const $fxBuffer = document.getElementById('fxBuffer');
    const $fxCover = document.getElementById('fxCover');
    const $fxPreview = document.getElementById('fxPreview');
    const $fxBaseLbl2 = document.getElementById('fxBaseLbl2');
    const $fxSpot = document.getElementById('fxSpot');
    const $fxApplied = document.getElementById('fxApplied');
    const $fxBufLbl = document.getElementById('fxBufLbl');
    const $fxCushion = document.getElementById('fxCushion');
    const nfFx = new Intl.NumberFormat('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    const symFx = (c) => c === 'USD' ? 'US$' : c === 'EUR' ? '€' : '$';

    function parseTotal() {
        const t = (document.getElementById('sumTotal')?.textContent || '0').replace(/[^0-9.]/g, '');
        return parseFloat(t) || 0;
    }

    let fxTimer = null;
    async function refreshFx() {
        if (!$fxBase) return;
        const base = $fxBase.value;
        const isForeign = base !== 'MXN';
        if ($fxCover) $fxCover.hidden = !isForeign;
        if (!isForeign) return;
        if ($fxBaseLbl2) $fxBaseLbl2.textContent = base;
        const buffer = $fxBuffer ? parseFloat($fxBuffer.value) || 0 : 0;
        if ($fxBufLbl) $fxBufLbl.textContent = '+' + buffer + '%';
        const amount = parseTotal();
        try {
            const res = await fetch(`/api/fx/quote?base=${base}&fiscal=MXN&amount=${amount}&buffer=${buffer}`);
            const fx = await res.json();
            const spot = Number(fx.spotRate || 0);
            const applied = Number(fx.appliedRate || 0);
            // Tasas: hoy vs. protegida (con tu colchón)
            if ($fxSpot) $fxSpot.textContent = '$' + nfFx.format(spot);
            if ($fxApplied) $fxApplied.textContent = '$' + nfFx.format(applied);
            // Lo que el cliente verá en SU moneda = total en pesos ÷ tasa protegida
            const clientSees = applied > 0 ? amount / applied : 0;
            if ($fxPreview) {
                $fxPreview.innerHTML = amount > 0
                    ? `Tu cliente verá ≈ <b>${symFx(base)}${nfFx.format(clientSees)}</b> · tú facturas <b>$${nfFx.format(amount)} MXN</b>`
                    : `Agrega productos para ver el total en ${base}.`;
            }
        } catch {
            if ($fxPreview) $fxPreview.textContent = 'No se pudo obtener el tipo de cambio.';
        }
    }
    function scheduleFx() { clearTimeout(fxTimer); fxTimer = setTimeout(refreshFx, 250); }
    $fxBase?.addEventListener('change', refreshFx);
    // Si la moneda inicial (default de la org o del borrador) no es MXN, el
    // panel de cobertura FX debe aparecer desde el primer render.
    if ($fxBase && $fxBase.value !== 'MXN') refreshFx();
    // Colchón: chips de preset (Poco / Normal / Cauto)
    $fxCushion?.querySelectorAll('.fx-cush-chip').forEach((chip) => {
        chip.addEventListener('click', () => {
            $fxCushion.querySelectorAll('.fx-cush-chip').forEach(c => c.classList.remove('active'));
            chip.classList.add('active');
            if ($fxBuffer) $fxBuffer.value = chip.dataset.buf;
            refreshFx();
        });
    });

    // ── Armar con IA (POST /api/cotizaciones/ai-draft) ──
    const $aiBtn = document.getElementById('aiBtn');
    const $aiText = document.getElementById('aiText');
    const $aiStatus = document.getElementById('aiStatus');

    // ── Adjuntar foto/PDF de una orden de compra (visión nativa de Claude) ──
    const $aiFile = document.getElementById('aiFile');
    const $aiAttachBtn = document.getElementById('aiAttachBtn');
    const $aiFileChip = document.getElementById('aiFileChip');
    const $aiFileName = document.getElementById('aiFileName');
    const $aiFileRemove = document.getElementById('aiFileRemove');
    let pendingFile = null; // { mediaType, data, name }

    const MAX_PDF_BYTES = 3 * 1024 * 1024; // crudo; ~4MB en base64, dentro del límite práctico del body de la función
    const IMG_MAX_DIM = 1600;
    const IMG_QUALITY = 0.82;

    const b64FromDataUrl = (dataUrl) => { const i = dataUrl.indexOf(','); return i >= 0 ? dataUrl.slice(i + 1) : dataUrl; };

    function setPendingFile(mediaType, data, name) {
        pendingFile = { mediaType, data, name };
        if ($aiFileName) $aiFileName.textContent = name;
        if ($aiFileChip) $aiFileChip.hidden = false;
    }
    function clearPendingFile() {
        pendingFile = null;
        if ($aiFile) $aiFile.value = '';
        if ($aiFileChip) $aiFileChip.hidden = true;
    }

    // Las fotos se reducen y recomprimen en el navegador antes de subir — una
    // foto de celular puede pesar 5-10MB, muy por encima del límite práctico del
    // body de la función; a 1600px/JPEG82 Claude lee el texto igual de bien.
    function readImageCompressed(file) {
        return new Promise((resolve, reject) => {
            const img = new Image();
            const reader = new FileReader();
            reader.onerror = () => reject(new Error('No se pudo leer la imagen'));
            reader.onload = () => {
                img.onerror = () => reject(new Error('No se pudo leer la imagen'));
                img.onload = () => {
                    let w = img.naturalWidth, h = img.naturalHeight;
                    const scale = Math.min(1, IMG_MAX_DIM / Math.max(w, h));
                    w = Math.round(w * scale); h = Math.round(h * scale);
                    const canvas = document.createElement('canvas');
                    canvas.width = w; canvas.height = h;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0, w, h);
                    resolve({ mediaType: 'image/jpeg', data: b64FromDataUrl(canvas.toDataURL('image/jpeg', IMG_QUALITY)) });
                };
                img.src = reader.result;
            };
            reader.readAsDataURL(file);
        });
    }
    function readPdf(file) {
        return new Promise((resolve, reject) => {
            if (file.size > MAX_PDF_BYTES) { reject(new Error('El PDF pesa más de 3MB — intenta escanearlo en menor resolución o sube una foto en su lugar.')); return; }
            const reader = new FileReader();
            reader.onerror = () => reject(new Error('No se pudo leer el PDF'));
            reader.onload = () => resolve({ mediaType: 'application/pdf', data: b64FromDataUrl(reader.result) });
            reader.readAsDataURL(file);
        });
    }

    if ($aiAttachBtn && $aiFile) {
        $aiAttachBtn.addEventListener('click', () => $aiFile.click());
        $aiFile.addEventListener('change', async () => {
            const file = $aiFile.files && $aiFile.files[0];
            if (!file) return;
            $aiStatus.textContent = 'Leyendo archivo…';
            try {
                const result = file.type.startsWith('image/') ? await readImageCompressed(file) : await readPdf(file);
                setPendingFile(result.mediaType, result.data, file.name);
                $aiStatus.textContent = '';
            } catch (err) {
                $aiStatus.textContent = err.message || 'No se pudo procesar el archivo';
                clearPendingFile();
            }
        });
    }
    if ($aiFileRemove) $aiFileRemove.addEventListener('click', clearPendingFile);
    const $ivaIncluido = document.getElementById('ivaIncluido');
    if ($ivaIncluido) $ivaIncluido.addEventListener('change', recalc);
    const $anticipoPct = document.getElementById('anticipoPct');
    if ($anticipoPct) $anticipoPct.addEventListener('input', recalc);
    
    if ($aiBtn) {
        $aiBtn.addEventListener('click', async () => {
            const text = ($aiText.value || '').trim();
            if (!text && !pendingFile) { $aiStatus.textContent = 'Escribe el pedido, pégalo, o adjunta una foto/PDF.'; return; }
            const label = $aiBtn.querySelector('.ai-btn-label');
            const prev = label.textContent;
            $aiBtn.disabled = true; label.textContent = pendingFile ? 'Leyendo documento…' : 'Armando…'; $aiStatus.textContent = '';
            try {
                const res = await fetch('/api/cotizaciones/ai-draft', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text, file: pendingFile }),
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'No se pudo armar');
                lines.length = 0;
                data.items.forEach((it) => {
                    const cat = it.id ? catMap[it.id] : null;
                    const l = {
                        id: it.id || null,
                        nombre: it.nombre || it.descripcion,
                        unidad: it.unidad || 'pieza',
                        baseLista: it.lista || 0,
                        lista: it.lista || 0,
                        vol: cat ? (cat.preciosVolumen || []) : [],
                        costo: cat ? (cat.costo || 0) : 0,
                        negociado: it.negociado,
                        cantidad: it.cantidad || 1,
                        negoTouched: it.negociado != null,
                    };
                    // Ajusta el precio de lista al nivel de volumen de su cantidad.
                    if (l.id) l.lista = volUnit(l);
                    lines.push(l);
                });
                render();
                lines.forEach((l, idx) => { if (l.id) loadPricing(idx); });
                clearPendingFile();
                const n = data.items.length;
                $aiStatus.textContent = `✓ ${n} línea${n === 1 ? '' : 's'} armada${n === 1 ? '' : 's'}. Revisa cantidades y precios.`;
            } catch (err) {
                $aiStatus.textContent = err.message || 'Error de red';
            } finally {
                $aiBtn.disabled = false; label.textContent = prev;
            }
        });
    }

    // ── Modal Nuevo Cliente ──
    const $ncOverlay = document.getElementById('clientModal');
    const $ncForm = document.getElementById('clientForm');
    const $ncSubmit = document.getElementById('mSave');
    const $ncContacto = document.getElementById('fContacto');
    const $ncEmail = document.getElementById('fEmail');

    // Manejo de chips y estado local del form
    let terminos = 'contado';
    const chips = Array.from(document.querySelectorAll('#fTerminos .chip'));
    const setTerm = (v) => { terminos = v; chips.forEach(c => c.classList.toggle('active', c.dataset.v === v)); };
    chips.forEach(c => c.addEventListener('click', () => setTerm(c.dataset.v)));

    const tierChips = Array.from(document.querySelectorAll('.chip.tier'));
    const updateDiscPreview = () => {
        const d = Number(document.getElementById('fDescuento').value || 0);
        const el = document.getElementById('discPreview');
        if (!el) return;
        if (d <= 0) { el.innerHTML = 'Sin descuento'; el.classList.remove('on'); }
        else { el.innerHTML = `$1,000 → <b>$${Math.round(1000 * (1 - d / 100)).toLocaleString('es-MX')}</b>`; el.classList.add('on'); }
    };
    const setNivel = (v, applySuggested = false) => {
        document.getElementById('fNivel').value = v;
        tierChips.forEach(c => c.classList.toggle('active', c.dataset.v === v));
        if (applySuggested) {
            const chip = tierChips.find(c => c.dataset.v === v);
            document.getElementById('fDescuento').value = chip && chip.dataset.sug && chip.dataset.sug !== '0' ? chip.dataset.sug : '';
        }
        updateDiscPreview();
    };
    tierChips.forEach(c => c.addEventListener('click', () => setNivel(c.dataset.v, true)));
    document.getElementById('fDescuento').addEventListener('input', updateDiscPreview);

    function openClientModal() {
        if (!$ncOverlay) return;
        $ncForm.reset();
        setNivel('estandar', false);
        setTerm('contado');
        const err = document.getElementById('mError');
        if (err) err.textContent = '';
        $ncOverlay.showModal();
        const emp = document.getElementById('fEmpresa');
        if (emp) setTimeout(() => emp.focus(), 60);
    }
    
    function closeClientModal() {
        if ($ncOverlay) $ncOverlay.close();
    }

    document.getElementById('mClose')?.addEventListener('click', closeClientModal);
    document.getElementById('mCancel')?.addEventListener('click', closeClientModal);
    $ncOverlay?.addEventListener('click', (e) => {
        if (e.target === $ncOverlay) closeClientModal();
    });

    const TERM_LABEL = { contado: 'Contado', net30: 'Net 30', net60: 'Net 60' };
    const $mError = document.getElementById('mError');

    $ncForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if ($mError) $mError.textContent = '';
        const empresa = document.getElementById('fEmpresa').value.trim();
        if (!empresa) {
            if ($mError) $mError.textContent = 'El nombre de la empresa es obligatorio.';
            document.getElementById('fEmpresa').focus();
            return;
        }

        const prevHTML = $ncSubmit.innerHTML;
        $ncSubmit.disabled = true;
        $ncSubmit.textContent = 'Creando…';

        try {
            const contactoVal = $ncContacto ? $ncContacto.value.trim() : '';
            const emailVal = $ncEmail ? $ncEmail.value.trim() : '';
            const nivelVal = document.getElementById('fNivel').value || 'estandar';
            const descVal = Number(document.getElementById('fDescuento').value || 0);
            // Payload COMPLETO: antes solo se mandaban empresa/contacto/email y el
            // resto del formulario (RFC, crédito, nivel, descuento, fiscal) se perdía.
            const res = await fetch('/api/clientes', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    empresa,
                    contacto: contactoVal,
                    email: emailVal,
                    rfc: document.getElementById('fRfc').value.trim(),
                    limite: document.getElementById('fLimite').value,
                    terminos,
                    nivel: nivelVal,
                    descuento_pct: descVal,
                    regimen_fiscal: document.getElementById('fRegimen').value,
                    uso_cfdi: document.getElementById('fUso').value,
                    cp_fiscal: document.getElementById('fCp').value,
                })
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.error || 'Error al crear cliente');

            const opt = document.createElement('option');
            opt.value = data.id;
            opt.dataset.desc = String(descVal || 0);
            opt.dataset.nivel = nivelVal;
            opt.dataset.term = TERM_LABEL[terminos] || 'Contado';
            opt.textContent = contactoVal ? `${empresa} — ${contactoVal}` : empresa;

            const newOpt = $client.querySelector('option[value="__NEW__"]');
            if (newOpt) {
                $client.insertBefore(opt, newOpt);
            } else {
                $client.appendChild(opt);
            }

            $client.value = data.id;
            lastClientVal = data.id;

            // Dispara el flujo normal de selección: aplica descuento por nivel
            // a las líneas ya agregadas y pre-selecciona sus términos de pago.
            $client.dispatchEvent(new Event('change'));

            closeClientModal();
            showToast(`Cliente "${empresa}" creado y seleccionado ✓`, 2400);
        } catch (err) {
            if ($mError) $mError.textContent = err.message || 'No se pudo crear el cliente.';
        } finally {
            $ncSubmit.disabled = false;
            $ncSubmit.innerHTML = prevHTML;
        }
    });

    if (draftQuote && draftQuote.cliente_id && $client) {
        $client.value = draftQuote.cliente_id;
        lastClientVal = draftQuote.cliente_id;
        reflectDesc();
    }

    // Inicializa la interfaz vacía.
    render();
    reflectDesc();
    lines.forEach((l, idx) => { if (l.id) loadPricing(idx); });
</script>

<style is:global>
