        font-size: 0.78rem; color: var(--color-text-muted);
        display: flex; align-items: center; justify-content: center;
        transition: background 0.2s, color 0.2s, transform 0.2s var(--ease-spring);
    }
    .m-close:hover { background: #e8e8ec; color: var(--color-text); }
    .m-close:active { transform: scale(0.92); }
    .m-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.95rem; }
    .m-fiscal { border-top: 1px solid var(--color-border); padding-top: 0.95rem; display: flex; flex-direction: column; gap: 0.95rem; }
    .m-fiscal > summary { cursor: pointer; font-size: 0.78rem; font-weight: 700; color: var(--color-text); list-style: none; user-select: none; }
    .m-fiscal > summary::-webkit-details-marker { display: none; }
    .m-fiscal > summary::before { content: '+ '; color: var(--color-text-muted); font-weight: 700; }
    .m-fiscal[open] > summary::before { content: '− '; }
    .m-field { display: flex; flex-direction: column; gap: 0.4rem; }
    .m-field label { font-size: 0.62rem; font-weight: 800; letter-spacing: 1.2px; text-transform: uppercase; color: #99a2af; }
    .m-input {
        font-family: var(--font-sans); font-size: 0.88rem; font-weight: 500;
        color: var(--color-text); background: #f5f5f7;
        border: 1.5px solid transparent; border-radius: 10px;
        padding: 10px 12px;
        transition: border-color 0.3s var(--ease-ios), box-shadow 0.3s var(--ease-ios), background 0.2s;
    }
    .m-input:hover { background: #ececee; }
    .m-input:focus { outline: none; border-color: var(--color-blue-deep); background: #fff; box-shadow: 0 0 0 3px rgba(10,25,47,0.08); }
    /* La "letra chiquita" de ayuda bajo un campo (antes esta clase no existía en
       esta página y el texto salía en tamaño normal — se veía roto). */
    .m-hint { font-size: 0.72rem; color: var(--color-text-muted); line-height: 1.5; margin: 0; }
    .m-hint b { color: var(--color-text); font-weight: 600; }

    .m-chips { display: flex; gap: 0.5rem; }
    .m-tiers { flex-wrap: wrap; }
    .m-chips .chip {
        font-family: var(--font-sans); font-size: 0.78rem; font-weight: 600;
        color: var(--color-text-muted); background: var(--color-bg-soft);
        border: 1px solid var(--color-border); border-radius: 100px;
        padding: 7px 16px; cursor: pointer;
        transition: all 0.25s var(--ease-ios);
    }
    .m-chips .chip.active { background: var(--color-blue-deep); color: #fff; border-color: var(--color-blue-deep); }

    /* Descuento por nivel: input con sufijo % + vista previa en pesos */
    .disc-row { display: flex; align-items: center; gap: 0.7rem; }
    .disc-input { position: relative; flex: 0 0 120px; }
    .disc-input .m-input { padding-right: 26px; width: 100%; }
    .disc-suffix { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); font-size: 0.85rem; color: var(--color-text-muted); pointer-events: none; }
    .disc-preview { font-size: 0.82rem; font-weight: 500; color: var(--color-text-muted); }
    .disc-preview.on { color: #059669; }
    .disc-preview b { font-weight: 700; }

    .m-error { font-size: 0.78rem; color: var(--color-danger); margin: 0; min-height: 1em; }

    .m-actions { display: flex; align-items: center; gap: 0.6rem; }
    .m-spacer { flex: 1; }
    .m-delete {
        font-family: var(--font-sans); font-size: 0.8rem; font-weight: 600;
        color: var(--color-danger); background: none; border: none; cursor: pointer;
        padding: 9px 4px;
    }
    .m-delete[hidden] { display: none; }
    .m-cancel {
        font-family: var(--font-sans); font-size: 0.82rem; font-weight: 600;
        color: var(--color-text); background: var(--color-bg-soft);
        border: 1px solid var(--color-border); border-radius: 9px;
        padding: 9px 16px; cursor: pointer;
    }
    .m-save {
        font-family: var(--font-sans); font-size: 0.82rem; font-weight: 600;
        background: var(--color-blue-deep); color: #fff;
        border: none; border-radius: 9px; padding: 9px 18px; cursor: pointer;
        box-shadow: 0 6px 18px -8px rgba(10,25,47,0.5);
    }
    .m-save:disabled { opacity: 0.6; cursor: wait; }

    @media (max-width: 880px) {
        .m-row { grid-template-columns: 1fr; }
    }

    /* En móvil el modal se vuelve un "bottom sheet" que sube desde abajo (nativo). */
    @media (max-width: 560px) {
        .modal {
            width: 100%; max-width: 100%;
            margin: 0; top: auto; bottom: 0; left: 0; right: 0;
            border-radius: 20px 20px 0 0;
            max-height: 92dvh;
            animation: sheet-up 0.32s var(--ease-spring);
        }
        .m-form {
            padding: 1.3rem 1.2rem;
            padding-bottom: calc(1.3rem + env(safe-area-inset-bottom));
            max-height: 92dvh; overflow-y: auto; -webkit-overflow-scrolling: touch;
        }
    }
    @keyframes sheet-up { from { transform: translateY(100%); } to { transform: translateY(0); } }
    @media (prefers-reduced-motion: reduce) { .modal { animation: none; } }

    .draft-tag { font-size: 0.72rem; font-weight: 600; color: var(--color-text-muted); background: var(--color-bg-soft); border: 1px solid var(--color-border); padding: 4px 10px; border-radius: 6px; }

    /* Encabezados flat */
    .section-head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; }
    .section-head h2 { font-size: 0.85rem; font-weight: 600; color: var(--color-text); margin: 0; }

    /* Bloques limpios sin sombras */
    .editor-grid { display: grid; grid-template-columns: 1fr 320px; gap: 3rem; align-items: start; }
    .ed-main { display: flex; flex-direction: column; gap: 2.5rem; min-width: 0; }
    .ed-block { padding: 0; }
    .opt { font-size: 0.75rem; font-weight: 400; color: var(--color-text-muted); }

    /* AI Block */
    /* Hero IA: la puerta de entrada del editor (card navy premium) */
    .ai-block { padding: 1.25rem 1.4rem; border: none; border-radius: 16px; position: relative; overflow: hidden;
        background: var(--color-blue-deep);
        box-shadow: 0 24px 50px -30px rgba(10,25,47,0.65), inset 0 1px 0 rgba(255,255,255,0.06); }
    .ai-title { font-size: 0.96rem; font-weight: 650; margin: 0 0 2px; color: #fff; letter-spacing: -0.01em; }
    .ai-sub { font-size: 0.79rem; color: rgba(255,255,255,0.55); margin: 0 0 0.75rem; line-height: 1.4; }
    .ai-textarea-wrap { position: relative; }
    .ai-block .ed-textarea.ai-textarea { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.14); color: #fff; padding-right: 42px; }
    .ai-block .ed-textarea.ai-textarea::placeholder { color: rgba(255,255,255,0.4); }
    .ai-block .ed-textarea.ai-textarea:focus { border-color: rgba(255,255,255,0.5); box-shadow: 0 0 0 2px rgba(255,255,255,0.1); }
    .ai-actions { display: flex; align-items: center; gap: 1rem; margin-top: 0.7rem; flex-wrap: wrap; }
    .ai-btn {
        font-family: var(--font-sans); font-size: 0.85rem; font-weight: 600; cursor: pointer;
        background: #fff; color: #0a192f; border: none; border-radius: 9px; padding: 9px 18px;
        transition: transform 0.2s var(--ease-spring), box-shadow 0.2s, opacity 0.2s;
    }
    .ai-btn:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 10px 24px -10px rgba(0,0,0,0.5); }
    .ai-btn:disabled { opacity: 0.6; cursor: wait; }
    .ai-status { font-size: 0.78rem; color: rgba(255,255,255,0.7); font-weight: 400; }
    /* Clip discreto, sin texto, anclado dentro del textarea (estilo iMessage/Apple) */
    .ai-attach-btn {
        all: unset; position: absolute; top: 9px; right: 9px; width: 26px; height: 26px;
        display: flex; align-items: center; justify-content: center; cursor: pointer;
        color: rgba(255,255,255,0.45); border-radius: 7px; transition: background 0.15s, color 0.15s;
    }
    .ai-attach-btn svg { width: 15px; height: 15px; }
    .ai-attach-btn:hover { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.85); }
    .ai-file-chip {
        display: flex; align-items: center; gap: 7px; margin-top: 0.55rem; padding: 5px 9px;
        background: rgba(255,255,255,0.07); border-radius: 8px; color: rgba(255,255,255,0.85); font-size: 0.76rem;
    }
    .ai-file-chip[hidden] { display: none; }
    .ai-file-chip svg { width: 13px; height: 13px; flex-shrink: 0; opacity: 0.6; }
    .ai-file-chip span { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .ai-file-chip button { all: unset; cursor: pointer; display: flex; opacity: 0.55; padding: 2px; }
    .ai-file-chip button:hover { opacity: 1; }
    .ai-file-chip button svg { width: 11px; height: 11px; opacity: 1; }

    /* Divisor "o créala manualmente" */
    .ed-or { display: flex; align-items: center; gap: 1rem; margin: 0.3rem 0; color: var(--color-text-muted); }
    .ed-or::before, .ed-or::after { content: ''; flex: 1; height: 1px; background: var(--color-border); }
    .ed-or span { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.3px; text-transform: uppercase; white-space: nowrap; }

    /* Client Row */
    .client-row { display: flex; gap: 0.8rem; align-items: center; flex-wrap: wrap; }
    .ed-select {
        font-family: var(--font-sans); font-size: 0.85rem; font-weight: 400;
        color: var(--color-text); background: #f5f5f7;
        border: 1.5px solid transparent; border-radius: 10px;
        padding: 10px 14px; min-width: 260px; cursor: pointer;
        transition: border-color 0.3s var(--ease-ios), box-shadow 0.3s var(--ease-ios), background 0.2s;
        -webkit-appearance: none; appearance: none;
        background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%2399a2af' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
        background-repeat: no-repeat;
        background-position: right 12px center;
        padding-right: 32px;
    }
    .ed-select:hover { background: #ececee; }
    .ed-select:focus { outline: none; border-color: var(--color-blue-deep); box-shadow: 0 0 0 3px rgba(10,25,47,0.08); background: #fff; }

    .term-chips { display: flex; gap: 0.35rem; }
    .chip {
        font-family: var(--font-sans); font-size: 0.78rem; font-weight: 600;
        color: var(--color-text-muted); background: #f5f5f7;
        border: 1.5px solid transparent; border-radius: 999px;
        padding: 7px 16px; cursor: pointer;
        transition: all 0.3s var(--ease-ios);
    }
    .chip:hover { background: #e8e8ec; }
    .chip.active { background: var(--color-blue-deep); color: #fff; border-color: var(--color-blue-deep); box-shadow: 0 2px 8px -2px rgba(10,25,47,0.3); }
    .desc-note { font-size: 0.76rem; font-weight: 500; color: #059669; margin: 0.6rem 0 0; }
    .desc-note[hidden] { display: none; }

    /* Products list */
    .lines-head {
        display: grid; grid-template-columns: 1.8fr 70px 90px 110px 1fr 58px 30px;
        gap: 0.8rem;
        font-size: 0.72rem; font-weight: 500; color: var(--color-text-muted);
        padding: 0 0 0.5rem; border-bottom: 1px solid var(--color-border);
    }
    .lh-right { text-align: right; }
    .lines-empty { display: flex; flex-direction: column; align-items: center; gap: 0.7rem; font-size: 0.82rem; color: var(--color-text-muted); padding: 2.8rem 1.5rem; text-align: center; border-bottom: 1px solid rgba(0,0,0,0.05); line-height: 1.5; background: #fafafa; border-radius: 12px; margin: 0.5rem 0; }
    .lines-empty svg { width: 36px; height: 36px; color: #d1d5db; }
    .lines-empty b { color: var(--color-text); font-weight: 600; }
    .lines-empty[hidden] { display: none; }
    
    .add-actions { display: flex; gap: 0.6rem; margin-top: 1rem; align-items: center; flex-wrap: wrap; }
    .add-hint { font-size: 0.72rem; color: #99a2af; margin: 0.5rem 0 0; }
    .add-hint kbd { font-family: var(--font-sans); font-size: 0.64rem; font-weight: 600; color: var(--color-text-muted); background: #f5f5f7; border-radius: 5px; padding: 2px 6px; box-shadow: inset 0 -1px 0 rgba(0,0,0,0.06); }
    .btn-free-line {
        font-family: var(--font-sans); font-size: 0.82rem; font-weight: 500; cursor: pointer;
        background: #f5f5f7; color: var(--color-text-muted); border: none; border-radius: 10px; padding: 9px 16px;
        transition: all 0.3s var(--ease-ios);
    }
    .btn-free-line:hover { color: var(--color-text); background: #e8e8ec; }

    /* ── Insertar kit (dropdown de paquetes pre-armados) ── */
    .kit-insert-wrap { position: relative; }
    .kit-insert-drop {
        position: absolute; bottom: calc(100% + 8px); left: 0; z-index: 60;
        width: min(360px, 86vw);
        background: #fff; border-radius: 14px; overflow: hidden;
        box-shadow: 0 0 0 0.5px rgba(0,0,0,0.05), 0 12px 32px -8px rgba(10,25,47,0.18), 0 4px 12px -4px rgba(10,25,47,0.08);
        max-height: 320px; overflow-y: auto;
    }
    .kit-insert-drop[hidden] { display: none; }
    .kit-insert-row { display: flex; align-items: center; gap: 0.6rem; padding: 9px 12px; border-bottom: 1px solid var(--color-border); }
    .kit-insert-row:last-child { border-bottom: none; }
    .kit-insert-name { flex: 1; min-width: 0; display: flex; flex-direction: column; font-size: 0.84rem; font-weight: 500; color: var(--color-text); }
    .kit-insert-name small { font-size: 0.66rem; color: #99a2af; font-weight: 500; }
    .kit-insert-qty {
        width: 44px; text-align: center; font-family: var(--font-sans); font-size: 0.82rem; color: var(--color-text);
        background: #f5f5f7; border: 1px solid transparent; border-radius: 8px; padding: 6px 2px; flex-shrink: 0;
        -moz-appearance: textfield;
    }
    .kit-insert-qty::-webkit-outer-spin-button, .kit-insert-qty::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
    .kit-insert-qty:focus { outline: none; border-color: var(--color-blue-deep); background: #fff; }
    .kit-insert-add {
        font-family: var(--font-sans); font-size: 0.76rem; font-weight: 600; color: #fff; background: var(--color-blue-deep);
        border: none; border-radius: 8px; padding: 7px 12px; cursor: pointer; flex-shrink: 0; transition: transform 0.25s var(--ease-spring);
    }
    .kit-insert-add:hover { transform: translateY(-1px); }

    .ed-textarea {
        font-family: var(--font-sans); font-size: 0.85rem; width: 100%;
        color: var(--color-text); background: #f5f5f7;
        border: 1.5px solid transparent; border-radius: 10px;
        padding: 10px 14px; resize: vertical; line-height: 1.5;
        transition: border-color 0.3s var(--ease-ios), box-shadow 0.3s var(--ease-ios), background 0.2s;
    }
    .ed-textarea:hover { background: #ececee; }
    .ed-textarea:focus { outline: none; border-color: var(--color-blue-deep); box-shadow: 0 0 0 3px rgba(10,25,47,0.08); background: #fff; }

    /* Pasos numerados (guía visual del flujo) */
    .step-head { display: flex; align-items: flex-start; gap: 0.7rem; margin-bottom: 1.1rem; }
    .step-num { flex-shrink: 0; width: 24px; height: 24px; border-radius: 7px; background: var(--color-blue-deep); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 0.78rem; font-weight: 700; margin-top: 1px; }
    .step-text h2 { font-size: 0.95rem; font-weight: 600; color: var(--color-text); margin: 0 0 2px; }
    .step-hint { font-size: 0.78rem; color: var(--color-text-muted); margin: 0; line-height: 1.45; }
    .step-hint b { color: var(--color-text); font-weight: 600; }

    /* Marcador "?" de ayuda en encabezados */
    .lh-i { display: inline-flex; align-items: center; justify-content: center; width: 14px; height: 14px; border-radius: 50%; border: 1px solid var(--color-border); font-size: 0.6rem; color: var(--color-text-muted); cursor: help; margin-left: 3px; font-weight: 700; }

    /* Resumen: conteo + ahorro al cliente */
    .sum-count { font-size: 0.74rem; color: var(--color-text-muted); margin: -0.2rem 0 0.3rem; }
    .sum-save { color: #059669; }
    .sum-save .editorial { color: #059669; }
    .sum-save[hidden] { display: none; }

    /* Multi-divisa — panel visual en lenguaje simple */
    .fx-cover { margin-top: 0.6rem; padding: 0.9rem; background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: 12px; display: flex; flex-direction: column; gap: 0.7rem; }
    .fx-cover[hidden] { display: none; }
    .fx-explain { font-size: 0.76rem; color: var(--color-text-muted); line-height: 1.5; margin: 0; }
    .fx-explain b { color: var(--color-text); font-weight: 600; }
    .fx-stepper { display: flex; align-items: stretch; gap: 0.45rem; }
    .fx-step { flex: 1; display: flex; flex-direction: column; gap: 2px; padding: 8px 10px; border-radius: 9px; border: 1px solid var(--color-border); background: var(--color-bg); }
    .fx-step-on { border-color: rgba(16,185,129,0.5); background: rgba(16,185,129,0.07); }
    .fx-step-lbl { font-size: 0.62rem; font-weight: 600; color: var(--color-text-muted); line-height: 1.25; }
    .fx-step-on .fx-step-lbl { color: #059669; }
    .fx-step-val { font-size: 0.98rem; color: var(--color-text); }
    .fx-arrow { align-self: center; font-size: 0.9rem; color: var(--color-text-muted); }
    .fx-cushion-lbl { font-size: 0.72rem; font-weight: 500; color: var(--color-text-muted); }
    .fx-cushion { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.4rem; }
    .fx-cush-chip { font-family: var(--font-sans); display: flex; flex-direction: column; align-items: center; gap: 1px; cursor: pointer; padding: 7px 4px; border: 1px solid var(--color-border); border-radius: 8px; background: var(--color-bg); transition: all 0.2s; }
    .fx-cush-chip b { font-size: 0.74rem; font-weight: 600; color: var(--color-text); }
    .fx-cush-chip small { font-size: 0.64rem; color: var(--color-text-muted); }
    .fx-cush-chip:hover { border-color: #cbd5e1; }
    .fx-cush-chip.active { border-color: var(--color-blue-deep); background: var(--color-blue-deep); }
    .fx-cush-chip.active b, .fx-cush-chip.active small { color: #fff; }
    .fx-client-sees { font-size: 0.8rem; color: var(--color-text); margin: 0; line-height: 1.4; }
    .fx-client-sees b { font-weight: 600; }
    .fx-lock-row { display: flex; align-items: center; gap: 6px; font-size: 0.68rem; color: var(--color-text-muted); }
    .fx-lock-ic { font-size: 0.7rem; }

    /* Sidebar summary — Apple checkout style */
    .ed-side { position: sticky; top: 76px; }
    .ed-summary {
        padding: 1.6rem; background: #fff; border-radius: 20px;
        border: none;
        box-shadow:
            0 0 0 0.5px rgba(0,0,0,0.04),
            0 4px 12px -2px rgba(0,0,0,0.06),
            0 16px 40px -8px rgba(10,25,47,0.1);
        display: flex; flex-direction: column; gap: 0.8rem;
    }
    .ed-summary .section-head { margin-bottom: 0.2rem; }
    .ed-summary .section-head h2 { font-size: 0.92rem; font-weight: 700; letter-spacing: -0.02em; }
    .sum-line { display: flex; justify-content: space-between; font-size: 0.85rem; color: var(--color-text-muted); }
    .sum-line .editorial { color: var(--color-text); font-size: 0.95rem; }
    .sum-divider { height: 1px; background: rgba(0,0,0,0.06); margin: 0.5rem 0; }
    .sum-total { font-weight: 700; color: var(--color-text); }
    .sum-total .editorial { font-size: 1.6rem; letter-spacing: -0.03em; }

    .sum-field { display: flex; flex-direction: column; gap: 0.4rem; margin-top: 0.5rem; }
    .sum-field label { font-size: 0.72rem; font-weight: 500; color: var(--color-text-muted); }
    .sum-anticipo-note { font-size: 0.74rem; color: var(--color-text-muted); line-height: 1.5; margin: 0.35rem 0 0; }

    .btn-send {
        display: flex; align-items: center; justify-content: center; gap: 8px;
        font-family: var(--font-sans); font-size: 0.88rem; font-weight: 600;
        background: var(--color-blue-deep); color: #fff;
        border: none; border-radius: 999px; padding: 12px 20px; cursor: pointer;
        transition: transform 0.25s var(--ease-spring), box-shadow 0.25s var(--ease-ios), background 0.2s;
        margin-top: 0.8rem;
        box-shadow: 0 4px 14px -4px rgba(10,25,47,0.4);
    }
    .btn-send svg { width: 16px; height: 16px; }
    .btn-send:hover { transform: translateY(-1px); box-shadow: 0 8px 24px -6px rgba(10,25,47,0.5); }
    .btn-send:active { transform: translateY(0) scale(0.97); }
    .btn-draft {
        font-family: var(--font-sans); font-size: 0.85rem; font-weight: 600;
        color: var(--color-text); background: #f5f5f7;
        border: none; border-radius: 999px;
        padding: 11px 20px; cursor: pointer;
        transition: all 0.25s var(--ease-ios);
    }
    .btn-draft:hover { background: #e8e8ec; }
    .btn-draft:active { transform: scale(0.97); }
    .sum-note { font-size: 0.75rem; color: var(--color-text-muted); margin: 0.4rem 0 0; line-height: 1.4; text-align: center; }
    .sum-kbd { display: flex; align-items: center; justify-content: center; gap: 4px; font-size: 0.68rem; color: #99a2af; margin: 0.1rem 0 0; }
    .sum-kbd kbd { font-family: var(--font-sans); font-size: 0.62rem; font-weight: 600; color: var(--color-text-muted); background: #f5f5f7; border-radius: 5px; padding: 2px 6px; box-shadow: inset 0 -1px 0 rgba(0,0,0,0.06); }

    .toast {
        position: fixed; bottom: 1.5rem; left: 50%; transform: translateX(-50%);
        display: flex; align-items: center; gap: 10px;
