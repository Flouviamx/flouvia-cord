    /* ── Buscador de productos (combobox) — hijos inyectados por JS → is:global ── */
    .prod-search { position: relative; flex: 1; min-width: 240px; max-width: 460px; }
    .prod-search-ic { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); width: 15px; height: 15px; color: #99a2af; pointer-events: none; }
