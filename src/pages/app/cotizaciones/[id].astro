<script>
    // Acciones de la cotización contra PATCH/DELETE /api/cotizaciones/[id].
    document.addEventListener('DOMContentLoaded', () => {
        const panel = document.querySelector<HTMLElement>('.d-actions');
        if (!panel) return;
        const qid = panel.dataset.qid!;
        const token = panel.dataset.token!;
        const errorEl = document.getElementById('actError')!;

        // ── Presencia + conversación en vivo (polling cada 8s) ──
        // La presencia ("viendo ahora") se muestra solo en planes con la feature;
        // el aviso de mensajes nuevos aplica para todos (no recarga solo: ofrece botón).
        const lv = document.getElementById('liveViewing');
        const hasLiveView = panel.dataset.liveView === '1';
        const tlNew = document.getElementById('tlNew');
        let convBaseline: number | null = null;

        const poll = async () => {
            try {
                const r = await fetch(`/api/cotizaciones/${qid}/presence`);
                const d = await r.json();
                if (lv && hasLiveView) lv.hidden = !d.online;
                const count = Number(d.convCount) || 0;
                if (convBaseline === null) convBaseline = count;
                else if (tlNew && count > convBaseline) tlNew.hidden = false;
            } catch { /* ignora */ }
        };
        poll();
        setInterval(poll, 8000);
        tlNew?.addEventListener('click', () => location.reload());

        // ── Flujo de aprobación (gerencia) ──
        const apAction = async (action: string, btn: HTMLButtonElement) => {
            btn.disabled = true; errorEl.textContent = '';
            try {
                const res = await fetch(`/api/cotizaciones/${qid}`, { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action }) });
                const d = await res.json();
                if (!res.ok) throw new Error(d.error || 'No se pudo procesar');
                location.reload();
            } catch (e: any) { errorEl.textContent = e.message; btn.disabled = false; }
        };
        document.getElementById('apApprove')?.addEventListener('click', (e) => apAction('approve_request', e.currentTarget as HTMLButtonElement));
        document.getElementById('apReject')?.addEventListener('click', async (e) => { const b = e.currentTarget as HTMLButtonElement; if (await (window as any).cordConfirm({ title: 'Rechazar solicitud', body: '¿Rechazar esta solicitud de aprobación?', danger: true, confirmText: 'Rechazar' })) apAction('reject_request', b); });

        const CONFIRM: Record<string, string> = {
            reject: '¿Marcar esta cotización como rechazada?',
            paid: '¿Registrar el pago? La cotización quedará marcada como pagada.',
            invoiced: 'Se marcará como facturada y se emitirá el documento fiscal (CFDI real si tienes tu facturación conectada; si no, queda registrado como simulado). ¿Continuar?',
        };

        panel.querySelectorAll<HTMLButtonElement>('.act-do').forEach((btn) => {
            btn.addEventListener('click', async () => {
                const action = btn.dataset.action!;
                if (CONFIRM[action] && !await (window as any).cordConfirm({ title: 'Confirmar acción', body: CONFIRM[action], confirmText: 'Continuar' })) return;
                btn.disabled = true;
                errorEl.textContent = '';
                try {
                    const res = await fetch(`/api/cotizaciones/${qid}`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action }),
                    });
                    const data = await res.json();
                    if (!res.ok) throw new Error(data.error || 'No se pudo aplicar la acción');
                    location.reload();
                } catch (err: any) {
                    errorEl.textContent = err.message;
                    btn.disabled = false;
                }
            });
        });

        document.getElementById('btnWhats')?.addEventListener('click', () => {
            const folio = panel.dataset.folio || '';
            const cliente = panel.dataset.cliente || '';
            const total = panel.dataset.total || '';
            const link = `${location.origin}/q/${token}`;
            const msg = `¡Hola${cliente ? ' ' + cliente : ''}! Te comparto la cotización ${folio}${total ? ' por ' + total : ''}. Puedes revisarla y aprobarla aquí: ${link}`;
            window.open(`https://wa.me/?text=${encodeURIComponent(msg)}`, '_blank');
        });

        document.getElementById('btnCopy')?.addEventListener('click', async (e) => {
            const btn = e.currentTarget as HTMLButtonElement;
            try {
                await navigator.clipboard.writeText(`${location.origin}/q/${token}`);
            } catch {
                errorEl.textContent = 'No se pudo copiar el link';
                return;
            }
            // Feedback sin destruir el ícono SVG (antes textContent lo borraba).
            const lbl = btn.querySelector<HTMLElement>('.act-util-lbl');
            const prev = lbl?.textContent || '';
            btn.classList.add('act-copied');
            if (lbl) lbl.textContent = 'Copiado';
            (window as any).cordToast?.('Link copiado al portapapeles', 'ok', 1800);
            setTimeout(() => { btn.classList.remove('act-copied'); if (lbl) lbl.textContent = prev; }, 1800);
        });

        // ── Chat general (Conversación) — envío optimista, sin recargar la página ──
        const dcThread = document.getElementById('dcThread');
        const dcError = document.getElementById('dcError') as HTMLElement | null;
        const replyTa = document.getElementById('replyMsg') as HTMLTextAreaElement | null;
        const btnReply = document.getElementById('btnReply') as HTMLButtonElement | null;

        const appendBubble = (thread: HTMLElement, text: string, mine: boolean, small = false) => {
            thread.querySelector('.dc-thread-empty, .di-thread-empty')?.remove();
            const div = document.createElement('div');
            div.className = (small ? 'di-msg' : 'dc-msg') + (mine ? ' mine' : '');
            const t = document.createElement('span'); t.className = small ? 'di-msg-text' : 'dc-msg-text'; t.textContent = text;
            const time = document.createElement('span'); time.className = small ? 'di-msg-time' : 'dc-msg-time'; time.textContent = 'ahora';
            div.append(t, time);
            thread.appendChild(div);
            thread.scrollTop = thread.scrollHeight;
        };

        // Auto-resize + Enter para enviar (Shift+Enter = salto de línea) — se siente como chat real.
        replyTa?.addEventListener('input', () => { replyTa.style.height = 'auto'; replyTa.style.height = Math.min(replyTa.scrollHeight, 90) + 'px'; });
        replyTa?.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); btnReply?.click(); }
        });

        const sendReply = async () => {
            if (!btnReply || !replyTa || !dcThread) return;
            const mensaje = replyTa.value.trim();
            if (!mensaje) return;
            btnReply.disabled = true; if (dcError) dcError.textContent = '';
            appendBubble(dcThread, mensaje, true);
            replyTa.value = ''; replyTa.style.height = 'auto';
            try {
                const res = await fetch(`/api/cotizaciones/${qid}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: 'reply', mensaje }),
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'No se pudo enviar');
            } catch (err: any) {
                if (dcError) dcError.textContent = err.message;
            } finally {
                btnReply.disabled = false;
            }
        };
        btnReply?.addEventListener('click', sendReply);

        // ── Chat por línea/producto — abrir/cerrar hilo + responder ──
        document.querySelectorAll<HTMLButtonElement>('.di-chat-toggle').forEach((toggle) => {
            toggle.addEventListener('click', () => {
                const wrap = document.getElementById(`di-thread-${toggle.dataset.itemToggle}`);
                if (wrap) wrap.hidden = !wrap.hidden;
            });
        });
        document.querySelectorAll<HTMLButtonElement>('.di-thread-send').forEach((btn) => {
            btn.addEventListener('click', async () => {
                const itemId = btn.dataset.itemReply!;
                const wrap = document.getElementById(`di-thread-${itemId}`);
                const input = wrap?.querySelector<HTMLInputElement>('.di-thread-input');
                const msgs = wrap?.querySelector<HTMLElement>('.di-thread-msgs');
                const mensaje = (input?.value || '').trim();
                if (!mensaje || !msgs) return;
                btn.disabled = true;
                appendBubble(msgs, mensaje, true, true);
                if (input) input.value = '';
                try {
                    const res = await fetch(`/api/cotizaciones/${qid}`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'item_reply', item_id: itemId, mensaje }),
                    });
                    const data = await res.json();
                    if (!res.ok) throw new Error(data.error || 'No se pudo enviar');
                } catch (err: any) {
                    errorEl.textContent = err.message;
                } finally {
                    btn.disabled = false;
                }
            });
        });

        document.getElementById('btnDuplicate')?.addEventListener('click', async (e) => {
            const btn = e.currentTarget as HTMLButtonElement;
            btn.disabled = true;
            errorEl.textContent = '';
            try {
                const res = await fetch(`/api/cotizaciones/${qid}/duplicate`, { method: 'POST' });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'No se pudo duplicar');
                location.href = `/app/cotizaciones/${data.id}`;
            } catch (err: any) {
                errorEl.textContent = err.message;
                btn.disabled = false;
            }
        });

        document.getElementById('btnDelete')?.addEventListener('click', async () => {
            if (!await (window as any).cordConfirm({ title: 'Eliminar borrador', body: 'Esta acción no se puede deshacer. ¿Eliminar este borrador?', danger: true, confirmText: 'Eliminar' })) return;
            const res = await fetch(`/api/cotizaciones/${qid}`, { method: 'DELETE' });
            if (res.ok) location.href = '/app/cotizaciones';
            else errorEl.textContent = (await res.json()).error || 'No se pudo eliminar';
        });
    });
</script>
