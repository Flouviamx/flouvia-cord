---
// Ajustes › Developers › API.
// Claves de API REALES (tabla api_keys, hash sha-256) en tabla estilo Stripe:
// la clave en claro se muestra UNA vez al crearla. Endpoints REST + actividad
// en vivo. Webhooks y MCP viven en sus propias pestañas (jun 2026: se separó
// la antigua página "API y webhooks" en API · Webhooks · MCP).
import SettingsShell from '../../../components/app/SettingsShell.astro';
import { getApiKeys, getOrg, getApiActivity } from '../../../lib/queries';
import { planTieneApi } from '../../../lib/permissions';
import '../../../styles/developers.css';
const ORG = await getOrg();
const tienePlan = planTieneApi(ORG.plan_raw);

const KEYS = await getApiKeys();
const ACTIVITY = await getApiActivity();
---

<SettingsShell title="API — Ajustes" tab="api" perm="ajustes"
    intro="Conecta Cord con tu propio sistema (ERP, CRM, scripts): lee y crea cotizaciones, clientes y productos por API. Genera una clave abajo y consulta los endpoints disponibles.">
<div class="dev-wrapper">

    {!tienePlan && (
        <div class="dev-upsell">
            <div>
                <span class="dev-upsell-eyebrow">Plan Negocio</span>
                <p>Las claves <b>en vivo</b> requieren el plan Negocio. Las claves de <b>prueba</b> (sk_test_) son gratis — intégrate hoy y activa producción cuando subas de plan.</p>
            </div>
            <a href="/app/ajustes/plan" class="dev-upsell-cta">Ver planes</a>
        </div>
    )}

    <!-- ── CLAVES DE API (tabla estilo Stripe) ── -->
    <div class="dev-card">
        <div class="dev-card-header">
            <div>
                <h3 class="dev-card-title">Claves de API</h3>
                <p class="dev-card-sub">Autentícate con <code>Authorization: Bearer &lt;clave&gt;</code>. Trátalas como contraseñas: nunca las publiques en el front ni en repos.</p>
            </div>
            <div class="dev-head-actions">
                <div class="dev-seg" role="tablist" aria-label="Modo de la clave">
                    <button class="dev-seg-btn active" data-mode="test">Prueba</button>
                    <button class={`dev-seg-btn ${tienePlan ? '' : 'locked'}`} data-mode="live">Vivo</button>
                </div>
                <button class="api-btn-solid" id="kNew">+ Generar clave</button>
            </div>
        </div>

        <div class="key-table" id="keyList">
            <div class="key-thead">
                <span>Nombre</span><span>Token</span><span>Permisos</span><span>Último uso</span><span>Creación</span><span></span>
            </div>
            {KEYS.length === 0 && (
                <div class="key-empty" id="keyEmpty">Aún no tienes claves. Genera una para empezar a llamar la API.</div>
            )}
            {KEYS.map((k) => (
                <div class:list={['key-trow', { revoked: k.revocada }]} data-id={k.id}>
                    <span class="key-cell-name">
                        <span class="key-nm">{k.nombre}</span>
                        <span class={`key-mode ${k.mode}`}>{k.mode === 'test' ? 'Prueba' : 'Vivo'}</span>
                    </span>
                    <code class="key-cell-token">{k.masked}</code>
                    <span class={`key-scope ${k.scope}`}>{k.scope === 'write' ? 'Escritura' : 'Lectura'}</span>
                    <span class="key-cell-muted">{k.ultimoUso || 'Sin uso'}</span>
                    <span class="key-cell-muted">{k.creada}</span>
                    <span class="key-cell-act">
                        {k.revocada
                            ? <span class="key-badge-revoked">Revocada</span>
                            : <button class="key-revoke" data-revoke={k.id}>Revocar</button>}
                    </span>
                </div>
            ))}
        </div>
    </div>

    <!-- ── ENDPOINTS ── -->
    <div class="dev-card">
        <h3 class="dev-card-title">Endpoints disponibles</h3>
        <p class="dev-note" style="margin: 0.4rem 0 1.2rem">Base: <code>https://cord.flouvia.com/api/v1</code> · autentícate con <code>Authorization: Bearer &lt;tu_clave&gt;</code>.</p>
        <div class="ep-rows">
            <div class="ep-row"><span class="ep-m get">GET</span><code class="ep-path">/me</code><span class="ep-d">A qué negocio pertenece la clave</span></div>
            <div class="ep-row"><span class="ep-m get">GET</span><code class="ep-path">/cotizaciones</code><span class="ep-d">Lista (filtra con <code>?status=</code>, pagina con <code>?limit=&amp;offset=</code>)</span></div>
            <div class="ep-row"><span class="ep-m post">POST</span><code class="ep-path">/cotizaciones</code><span class="ep-d">Crea una cotización (requiere escritura)</span></div>
            <div class="ep-row"><span class="ep-m get">GET</span><code class="ep-path">/cotizaciones/:id</code><span class="ep-d">Detalle con líneas y timeline</span></div>
            <div class="ep-row"><span class="ep-m get">GET</span><code class="ep-path">/clientes</code><span class="ep-d">Directorio de clientes</span></div>
            <div class="ep-row"><span class="ep-m post">POST</span><code class="ep-path">/clientes</code><span class="ep-d">Alta de cliente (requiere escritura)</span></div>
            <div class="ep-row"><span class="ep-m get">GET</span><code class="ep-path">/productos</code><span class="ep-d">Catálogo</span></div>
            <div class="ep-row"><span class="ep-m post">POST</span><code class="ep-path">/productos</code><span class="ep-d">Alta de producto (requiere escritura)</span></div>
            <div class="ep-row"><span class="ep-m get">GET</span><code class="ep-path">/cobranza</code><span class="ep-d">Cartera, vencidos y aging</span></div>
        </div>
        <div class="dev-terminal">
            <span class="ep-code-label">Ejemplo</span>
            <pre><code>curl https://cord.flouvia.com/api/v1/cotizaciones \
  -H "Authorization: Bearer sk_live_xxxxxxxxxxxx"</code></pre>
        </div>
    </div>

    <!-- ── ACTIVIDAD DEL API ── -->
    <div class="dev-card">
        <div class="dev-card-header">
            <h3 class="dev-card-title">Actividad del API</h3>
            <button class="dev-refresh" id="actRefresh" title="Actualizar">Actualizar</button>
        </div>
        <div class="dev-stats-grid">
            <div class="dev-stat-box"><span class="dev-stat-value editorial" id="actTotal">{ACTIVITY.total24}</span><span class="dev-stat-label">requests · 24 h</span></div>
            <div class="dev-stat-box"><span class={`dev-stat-value editorial ${ACTIVITY.errores24 > 0 ? 'bad' : ''}`} id="actErr">{ACTIVITY.errores24}</span><span class="dev-stat-label">errores · 24 h</span></div>
            <div class="dev-stat-box"><span class="dev-stat-value editorial" id="actLat">{ACTIVITY.latProm}<em>ms</em></span><span class="dev-stat-label">latencia promedio</span></div>
        </div>
        <div class="act-list" id="actList">
            {ACTIVITY.recent.length === 0 && <p class="dev-empty" id="actEmpty">Sin actividad todavía. Cuando llames la API con una clave, las requests aparecerán aquí.</p>}
            {ACTIVITY.recent.map((r) => (
                <div class="act-row">
                    <span class={`act-m ${r.metodo.toLowerCase()}`}>{r.metodo}</span>
                    <code class="act-path">{r.ruta}</code>
                    <span class={`act-status ${r.status >= 400 ? 'bad' : 'ok'}`}>{r.status}</span>
                    <span class="act-lat">{r.ms != null ? `${r.ms}ms` : '—'}</span>
                    <span class="act-when">{r.cuando}{r.mode === 'test' ? ' · test' : ''}</span>
                </div>
            ))}
        </div>
    </div>
</div>
</SettingsShell>

<!-- Modal: crear API key (nombre + scope) -->
<dialog id="kCreate" class="kdlg">
    <div class="kdlg-inner">
        <h4 id="kCreateTitle">Nueva API key</h4>
        <div class="s-field" style="margin-bottom:1.1rem">
            <label for="kName">Nombre</label>
            <input class="s-input" id="kName" placeholder="Producción, Zapier, Mi ERP…" />
        </div>
        <div class="s-field">
            <label>Permisos</label>
            <div class="scope-opts">
                <label class="scope-opt">
                    <input type="radio" name="kScope" value="read" checked />
                    <span class="scope-body"><b>Solo lectura</b><i>Consultar cotizaciones, clientes, productos y cobranza.</i></span>
                </label>
                <label class="scope-opt">
                    <input type="radio" name="kScope" value="write" />
                    <span class="scope-body"><b>Lectura y escritura</b><i>Además puede crear cotizaciones, clientes y productos.</i></span>
                </label>
            </div>
        </div>
        <div class="wh-dlg-actions">
            <button type="button" class="api-btn-ghost" id="kCreateCancel">Cancelar</button>
            <button type="button" class="api-btn-solid" id="kCreateGo">Generar clave</button>
        </div>
    </div>
</dialog>

<!-- Modal: clave recién creada (se muestra UNA vez) -->
<dialog id="kDialog" class="kdlg">
    <div class="kdlg-inner">
        <h4 id="kdlgTitle">Tu nueva API key</h4>
        <p class="kdlg-warn">Cópiala ahora. Por seguridad <b>no podrás volver a verla</b> — sólo verás el prefijo.</p>
        <div class="kdlg-key">
            <code id="kdlgSecret">sk_live_…</code>
            <button id="kdlgCopy" class="kdlg-copy">Copiar</button>
        </div>
        <form method="dialog"><button class="kdlg-done">Listo, ya la guardé</button></form>
    </div>
</dialog>

<script>
    function initApi() {
        const dialog = document.getElementById('kDialog') as HTMLDialogElement | null;
        const secretEl = document.getElementById('kdlgSecret');
        const newBtn = document.getElementById('kNew');
        const createDlg = document.getElementById('kCreate') as HTMLDialogElement | null;
        if (!dialog || !newBtn || !createDlg) return;

        // Segmented Vivo/Prueba → modo de la próxima clave (prueba por default).
        let mode = localStorage.getItem('cord_test_mode') === 'true' ? 'test' : 'live';

        const setModeUI = (newMode: string) => {
            mode = newMode;
            document.querySelectorAll('.dev-seg-btn').forEach((x) => x.classList.remove('active'));
            const activeBtn = document.querySelector(`.dev-seg-btn[data-mode="${mode}"]`);
            if (activeBtn) activeBtn.classList.add('active');
        };
        setModeUI(mode);

        document.querySelectorAll('.dev-seg-btn').forEach((b) => b.addEventListener('click', () => {
            setModeUI((b as HTMLElement).dataset.mode || 'test');
        }));

        // Sincroniza con el switch global "Entorno de prueba".
        window.addEventListener('cord:test_mode_changed', (e: any) => {
            setModeUI(e.detail.isTestMode ? 'test' : 'live');
        });

        const nameIn = document.getElementById('kName') as HTMLInputElement;
        const titleEl = document.getElementById('kCreateTitle')!;
        newBtn.addEventListener('click', () => {
            titleEl.textContent = mode === 'test' ? 'Nueva API key de prueba' : 'Nueva API key EN VIVO';
            nameIn.value = mode === 'test' ? 'Pruebas' : 'Producción';
            (createDlg.querySelector('input[name="kScope"][value="read"]') as HTMLInputElement).checked = true;
            createDlg.showModal(); nameIn.focus(); nameIn.select();
        });
        document.getElementById('kCreateCancel')?.addEventListener('click', () => createDlg.close());

        document.getElementById('kCreateGo')?.addEventListener('click', async () => {
            const nombre = nameIn.value.trim() || 'Sin nombre';
            const scope = (createDlg.querySelector('input[name="kScope"]:checked') as HTMLInputElement)?.value || 'read';
            const go = document.getElementById('kCreateGo') as HTMLButtonElement;
            go.disabled = true;
            try {
                const res = await fetch('/api/keys', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ nombre, scope, mode }),
                });
                const d = await res.json();
                if (!res.ok) throw new Error(d.error || 'No se pudo crear');
                createDlg.close();
                if (secretEl) secretEl.textContent = d.secret;
                dialog.showModal();
                dialog.addEventListener('close', () => location.reload(), { once: true });
            } catch (err: any) {
                alert(err.message || 'No se pudo crear la clave');
            } finally { go.disabled = false; }
        });

        document.getElementById('kdlgCopy')?.addEventListener('click', async () => {
            const txt = secretEl?.textContent || '';
            try { await navigator.clipboard.writeText(txt); const b = document.getElementById('kdlgCopy')!; b.textContent = '✓ Copiada'; setTimeout(() => (b.textContent = 'Copiar'), 1800); } catch {}
        });

        document.querySelectorAll('[data-revoke]').forEach((btn) => {
            btn.addEventListener('click', async () => {
                const id = (btn as HTMLElement).dataset.revoke!;
                if (!confirm('¿Revocar esta API key? Dejará de funcionar de inmediato y no se puede deshacer.')) return;
                try {
                    const res = await fetch('/api/keys', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
                    if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'No se pudo revocar'); }
                    location.reload();
                } catch (err: any) { alert(err.message || 'No se pudo revocar'); }
            });
        });
    }

    // ── Actividad del API: refrescar sin recargar ──
    function initActivity() {
        const btn = document.getElementById('actRefresh');
        if (!btn) return;
        btn.addEventListener('click', async () => {
            (btn as HTMLButtonElement).disabled = true; btn.textContent = 'Actualizando…';
            try {
                const res = await fetch('/api/dev/activity');
                if (res.ok) {
                    const d = await res.json();
                    document.getElementById('actTotal')!.textContent = String(d.total24);
                    const errEl = document.getElementById('actErr')!;
                    errEl.textContent = String(d.errores24);
                    errEl.classList.toggle('bad', d.errores24 > 0);
                    document.getElementById('actLat')!.innerHTML = `${d.latProm}<em>ms</em>`;
                    renderActivity(d.recent);
                }
            } catch {}
            (btn as HTMLButtonElement).disabled = false; btn.textContent = 'Actualizar';
        });
    }
    function renderActivity(recent: any[]) {
        const list = document.getElementById('actList');
        if (!list) return;
        if (!recent.length) { list.innerHTML = '<p class="dev-empty">Sin actividad todavía. Cuando llames la API con una clave, las requests aparecerán aquí.</p>'; return; }
        const esc = (s: string) => String(s).replace(/[<>&]/g, (c) => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;' }[c] || c));
        list.innerHTML = recent.map((r) => `
            <div class="act-row">
                <span class="act-m ${r.metodo.toLowerCase()}">${esc(r.metodo)}</span>
                <code class="act-path">${esc(r.ruta)}</code>
                <span class="act-status ${r.status >= 400 ? 'bad' : 'ok'}">${r.status}</span>
                <span class="act-lat">${r.ms != null ? r.ms + 'ms' : '—'}</span>
                <span class="act-when">${esc(r.cuando)}${r.mode === 'test' ? ' · test' : ''}</span>
            </div>`).join('');
    }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', () => { initApi(); initActivity(); });
    else { initApi(); initActivity(); }
</script>
