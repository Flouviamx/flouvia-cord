---
// Ajustes — ÍNDICE. Lista agrupada de secciones (estilo Stripe, sin tarjetas).
// Cada sección abre su sub-página. La personalización vive dividida por tema.
import AppLayout from '../../../layouts/AppLayout.astro';
import { getOrg } from '../../../lib/queries';
import { SETTINGS_SECTIONS, SETTINGS_GROUPS } from '../../../lib/settings';

const ORG = await getOrg();
---

<AppLayout title="Ajustes — Trato" page="ajustes" heading="Ajustes">
    <div class="idx">
        <header class="idx-head">
            <h2>Ajustes de {ORG.nombre}</h2>
            <p>Configura todo lo que se personaliza en Trato. Cada sección guarda por separado.</p>
        </header>

        {SETTINGS_GROUPS.map((group) => (
            <section class="idx-grp">
                <h3 class="idx-grp-title">{group}</h3>
                <div class="idx-rows">
                    {SETTINGS_SECTIONS.filter((s) => s.group === group).map((s) => (
                        <a href={s.href} class="idx-row">
                            <svg class="idx-row-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
                            <span class="idx-row-body">
                                <span class="idx-row-title">{s.label}</span>
                                <span class="idx-row-desc">{s.desc}</span>
                            </span>
                            <svg class="idx-row-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                        </a>
                    ))}
                </div>
            </section>
        ))}
    </div>
</AppLayout>

<style>
    .idx { max-width: 880px; }
    .idx-head { margin-bottom: 2.4rem; }
    .idx-head h2 { font-size: 1.5rem; font-weight: 700; letter-spacing: -0.5px; margin: 0; }
    .idx-head p { font-size: 0.88rem; color: var(--color-text-muted); margin: 0.4rem 0 0; }

    .idx-grp { margin-bottom: 2.4rem; }
    .idx-grp-title { font-size: 0.66rem; font-weight: 800; letter-spacing: 1.6px; text-transform: uppercase; color: #99a2af; margin: 0 0 0.3rem; }
    .idx-rows { display: flex; flex-direction: column; }

    /* Fila de enlace — sin borde de tarjeta; solo hairline entre filas */
    .idx-row {
        display: flex; align-items: center; gap: 1rem;
        padding: 1.05rem 0.4rem; text-decoration: none; color: inherit;
        border-bottom: 1px solid var(--color-border);
        transition: padding-left 0.25s var(--ease-spring);
    }
    .idx-row:hover { padding-left: 0.9rem; }
    .idx-row-ico { width: 20px; height: 20px; color: var(--color-blue-deep); flex-shrink: 0; }
    .idx-row-body { display: flex; flex-direction: column; gap: 2px; min-width: 0; flex: 1; }
    .idx-row-title { font-size: 0.95rem; font-weight: 600; color: var(--color-text); }
    .idx-row-desc { font-size: 0.8rem; color: var(--color-text-muted); line-height: 1.45; }
    .idx-row-arrow { width: 16px; height: 16px; color: #c4cad3; flex-shrink: 0; opacity: 0; transform: translateX(-4px); transition: opacity 0.25s, transform 0.25s var(--ease-spring); }
    .idx-row:hover .idx-row-arrow { opacity: 1; transform: translateX(0); color: var(--color-blue-deep); }

    @media (max-width: 640px) { .idx-row-desc { display: none; } }
</style>
