---
// Ajustes — HUB. Rejilla de categorías (estilo Stripe). Cada tarjeta abre su
// sub-página. La personalización vive dividida por tema (marca, fiscal, PDF…).
import AppLayout from '../../../layouts/AppLayout.astro';
import { getOrg } from '../../../lib/queries';
import { SETTINGS_SECTIONS } from '../../../lib/settings';

const ORG = await getOrg();
---

<AppLayout title="Ajustes — Trato" page="ajustes" heading="Ajustes">
    <div class="hub">
        <header class="hub-head">
            <div>
                <h2>Ajustes de {ORG.nombre}</h2>
                <p>Configura todo lo que se personaliza en Trato. Cada sección guarda por separado.</p>
            </div>
            <span class="hub-plan">Plan {ORG.plan}</span>
        </header>

        <div class="hub-grid">
            {SETTINGS_SECTIONS.map((s) => (
                <a href={s.href} class="hub-card">
                    <span class="hub-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} /></span>
                    <span class="hub-card-body">
                        <span class="hub-card-title">{s.label}</span>
                        <span class="hub-card-desc">{s.desc}</span>
                    </span>
                    <svg class="hub-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
            ))}
        </div>
    </div>
</AppLayout>

<style>
    .hub { max-width: 980px; }
    .hub-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 1.8rem; }
    .hub-head h2 { font-size: 1.5rem; font-weight: 700; letter-spacing: -0.5px; margin: 0; }
    .hub-head p { font-size: 0.88rem; color: var(--color-text-muted); margin: 0.4rem 0 0; }
    .hub-plan { font-size: 0.72rem; font-weight: 700; color: var(--color-blue-deep); background: var(--color-bg-soft); border: 1px solid var(--color-border); padding: 6px 12px; border-radius: 100px; white-space: nowrap; flex-shrink: 0; }

    .hub-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.9rem; }
    .hub-card {
        display: flex; align-items: flex-start; gap: 0.9rem;
        padding: 1.2rem 1.3rem; border: 1px solid var(--color-border); border-radius: 14px;
        background: #fff; text-decoration: none; color: inherit;
        transition: border-color 0.25s, box-shadow 0.3s var(--ease-spring), transform 0.3s var(--ease-spring);
    }
    .hub-card:hover { border-color: rgba(10,25,47,0.18); box-shadow: 0 16px 34px -22px rgba(10,25,47,0.4); transform: translateY(-2px); }
    .hub-ico {
        width: 40px; height: 40px; border-radius: 11px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        background: var(--color-bg-soft); color: var(--color-blue-deep);
        border: 1px solid var(--color-border);
    }
    .hub-ico svg { width: 19px; height: 19px; }
    .hub-card-body { display: flex; flex-direction: column; gap: 4px; min-width: 0; flex: 1; }
    .hub-card-title { font-size: 0.95rem; font-weight: 700; color: var(--color-text); }
    .hub-card-desc { font-size: 0.78rem; color: var(--color-text-muted); line-height: 1.5; }
    .hub-arrow { width: 16px; height: 16px; color: #c4cad3; flex-shrink: 0; margin-top: 3px; transition: transform 0.3s var(--ease-spring), color 0.25s; }
    .hub-card:hover .hub-arrow { transform: translateX(3px); color: var(--color-blue-deep); }

    @media (max-width: 720px) {
        .hub-grid { grid-template-columns: 1fr; }
        .hub-head { flex-direction: column; }
    }
</style>
