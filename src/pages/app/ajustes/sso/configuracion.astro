---
import SettingsShell from '../../../../components/app/SettingsShell.astro';
import { getMyMembership } from '../../../../lib/queries';
import { memberCan } from '../../../../lib/permissions';

const ME = await getMyMembership();
const canEdit = memberCan(ME, 'ajustes') || memberCan(ME, 'equipo');

if (!canEdit) {
    return Astro.redirect('/app/ajustes/sso');
}
---

<SettingsShell title="Configuración SSO — Ajustes" tab="sso"
    intro="Conecta y verifica tu dominio para habilitar el inicio de sesión mediante SAML.">
    
    <div class="setup-container">
        <!-- Steps Progress -->
        <div class="wizard-progress">
            <div class="step active" id="ind1">1. Funciones</div>
            <div class="step-line"></div>
            <div class="step" id="ind2">2. Dominio</div>
            <div class="step-line"></div>
            <div class="step" id="ind3">3. DNS</div>
        </div>

        <!-- Step 1: Roles -->
        <div class="wizard-step active" id="step1">
            <div class="wizard-header">
                <h2>¿Cómo quieres asignar las funciones?</h2>
                <p>Elige cómo quieres gestionar la asignación de funciones para los miembros de tu equipo.</p>
            </div>
            
            <div class="role-options">
                <!-- Option 1: Dashboard -->
                <label class="role-card">
                    <input type="radio" name="role_assignment" value="dashboard" checked hidden />
                    <div class="rc-inner">
                        <div class="rc-visual">
                            <div class="rc-mockup">
                                <div class="rc-icon" style="background:#fff;border:1px solid #e2e8f0;box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
                                    <img src="/imgs/logo-cord-navy.png" alt="Cord" style="height:14px;" />
                                </div>
                                <div class="rc-mock-title">Dashboard de Cord</div>
                                <div class="rc-users">
                                    <div class="rc-user">
                                        <div class="rc-avatar"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></div>
                                        <div class="rc-user-info">
                                            <span class="rc-name">Carmen Rodríguez</span>
                                            <span class="rc-role-badge">Administrador</span>
                                        </div>
                                    </div>
                                    <div class="rc-user">
                                        <div class="rc-avatar"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></div>
                                        <div class="rc-user-info">
                                            <span class="rc-name">Sam Li</span>
                                            <span class="rc-role-badge">Desarrollador</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="rc-content">
                            <h3>Dashboard de Cord</h3>
                            <p>Asigna y gestiona manualmente las funciones de los miembros del equipo dentro del Dashboard. Invita a nuevos usuarios directamente desde el Dashboard o créalos mediante SCIM.</p>
                        </div>
                    </div>
                </label>

                <!-- Option 2: IdP -->
                <label class="role-card">
                    <input type="radio" name="role_assignment" value="idp" hidden />
                    <div class="rc-inner">
                        <div class="rc-visual">
                            <div class="rc-mockup">
                                <div class="rc-icon" style="background:#f8fafc;color:#64748b;border:1px solid #e2e8f0;">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                                </div>
                                <div class="rc-mock-title">Proveedor de identidad</div>
                                <div class="rc-users">
                                    <div class="rc-user">
                                        <div class="rc-avatar"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></div>
                                        <div class="rc-user-info">
                                            <span class="rc-name">Carmen Rodríguez</span>
                                            <span class="rc-role-badge">Administrador</span>
                                        </div>
                                    </div>
                                    <div class="rc-user">
                                        <div class="rc-avatar"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></div>
                                        <div class="rc-user-info">
                                            <span class="rc-name">Sam Li</span>
                                            <span class="rc-role-badge">Desarrollador</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="rc-content">
                            <h3>Proveedor de identidad</h3>
                            <p>Asigne funciones mediante aserciones SAML en tu proveedor de identidad para la gestión automatizada durante la autenticación.</p>
                        </div>
                    </div>
                </label>
            </div>

            <div class="wizard-footer space-between">
                <span class="wizard-help">¿No tienes claro cuál es la adecuada para ti? <a href="#">Consulta la documentación</a></span>
                <button class="btn-primary" onclick="nextStep(2)">Continuar</button>
            </div>
        </div>

        <!-- Step 2: Domain -->
        <div class="wizard-step hidden" id="step2">
            <div class="wizard-header">
                <h2>Verificar tu dominio</h2>
                <p>Añade el dominio que tus empleados usan para iniciar sesión. Esto nos permite dirigir a tus usuarios a tu proveedor de identidad correctamente.</p>
            </div>
            
            <div class="domain-input-group">
                <label>Dominio de la empresa</label>
                <div class="input-with-prefix">
                    <span class="prefix">@</span>
                    <input type="text" id="domainInput" placeholder="flouvia.com" />
                </div>
                <p class="input-hint">Introduce el dominio principal (por ejemplo, flouvia.com). No incluyas subdominios a menos que quieras restringir el acceso a ese subdominio específico.</p>
            </div>

            <div class="wizard-footer">
                <button class="btn-secondary" onclick="nextStep(1)">Atrás</button>
                <button class="btn-primary" onclick="processDomain()">Añadir dominio</button>
            </div>
        </div>

        <!-- Step 3: DNS -->
        <div class="wizard-step hidden" id="step3">
            <div class="wizard-header">
                <h2>Añadir registro DNS</h2>
                <p>Consulta con tu proveedor de DNS y añade un registro con los datos siguientes. Puede que este tarde hasta 24 horas en completar la verificación del dominio.</p>
                <a href="#" class="link-learn-more">Más información sobre los dominios &rarr;</a>
            </div>
            
            <div class="dns-info-box">
                <div class="dns-row">
                    <span class="dns-label">Dominio</span>
                    <span class="dns-value" id="displayDomain">flouvia.com</span>
                </div>
                <div class="dns-row">
                    <span class="dns-label">Nombre</span>
                    <span class="dns-value">@</span>
                </div>
                <div class="dns-row">
                    <span class="dns-label">Registro</span>
                    <span class="dns-value">TXT</span>
                </div>
                <div class="dns-row">
                    <span class="dns-label">Código DNS</span>
                    <div class="dns-code-wrap">
                        <code id="dnsCode">flouvia-verification=16395766C13E31743BDF893AC3AB5E0C381D6FA45CEA5F7AD37847CE12DDAEE4</code>
                        <button class="btn-copy" onclick="copyDns()">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                        </button>
                    </div>
                </div>
            </div>

            <div class="wizard-footer space-between">
                <button class="btn-secondary" onclick="nextStep(2)">Atrás</button>
                <button class="btn-primary" onclick="finishSetup()">Verificar conexión</button>
            </div>
        </div>
    </div>

</SettingsShell>

<style>
    /* Wizard Shared Styles */
    .setup-container {
        background: #fff;
        border-radius: 16px;
        border: 1px solid var(--color-border);
        box-shadow: 0 4px 24px rgba(0,0,0,0.02);
        overflow: hidden;
        margin-top: 1.5rem;
    }

    .wizard-progress {
        display: flex;
        align-items: center;
        padding: 1.5rem 2rem;
        background: #f8fafc;
        border-bottom: 1px solid var(--color-border);
        gap: 1rem;
    }

    .wizard-progress .step {
        font-size: 0.85rem;
        font-weight: 600;
        color: #94a3b8;
        transition: color 0.3s;
    }
    .wizard-progress .step.active {
        color: var(--color-blue-deep);
    }
    .wizard-progress .step.completed {
        color: #10b981;
    }
    .wizard-progress .step-line {
        height: 2px;
        flex: 1;
        background: #e2e8f0;
        border-radius: 2px;
    }

    .wizard-step {
        padding: 2.5rem;
        animation: fadeIn 0.3s ease-out forwards;
    }
    .wizard-step.hidden {
        display: none;
    }
    
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .wizard-header {
        margin-bottom: 2.5rem;
    }
    .wizard-header h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--color-text);
        margin: 0 0 0.5rem 0;
        letter-spacing: -0.02em;
    }
    .wizard-header p {
        font-size: 0.95rem;
        color: var(--color-text-muted);
        margin: 0;
        max-width: 600px;
        line-height: 1.5;
    }
    .link-learn-more {
        display: inline-block;
        margin-top: 0.5rem;
        font-size: 0.9rem;
        color: var(--color-blue-deep, #0a192f);
        text-decoration: none;
        font-weight: 500;
    }
    .link-learn-more:hover { text-decoration: underline; }

    /* Step 1: Role Options */
    .role-options {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-bottom: 2rem;
    }
    @media (max-width: 768px) {
        .role-options { grid-template-columns: 1fr; }
    }

    .role-card {
        cursor: pointer;
        display: block;
    }
    .rc-inner {
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        overflow: hidden;
        transition: all 0.2s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
    }
    .role-card input:checked + .rc-inner {
        border-color: #0a192f;
        box-shadow: 0 0 0 4px rgba(10, 25, 47, 0.1);
    }
    .role-card input:checked + .rc-inner .rc-content h3 {
        color: #0a192f;
    }

    .rc-visual {
        background: #f8fafc;
        padding: 2rem;
        display: flex;
        justify-content: center;
        border-bottom: 1px solid #e2e8f0;
    }
    
    .rc-mockup {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.06), 0 0 0 1px rgba(0,0,0,0.02);
        padding: 1.5rem;
        width: 100%;
        max-width: 260px;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        position: relative;
    }
    
    .rc-icon {
        width: 36px; height: 36px;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
    }
    .rc-icon svg { width: 20px; height: 20px; }
    
    .rc-mock-title {
        font-size: 0.95rem; font-weight: 600; color: #1e293b;
        position: absolute; top: 1.5rem; left: 4.5rem;
    }

    .rc-users {
        display: flex; flex-direction: column; gap: 0.75rem;
        border-left: 1px solid #e2e8f0;
        margin-left: 18px;
        padding-left: 1.5rem;
        position: relative;
    }
    .rc-users::before {
        content: ''; position: absolute; top: -10px; left: -1px; height: 10px; width: 1px; background: #e2e8f0;
    }

    .rc-user {
        display: flex; align-items: center; gap: 0.75rem;
        position: relative;
    }
    .rc-user::before {
        content: ''; position: absolute; left: -1.5rem; top: 50%; width: 1.5rem; height: 1px; background: #e2e8f0;
    }

    .rc-avatar {
        width: 24px; height: 24px; border-radius: 50%;
        background: #f1f5f9; color: #94a3b8;
        display: flex; align-items: center; justify-content: center;
    }
    .rc-avatar svg { width: 14px; height: 14px; }
    
    .rc-user-info { display: flex; flex-direction: column; gap: 2px; }
    .rc-name { font-size: 0.75rem; font-weight: 600; color: #334155; }
    .rc-role-badge { 
        font-size: 0.65rem; color: #64748b; background: #f1f5f9; 
        padding: 2px 6px; border-radius: 4px; display: inline-block; width: fit-content;
    }

    .rc-content {
        padding: 1.5rem;
        background: #fff;
        flex: 1;
    }
    .rc-content h3 {
        margin: 0 0 0.5rem 0;
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--color-text);
        transition: color 0.2s;
    }
    .rc-content p {
        margin: 0;
        font-size: 0.85rem;
        color: var(--color-text-muted);
        line-height: 1.5;
    }

    /* Step 2: Domain */
    .domain-input-group {
        max-width: 480px;
        margin-bottom: 2rem;
    }
    .domain-input-group label {
        display: block;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--color-text);
        margin-bottom: 0.5rem;
    }
    .input-with-prefix {
        display: flex;
        align-items: center;
        border: 1px solid var(--color-border);
        border-radius: 8px;
        overflow: hidden;
        background: #fff;
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    .input-with-prefix:focus-within {
        border-color: #0a192f;
        box-shadow: 0 0 0 3px rgba(10, 25, 47, 0.1);
    }
    .input-with-prefix .prefix {
        padding: 0.75rem 1rem;
        background: #f8fafc;
        color: #64748b;
        font-size: 0.95rem;
        border-right: 1px solid var(--color-border);
        font-weight: 500;
    }
    .input-with-prefix input {
        flex: 1;
        padding: 0.75rem 1rem;
        border: none;
        outline: none;
        font-size: 0.95rem;
        color: var(--color-text);
        font-family: var(--font-sans);
    }
    .input-hint {
        margin: 0.5rem 0 0 0;
        font-size: 0.85rem;
        color: var(--color-text-muted);
    }

    /* Step 3: DNS Box */
    .dns-info-box {
        background: #fff;
        border: 1px solid var(--color-border);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 2rem;
    }
    .dns-row {
        display: grid;
        grid-template-columns: 140px 1fr;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--color-border);
        align-items: center;
    }
    .dns-row:last-child { border-bottom: none; }
    .dns-label {
        font-size: 0.9rem;
        font-weight: 500;
        color: #64748b;
    }
    .dns-value {
        font-size: 0.95rem;
        color: var(--color-text);
        font-weight: 500;
    }
    .dns-code-wrap {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: #f8fafc;
        padding: 0.5rem 0.75rem;
        border-radius: 6px;
        border: 1px solid #e2e8f0;
    }
    .dns-code-wrap code {
        font-family: var(--font-mono);
        font-size: 0.85rem;
        color: #334155;
        word-break: break-all;
    }
    .btn-copy {
        background: #fff;
        border: 1px solid #cbd5e1;
        border-radius: 4px;
        padding: 4px;
        cursor: pointer;
        color: #64748b;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.2s;
    }
    .btn-copy:hover {
        background: #f1f5f9; color: #334155; border-color: #94a3b8;
    }
    .btn-copy svg { width: 16px; height: 16px; }

    /* Footer & Buttons */
    .wizard-footer {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 1rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--color-border);
    }
    .wizard-footer.space-between {
        justify-content: space-between;
    }
    
    .wizard-help {
        font-size: 0.85rem;
        color: var(--color-text-muted);
    }
    .wizard-help a {
        color: var(--color-blue-deep, #0a192f); text-decoration: none; font-weight: 500;
    }
    .wizard-help a:hover { text-decoration: underline; }

    .btn-primary {
        display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
        background: linear-gradient(135deg, #0a192f 0%, #112240 100%); color: white;
        padding: 0.75rem 1.5rem; border-radius: 8px; font-weight: 500; font-size: 0.95rem;
        border: none; cursor: pointer; box-shadow: 0 4px 12px rgba(10, 25, 47, 0.15);
        transition: all 0.2s ease;
    }
    .btn-primary:hover {
        transform: translateY(-1px); box-shadow: 0 6px 16px rgba(10, 25, 47, 0.25);
    }
    
    .btn-secondary {
        display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
        background: #fff; color: #334155;
        padding: 0.75rem 1.5rem; border-radius: 8px; font-weight: 500; font-size: 0.95rem;
        border: 1px solid #cbd5e1; cursor: pointer;
        transition: all 0.2s;
    }
    .btn-secondary:hover {
        background: #f8fafc; border-color: #94a3b8; color: #0f172a;
    }
</style>

<script>
    function nextStep(step: number) {
        // Hide all steps
        document.querySelectorAll('.wizard-step').forEach(el => el.classList.add('hidden'));
        
        // Show target step
        const target = document.getElementById(`step${step}`);
        if (target) target.classList.remove('hidden');

        // Update indicators
        document.querySelectorAll('.wizard-progress .step').forEach((el, index) => {
            if (index + 1 < step) {
                el.className = 'step completed';
            } else if (index + 1 === step) {
                el.className = 'step active';
            } else {
                el.className = 'step';
            }
        });
    }

    function processDomain() {
        const input = document.getElementById('domainInput') as HTMLInputElement;
        let domain = input.value.trim();
        if (!domain) {
            (window as any).cordToast?.('Por favor, ingresa un dominio', 'error');
            return;
        }
        
        // Strip http/https if pasted
        domain = domain.replace(/^https?:\/\//, '').replace(/\/$/, '');
        
        // Basic validation
        if (!domain.includes('.')) {
            (window as any).cordToast?.('Ingresa un dominio válido (ej. empresa.com)', 'error');
            return;
        }

        // Set display domain
        document.getElementById('displayDomain')!.textContent = domain;
        
        // Generate a random looking verification code
        const code = 'flouvia-verification=' + Array.from({length: 64}, () => Math.floor(Math.random()*16).toString(16).toUpperCase()).join('');
        document.getElementById('dnsCode')!.textContent = code;

        nextStep(3);
    }

    function copyDns() {
        const code = document.getElementById('dnsCode')?.textContent;
        if (code) {
            navigator.clipboard.writeText(code);
            (window as any).cordToast?.('Código DNS copiado al portapapeles', 'ok');
        }
    }

    function finishSetup() {
        (window as any).cordToast?.('Verificando conexión DNS...', 'ok');
        setTimeout(() => {
            (window as any).cordToast?.('La verificación DNS puede tardar hasta 24 horas. Te notificaremos cuando esté lista.', 'ok');
            setTimeout(() => {
                window.location.href = '/app/ajustes/sso';
            }, 2000);
        }, 1500);
    }

    // Attach to window for inline handlers
    (window as any).nextStep = nextStep;
    (window as any).processDomain = processDomain;
    (window as any).copyDns = copyDns;
    (window as any).finishSetup = finishSetup;
</script>
