---
import SettingsShell from '../../../components/app/SettingsShell.astro';
import { getMyMembership, getOrg } from '../../../lib/queries';
import { memberCan } from '../../../lib/permissions';

const ME = await getMyMembership();
const org = await getOrg();
// Permiso requerido para configurar SSO: 'ajustes' o 'equipo'
const canEdit = memberCan(ME, 'ajustes') || memberCan(ME, 'equipo');
const isManaged = !canEdit;
---

<SettingsShell title="SSO — Ajustes" tab="sso"
    intro="Conecta tu proveedor de identidad a Cord para que tu equipo pueda iniciar sesión con SSO de forma segura mediante SAML.">

    <div class="sso-hero">
        <div class="sso-text">
            <div class="sso-badge-wrap">
                <span class="sso-badge">Enterprise Security</span>
            </div>
            <h2>Configura el inicio de sesión único</h2>
            <p>El Inicio de sesión único (SSO) permite a tus empleados acceder a Cord usando las credenciales de tu empresa (Google Workspace, Microsoft Entra, Okta, etc.), mejorando la seguridad y centralizando el acceso.</p>
            
            {isManaged ? (
                <>
                    <div class="managed-notice">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                        <span>Gestionado por <strong>{org.nombre}</strong></span>
                    </div>
                    <div class="sso-actions">
                        <button class="btn-primary disabled" disabled>Empezar configuración</button>
                    </div>
                    <p class="sso-hint">Contacta a los administradores de tu organización para modificar la configuración de SSO.</p>
                </>
            ) : (
                <div class="sso-actions">
                    <a href="/app/ajustes/sso/configuracion" class="btn-primary" style="text-decoration: none;">Empezar configuración</a>
                    <a href="/soporte/configuracion-sso" target="_blank" class="btn-secondary" style="text-decoration: none;">Documentación</a>
                </div>
            )}
        </div>
        
        <div class="sso-graphic-wrap">
            <div class="sso-graphic">
                
                <!-- Proveedor de Identidad -->
                <div class="sso-box">
                    <div class="sso-box-header">
                        <div class="sso-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        </div>
                        <span>Proveedor de identidad</span>
                    </div>
                    <div class="sso-users-row">
                        <div class="sso-branch"></div>
                        <div class="sso-user"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></div>
                        <div class="sso-user"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></div>
                        <div class="sso-user"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></div>
                        <div class="sso-user"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></div>
                        <div class="sso-user"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></div>
                    </div>
                </div>
                
                <div class="sso-arrow">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
                </div>
                
                <!-- Cord -->
                <div class="sso-box">
                    <div class="sso-box-header">
                        <div class="sso-icon cord-blue" style="background:#4f46e5;">
                            <svg viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg" style="width:22px; height:22px;"><path d="M4 12l8-8 8 8-8 8-8-8z" fill="white"/></svg>
                        </div>
                        <span>Cord</span>
                    </div>
                    <div class="sso-users-row">
                        <div class="sso-branch"></div>
                        <div class="sso-user"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></div>
                        <div class="sso-user"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></div>
                        <div class="sso-user"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></div>
                        <div class="sso-user"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></div>
                        <div class="sso-user"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></div>
                    </div>
                </div>
                
            </div>
        </div>
    </div>
</SettingsShell>

<style>
    /* SSO Hero Section */
    .sso-hero { display: grid; grid-template-columns: 1fr 1.2fr; gap: 4rem; align-items: center; margin-top: 1rem; }
    @media (max-width: 900px) { .sso-hero { grid-template-columns: 1fr; gap: 2rem; } }
    
    .sso-badge-wrap { margin-bottom: 1.25rem; }
    .sso-badge {
        display: inline-block; padding: 0.35rem 0.85rem;
        background: rgba(14, 165, 233, 0.1); color: #0ea5e9;
        border: 1px solid rgba(14, 165, 233, 0.2); border-radius: 100px;
        font-size: 0.75rem; font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase;
    }
    
    .sso-text h2 { font-size: 1.85rem; font-weight: 700; color: var(--color-text); margin: 0 0 1rem 0; letter-spacing: -0.6px; line-height: 1.2; }
    .sso-text p { font-size: 0.95rem; color: var(--color-text-muted); margin: 0 0 2rem 0; line-height: 1.55; }
    
    .managed-notice {
        display: inline-flex; align-items: center; gap: 0.75rem;
        background: rgba(245, 158, 11, 0.1); border: 1px solid rgba(245, 158, 11, 0.2); color: #d97706;
        padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.9rem; margin-bottom: 1.25rem;
    }
    .managed-notice svg { width: 18px; height: 18px; flex-shrink: 0; }
    .managed-notice strong { font-weight: 600; color: #b45309; }
    
    .sso-actions { display: flex; gap: 1rem; align-items: center; }
    .sso-hint { margin: 1rem 0 0 0; font-size: 0.85rem; color: var(--color-text-muted); }
    
    .btn-primary {
        display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
        background: linear-gradient(135deg, #0a192f 0%, #112240 100%); color: white;
        padding: 0.75rem 1.5rem; border-radius: 8px; font-weight: 500; font-size: 0.95rem;
        border: none; cursor: pointer; box-shadow: 0 4px 12px rgba(10, 25, 47, 0.15);
    }
    .btn-primary.disabled {
        background: #e2e8f0; color: #94a3b8; box-shadow: none; cursor: not-allowed;
    }
    
    .btn-secondary {
        display: inline-flex; align-items: center; justify-content: center;
        background: transparent; color: var(--color-text);
        padding: 0.75rem 1.5rem; border-radius: 8px; font-weight: 500; font-size: 0.95rem;
        border: 1px solid var(--color-border);
    }
    
    .sso-graphic-wrap { 
        background: linear-gradient(135deg, #e0f2fe 0%, #e9d5ff 100%); 
        border-radius: 20px; padding: 3.5rem 2rem; display: flex; justify-content: center; 
        position: relative; overflow: hidden; 
    }
    
    .sso-graphic { display: flex; flex-direction: column; gap: 1.25rem; width: 100%; max-width: 400px; align-items: center; z-index: 2; }
    
    .sso-box { 
        background: #fff;
        width: 100%; border-radius: 16px; padding: 1.5rem 1.75rem; 
        display: flex; flex-direction: column; gap: 1.25rem; 
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
    }
    .sso-box-header { display: flex; align-items: center; gap: 14px; font-weight: 700; font-size: 1.15rem; color: #1e293b; letter-spacing: -0.3px; justify-content: flex-start; }
    
    .sso-icon { width: 44px; height: 44px; border-radius: 12px; border: 1.5px solid #e2e8f0; display: flex; align-items: center; justify-content: center; color: #475569; background: #ffffff; }
    .sso-icon svg { width: 22px; height: 22px; }
    .sso-icon.cord-blue { border-color: transparent; }
    
    .sso-arrow { color: #475569; margin: 0; }
    .sso-arrow svg { width: 28px; height: 28px; }

    .sso-users-row {
        display: flex; align-items: center; gap: 10px; position: relative; margin-top: 0;
        padding-left: 21px; /* Center of the 44px icon is 22px */
    }
    
    .sso-branch {
        position: absolute;
        left: 21px; /* Align with center of icon above */
        top: -24px; /* Go up to connect with the header */
        bottom: 50%;
        width: 16px;
        border-left: 1.5px solid #cbd5e1;
        border-bottom: 1.5px solid #cbd5e1;
        border-bottom-left-radius: 8px;
    }

    .sso-user {
        width: 44px; height: 44px; border-radius: 10px; border: 1.5px solid #e2e8f0;
        display: flex; align-items: center; justify-content: center;
        background: #fff; color: #475569; position: relative; z-index: 2;
    }
    .sso-user svg { width: 20px; height: 20px; }
</style>
