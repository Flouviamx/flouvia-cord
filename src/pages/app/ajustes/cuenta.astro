---
// Ajustes › Tu cuenta — perfil, sesiones, seguridad (2FA, passkeys), cuentas
// conectadas. Montamos una UI 100% custom en React (CustomUserProfile).
import SettingsShell from '../../../components/app/SettingsShell.astro';
import CustomUserProfile from '../../../components/app/CustomUserProfile.tsx';
---

