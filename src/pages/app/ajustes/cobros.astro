---
import SettingsShell from '../../../components/app/SettingsShell.astro';
import ConnectCustomOnboarding from '../../../components/app/ConnectCustomOnboarding';
import { getOrg } from '../../../lib/queries';
const ORG = await getOrg();

// Estado de la cuenta de cobros
const conectado = !!ORG.stripeAccountId;
const activo = conectado && ORG.stripeChargesEnabled;
const estado = !conectado ? 'nuevo' : activo ? 'activo' : 'pendiente';
const puedeCobrar = activo; // habilita tarjeta / SPEI (transferencia manual no depende de Stripe)
const marca = ORG.colorMarca || '#0a192f';

// Stepper macro derivado del estado REAL (los únicos datos ciertos que tenemos de
// Stripe son: si existe la cuenta y si ya puede cobrar). El detalle granular del
// KYC lo muestra el propio componente embebido de Stripe abajo.
const pasos = [
    { label: 'Conecta tu cuenta',      done: estado !== 'nuevo',  active: estado === 'nuevo' },
    { label: 'Verificación de Stripe', done: estado === 'activo', active: estado === 'pendiente' },
    { label: 'Listo para cobrar',      done: estado === 'activo', active: false },
];
---

<SettingsShell title="Cobros — Ajustes" tab="cobros" perm="ajustes"
    intro="Recibe pagos de tus cotizaciones en línea. El dinero cae directo a tu cuenta — Cord no toca ni retiene tus fondos." save>

    {estado === 'nuevo' ? (
        <>
        <div style="margin-bottom: 2.5rem; padding-bottom: 2rem; border-bottom: 1px solid var(--color-border);">
            <span style="font-size: 0.65rem; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; color: var(--color-text-muted);">COBROS EN LÍNEA</span>
            <h2 class="editorial" style="font-size: 1.8rem; margin: 0.5rem 0 1rem; color: var(--color-text);">Deja que tus clientes te paguen con un clic</h2>
            <p style="font-size: 0.95rem; color: var(--color-text-muted); line-height: 1.6; max-width: 60ch; margin: 0 0 1.5rem;">Conecta tu cuenta en un par de minutos y empieza a cobrar tus cotizaciones con tarjeta o transferencia. Sin mensualidades extra, sin comisiones de Cord.</p>
            
            <div style="display: flex; flex-direction: column;">
                <div style="display: flex; align-items: center; gap: 12px; padding: 14px 0; border-bottom: 1px solid var(--color-border);">
                    <svg style="width: 20px; height: 20px; color: var(--color-blue-deep);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                    <div style="display: flex; flex-direction: column; gap: 2px;">
                        <strong style="font-size: 0.85rem; font-weight: 600; color: var(--color-text);">Directo a tu cuenta</strong>
                        <span style="font-size: 0.75rem; color: var(--color-text-muted);">Cord nunca toca tus fondos.</span>
                    </div>
                </div>
                <div style="display: flex; align-items: center; gap: 12px; padding: 14px 0; border-bottom: 1px solid var(--color-border);">
                    <svg style="width: 20px; height: 20px; color: var(--color-blue-deep);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m8 12 3 3 5-6"/></svg>
                    <div style="display: flex; flex-direction: column; gap: 2px;">
                        <strong style="font-size: 0.85rem; font-weight: 600; color: var(--color-text);">0% comisión de Cord</strong>
                        <span style="font-size: 0.75rem; color: var(--color-text-muted);">Solo pagas las tarifas de Stripe.</span>
                    </div>
                </div>
                <div style="display: flex; align-items: center; gap: 12px; padding: 14px 0;">
                    <svg style="width: 20px; height: 20px; color: var(--color-blue-deep);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2.5"/><path d="M2 10h20"/></svg>
                    <div style="display: flex; flex-direction: column; gap: 2px;">
                        <strong style="font-size: 0.85rem; font-weight: 600; color: var(--color-text);">Tarjeta y SPEI</strong>
                        <span style="font-size: 0.75rem; color: var(--color-text-muted);">Con conciliación automática.</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="c-stepper">
            {pasos.map((p, i) => (
                <span class={`cs-step ${p.done ? 'is-complete' : ''} ${p.active ? 'is-active' : ''}`}>{i + 1}. {p.label}</span>
            ))}
        </div>
        <div class="connect-frame">
            <ConnectCustomOnboarding client:only="react" org={ORG} />
        </div>
        </>
    ) : (
        <>
        <div style="margin-bottom: 3rem;">
            <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1rem; color: var(--color-text);">Estado de tu cuenta</h3>
            <div>
                {estado === 'activo' ? (
                    <div class="cobros-status cobros-status--activo">
                        <span class="cs-dot"></span>
                        <div class="cs-text">
                            <strong>¡Todo listo, ya puedes cobrar!</strong>
                            <span>Tu cuenta está verificada y activa. El dinero de tus cobros se enviará automáticamente a tu banco.</span>
                        </div>
                        <button type="button" class="cs-disconnect" id="btnDisconnect">Desconectar</button>
                    </div>
                ) : (
                    <>
                        <div class="cobros-status cobros-status--pendiente">
                            <span class="cs-dot"></span>
                            <div class="cs-text">
                                <strong>Verificación pendiente</strong>
                                <span>Stripe necesita algunos datos más para habilitar tus cobros. Complétalos en el formulario de abajo.</span>
                            </div>
                            <button type="button" class="cs-disconnect" id="btnDisconnect">Desconectar</button>
                        </div>
                        <div class="c-stepper">
                            {pasos.map((p, i) => (
                                <span class={`cs-step ${p.done ? 'is-complete' : ''} ${p.active ? 'is-active' : ''}`}>{i + 1}. {p.label}</span>
                            ))}
                        </div>
                    </>
                )}
                <div class={`connect-frame ${estado === 'activo' ? 'is-active' : ''}`}>
                    <ConnectCustomOnboarding client:only="react" org={ORG} />
                </div>
            </div>
        </div>
        </>
    )}

    <div style="margin-bottom: 2rem;">
        <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1rem; color: var(--color-text);">Métodos de pago</h3>
        <div>
            <div class={`pay-methods ${!puedeCobrar ? 'has-locked' : ''}`}>
                {!puedeCobrar && (
                    <p class="methods-locked">Activa y verifica tu cuenta arriba para habilitar tarjeta y SPEI. La transferencia manual funciona sin Stripe.</p>
                )}

                <!-- Tarjeta -->
                <div class={`pay-method ${!puedeCobrar ? 'is-locked' : ''}`}>
                    <div class="pm-ico">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2.5" fill="currentColor" fill-opacity="0.12"/><path d="M2 10h20"/></svg>
                    </div>
                    <div class="pm-text">
                        <strong>Tarjeta de crédito y débito</strong>
                        <span>Visa, Mastercard y Amex. Se procesa al instante vía Stripe.</span>
                    </div>
                    <label class="s-toggle pm-toggle">
                        <input type="checkbox" data-field="acepta_tarjeta" data-pv="tarjeta" checked={puedeCobrar && ORG.aceptaTarjeta} disabled={!puedeCobrar} />
                        <span class="s-toggle-track"><span class="s-toggle-thumb"></span></span>
                    </label>
                </div>

                <!-- SPEI automático -->
                <div class={`pay-method ${!puedeCobrar ? 'is-locked' : ''}`}>
                    <div class="pm-ico">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M5 21V10l7-5 7 5v11" fill="currentColor" fill-opacity="0.12"/><path d="M9 21v-6h6v6"/></svg>
                    </div>
                    <div class="pm-text">
                        <strong>Transferencia SPEI automática</strong>
                        <span>Stripe genera una CLABE única por cotización y la marca pagada sola.</span>
                    </div>
                    <label class="s-toggle pm-toggle">
                        <input type="checkbox" data-field="cobro_spei_auto" data-pv="spei" checked={puedeCobrar && ORG.cobroSpeiAuto} disabled={!puedeCobrar} />
                        <span class="s-toggle-track"><span class="s-toggle-thumb"></span></span>
                    </label>
                </div>

                <!-- Transferencia manual -->
                <div class="pay-method pay-method--stack">
                    <div class="pm-head">
                        <div class="pm-ico">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="12" rx="2" fill="currentColor" fill-opacity="0.12"/><path d="M3 8l9-5 9 5"/><path d="M7 20v-6M12 20v-6M17 20v-6"/></svg>
                        </div>
                        <div class="pm-text">
                            <strong>Transferencia bancaria manual</strong>
                            <span>Muestra tu CLABE en el link público. Tú confirmas el cobro al recibirlo.</span>
                        </div>
                        <label class="s-toggle pm-toggle">
                            <input type="checkbox" data-field="acepta_transferencia" data-pv="transferencia" checked={ORG.aceptaTransferencia} />
                            <span class="s-toggle-track"><span class="s-toggle-thumb"></span></span>
                        </label>
                    </div>
                    <div class="pm-bank">
                        <div class="s-row">
                            <div class="s-field">
                                <label for="oBanco">Banco</label>
                                <input class="s-input" id="oBanco" data-field="banco_nombre" value={ORG.bancoNombre} placeholder="Ej. BBVA" />
                            </div>
                            <div class="s-field">
                                <label for="oClabe">CLABE interbancaria</label>
                                <input class="s-input" id="oClabe" data-field="banco_clabe" value={ORG.bancoClabe} placeholder="18 dígitos" maxlength="18" inputmode="numeric" />
                            </div>
                        </div>
                        <div class="s-field">
                            <label for="oBen">Nombre del beneficiario</label>
                            <input class="s-input" id="oBen" data-field="banco_beneficiario" value={ORG.bancoBeneficiario} placeholder="Razón social o nombre" />
                        </div>
                    </div>
                </div>
            </div>

            </div>
        </div>
    </div>

    <p class="cobros-foot">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Procesado de forma segura por Stripe. Cord nunca almacena datos de tarjetas ni retiene tus fondos.
    </p>
</SettingsShell>

<style>
    /* ── Estado (conectado) ── */
    .cobros-status {
        display: flex; align-items: center; gap: 14px;
        padding: 0 0 16px 0; border-radius: 0;
        border: none; border-bottom: 1px solid var(--color-border); background: transparent;
    }
    .cobros-status .cs-dot { flex-shrink: 0; width: 10px; height: 10px; border-radius: 50%; }
    .cobros-status--activo   .cs-dot { background: var(--color-ok); box-shadow: 0 0 0 4px rgba(16,185,129,0.14); }
    .cobros-status--pendiente .cs-dot { background: var(--color-warn); box-shadow: 0 0 0 4px rgba(245,158,11,0.14); }
    .cobros-status .cs-text { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
    .cobros-status .cs-text strong { font-size: 0.92rem; font-weight: 600; letter-spacing: -0.01em; color: var(--color-text); }
    .cobros-status .cs-text span { font-size: 0.78rem; color: var(--color-text-muted); line-height: 1.45; }
    .cobros-status .cs-disconnect {
        flex-shrink: 0; margin-left: auto; align-self: flex-start;
        font-size: 0.76rem; font-weight: 600; color: var(--color-danger);
        background: transparent; border: 1px solid rgba(239,68,68,0.25); border-radius: 999px;
        padding: 7px 14px; cursor: pointer; transition: background 0.2s ease;
    }
    .cobros-status .cs-disconnect:hover { background: rgba(239,68,68,0.06); }

    /* ── Stepper ── */
    .c-stepper { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 18px; }
    .cs-step {
        font-size: 0.75rem; font-weight: 500; color: var(--color-text-muted);
        display: flex; align-items: center; gap: 6px;
    }
    .cs-step:not(:last-child)::after { content: "›"; color: var(--color-border); font-size: 1rem; line-height: 1; margin-left: 6px; }
    .cs-step.is-active {
        color: var(--color-blue-deep); font-weight: 600;
    }
    .cs-step.is-complete {
        color: var(--color-ok);
    }

    /* ── Marco del componente embebido de Stripe ── */
    .connect-frame {
        padding: 1.5rem 0 0; background: transparent;
        box-shadow: none;
        margin-top: 10px;
    }
    .connect-frame.is-active { margin-top: 24px; padding-top: 0; }

    /* ── Métodos ── */
    .methods-locked {
        font-size: 0.78rem; color: var(--color-text-muted);
        margin: 0 0 0.4rem; padding: 10px 0; border-bottom: 1px solid var(--color-border);
    }
    .pay-methods { gap: 0 !important; display: flex; flex-direction: column; }
    .pay-method {
        display: flex; align-items: center; gap: 14px;
        padding: 16px 4px; border-bottom: 1px solid var(--color-border);
    }
    .pay-method:last-child { border-bottom: none; }
    .pay-method.is-locked { opacity: 0.5; }
    .pay-method--stack { flex-direction: column; align-items: stretch; gap: 0; }
    .pay-method--stack .pm-head { display: flex; align-items: center; gap: 14px; }
    .pm-ico {
        flex-shrink: 0; width: 38px; height: 38px; border-radius: 11px;
        display: grid; place-items: center;
        background: rgba(10,25,47,0.06); color: var(--color-blue-deep);
    }
    .pm-text { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
    .pm-text strong { font-size: 0.88rem; font-weight: 600; letter-spacing: -0.01em; color: var(--color-text); }
    .pm-text span { font-size: 0.76rem; color: var(--color-text-muted); line-height: 1.4; }
    .pm-toggle { margin-left: auto; }
    .pm-bank {
        display: flex; flex-direction: column; gap: 1rem;
        margin: 14px 0 4px 52px; padding-top: 14px; border-top: 1px solid var(--color-border);
    }
    @media (max-width: 640px) { .pm-bank { margin-left: 0; } }

    /* ── Pie ── */
    .cobros-foot { display: flex; align-items: center; gap: 8px; font-size: 0.72rem; color: var(--color-text-muted); margin: 1.4rem 0 0; }
    .cobros-foot svg { flex-shrink: 0; opacity: 0.7; }
</style>

<!-- CSS del wizard Custom: GLOBAL porque el island React (client:only) NO lleva el
     data-astro-cid, así que las reglas scopeadas (incl. las .s-* de SettingsShell) no
     le aplican. Se scopea bajo .connect-custom-onboarding para no pisar nada global. -->
<style is:global>
    .connect-custom-onboarding { display: flex; flex-direction: column; }
    .connect-custom-onboarding .co-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 0.9rem; }
    .connect-custom-onboarding .co-header-text { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
    .connect-custom-onboarding .co-header h3 { font-size: 1.05rem; font-weight: 600; letter-spacing: -0.02em; color: var(--color-text); margin: 0; }
    .connect-custom-onboarding .co-step-count { font-size: 0.72rem; font-weight: 500; color: var(--color-text-muted); }
    .connect-custom-onboarding .co-account-id { flex-shrink: 0; font-size: 0.66rem; color: var(--color-text-muted); font-family: ui-monospace, monospace; background: var(--color-bg-soft); padding: 3px 8px; border-radius: 6px; }
    .connect-custom-onboarding .co-error { font-size: 0.8rem; color: var(--color-danger); background: rgba(239,68,68,0.06); border: 1px solid rgba(239,68,68,0.2); border-radius: 10px; padding: 10px 14px; margin-bottom: 1rem; }

    /* Barra de progreso (hairline, estilo Apple) */
    .connect-custom-onboarding .co-progress { height: 3px; border-radius: 999px; background: rgba(10,25,47,0.07); overflow: hidden; margin-bottom: 1.5rem; }
    .connect-custom-onboarding .co-progress-fill { display: block; height: 100%; border-radius: 999px; background: var(--color-blue-deep); transition: width 0.55s cubic-bezier(0.16, 1, 0.3, 1); }

    .connect-custom-onboarding .co-step-content { min-height: 180px; }
    .connect-custom-onboarding .co-step { display: flex; flex-direction: column; gap: 1rem; animation: co-step-in 0.4s cubic-bezier(0.16, 1, 0.3, 1) both; }
    @keyframes co-step-in { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
    @media (prefers-reduced-motion: reduce) { .connect-custom-onboarding .co-step { animation: none; } }
    .connect-custom-onboarding .co-sub { font-size: 0.82rem; color: var(--color-text-muted); line-height: 1.5; margin: -0.4rem 0 0.2rem; }
    .connect-custom-onboarding .co-sub-strong { font-weight: 600; color: var(--color-text); margin-top: 0; }
    .connect-custom-onboarding .co-divider { border-top: 1px solid var(--color-border); margin: 0.4rem 0 0; }

    /* Spinner */
    .co-spinner { width: 15px; height: 15px; border-radius: 50%; border: 2px solid rgba(10,25,47,0.15); border-top-color: var(--color-blue-deep); animation: co-spin 0.7s linear infinite; flex-shrink: 0; display: inline-block; }
    .co-spinner-btn { width: 12px; height: 12px; border-color: rgba(255,255,255,0.3); border-top-color: #fff; margin-right: 7px; vertical-align: -2px; }
    .co-spinner-lg { width: 26px; height: 26px; border-width: 2.5px; }
    @keyframes co-spin { to { transform: rotate(360deg); } }
    .co-boot { display: flex; align-items: center; gap: 10px; padding: 1.6rem 0; font-size: 0.82rem; color: var(--color-text-muted); }

    /* Inputs (redefinidos aquí porque las .s-* de SettingsShell son scopeadas) */
    .connect-custom-onboarding .s-row { display: grid; grid-template-columns: 1fr; gap: 1rem; }
    @media (min-width: 560px) { .connect-custom-onboarding .s-row { grid-template-columns: 1fr 1fr; } }
    @media (min-width: 560px) { .connect-custom-onboarding .s-row-3 { grid-template-columns: 1fr 1fr 90px; } }
    .connect-custom-onboarding .s-hint { font-size: 0.7rem; color: var(--color-text-muted); line-height: 1.4; }
    .connect-custom-onboarding .co-hint-ok { color: var(--color-ok); font-weight: 600; }
    .connect-custom-onboarding .co-hint-bad { color: var(--color-danger); font-weight: 600; }
    .connect-custom-onboarding .co-clabe { font-family: ui-monospace, 'SF Mono', monospace; letter-spacing: 0.08em; font-variant-numeric: tabular-nums; }

    /* Fecha de nacimiento */
    .connect-custom-onboarding .co-dob { display: flex; align-items: center; gap: 6px; }
    .connect-custom-onboarding .co-dob .s-input { text-align: center; padding-left: 6px; padding-right: 6px; }
    .connect-custom-onboarding .co-dob .s-input:nth-child(1) { width: 56px; }
    .connect-custom-onboarding .co-dob .s-input:nth-child(3) { width: 56px; }
    .connect-custom-onboarding .co-dob .s-input:nth-child(5) { width: 78px; }
    .connect-custom-onboarding .co-dob-sep { color: var(--color-text-muted); opacity: 0.5; }

    /* Attestation de dueños */
    .connect-custom-onboarding .co-attest { display: flex; align-items: flex-start; gap: 14px; cursor: pointer; padding: 16px 0; border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
    .connect-custom-onboarding .co-attest-text { display: flex; flex-direction: column; gap: 3px; }
    .connect-custom-onboarding .co-attest-text strong { font-size: 0.85rem; font-weight: 600; color: var(--color-text); }
    .connect-custom-onboarding .co-attest-text span { font-size: 0.75rem; color: var(--color-text-muted); line-height: 1.45; }

    /* Documentos de identidad */
    .connect-custom-onboarding .co-doc-actions { display: flex; gap: 10px; flex-wrap: wrap; }
    .connect-custom-onboarding .co-doc-actions .co-btn { flex: 1; min-width: 140px; display: inline-flex; align-items: center; justify-content: center; gap: 8px; }
    .connect-custom-onboarding .co-upload { position: relative; overflow: hidden; text-align: center; }
    .connect-custom-onboarding .co-upload input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
    .connect-custom-onboarding .co-doc-preview { display: flex; align-items: center; gap: 12px; padding: 10px 0; }
    .connect-custom-onboarding .co-doc-preview img { width: 64px; height: 42px; object-fit: cover; border-radius: 8px; box-shadow: 0 1px 4px rgba(10,25,47,0.18); }
    .connect-custom-onboarding .co-doc-ok { display: inline-flex; align-items: center; gap: 5px; font-size: 0.76rem; font-weight: 600; color: var(--color-ok); }
    .connect-custom-onboarding .co-btn-sm { padding: 5px 12px; font-size: 0.76rem; margin-left: auto; }

    /* TOS */
    .connect-custom-onboarding .co-tos { background: var(--color-bg-soft); padding: 1.1rem 1.2rem; border-radius: 14px; font-size: 0.8rem; color: var(--color-text-muted); line-height: 1.6; max-height: 220px; overflow-y: auto; }
    .connect-custom-onboarding .co-tos p { margin: 0 0 0.7rem; }
    .connect-custom-onboarding .co-tos p:last-child { margin-bottom: 0; }
    .connect-custom-onboarding .co-tos a { color: var(--color-blue-deep); font-weight: 600; }
    .connect-custom-onboarding .co-tos-note { font-size: 0.82rem; font-weight: 600; color: var(--color-text); margin: 0; }

    /* Estado "en revisión" / activo */
    .co-review { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.9rem; padding: 2.4rem 1rem; }
    .co-review h3 { font-size: 1.05rem; font-weight: 600; letter-spacing: -0.01em; color: var(--color-text); margin: 0; }
    .co-review p { font-size: 0.84rem; color: var(--color-text-muted); line-height: 1.6; max-width: 44ch; margin: 0; }
    .co-review-reason { font-size: 0.72rem !important; font-family: ui-monospace, monospace; opacity: 0.7; }
    .co-active { padding: 0.3rem 0; }
    .co-bank-row { display: flex; align-items: center; gap: 13px; padding: 12px 0; }
