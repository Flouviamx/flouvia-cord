---
import SettingsShell from '../../../components/app/SettingsShell.astro';
import ConnectOnboarding from '../../../components/app/ConnectOnboarding';
import { getOrg } from '../../../lib/queries';
const ORG = await getOrg();

// Estado de la cuenta de cobros
const conectado = !!ORG.stripeAccountId;
const activo = conectado && ORG.stripeChargesEnabled;
const estado = !conectado ? 'nuevo' : activo ? 'activo' : 'pendiente';
const puedeCobrar = activo; // habilita tarjeta / SPEI (transferencia manual no depende de Stripe)
const marca = ORG.colorMarca || '#0a192f';
---

<SettingsShell title="Cobros — Ajustes" tab="cobros" perm="ajustes"
    intro="Recibe pagos de tus cotizaciones en línea. El dinero cae directo a tu cuenta — Cord no toca ni retiene tus fondos." save>

    {estado === 'nuevo' ? (
        <!-- ── Hero de onboarding (no conectado) ───────────────────────── -->
        <div class="cobros-hero">
            <div class="ch-glow"></div>
            <div class="ch-inner">
                <span class="ch-eyebrow">COBROS EN LÍNEA</span>
                <h2 class="ch-title">Deja que tus clientes te paguen con un clic</h2>
                <p class="ch-sub">Conecta tu cuenta en un par de minutos y empieza a cobrar tus cotizaciones con tarjeta o transferencia. Sin mensualidades extra, sin comisiones de Cord.</p>
                <div class="ch-props">
                    <div class="chp">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                        <div><strong>Directo a tu cuenta</strong><span>Cord nunca toca tus fondos.</span></div>
                    </div>
                    <div class="chp">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m8 12 3 3 5-6"/></svg>
                        <div><strong>0% comisión de Cord</strong><span>Solo pagas las tarifas de Stripe.</span></div>
                    </div>
                    <div class="chp">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2.5"/><path d="M2 10h20"/></svg>
                        <div><strong>Tarjeta y SPEI</strong><span>Con conciliación automática.</span></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="connect-frame">
            <ConnectOnboarding client:only="react" chargesEnabled={ORG.stripeChargesEnabled} />
        </div>
    ) : (
        <!-- ── Estado (conectado) ──────────────────────────────────────── -->
        <div class="s-block">
            <h3>Estado de tu cuenta</h3>
            <div class="s-body">
                <div class={`cobros-status cobros-status--${estado}`}>
                    <span class="cs-dot"></span>
                    <div class="cs-text">
                        <strong>{estado === 'activo' ? 'Cobros activos' : 'Verificación pendiente'}</strong>
                        <span>{estado === 'activo'
                            ? 'Tu cuenta está lista. Tus clientes ya pueden pagar sus cotizaciones.'
                            : 'Stripe necesita algunos datos más para habilitar tus cobros. Complétalos abajo.'}</span>
                    </div>
                    <button type="button" class="cs-disconnect" id="btnDisconnect">Desconectar</button>
                </div>
                <div class="connect-frame">
                    <ConnectOnboarding client:only="react" chargesEnabled={ORG.stripeChargesEnabled} />
                </div>
            </div>
        </div>
    )}

    <!-- ── Métodos de pago + preview ───────────────────────────────────── -->
    <div class="s-block cobros-methods-block">
        <h3>Métodos de pago</h3>
        <div class="methods-grid">
            <div class={`s-body pay-methods ${!puedeCobrar ? 'has-locked' : ''}`}>
                {!puedeCobrar && (
                    <p class="methods-locked">Activa y verifica tu cuenta arriba para habilitar tarjeta y SPEI. La transferencia manual funciona sin Stripe.</p>
                )}

                <!-- Tarjeta -->
                <div class={`pay-method ${!puedeCobrar ? 'is-locked' : ''}`}>
                    <div class="pm-ico">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2.5" fill="currentColor" fill-opacity="0.12"/><path d="M2 10h20"/></svg>
                    </div>
                    <div class="pm-text">
                        <strong>Tarjeta de crédito y débito</strong>
                        <span>Visa, Mastercard y Amex. Se procesa al instante vía Stripe.</span>
                    </div>
                    <label class="s-toggle pm-toggle">
                        <input type="checkbox" data-field="acepta_tarjeta" data-pv="tarjeta" checked={ORG.aceptaTarjeta} disabled={!puedeCobrar} />
                        <span class="s-toggle-track"><span class="s-toggle-thumb"></span></span>
                    </label>
                </div>

                <!-- SPEI automático -->
                <div class={`pay-method ${!puedeCobrar ? 'is-locked' : ''}`}>
                    <div class="pm-ico">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M5 21V10l7-5 7 5v11" fill="currentColor" fill-opacity="0.12"/><path d="M9 21v-6h6v6"/></svg>
                    </div>
                    <div class="pm-text">
                        <strong>Transferencia SPEI automática</strong>
                        <span>Stripe genera una CLABE única por cotización y la marca pagada sola.</span>
                    </div>
                    <label class="s-toggle pm-toggle">
                        <input type="checkbox" data-field="cobro_spei_auto" data-pv="spei" checked={ORG.cobroSpeiAuto} disabled={!puedeCobrar} />
                        <span class="s-toggle-track"><span class="s-toggle-thumb"></span></span>
                    </label>
                </div>

                <!-- Transferencia manual -->
                <div class="pay-method pay-method--stack">
                    <div class="pm-head">
                        <div class="pm-ico">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="12" rx="2" fill="currentColor" fill-opacity="0.12"/><path d="M3 8l9-5 9 5"/><path d="M7 20v-6M12 20v-6M17 20v-6"/></svg>
                        </div>
                        <div class="pm-text">
                            <strong>Transferencia bancaria manual</strong>
                            <span>Muestra tu CLABE en el link público. Tú confirmas el cobro al recibirlo.</span>
                        </div>
                        <label class="s-toggle pm-toggle">
                            <input type="checkbox" data-field="acepta_transferencia" data-pv="transferencia" checked={ORG.aceptaTransferencia} />
                            <span class="s-toggle-track"><span class="s-toggle-thumb"></span></span>
                        </label>
                    </div>
                    <div class="pm-bank">
                        <div class="s-row">
                            <div class="s-field">
                                <label for="oBanco">Banco</label>
                                <input class="s-input" id="oBanco" data-field="banco_nombre" value={ORG.bancoNombre} placeholder="Ej. BBVA" />
                            </div>
                            <div class="s-field">
                                <label for="oClabe">CLABE interbancaria</label>
                                <input class="s-input" id="oClabe" data-field="banco_clabe" value={ORG.bancoClabe} placeholder="18 dígitos" maxlength="18" inputmode="numeric" />
                            </div>
                        </div>
                        <div class="s-field">
                            <label for="oBen">Nombre del beneficiario</label>
                            <input class="s-input" id="oBen" data-field="banco_beneficiario" value={ORG.bancoBeneficiario} placeholder="Razón social o nombre" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Vista previa: así lo verá tu cliente -->
            <div class="pay-preview" id="payPreview">
                <span class="pp-label">ASÍ LO VERÁ TU CLIENTE</span>
                <div class="pp-card">
                    <div class="pp-brand">
                        {ORG.logoUrl
                            ? <img src={ORG.logoUrl} alt={ORG.nombre} class="pp-logo" />
                            : <span class="pp-initial" style={`background:${marca}`}>{ORG.inicial}</span>}
                        <span class="pp-org">{ORG.nombre}</span>
                    </div>
                    <div class="pp-amount">
                        <span class="pp-amount-label">TOTAL A PAGAR</span>
                        <span class="editorial pp-amount-num">$ 12,480.00 <small>MXN</small></span>
                    </div>
                    <button class="pp-cta" style={`background:${marca}`} type="button" tabindex="-1">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        Pagar de forma segura
                    </button>
                    <div class="pp-methods">
                        <span class="pp-badge" data-pv-badge="tarjeta">Tarjeta</span>
                        <span class="pp-badge" data-pv-badge="spei">SPEI</span>
                        <span class="pp-badge" data-pv-badge="transferencia">Transferencia</span>
                    </div>
                    <span class="pp-secure">Pago protegido vía Stripe</span>
                </div>
            </div>
        </div>
    </div>

    <p class="cobros-foot">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Procesado de forma segura por Stripe. Cord nunca almacena datos de tarjetas ni retiene tus fondos.
    </p>
</SettingsShell>

<style>
    /* ── Hero de onboarding ── */
    .cobros-hero {
        position: relative; overflow: hidden;
        background: #0a192f; color: #fff;
        border-radius: 22px; padding: 30px 32px; margin-bottom: 14px;
        box-shadow: 0 2px 4px rgba(10,25,47,0.08), 0 30px 60px -24px rgba(10,25,47,0.5);
    }
    .cobros-hero .ch-glow {
        position: absolute; top: -40%; right: -10%; width: 460px; height: 460px;
        background: radial-gradient(circle, rgba(59,130,246,0.28) 0%, transparent 62%);
        pointer-events: none;
    }
    .cobros-hero .ch-inner { position: relative; }
    .ch-eyebrow { font-size: 0.62rem; font-weight: 800; letter-spacing: 2.4px; color: rgba(255,255,255,0.5); }
    .ch-title { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.03em; line-height: 1.15; margin: 10px 0 8px; max-width: 22ch; }
    .ch-sub { font-size: 0.86rem; line-height: 1.55; color: rgba(255,255,255,0.68); margin: 0; max-width: 54ch; }
    .ch-props { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 22px; }
    .chp {
        display: flex; align-items: center; gap: 10px; flex: 1; min-width: 180px;
        padding: 12px 14px; border-radius: 13px;
        background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08);
    }
    .chp svg { width: 22px; height: 22px; flex-shrink: 0; color: #8ec5ff; }
    .chp div { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
    .chp strong { font-size: 0.8rem; font-weight: 600; }
    .chp span { font-size: 0.7rem; color: rgba(255,255,255,0.6); }

    /* ── Estado (conectado) ── */
    .cobros-status {
        display: flex; align-items: center; gap: 14px;
        padding: 16px 18px; border-radius: var(--radius-card, 16px);
        border: 1px solid var(--color-border); background: var(--color-bg-soft);
    }
    .cobros-status .cs-dot { flex-shrink: 0; width: 10px; height: 10px; border-radius: 50%; }
    .cobros-status--activo   .cs-dot { background: var(--color-ok); box-shadow: 0 0 0 4px rgba(16,185,129,0.14); }
    .cobros-status--pendiente .cs-dot { background: var(--color-warn); box-shadow: 0 0 0 4px rgba(245,158,11,0.14); }
    .cobros-status .cs-text { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
    .cobros-status .cs-text strong { font-size: 0.92rem; font-weight: 600; letter-spacing: -0.01em; color: var(--color-text); }
    .cobros-status .cs-text span { font-size: 0.78rem; color: var(--color-text-muted); line-height: 1.45; }
    .cobros-status .cs-disconnect {
        flex-shrink: 0; margin-left: auto; align-self: flex-start;
        font-size: 0.76rem; font-weight: 600; color: var(--color-danger);
        background: transparent; border: 1px solid rgba(239,68,68,0.25); border-radius: 999px;
        padding: 7px 14px; cursor: pointer; transition: background 0.2s ease;
    }
    .cobros-status .cs-disconnect:hover { background: rgba(239,68,68,0.06); }

    /* ── Marco del componente embebido de Stripe ── */
    .connect-frame {
        border: 1px solid var(--color-border); border-radius: var(--radius-card, 16px);
        padding: 6px; background: var(--surface, #fff);
    }

    /* ── Métodos + preview (2 columnas) ── */
    .methods-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; align-items: start; }
    @media (min-width: 900px) { .methods-grid { grid-template-columns: 1.6fr 1fr; } }

    .methods-locked {
        font-size: 0.78rem; color: var(--color-text-muted);
        margin: 0 0 0.4rem; padding: 10px 14px; border-radius: 12px;
        background: var(--color-bg-soft); border: 1px dashed var(--color-border);
    }
    .pay-methods { gap: 0 !important; }
    .pay-method {
        display: flex; align-items: center; gap: 14px;
        padding: 16px 4px; border-bottom: 1px solid var(--color-border);
    }
    .pay-method:last-child { border-bottom: none; }
    .pay-method.is-locked { opacity: 0.5; }
    .pay-method--stack { flex-direction: column; align-items: stretch; gap: 0; }
    .pay-method--stack .pm-head { display: flex; align-items: center; gap: 14px; }
    .pm-ico {
        flex-shrink: 0; width: 38px; height: 38px; border-radius: 11px;
        display: grid; place-items: center;
        background: rgba(10,25,47,0.06); color: var(--color-blue-deep);
    }
    .pm-text { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
    .pm-text strong { font-size: 0.88rem; font-weight: 600; letter-spacing: -0.01em; color: var(--color-text); }
    .pm-text span { font-size: 0.76rem; color: var(--color-text-muted); line-height: 1.4; }
    .pm-toggle { margin-left: auto; }
    .pm-bank {
        display: flex; flex-direction: column; gap: 1rem;
        margin: 14px 0 4px 52px; padding-top: 14px; border-top: 1px dashed var(--color-border);
    }
    @media (max-width: 640px) { .pm-bank { margin-left: 0; } }

    /* ── Vista previa del link público ── */
    .pay-preview { position: sticky; top: 1rem; }
    .pp-label { display: block; font-size: 0.6rem; font-weight: 800; letter-spacing: 1.6px; color: #99a2af; margin-bottom: 10px; }
    .pp-card {
        background: var(--surface, #fff); border: 1px solid var(--color-border);
        border-radius: 20px; padding: 22px 20px;
        display: flex; flex-direction: column; align-items: center; text-align: center; gap: 14px;
        box-shadow: 0 2px 4px rgba(10,25,47,0.04), 0 24px 50px -20px rgba(10,25,47,0.16);
    }
    .pp-brand { display: flex; align-items: center; gap: 9px; }
    .pp-logo { height: 24px; width: auto; max-width: 120px; object-fit: contain; }
    .pp-initial { width: 26px; height: 26px; border-radius: 8px; color: #fff; font-size: 0.8rem; font-weight: 700; display: grid; place-items: center; }
    .pp-org { font-size: 0.82rem; font-weight: 600; color: var(--color-text); }
    .pp-amount { display: flex; flex-direction: column; gap: 3px; }
    .pp-amount-label { font-size: 0.58rem; font-weight: 800; letter-spacing: 1.4px; color: #99a2af; }
    .pp-amount-num { font-size: 1.9rem; color: var(--color-text); letter-spacing: -0.03em; }
    .pp-amount-num small { font-size: 0.85rem; color: var(--color-text-muted); font-weight: 500; }
    .pp-cta {
        width: 100%; color: #fff; border: none; border-radius: 999px;
        padding: 12px; font-size: 0.86rem; font-weight: 600;
        display: flex; align-items: center; justify-content: center; gap: 8px;
        cursor: default; box-shadow: 0 8px 20px -8px rgba(10,25,47,0.4);
    }
    .pp-methods { display: flex; flex-wrap: wrap; justify-content: center; gap: 6px; }
    .pp-badge {
        font-size: 0.66rem; font-weight: 600; color: var(--color-text-muted);
        padding: 4px 10px; border-radius: 999px; background: var(--color-bg-soft);
        border: 1px solid var(--color-border); transition: opacity 0.2s ease;
    }
    .pp-badge.is-off { display: none; }
    .pp-secure { font-size: 0.66rem; color: #99a2af; }

    /* ── Pie ── */
    .cobros-foot { display: flex; align-items: center; gap: 8px; font-size: 0.72rem; color: var(--color-text-muted); margin: 1.4rem 0 0; }
    .cobros-foot svg { flex-shrink: 0; opacity: 0.7; }
</style>

<script>
    // Preview en vivo: los badges reflejan los toggles sin recargar.
    function syncPreview() {
        document.querySelectorAll('input[data-pv]').forEach((el) => {
            const input = el as HTMLInputElement;
            const key = input.getAttribute('data-pv');
            const badge = document.querySelector(`[data-pv-badge="${key}"]`);
            if (badge) badge.classList.toggle('is-off', !input.checked);
        });
    }
    document.querySelectorAll('input[data-pv]').forEach((el) => el.addEventListener('change', syncPreview));
    syncPreview();

    // Desconectar
    document.getElementById('btnDisconnect')?.addEventListener('click', async () => {
        const cc = (window as any).cordConfirm;
        const ct = (window as any).cordToast;
        const ok = cc
          ? await cc({ title: 'Desconectar Stripe', body: 'Dejarás de recibir pagos en línea. Tus datos de transferencia manual se conservan. ¿Continuar?', danger: true, confirmText: 'Desconectar' })
          : confirm('¿Seguro que deseas desconectar tu cuenta de Stripe? Dejarás de recibir pagos en línea.');
        if (!ok) return;
        try {
            const res = await fetch('/api/billing/connect/disconnect', { method: 'POST' });
            if (!res.ok) { const data = await res.json(); throw new Error(data.error || 'Error al desconectar'); }
            if (ct) ct('Cuenta desconectada');
            setTimeout(() => window.location.reload(), 1200);
        } catch (e: any) {
            if (ct) ct(e.message, 'error'); else alert(e.message);
        }
    });
</script>
