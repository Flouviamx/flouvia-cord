---
import Layout from '../layouts/Layout.astro';
import { SignIn } from '@clerk/astro/components';
import { clerkAppearance } from '../lib/clerk-theme';
---

<Layout title="Iniciar sesión - Cord">
    <div style="display: flex; justify-content: center; align-items: center; min-height: 100vh; background-color: #09090b; padding: 2rem;">
        <SignIn appearance={clerkAppearance} routing="path" path="/sign-in" />
    </div>
</Layout>
