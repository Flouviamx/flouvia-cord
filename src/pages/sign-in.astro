---
import Layout from '../layouts/Layout.astro';
import CustomSignIn from '../components/auth/CustomSignIn';
---

<Layout title="Iniciar sesión - Cord">
    <div class="auth-page">
        <div class="auth-wrapper">
            <div class="cord-bg-mesh"></div>
            
            <div class="auth-header-top">
                <a href="/">
                    <img src="/imgs/logo-cord-navy.png" alt="Cord Logo" height="28" style="display: block; margin: 0;" />
                </a>
            </div>
            
            <CustomSignIn client:load />
            
            <div class="auth-footer-text">
                &copy; 2026 Flouvia Cord. Hecho en México.
            </div>
        </div>
    </div>
</Layout>

<style is:global>
    .auth-page {
        min-height: 100vh;
        background: #ffffff;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
        font-family: var(--font-sans, system-ui, sans-serif);
    }

    .cord-bg-mesh {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background-image: radial-gradient(rgba(10, 25, 47, 0.04) 1px, transparent 1px);
        background-size: 32px 32px;
        z-index: 0;
        pointer-events: none;
    }

    .auth-wrapper {
        position: relative;
        z-index: 1;
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }

    .auth-header-top {
        width: 100%;
        max-width: 440px;
        margin-bottom: 2.5rem;
        display: flex;
        justify-content: center;
    }

    .auth-header-top a {
        text-decoration: none;
        transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .auth-header-top a:hover {
        transform: scale(1.02);
    }

    .auth-card {
        background: #ffffff;
        width: 100%;
        max-width: 440px;
        border-radius: 16px;
        border: 1px solid rgba(10, 25, 47, 0.06);
        box-shadow: 0 20px 40px -10px rgba(10, 25, 47, 0.05), 0 10px 20px -5px rgba(10, 25, 47, 0.02);
        padding: 3rem 2.5rem;
        animation: fadeinup 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .auth-header {
        margin-bottom: 2rem;
    }

    .auth-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #0a192f;
        margin: 0;
        letter-spacing: -0.02em;
    }

    .auth-form {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .label-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .form-group label {
        font-size: 0.85rem;
        font-weight: 600;
        color: #334155;
    }

    .forgot-link {
        font-size: 0.8rem;
        color: #0a192f;
        text-decoration: none;
        font-weight: 500;
        opacity: 0.7;
        transition: opacity 0.2s;
    }
    .forgot-link:hover {
        opacity: 1;
        text-decoration: underline;
    }

    .form-input {
        padding: 0.75rem 1rem;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 1rem;
        color: #0a192f;
        background: #f8fafc;
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
        outline: none;
    }

    .form-input:hover {
        border-color: #cbd5e1;
    }
    .form-input:focus {
        background: #ffffff;
        border-color: #0a192f;
        box-shadow: 0 0 0 4px rgba(10, 25, 47, 0.08);
    }

    .checkbox-row {
        flex-direction: row;
        align-items: center;
        gap: 0.6rem;
        margin-top: -0.25rem;
    }

    .form-checkbox {
        width: 1.1rem;
        height: 1.1rem;
        border-radius: 4px;
        border: 1px solid #cbd5e1;
        accent-color: #0a192f;
        cursor: pointer;
    }

    .checkbox-row label {
        font-size: 0.85rem;
        font-weight: 500;
        color: #475569;
        cursor: pointer;
    }

    .btn-primary {
        margin-top: 0.75rem;
        background: #0a192f;
        color: #ffffff;
        border: none;
        padding: 0.8rem 1rem;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 4px 6px -1px rgba(10, 25, 47, 0.1), 0 2px 4px -1px rgba(10, 25, 47, 0.06);
    }
    .btn-primary:hover:not(:disabled) { 
        background: #172a4d; 
        transform: translateY(-1px);
        box-shadow: 0 6px 8px -1px rgba(10, 25, 47, 0.15), 0 4px 6px -1px rgba(10, 25, 47, 0.1);
    }
    .btn-primary:active:not(:disabled) {
        transform: translateY(0);
        box-shadow: 0 2px 4px -1px rgba(10, 25, 47, 0.1);
    }
    .btn-primary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
    }

    .auth-error {
        font-size: 0.85rem;
        color: #ef4444;
        background: #fef2f2;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        border: 1px solid #fecaca;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .auth-divider {
        position: relative;
        text-align: center;
        margin: 2rem 0;
    }

    .auth-divider::before {
        content: "";
        position: absolute;
        top: 50%;
        left: 0;
        right: 0;
        height: 1px;
        background: #e2e8f0;
        z-index: 0;
    }

    .auth-divider span {
        position: relative;
        background: #ffffff;
        padding: 0 1rem;
        color: #94a3b8;
        font-size: 0.8rem;
        font-weight: 500;
        z-index: 1;
    }

    .auth-social {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .btn-social {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        font-size: 0.95rem;
        font-weight: 600;
        color: #334155;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .btn-social:hover:not(:disabled) { 
        background: #f8fafc; 
        border-color: #cbd5e1; 
        transform: translateY(-1px);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    .btn-social:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .auth-footer {
        margin-top: 2.5rem;
        text-align: center;
        font-size: 0.85rem;
        color: #64748b;
    }

    .auth-footer a {
        color: #0a192f;
        font-weight: 600;
        text-decoration: none;
        transition: opacity 0.2s;
    }
    .auth-footer a:hover {
        opacity: 0.8;
        text-decoration: underline;
    }

    .auth-footer-text {
        margin-top: 3rem;
        font-size: 0.75rem;
        color: #94a3b8;
        font-weight: 500;
    }

    @keyframes fadeinup {
        from { opacity: 0; transform: translateY(20px) scale(0.98); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }
</style>
