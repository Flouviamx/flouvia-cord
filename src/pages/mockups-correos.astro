---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mockups de Correos - Cord</title>
    <style>
        body {
            font-family: system-ui, -apple-system, sans-serif;
            background-color: #f1f5f9;
            margin: 0;
            padding: 40px;
            color: #334155;
        }
        h1 {
            text-align: center;
            margin-bottom: 40px;
            color: #0f172a;
        }
        .category-title {
            text-align: center;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
            color: #64748b;
            margin-bottom: 16px;
        }
        .tabs {
            display: flex;
            justify-content: center;
            gap: 12px;
            margin-bottom: 32px;
            flex-wrap: wrap;
        }
        .tabs-container {
            max-width: 800px;
            margin: 0 auto 40px auto;
        }
        .tab-btn {
            background: #e2e8f0;
            border: none;
            padding: 10px 24px;
            border-radius: 9999px;
            font-size: 15px;
            font-weight: 500;
            color: #475569;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        }
        .tab-btn:hover {
            background: #cbd5e1;
        }
        .tab-btn.active {
            background: #0a192f;
            color: #ffffff;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        }
        .mockup-container {
            display: none;
            max-width: 800px;
            margin: 0 auto;
            background: #fff;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06);
        }
        .mockup-container.active {
            display: block;
            animation: fadeIn 0.3s ease;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .mockup-title {
            font-size: 18px;
            font-weight: 600;
            margin-top: 0;
            margin-bottom: 20px;
            padding-bottom: 12px;
            border-bottom: 1px solid #e2e8f0;
            color: #0f172a;
            text-align: center;
        }
        .email-wrapper {
            background-color: #F9FAFB;
            border-radius: 8px;
            border: 1px solid #e2e8f0;
            overflow: hidden;
        }
    </style>
</head>
<body>
    <h1>Mockups de Correos (Estilo Stripe/Apple)</h1>
    
    <div class="tabs-container">
        <div class="category-title">Externos (A Clientes / Prospectos)</div>
        <div class="tabs">
            <button class="tab-btn active" onclick="showTab('tab-quote', this)">Envío de Cotización</button>
            <button class="tab-btn" onclick="showTab('tab-ventas-ack', this)">Confirmación de Ventas</button>
            <button class="tab-btn" onclick="showTab('tab-cobranza', this)">Cobranza (Agente IA)</button>
        </div>
        
        <div class="category-title" style="margin-top: 32px;">Internos (Al Equipo)</div>
        <div class="tabs">
            <button class="tab-btn" onclick="showTab('tab-ventas-interno', this)">Aviso de Nuevo Prospecto</button>
        </div>
    </div>
    
    <!-- 1. Cotización (Externo) -->
    <div id="tab-quote" class="mockup-container active">
        <h2 class="mockup-title">Externo: Envío de Cotización</h2>
        <div class="email-wrapper">
            <div style="background-color:#FAFAFA;padding:48px 20px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif,'Apple Color Emoji','Segoe UI Emoji','Segoe UI Symbol';">
                <div style="max-width:540px;margin:0 auto;background-color:#ffffff;border:1px solid #E5E7EB;border-radius:12px;overflow:hidden;">
                    <div style="padding:48px;">
                        <p style="font-size:16px;color:#111827;margin-top:0;font-weight:500;">Estimado equipo de Acme Corp,</p>
                        <p style="font-size:16px;line-height:1.6;color:#4B5563;margin-bottom:32px;font-weight:400;">Flouvia le comparte la cotización <b>COT-2026-001</b> por <b>$54,300.00</b>. Puede revisarla, dejar comentarios y aprobarla en línea:</p>
                        
                        <div style="margin:40px 0;">
                            <a href="#" style="display:inline-block;background-color:#0a192f;color:#ffffff;text-decoration:none;font-weight:600;font-size:14px;padding:12px 24px;border-radius:8px;">Ver cotización COT-2026-001</a>
                        </div>
                        
                        <p style="font-size:14px;color:#6B7280;line-height:1.5;word-break:break-all;">O copie este enlace en su navegador:<br><a href="#" style="color:#2563EB;text-decoration:underline;">https://cord.flouvia.com/q/mock-token-123</a></p>
                        
                        <div style="margin-top:40px;padding-top:32px;border-top:1px solid #F3F4F6;"><p style="font-size:15px;color:#4B5563;line-height:1.6;margin:0;">Gracias por su preferencia, quedamos a su disposición para cualquier duda.</p></div>
                        <div style="margin-top:32px;"><p style="font-size:15px;color:#4B5563;line-height:1.6;margin:0;">Atentamente,<br>Equipo de Ventas</p></div>
                    </div>
                    <div style="background-color:#FAFAFA;padding:24px 48px;border-top:1px solid #E5E7EB;">
                        <p style="font-size:12px;color:#9CA3AF;margin:0;line-height:1.5;text-align:center;">Flouvia · enviado con Cord</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. Ventas Ack (Externo) -->
    <div id="tab-ventas-ack" class="mockup-container">
        <h2 class="mockup-title">Externo: Confirmación de Contacto</h2>
        <div class="email-wrapper">
            <div style="background-color:#FAFAFA;padding:48px 20px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif,'Apple Color Emoji','Segoe UI Emoji','Segoe UI Symbol';">
                <div style="max-width:540px;margin:0 auto;background-color:#ffffff;border:1px solid #E5E7EB;border-radius:12px;overflow:hidden;">
                    <div style="padding:48px;">
                        <p style="font-size:20px;color:#111827;margin-top:0;font-weight:600;letter-spacing:-0.5px;">Cord</p>
                        <p style="font-size:16px;color:#111827;margin-top:32px;font-weight:500;">Hola Juan,</p>
                        <p style="font-size:16px;line-height:1.6;color:#4B5563;">Gracias por escribirnos. Hemos recibido tu información de forma segura y un especialista se pondrá en contacto contigo muy pronto para descubrir cómo podemos ayudar a Industrias Globales a digitalizar sus cotizaciones y pedidos B2B.</p>
                        
                        <div style="margin-top:40px;padding-top:32px;border-top:1px solid #F3F4F6;">
                            <p style="font-size:14px;line-height:1.6;color:#6B7280;margin:0;">Mientras tanto, te invitamos a explorar nuestra plataforma:<br><a href="https://cord.flouvia.com" style="color:#2563EB;text-decoration:none;">cord.flouvia.com</a></p>
                        </div>
                    </div>
                    <div style="background-color:#FAFAFA;padding:24px 48px;border-top:1px solid #E5E7EB;">
                        <p style="font-size:12px;color:#9CA3AF;margin:0;line-height:1.5;text-align:center;">Equipo Cord · Flouvia · Hecho en México</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 3. Cobranza IA (Externo) -->
    <div id="tab-cobranza" class="mockup-container">
        <h2 class="mockup-title">Externo: Recordatorio de Cobranza (IA)</h2>
        <div class="email-wrapper">
            <div style="background-color:#FAFAFA;padding:48px 20px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif,'Apple Color Emoji','Segoe UI Emoji','Segoe UI Symbol';">
                <div style="max-width:540px;margin:0 auto;background-color:#ffffff;border:1px solid #E5E7EB;border-radius:12px;overflow:hidden;">
                    <div style="padding:48px;">
                        <div style="font-size:16px;line-height:1.6;color:#111827;white-space:pre-wrap;font-weight:400;">Hola María,

Espero que te encuentres muy bien.

Te escribo para recordarte amablemente que la factura F-4589 por un monto de $12,500.00 MXN venció hace 3 días. Entendemos que a veces hay retrasos administrativos, ¿podrías apoyarnos revisando el estatus de este pago?

Si tienes alguna duda o necesitas que te reenviemos la factura, no dudes en decirnos.

¡Que tengas excelente día!</div>
                    </div>
                    <div style="background-color:#FAFAFA;padding:24px 48px;border-top:1px solid #E5E7EB;">
                        <p style="font-size:12px;color:#9CA3AF;margin:0;line-height:1.5;text-align:center;">Enviado vía Cord</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 4. Ventas Interno (Interno) -->
    <div id="tab-ventas-interno" class="mockup-container">
        <h2 class="mockup-title">Interno: Aviso de Nuevo Lead</h2>
        <div class="email-wrapper">
            <div style="background-color:#FAFAFA;padding:48px 20px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif,'Apple Color Emoji','Segoe UI Emoji','Segoe UI Symbol';">
                <div style="max-width:540px;margin:0 auto;background-color:#ffffff;border:1px solid #E5E7EB;border-radius:12px;overflow:hidden;">
                    <div style="padding:48px;">
                        <p style="font-size:12px;color:#6B7280;text-transform:uppercase;letter-spacing:0.5px;font-weight:600;margin:0 0 16px 0;">Cord · Nuevo Prospecto</p>
                        <p style="font-size:24px;color:#111827;margin-top:0;margin-bottom:32px;font-weight:600;line-height:1.3;letter-spacing:-0.5px;">Juan Pérez de Industrias Globales</p>
                        
                        <table style="width:100%;border-collapse:collapse;font-size:14px;line-height:1.5;text-align:left;">
                            <tr style="border-bottom:1px solid #F3F4F6;"><td style="width:140px;color:#6B7280;padding:16px 0;">Nombre</td><td style="color:#111827;font-weight:500;padding:16px 0;">Juan Pérez</td></tr>
                            <tr style="border-bottom:1px solid #F3F4F6;"><td style="color:#6B7280;padding:16px 0;">Correo</td><td style="padding:16px 0;"><a href="mailto:juan@ejemplo.com" style="color:#2563EB;text-decoration:none;">juan@ejemplo.com</a></td></tr>
                            <tr style="border-bottom:1px solid #F3F4F6;"><td style="color:#6B7280;padding:16px 0;">Cargo</td><td style="color:#111827;padding:16px 0;">Director de Compras</td></tr>
                            <tr style="border-bottom:1px solid #F3F4F6;"><td style="color:#6B7280;padding:16px 0;">Empresa</td><td style="color:#111827;padding:16px 0;">Industrias Globales</td></tr>
                            <tr style="border-bottom:1px solid #F3F4F6;"><td style="color:#6B7280;padding:16px 0;">ERP actual</td><td style="color:#111827;padding:16px 0;">SAP Business One</td></tr>
                            <tr><td style="color:#6B7280;padding:16px 0;">Volumen B2B</td><td style="color:#111827;font-weight:500;padding:16px 0;">$10M - $50M MXN</td></tr>
                        </table>
                        
                        <div style="margin-top:40px;padding-top:32px;border-top:1px solid #F3F4F6;"><p style="font-size:12px;color:#6B7280;text-transform:uppercase;letter-spacing:0.5px;font-weight:600;margin:0 0 12px 0;">Mensaje / Retos</p><p style="font-size:15px;line-height:1.6;color:#374151;margin:0;white-space:pre-wrap;">Tenemos problemas gestionando nuestras cotizaciones porque el equipo comercial tarda demasiado en generarlas manualmente en PDF. Necesitamos algo más rápido.</p></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script is:inline>
        function showTab(tabId, btnElement) {
            // Ocultar todos los contenedores
            document.querySelectorAll('.mockup-container').forEach(el => {
                el.classList.remove('active');
            });
            // Quitar la clase active de todos los botones
            document.querySelectorAll('.tab-btn').forEach(el => {
                el.classList.remove('active');
            });
            
            // Mostrar el tab seleccionado y activar el botón
            document.getElementById(tabId).classList.add('active');
            btnElement.classList.add('active');
        }
    </script>
</body>
</html>
