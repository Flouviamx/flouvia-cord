---
// Landing de Trato — página de ventas completa.
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/landing/Nav.astro';
import Hero from '../components/landing/Hero.astro';
import Features from '../components/landing/Features.astro';
import Steps from '../components/landing/Steps.astro';
import ClientView from '../components/landing/ClientView.astro';
import Pricing from '../components/landing/Pricing.astro';
import Faq from '../components/landing/Faq.astro';
import Footer from '../components/landing/Footer.astro';
---

<Layout title="Trato — Cotizaciones B2B que cierran tratos | by Flouvia">
    <Nav />
    <main>
        <Hero />
        <Features />
        <Steps />
        <ClientView />
        <Pricing />
        <Faq />
    </main>
    <Footer />
</Layout>

<!-- Gate anti-FOUC global: oculta elementos animados antes del primer paint -->
<style is:global>
    .js-anim .reveal,
    .js-anim .reveal-mockup { opacity: 0; }
</style>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener('DOMContentLoaded', () => {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        if (reduced) {
            // Sin animación: todo visible (el gate .js-anim ni se añadió)
            gsap.set('.reveal, .reveal-mockup', { opacity: 1, y: 0 });
            return;
        }

        // El navbar (Nav.astro) maneja su propia entrada GSAP internamente.

        // ── Hero: revela en carga con stagger (está sobre el fold) ──
        const heroReveals = gsap.utils.toArray<HTMLElement>('.hero .reveal');
        gsap.set(heroReveals, { y: 16 });
        gsap.to(heroReveals, {
            opacity: 1, y: 0, duration: 0.95, ease: 'power2.out', stagger: 0.08, delay: 0.1,
        });

        // El mockup del hero entra un pelín después, más suave
        const heroMockup = document.querySelector<HTMLElement>('.hero .reveal-mockup');
        if (heroMockup) {
            gsap.set(heroMockup, { y: 40, scale: 0.98 });
            gsap.to(heroMockup, { opacity: 1, y: 0, scale: 1, duration: 1.2, ease: 'power3.out', delay: 0.5 });
        }

        // ── Reveals on-scroll para el resto (patrón anti-parpadeo de flouvia) ──
        const scrollReveals = gsap.utils.toArray<HTMLElement>('.reveal').filter(
            (el) => !el.closest('.hero')
        );
        scrollReveals.forEach((el) => {
            gsap.set(el, { y: 18 });
            ScrollTrigger.create({
                trigger: el,
                start: 'top 88%',
                once: true,
                // clearProps SOLO de transform — NO de opacity: el gate CSS
                // (.js-anim .reveal{opacity:0}) volvería a ocultar el elemento si
                // limpiamos el opacity inline. Dejamos opacity:1 inline para que gane.
                onEnter: () => gsap.to(el, {
                    opacity: 1, y: 0, duration: 0.85, ease: 'power2.out',
                    clearProps: 'transform',
                }),
            });
        });

        // Mockups fuera del hero (ClientView): entrada un poco más rica
        const otherMockups = gsap.utils.toArray<HTMLElement>('.reveal-mockup').filter(
            (el) => !el.closest('.hero')
        );
        otherMockups.forEach((el) => {
            gsap.set(el, { y: 40, scale: 0.97 });
            ScrollTrigger.create({
                trigger: el,
                start: 'top 85%',
                once: true,
                onEnter: () => gsap.to(el, {
                    opacity: 1, y: 0, scale: 1, duration: 1.1, ease: 'power3.out',
                }),
            });
        });

        // Smooth scroll para los anchors del nav
        document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
            a.addEventListener('click', (e) => {
                const id = a.getAttribute('href');
                if (!id || id === '#') return;
                const target = document.querySelector(id);
                if (target) {
                    e.preventDefault();
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });

        // Refresh tras cargar fuentes/imágenes
        Promise.all([
            new Promise<void>((r) => window.addEventListener('load', () => r(), { once: true })),
            (document as any).fonts?.ready ?? Promise.resolve(),
        ]).then(() => setTimeout(() => ScrollTrigger.refresh(), 120));
    });
</script>
