---
// Landing de Cord — página de ventas completa.
// NO es prerender a propósito: en modo `server`, las páginas prerender=true se sirven
// como HTML estático desde el edge y SALTAN el middleware. La raíz "/" de los subdominios
// (dev.cordhq.app / docs.cordhq.app) necesita pasar por SSR para que src/middleware.ts
// pueda reescribirla al árbol /dev-blog o /docs. Si esto vuelve a ser prerender, los
// subdominios volverán a mostrar la landing principal en su raíz.
import Layout from '../layouts/Layout.astro';
import Nav from '../components/landing/Nav.astro';
import Hero from '../components/landing/Hero.astro';
import Features from '../components/landing/Features.astro';
import AdvancedFeatures from '../components/landing/AdvancedFeatures.astro';
import Steps from '../components/landing/Steps.astro';
import CtaDuo from '../components/landing/CtaDuo.astro';
import ClientView from '../components/landing/ClientView.astro';
import Pricing from '../components/landing/Pricing.astro';
import Faq from '../components/landing/Faq.astro';
import Footer from '../components/landing/Footer.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
const t = useTranslations(lang);

// ── Datos estructurados (JSON-LD) — HowTo del flujo de venta B2B de Cord.
//    Lo lee Google para enriquecer el resultado de búsqueda de la home.
const howToSchema = {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: isEn ? 'How Cord works: from first contact to CFDI' : 'Cómo funciona Cord: del primer contacto al CFDI',
    description: isEn 
        ? 'Cord digitizes the B2B sales process in three steps: from quote creation to SAT-stamped CFDI 4.0, without data re-entry.'
        : 'Cord digitaliza el proceso de venta B2B en tres pasos: desde la creación de la cotización hasta el timbrado del CFDI 4.0 ante el SAT, sin recaptura de datos.',
    totalTime: 'PT10M',
    tool: [
        { '@type': 'HowToTool', name: isEn ? 'Cord account (free)' : 'Cuenta de Cord (gratuita)' },
        { '@type': 'HowToTool', name: isEn ? 'Product catalog loaded in Cord' : 'Catálogo de productos cargado en Cord' },
    ],
    step: [
        {
            '@type': 'HowToStep',
            position: '1',
            name: isEn ? 'Build the quote' : 'Arma la cotización',
            text: isEn 
                ? 'Choose the client from the directory, add catalog products, and negotiate line prices. Define credit terms (Cash, Net 30/60), apply volume discounts, and set validity. The total with tax recalculates in real-time. All done in minutes.'
                : 'Elige al cliente desde el directorio, agrega productos del catálogo y negocia el precio de cada línea. Define los términos de crédito (Contado, Net 30 o Net 60), aplica descuentos por volumen y establece la vigencia. El total con IVA se recalcula en tiempo real. Todo listo en minutos.',
            url: isEn ? 'https://cordhq.app/en/producto/editor' : 'https://cordhq.app/producto/editor',
        },
        {
            '@type': 'HowToStep',
            position: '2',
            name: isEn ? 'Send the link' : 'Envía el link',
            text: isEn 
                ? 'Cord generates a branded link (logo, colors, and tax details) that the client can open from any device. You also get a PDF. Receive a notification the exact moment your client opens the quote.'
                : 'Cord genera un link con tu marca (logo, colores y datos fiscales) que el cliente puede abrir desde cualquier dispositivo. También puedes descargar un PDF. Recibes una notificación en el instante exacto en que tu cliente abre la cotización.',
            url: isEn ? 'https://cordhq.app/en/producto/link-publico' : 'https://cordhq.app/producto/link-publico',
        },
        {
            '@type': 'HowToStep',
            position: '3',
            name: isEn ? 'Close and invoice' : 'Cierra y factura',
            text: isEn 
                ? 'The client approves with one click and pays online, or the quote stays on credit based on defined terms. The quote automatically turns into an order and the CFDI 4.0 is stamped with the SAT with no data re-entry needed.'
                : 'El cliente aprueba con un clic y paga en línea, o la cotización queda a crédito según los términos definidos. La cotización se convierte automáticamente en pedido y el CFDI 4.0 se timbra ante el SAT sin necesidad de recapturar datos en otro portal.',
            url: isEn ? 'https://cordhq.app/en/producto/cfdi' : 'https://cordhq.app/producto/cfdi',
        },
    ],
};

// Título y descripción (jul 2026, auditoría SEO/AI-SEO): reescritos para dejar
// explícito desde el <title> que Cord es un SOFTWARE PÚBLICO e INDEPENDIENTE
// (no una herramienta interna/exclusiva de Flouvia) — así los motores de
// búsqueda y los LLMs que citan la página no infieren "producto exclusivo de
// clientes de Flouvia". "by Flouvia" se movió del <title> a un dato de
// confianza secundario dentro de la descripción, sin liderar el mensaje.
const title = isEn
    ? "Cord — B2B Quoting, Order & CFDI Invoicing Software (Mexico)"
    : "Cord — Software de Cotizaciones B2B y CFDI 4.0 en México";

const description = isEn
    ? "Cord is independent B2B software for quotes, orders, credit terms (Net 30/60) and automated SAT e-invoicing (CFDI 4.0). Built for any B2B business in Mexico — not only Flouvia customers. Free plan forever, by the team at Flouvia."
    : "Cord es un software B2B independiente para cotizaciones, pedidos, términos de crédito (Net 30/60) y CFDI 4.0 automático ante el SAT. Para cualquier negocio B2B en México — no solo clientes de Flouvia. Plan gratis para siempre, hecho por el equipo de Flouvia.";

// ── Datos estructurados adicionales (jul 2026) ──────────────────────────
// Organization (Flouvia, la empresa creadora) + SoftwareApplication (Cord,
// el producto — independiente, con su propio dominio/oferta) + FAQPage
// (misma fuente que <Faq /> más abajo, así el schema SIEMPRE coincide con
// el texto visible). Este trío es la forma "machine-readable" correcta de
// decir "Cord es un producto propio, hecho por Flouvia, disponible para
// cualquier negocio" — exactamente el problema que los LLMs venían
// malinterpretando al no encontrar esta señal explícita en el HTML.
const orgSchema = {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': 'https://flouvia.com/#organization',
    name: 'Flouvia',
    url: 'https://flouvia.com',
    logo: 'https://cordhq.app/imgs/logo-cord-navy.png',
    sameAs: [
        'https://instagram.com/flouvia',
        'https://tiktok.com/@flouvia',
        'https://x.com/flouvia',
    ],
};

const softwareSchema = {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    '@id': 'https://cordhq.app/#software',
    name: 'Cord',
    url: 'https://cordhq.app',
    applicationCategory: 'BusinessApplication',
    applicationSubCategory: isEn ? 'B2B Quoting & Invoicing Software' : 'Software de Cotizaciones y Facturación B2B',
    operatingSystem: 'Web',
    description: isEn
        ? 'Cord is a standalone, publicly available B2B SaaS for creating quotes with negotiated pricing, tracking approvals in real time, and stamping Mexican CFDI 4.0 e-invoices automatically. Open to any B2B business in Mexico, independent of Flouvia\'s other products.'
        : 'Cord es un SaaS B2B independiente y de acceso público para crear cotizaciones con precios negociados, dar seguimiento a las aprobaciones en tiempo real y timbrar CFDI 4.0 automáticamente ante el SAT. Abierto a cualquier negocio B2B en México, independiente de los demás productos de Flouvia.',
    audience: {
        '@type': 'BusinessAudience',
        audienceType: isEn ? 'Any B2B business in Mexico (distributors, wholesalers, manufacturers, service providers, SaaS, agencies)' : 'Cualquier negocio B2B en México (distribuidoras, mayoristas, manufactura, servicios, SaaS, agencias)',
    },
    creator: { '@id': 'https://flouvia.com/#organization' },
    provider: { '@id': 'https://flouvia.com/#organization' },
    offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: isEn ? 'USD' : 'MXN',
        description: isEn ? 'Free plan, forever — no credit card required.' : 'Plan gratis para siempre — sin tarjeta de crédito.',
    },
    featureList: isEn
        ? ['Negotiated B2B pricing', 'One-click quote approval', 'Real-time view tracking', 'Automated CFDI 4.0 e-invoicing', 'Net 30/60 credit terms', 'Public API & webhooks']
        : ['Precios negociados B2B', 'Aprobación de cotizaciones en un clic', 'Seguimiento en tiempo real', 'CFDI 4.0 automático', 'Términos de crédito Net 30/60', 'API pública y webhooks'],
};

// Misma fuente (claves faq.1..faq.8 de ui.ts) que consume <Faq /> — el
// schema queda garantizado a coincidir con el contenido visible.
const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: Array.from({ length: 8 }, (_, i) => i + 1).map((n) => ({
        '@type': 'Question',
        name: t(`faq.${n}.q` as any),
        acceptedAnswer: {
            '@type': 'Answer',
            text: t(`faq.${n}.a` as any),
        },
    })),
};
---

<Layout title={title} description={description}>
    <script
        slot="head"
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify(orgSchema)}
    />
    <script
        slot="head"
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify(softwareSchema)}
    />
    <script
        slot="head"
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify(howToSchema)}
    />
    <script
        slot="head"
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify(faqSchema)}
    />
    <Nav />
    <main>
        <Hero />
        <Features />
        <AdvancedFeatures />
        <Steps />
        <CtaDuo />
        <ClientView />
        <Pricing />
        <Faq />
    </main>
    <Footer />
</Layout>

<!-- Gate anti-FOUC + estilos de los masked line reveals -->
<style is:global>
    .js-anim .reveal,
    .js-anim .reveal-mockup { opacity: 0; }

    /* Masked line reveal (Linear-style): cada línea del título sube desde
       una máscara con overflow hidden. Los spans los inyecta el JS. */
    .m-line { display: block; overflow: hidden; }
    .m-line-in { display: inline-block; will-change: transform; }
</style>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener('DOMContentLoaded', () => {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // ───────────────────────── COUNT-UP util ─────────────────────────
        const mxn = (n: number, dec: number) =>
            '$' + new Intl.NumberFormat('es-MX', { minimumFractionDigits: dec, maximumFractionDigits: dec }).format(n);
        const countUp = (el: HTMLElement, target: number, dec: number, dur = 1.3) => {
            const obj = { v: 0 };
            return gsap.to(obj, {
                v: target, duration: dur, ease: 'power2.out',
                onUpdate: () => { el.textContent = mxn(obj.v, dec); },
            });
        };

        if (reduced) {
            gsap.set('.reveal, .reveal-mockup', { opacity: 1, y: 0 });
            return; // números muestran su valor final del HTML; nada se anima
        }

        // ───────────────────── MASKED LINE REVEALS (Linear) ─────────────────────
        // Envuelve cada línea (separada por <br>) en una máscara y la sube.
        // Los títulos marcados dejan de participar del reveal genérico.
        const wrapLines = (el: HTMLElement): HTMLElement[] => {
            const parts = el.innerHTML.split(/<br\s*\/?>/i);
            el.innerHTML = parts
                .map(p => `<span class="m-line"><span class="m-line-in">${p.trim()}</span></span>`)
                .join('');
            return Array.from(el.querySelectorAll<HTMLElement>('.m-line-in'));
        };

        const maskTargets = gsap.utils.toArray<HTMLElement>(
            '.ft-title, .steps-title, .cv-title, .pr-title, .faq-title, .fc-title'
        );
        const maskedSet = new Set<HTMLElement>(maskTargets);

        maskTargets.forEach((el) => {
            const lines = wrapLines(el);
            gsap.set(lines, { yPercent: 115 });
            gsap.set(el, { opacity: 1 }); // el gate ya no lo oculta; lo ocultan las máscaras
            ScrollTrigger.create({
                trigger: el, start: 'top 86%', once: true,
                onEnter: () => gsap.to(lines, {
                    yPercent: 0, duration: 1.0, ease: 'power3.out', stagger: 0.09,
                }),
            });
        });

        // ───────────────────────── HERO (en carga) ─────────────────────────
        const heroTitleLines = document.querySelectorAll<HTMLElement>('.hero-title .m-line-in');
        const heroReveals = gsap.utils.toArray<HTMLElement>('.hero .reveal').filter(el => !maskedSet.has(el));
        gsap.set(heroReveals, { y: 16 });

        const heroTl = gsap.timeline({ delay: 0.15, defaults: { ease: 'power2.out' } });
        heroTl
            .to('.hero .hero-pill', { opacity: 1, y: 0, duration: 0.8 }, 0)
            .to('.hero .hero-desc', { opacity: 1, y: 0, duration: 0.9 }, 0.45)
            .to('.hero .hero-actions', { opacity: 1, y: 0, duration: 0.9 }, 0.65)
            .to('.hero .hero-microcopy', { opacity: 1, y: 0, duration: 0.9 }, 0.75);

        // Mockup del hero: entra con perspectiva y se ASIENTA al hacer scroll (Stripe).
        const heroMockup = document.querySelector<HTMLElement>('.hero .reveal-mockup');
        const heroMk = document.querySelector<HTMLElement>('.hero .mockup');
        if (heroMockup && heroMk) {
            gsap.set(heroMk, { transformPerspective: 1400, transformOrigin: 'center top' });
            gsap.set(heroMockup, { y: 50 });
            gsap.set(heroMk, { rotationX: 9 });
            gsap.to(heroMockup, { opacity: 1, y: 0, duration: 1.3, ease: 'power3.out', delay: 0.55 });
            // settle: la perspectiva se aplana conforme el mockup viaja hacia el centro
            gsap.to(heroMk, {
                rotationX: 0, ease: 'none',
                scrollTrigger: { trigger: heroMockup, start: 'top 88%', end: 'top 32%', scrub: 0.6 },
            });
        }

        // ───────── HERO DEMO INTERACTIVO: Creas → Envías → La ven → Aprueban → Facturas ─────────
        // El visitante recorre el flujo con los botones de paso; además auto-avanza
        // como tour guiado y se pausa al pasar el mouse. El HTML por defecto es el
        // estado final (completo) → sin JS / reduced-motion el mockup queda estático
        // (los botones de paso se ocultan por CSS en reduced-motion).
        const mkStatus = document.getElementById('mkStatus');
        const mkToast = document.getElementById('mkToast');
        const mkChip = document.getElementById('mkChip');
        const demoEl = document.getElementById('heroDemo');
        const stepEls = Array.from(document.querySelectorAll<HTMLButtonElement>('.demo-step'));
        const tlItems = Array.from(document.querySelectorAll<HTMLElement>('.mk-tl-item[data-story]'));
        const stpItems = Array.from(document.querySelectorAll<HTMLElement>('.mk-stp[data-story]'));

        if (mkStatus && mkToast && mkChip && demoEl && stepEls.length) {
            const DWELL = 2.7;
            const fills = stepEls.map((s) => s.querySelector<HTMLElement>('.ds-fill')!);
            const STAGES = [
                { badge: ['mk-badge-draft', 'Borrador'],  on: ['created'],                                  toast: false, chip: false },
                { badge: ['mk-badge-sent', 'Enviada'],    on: ['created', 'sent'],                          toast: false, chip: false },
                { badge: ['mk-badge-viewed', 'Vista'],    on: ['created', 'sent', 'viewed'],                toast: true,  chip: false },
                { badge: ['mk-badge-ok', 'Aprobada'],     on: ['created', 'sent', 'viewed', 'approved'],    toast: false, chip: false },
                { badge: ['mk-badge-ok', 'Facturada'],    on: ['created', 'sent', 'viewed', 'approved'],    toast: false, chip: true },
            ];
            let active = 0, paused = false, fillTween: gsap.core.Tween | null = null;

            const applyStage = (i: number, animate: boolean) => {
                const st = STAGES[i];
                mkStatus.className = `mk-badge ${st.badge[0]}`;
                mkStatus.textContent = `● ${st.badge[1]}`;
                if (animate) gsap.fromTo(mkStatus, { scale: 0.84, opacity: 0.4 }, { scale: 1, opacity: 1, duration: 0.45, ease: 'power2.out' });
                tlItems.forEach((it) => it.classList.toggle('is-pending', !st.on.includes(it.dataset.story || '')));
                stpItems.forEach((it) => it.classList.toggle('is-pending', !st.on.includes(it.dataset.story || '')));
                const dur = animate ? 0.5 : 0;
                gsap.to(mkToast, { opacity: st.toast ? 1 : 0, duration: dur });
                gsap.to(mkChip, { opacity: st.chip ? 1 : 0, y: st.chip ? 0 : -10, duration: dur });
            };
            const render = (i: number, animate = true) => {
                active = i;
                applyStage(i, animate);
                stepEls.forEach((b, idx) => {
                    b.classList.toggle('is-active', idx === i);
                    b.setAttribute('aria-selected', idx === i ? 'true' : 'false');
                });
            };
            const go = (i: number) => {
                render(i, true);
                fillTween?.kill();
                gsap.set(fills, { scaleX: 0 });
                fillTween = gsap.fromTo(fills[i], { scaleX: 0 }, {
                    scaleX: 1, duration: DWELL, ease: 'none',
                    onComplete: () => { if (!paused) go((i + 1) % STAGES.length); },
                });
            };

            render(0, false); // estado inicial inmediato (sin pop), evita flash del estado final

            stepEls.forEach((b, idx) => b.addEventListener('click', () => {
                if (paused) { render(idx, true); fillTween?.kill(); gsap.set(fills, { scaleX: 0 }); }
                else go(idx);
            }));
            demoEl.addEventListener('mouseenter', () => { paused = true; fillTween?.kill(); });
            demoEl.addEventListener('mouseleave', () => { paused = false; go(active); });
            gsap.delayedCall(2.0, () => { if (!paused) go(0); });
        }

        // Trust strip del hero (está bajo el fold normalmente)
        const heroTrust = document.querySelector<HTMLElement>('.hero-trust');
        if (heroTrust) {
            const logos = heroTrust.querySelectorAll('.trust-label, .trust-logos > *, .trust-usecase');
            gsap.set(heroTrust, { opacity: 1, y: 0 });
            gsap.set(logos, { opacity: 0, y: 8 });
            ScrollTrigger.create({
                trigger: heroTrust, start: 'top 92%', once: true,
                onEnter: () => gsap.to(logos, { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out', stagger: 0.05 }),
            });
        }

        // ───────────────────────── REVEALS ON-SCROLL ─────────────────────────
        const scrollReveals = gsap.utils.toArray<HTMLElement>('.reveal')
            .filter((el) => !el.closest('.hero') && !maskedSet.has(el));
        scrollReveals.forEach((el) => {
            gsap.set(el, { y: 18 });
            ScrollTrigger.create({
                trigger: el, start: 'top 88%', once: true,
                // clearProps SOLO de transform — el opacity:1 inline gana sobre el gate.
                onEnter: () => gsap.to(el, { opacity: 1, y: 0, duration: 0.85, ease: 'power2.out', clearProps: 'transform' }),
            });
        });

        const otherMockups = gsap.utils.toArray<HTMLElement>('.reveal-mockup').filter((el) => !el.closest('.hero'));
        otherMockups.forEach((el) => {
            gsap.set(el, { y: 36, scale: 0.985 });
            ScrollTrigger.create({
                trigger: el, start: 'top 85%', once: true,
                onEnter: () => gsap.to(el, { opacity: 1, y: 0, scale: 1, duration: 1.1, ease: 'power3.out' }),
            });
        });

        // ───────────────────────── MICRO-DEMOS DE LOS BENTO ─────────────────────────
        // Editor: el precio negociado "baja" en vivo y el chip de descuento hace pop.
        const evLine = document.querySelector<HTMLElement>('.ev-edit');
        const evPrice = document.querySelector<HTMLElement>('.ev-edit .editorial');
        const evTag = document.querySelector<HTMLElement>('.ev-edit .ev-tag');
        if (evLine && evPrice && evTag) {
            gsap.set(evTag, { scale: 0, transformOrigin: 'center' });
            ScrollTrigger.create({
                trigger: evLine, start: 'top 88%', once: true,
                onEnter: () => {
                    const obj = { v: 191.48 }; // precio de lista antes del −12%
                    const tl = gsap.timeline({ delay: 0.5 });
                    tl.to(obj, {
                        v: 168.5, duration: 1.1, ease: 'power2.out',
                        onUpdate: () => { evPrice.textContent = mxn(obj.v, 2); },
                    }, 0)
                    .fromTo(evLine,
                        { backgroundColor: 'rgba(16,185,129,0.04)' },
                        { backgroundColor: 'rgba(16,185,129,0.16)', duration: 0.4, yoyo: true, repeat: 1, onComplete: () => gsap.set(evLine, { clearProps: 'backgroundColor' }) },
                        0.5)
                    .fromTo(evTag, { scale: 0.4, opacity: 0 }, { scale: 1, opacity: 1, duration: 0.5, ease: 'power3.out' }, 0.7);
                },
            });
        }

        // CFDI: el check de timbrado entra con un pop sutil.
        const cfdiCheck = document.querySelector<HTMLElement>('.cfdi-visual .cfdi-check');
        if (cfdiCheck) {
            ScrollTrigger.create({
                trigger: cfdiCheck, start: 'top 90%', once: true,
                onEnter: () => gsap.fromTo(cfdiCheck, { scale: 0, opacity: 0 }, { scale: 1, opacity: 1, duration: 0.55, ease: 'power3.out', delay: 0.45, clearProps: 'transform,opacity' }),
            });
        }

        // ───────────────────────── COUNT-UP (números) ─────────────────────────
        gsap.utils.toArray<HTMLElement>('[data-countup]').forEach((el) => {
            const target = parseFloat(el.dataset.countup || '0');
            const dec = parseInt(el.dataset.decimals || '0', 10);
            ScrollTrigger.create({
                trigger: el, start: 'top 92%', once: true,
                onEnter: () => countUp(el, target, dec, 1.3),
            });
        });

        // ───────────────────────── DEMO DEL TELÉFONO ─────────────────────────
        const stage = document.querySelector<HTMLElement>('.cv-visual');
        if (stage) {
            const amount = stage.querySelector<HTMLElement>('#cvAmount');
            const items = gsap.utils.toArray<HTMLElement>('.cv-visual .ps-item');
            const approve = stage.querySelector<HTMLElement>('#cvApprove');
            const ring = stage.querySelector<HTMLElement>('.ps-ring');
            const cursor = stage.querySelector<HTMLElement>('#cvCursor');
            const success = stage.querySelector<HTMLElement>('#cvSuccess');
            const check = stage.querySelector<SVGPathElement>('#cvCheck');

            if (amount && approve && cursor && success && check) {
                const len = check.getTotalLength();
                gsap.set(check, { strokeDasharray: len, strokeDashoffset: len });
                gsap.set(items, { opacity: 0, y: 10 });
                gsap.set(cursor, { opacity: 0 });

                const center = (el: HTMLElement) => ({
                    x: el.offsetLeft + el.offsetWidth * 0.62,
                    y: el.offsetTop + el.offsetHeight / 2,
                });

                const playLoop = () => {
                    const t = center(approve);
                    const loop = gsap.timeline({ repeat: -1, repeatDelay: 3.4 });
                    loop
                        .set(success, { opacity: 0 })
                        .set(check, { strokeDashoffset: len })
                        .set(ring, { opacity: 0, scale: 0.85, transformOrigin: 'center' })
                        .set(cursor, { opacity: 0, x: t.x + 46, y: t.y + 88 })
                        .to(cursor, { opacity: 1, duration: 0.3 })
                        .to(cursor, { x: t.x, y: t.y, duration: 1.0, ease: 'power3.inOut' })
                        .to(approve, { scale: 0.95, duration: 0.12 }, '-=0.04')
                        .to(ring, { opacity: 1, scale: 1.18, duration: 0.5, ease: 'power2.out' }, '<')
                        .to(approve, { scale: 1, duration: 0.3, ease: 'power2.out' })
                        .to(ring, { opacity: 0, duration: 0.35 }, '<')
                        .to(success, { opacity: 1, duration: 0.4 }, '-=0.1')
                        .to(check, { strokeDashoffset: 0, duration: 0.6, ease: 'power2.out' }, '<0.12')
                        .to(cursor, { opacity: 0, duration: 0.3 }, '<')
                        .to(success, { opacity: 0, duration: 0.5 }, '+=1.7');
                };

                ScrollTrigger.create({
                    trigger: stage, start: 'top 72%', once: true,
                    onEnter: () => {
                        const intro = gsap.timeline({ onComplete: playLoop });
                        intro.add(countUp(amount, 196469.20, 2, 1.5), 0);
                        intro.to(items, { opacity: 1, y: 0, stagger: 0.08, duration: 0.5, ease: 'power2.out' }, 0.25);
                    },
                });
            }
        }

        // ───────────────────────── PARALLAX (scrub sutil) ─────────────────────────
        const parallax = (sel: string, amount: number, triggerSel: string) => {
            const el = document.querySelector<HTMLElement>(sel);
            const trig = document.querySelector<HTMLElement>(triggerSel);
            if (!el || !trig) return;
            gsap.to(el, {
                yPercent: amount, ease: 'none',
                scrollTrigger: { trigger: trig, start: 'top bottom', end: 'bottom top', scrub: 1 },
            });
        };
        parallax('.hero-mesh', 18, '.hero');

        // ───────────────────────── SMOOTH SCROLL + REFRESH ─────────────────────────
        document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
            a.addEventListener('click', (e) => {
                const id = a.getAttribute('href');
                if (!id || id === '#') return;
                const target = document.querySelector(id);
                if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
            });
        });

        Promise.all([
            new Promise<void>((r) => window.addEventListener('load', () => r(), { once: true })),
            (document as any).fonts?.ready ?? Promise.resolve(),
        ]).then(() => setTimeout(() => ScrollTrigger.refresh(), 120));
    });
</script>
