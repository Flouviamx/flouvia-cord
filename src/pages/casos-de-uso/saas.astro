---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import RampShader from '../../components/soluciones/RampShader.jsx';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
const t = useTranslations(lang);

const metaTitle = "Cord para SaaS B2B | Gestión de Suscripciones y Contratos";
const metaDesc = "Optimiza tus cobros recurrentes y contratos empresariales con Cord. La plataforma ideal para startups SaaS y negocios de software.";
---

<Layout title={metaTitle} description={metaDesc}>
    <Nav />
    
    <main class="use-case-main">
        <!-- HERO (shader full-bleed, Light) -->
        <header class="uc-hero">
            <div class="uc-hero-bg">
                <RampShader client:only="react" variant="blue" />
            </div>
            <div class="uc-container uc-hero-inner">
                <div class="uc-hero-content">
                    <h1 class="uc-title reveal">Gestión de suscripciones para el software moderno</h1>
                    <p class="uc-sub reveal">
                        Automatiza los pagos recurrentes, unifica tus contratos B2B y emite CFDI 4.0 en automático. Construido para empresas SaaS de alto crecimiento.
                    </p>
                    <div class="uc-actions reveal">
                        <a href="/registro" class="btn-luxe">
                            <span>Empezar ahora</span>
                            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            <div class="btn-shimmer"></div>
                        </a>
                        <a href="/contacto/ventas" class="btn-ghost"><span>Contactar a ventas</span></a>
                    </div>
                </div>
            </div>
        </header>

        <!-- LOGOS / TRUST -->
        <section class="uc-trust reveal">
            <p>Empresas de SaaS innovadoras crecen con Cord</p>
            <div class="uc-logos">
                <span class="trust-logo">Linear</span>
                <span class="trust-logo">Vercel</span>
                <span class="trust-logo">Stripe</span>
                <span class="trust-logo">Notion</span>
            </div>
        </section>

        <!-- FEATURES GRID -->
        <section class="uc-features">
            <div class="uc-container">
                <div class="uc-features-header reveal">
                    <h2>Diseñado para la velocidad y la escala</h2>
                    <p>Todo lo que tu SaaS necesita para gestionar su revenue, desde el primer cliente hasta tu IPO.</p>
                </div>

                <div class="uc-bento-grid">
                    <div class="uc-bento-card reveal">
                        <div class="uc-bento-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg></div>
                        <h3>Billing Engine Potente</h3>
                        <p>Soporta modelos de precios complejos: por asiento, por uso, tiers, o tarifa plana. Cord se encarga de prorrateos y upgrades automáticamente.</p>
                    </div>
                    <div class="uc-bento-card reveal">
                        <div class="uc-bento-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"></path><path d="M14 2v6h6"></path><path d="M16 13H8"></path><path d="M16 17H8"></path><path d="M10 9H8"></path></svg></div>
                        <h3>Facturación Inteligente (CFDI)</h3>
                        <p>Genera facturas mexicanas (CFDI 4.0) por cada cobro de suscripción recurrente sin intervención manual ni recaptura de RFCs.</p>
                    </div>
                    <div class="uc-bento-card reveal">
                        <div class="uc-bento-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg></div>
                        <h3>API First</h3>
                        <p>Integra el flujo de suscripciones directamente en tu app con nuestra API REST, o usa webhooks para mantener tu base de datos sincronizada.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA SECTION -->
        <section class="uc-cta-section">
            <div class="uc-container">
                <div class="uc-cta-box reveal">
                    <h2>¿Listo para escalar tu SaaS?</h2>
                    <p>Únete a las empresas que ya automatizan su pipeline B2B con Cord.</p>
                    <a href="/registro" class="btn-luxe">Comenzar gratis</a>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Layout>

<style>
    /* VARIABLES Y UTILIDADES GLOBALES PARA USE CASES */
    .use-case-main {
        background: #fff;
        padding-top: 0;
        overflow-x: hidden;
        color: #425466; /* Texto Stripe */
    }

    .uc-container {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 5%;
    }

    /* ── HERO SECTION (shader full-bleed) ── */
    .uc-hero {
        position: relative;
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        align-items: center;
        padding: 8rem 0 4rem;
        background: #ffffff;
        overflow: hidden;
        border-bottom: 1px solid #e6ebf1;
    }

    /* Shader background (R3F) — fondo absoluto del hero */
    .uc-hero-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
    }
    /* Fade suave hacia el blanco del contenido (legibilidad del texto) */
    .uc-hero-bg::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(105deg, rgba(255,255,255,0.92) 0%, rgba(255,255,255,0.55) 38%, rgba(255,255,255,0) 72%);
        pointer-events: none;
        z-index: 2;
    }

    .uc-hero-inner {
        position: relative;
        z-index: 1;
        width: 100%;
    }

    .uc-hero-content {
        max-width: 640px;
    }

    .uc-title {
        font-size: clamp(2.2rem, 4vw, 3.8rem);
        font-weight: 800;
        color: #0a2540;
        line-height: 1.1;
        letter-spacing: -0.04em;
        margin-bottom: 1.2rem;
        text-wrap: balance;
    }

    .uc-sub {
        font-size: 1.15rem;
        color: #425466;
        line-height: 1.6;
        margin-bottom: 2rem;
        max-width: 90%;
    }

    .uc-actions {
        display: flex;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
    }

    /* ── BUTTONS (estilo soluciones/startups) ── */
    .btn-luxe {
        position: relative;
        display: inline-flex; align-items: center; justify-content: center;
        background: #0a2540; color: #fff;
        padding: 18px 38px; border-radius: 100px;
        font-size: 0.95rem; font-weight: 600; text-decoration: none;
        overflow: hidden;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 8px 24px rgba(10, 37, 64, 0.2);
    }
    .btn-luxe span { position: relative; z-index: 2; }
    .btn-arrow {
        position: relative; z-index: 2; display: inline-block;
        width: 16px; height: 16px; margin-left: 6px;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .btn-luxe:hover .btn-arrow { transform: translateX(4px); }
    .btn-shimmer {
        position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.18), transparent);
        transform: skew(-20deg); transition: 0s; z-index: 1;
    }
    .btn-luxe:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(10, 37, 64, 0.3);
    }
    .btn-luxe:active {
        transform: translateY(-1px);
        box-shadow: 0 2px 4px rgba(10, 37, 64, 0.1);
    }
    .btn-luxe:hover .btn-shimmer {
        left: 150%;
        transition: left 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .btn-ghost {
        display: inline-flex; align-items: center; gap: 9px;
        color: #0a2540; text-decoration: none;
        font-size: 1rem; font-weight: 600;
        padding: 15px 26px; border-radius: 100px;
        border: 1px solid rgba(10, 37, 64, 0.15);
        background: rgba(10, 37, 64, 0.03);
        transition: background 0.3s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease;
    }
    .btn-ghost:hover {
        background: rgba(10, 37, 64, 0.08);
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.05);
    }

    /* ── TRUST LOGOS ── */
    .uc-trust {
        text-align: center;
        padding: 3rem 5%;
        background: #fff;
    }
    .uc-trust p {
        font-size: 0.9rem; font-weight: 600; color: #687385; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1.5rem;
    }
    .uc-logos {
        display: flex; justify-content: center; gap: 3rem; flex-wrap: wrap; align-items: center;
    }
    .trust-logo {
        font-size: 1.4rem; font-weight: 800; color: #c1c9d2; letter-spacing: -0.5px;
    }

    /* ── FEATURES ── */
    .uc-features {
        padding: 6rem 0 6rem;
        background: #fff;
    }
    .uc-features-header {
        text-align: center;
        max-width: 600px;
        margin: 0 auto 4rem;
    }
    .uc-features-header h2 { font-size: 2.2rem; font-weight: 800; color: #0a2540; margin-bottom: 1rem; }
    .uc-features-header p { font-size: 1.1rem; color: #425466; line-height: 1.6; }

    .uc-bento-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }
    .uc-bento-card {
        background: #fff;
        padding: 2.5rem;
        border-radius: 16px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 0 0 1px rgba(10,37,64,0.05);
        transition: transform 0.3s, box-shadow 0.3s;
    }
    .uc-bento-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 0 0 1px rgba(10,37,64,0.05);
    }
    .uc-bento-icon {
        width: 48px; height: 48px;
        background: #f6f9fc;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 1.5rem;
    }
    .uc-bento-card h3 { font-size: 1.2rem; font-weight: 700; color: #0a2540; margin-bottom: 0.8rem; }
    .uc-bento-card p { font-size: 0.95rem; color: #425466; line-height: 1.6; }

    /* ── CTA SECTION ── */
    .uc-cta-section {
        padding: 4rem 0 8rem;
        background: #fff;
    }
    .uc-cta-box {
        background: #0a2540;
        border-radius: 20px;
        padding: 4rem 2rem;
        text-align: center;
        color: #fff;
        position: relative;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(10,37,64,0.25);
    }
    .uc-cta-box::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: radial-gradient(circle at center top, rgba(16,185,129,0.15), transparent 70%);
        pointer-events: none;
    }
    .uc-cta-box h2 { font-size: 2.2rem; font-weight: 800; margin-bottom: 1rem; position: relative; z-index: 1; }
    .uc-cta-box p { font-size: 1.1rem; color: #aab7c4; margin-bottom: 2rem; position: relative; z-index: 1; }
    .uc-cta-box .btn-luxe { background: #10b981; color: #fff; box-shadow: 0 4px 14px rgba(16,185,129,0.3); }
    .uc-cta-box .btn-luxe:hover { background: #059669; box-shadow: 0 6px 20px rgba(16,185,129,0.4); }

    @media (max-width: 900px) {
        .uc-hero { padding: 9rem 0 6rem; }
        .uc-hero-content { max-width: 100%; }
        .uc-title { font-size: 2.5rem; }
        .uc-bento-grid { grid-template-columns: 1fr; }
    }
</style>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener('DOMContentLoaded', () => {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if(reduced) return;

        gsap.utils.toArray('.reveal').forEach((el: any) => {
            gsap.fromTo(el, { opacity: 0, y: 20 }, {
                opacity: 1, y: 0, duration: 0.8, ease: 'power2.out',
                scrollTrigger: { trigger: el, start: 'top 85%' }
            });
        });
    });
</script>
