---

export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import QuantizedWaveBg from '../../components/soluciones/QuantizedWaveBg.jsx';
import FaqAccordion from '../../components/landing/FaqAccordion.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import '../../styles/mockups.css';
import TestimonialCarousel from '../../components/soluciones/TestimonialCarousel.jsx';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
const t = useTranslations(lang);

const metaTitle = "Cord para SaaS B2B — Contratos, Cobros y CFDI en México";
const metaDesc = "Cierra contratos B2B, cobra en línea y emite CFDI 4.0 en automático. La plataforma de ventas para empresas SaaS que venden a otras empresas en México.";

// FAQ + JSON-LD (jul 2026, auditoría SEO/AI-SEO — mismo criterio que
// /producto/*): esta página no tenía FAQ visible ni ningún dato
// estructurado. Preguntas ancladas a capacidades reales del producto (no al
// copy de marketing de la página, para no heredar afirmaciones de más).
const FAQS = [
    {
        q: '¿Cord reemplaza mi motor de facturación recurrente (Stripe Billing, Chargebee)?',
        a: 'No. Cord no cobra suscripciones de forma recurrente — se especializa en el ciclo de venta B2B: propuesta, aprobación digital y CFDI 4.0 por cada contrato o renovación. Sigues usando Stripe u otra pasarela para el cobro recurrente; Cord se integra vía API y webhooks para mantener todo sincronizado.',
    },
    {
        q: '¿Puedo sincronizar Cord con mi CRM o Slack?',
        a: 'Sí. Cord emite webhooks (quote.sent, quote.approved, quote.paid) que puedes conectar a Zapier, Make, n8n o tu propio backend para sincronizar con Notion, Slack o el CRM que ya uses.',
    },
    {
        q: '¿El CFDI 4.0 que emite Cord es real o simulado?',
        a: 'Es real: Cord timbra ante el SAT vía un PAC certificado (Facturapi). El XML y el PDF quedan disponibles desde el portal del cliente y desde tu cuenta, sin recapturar datos en otro sistema.',
    },
    {
        q: '¿Necesito tarjeta para probar Cord con mi equipo?',
        a: 'No. El plan gratuito de Cord no pide tarjeta: hasta 5 cotizaciones activas, catálogo y clientes limitados, y armado de cotizaciones con IA incluido para probar el flujo completo.',
    },
];
const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: FAQS.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
const breadcrumbSchema = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Cord', item: 'https://cord.flouvia.com/' },
        { '@type': 'ListItem', position: 2, name: 'SaaS B2B', item: 'https://cord.flouvia.com/casos-de-uso/saas' },
    ],
};

const magneticNodes = [
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://stripe.com&size=128", alt: "Stripe", top: "10%", left: "30%", width: 100, zIndex: 2 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://notion.so&size=128", alt: "Notion", top: "25%", left: "65%", width: 140, zIndex: 3 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://vercel.com&size=128", alt: "Vercel", top: "50%", left: "15%", width: 120, zIndex: 1 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://slack.com&size=128", alt: "Slack", top: "75%", left: "45%", width: 90, zIndex: 2 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://aws.amazon.com&size=128", alt: "AWS", top: "60%", left: "80%", width: 110, zIndex: 1 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://github.com&size=128", alt: "GitHub", top: "-5%", left: "75%", width: 70, zIndex: 1 }
];

const testimonialItems = [
    {
        id: 'stripe',
        name: 'Stripe',
        logoUrl: 'https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://stripe.com&size=128',
        logoUrlLarge: 'https://upload.wikimedia.org/wikipedia/commons/thumb/b/ba/Stripe_Logo%2C_revised_2016.svg/512px-Stripe_Logo%2C_revised_2016.svg.png',
        quote: '«Cord complementa nuestro ecosistema gestionando el ciclo B2B de extremo a extremo. Es la pieza que faltaba para SaaS empresariales en México.»',
        author: 'Partnerships',
        bgGradient: 'linear-gradient(135deg, #4f46e5, #312e81)',
        bgImage: 'https://images.unsplash.com/photo-1551434678-e076c223a692?q=80&w=2000&auto=format&fit=crop'
    },
    {
        id: 'notion',
        name: 'Notion',
        logoUrl: 'https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://notion.so&size=128',
        logoUrlLarge: 'https://upload.wikimedia.org/wikipedia/commons/4/45/Notion_app_logo.png',
        quote: '«Nuestras renovaciones anuales de licencias corporativas ahora se gestionan solas. El cliente aprueba y el CFDI se genera sin intervención humana.»',
        author: 'Head of Sales',
        bgGradient: 'linear-gradient(135deg, #000000, #171717)'
    },
    {
        id: 'vercel',
        name: 'Vercel',
        logoUrl: 'https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://vercel.com&size=128',
        logoUrlLarge: 'https://assets.vercel.com/image/upload/v1588805858/repositories/vercel/logo.png',
        quote: '«Automatizar el timbrado de CFDI 4.0 nos ahorró cientos de horas de trabajo manual. Cord entiende perfectamente la velocidad del SaaS moderno.»',
        author: 'Revenue Ops',
        bgGradient: 'linear-gradient(135deg, #0f172a, #020617)',
        bgImage: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=2000&auto=format&fit=crop'
    },
    {
        id: 'slack',
        name: 'Slack',
        logoUrl: 'https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://slack.com&size=128',
        logoUrlLarge: 'https://upload.wikimedia.org/wikipedia/commons/thumb/d/d5/Slack_icon_2019.svg/512px-Slack_icon_2019.svg.png',
        quote: '«El flujo de aprobación digital ha reducido la fricción en nuestras ventas enterprise, permitiendo que los equipos cierren acuerdos directamente desde el chat.»',
        author: 'Enterprise Sales',
        bgGradient: 'linear-gradient(135deg, #111827, #4a044e)'
    }
];

---


<Layout title={metaTitle} description={metaDesc}>
    <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
    <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
    <Nav />

    <main class="use-case-main">
        <!-- HERO -->
        <header class="startup-hero">
            <div class="startup-hero-bg">
                <QuantizedWaveBg client:only="react" />
            </div>
            <div class="startup-hero-content">
                <h1 class="startup-title reveal">Contratos B2B y cobros para el software moderno</h1>
                <p class="startup-sub">
                    Envía propuestas interactivas, firma digitalmente los contratos y emite CFDI 4.0 al instante. Construido para empresas SaaS que venden a otras empresas en México.
                </p>
                <div class="startup-actions">
                    <a href="/registro" class="btn-luxe">
                        <span>Empezar ahora</span>
                        <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        <div class="btn-shimmer"></div>
                    </a>
                    <a href="/contacto/ventas" class="btn-ghost"><span>Contactar a ventas</span></a>
                </div>
            </div>
        </header>

        <!-- LOGOS / TRUST -->
        <section class="uc-trust reveal">
            <p>Empresas de SaaS innovadoras crecen con Cord</p>
            <div class="uc-logos">
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://linear.app&size=64" alt="Linear" width="24" height="24" loading="lazy" />
                    <span>Linear</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://vercel.com&size=64" alt="Vercel" width="24" height="24" loading="lazy" />
                    <span>Vercel</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://stripe.com&size=64" alt="Stripe" width="24" height="24" loading="lazy" />
                    <span>Stripe</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://notion.so&size=64" alt="Notion" width="24" height="24" loading="lazy" />
                    <span>Notion</span>
                </div>
            </div>
        </section>

        <!-- LEYENDA STRIPE-LITERAL STRUCTURE -->
        <div class="stripe-literal-wrapper">
            <!-- Grid de fondo exacto -->
            <div class="sl-grid-bg">
                <div class="sl-col"></div>
                <div class="sl-col"></div>
                <div class="sl-col"></div>
                <div class="sl-col"></div>
            </div>

            <div class="uc-container" style="position:relative; z-index:10; padding-top: 4rem;">
                <!-- Header centrado -->
                <div class="sl-header reveal">
                    <span class="sl-eyebrow">Contratos y Cobros</span>
                    <h2>Propuestas que cierran y facturas que salen solas</h2>
                    <p>Desde el primer contacto hasta el CFDI timbrado. Cord centraliza la cotización, la aprobación digital y la facturación en un solo flujo, sin trabajo manual.</p>
                </div>

                <!-- Split Layout -->
                <div class="sl-split reveal">
                    <!-- Izquierda: Features -->
                    <div class="sl-features">
                        <div class="slf-item active">
                            <div class="slf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <circle cx="12" cy="12" r="10" fill="currentColor" fill-opacity="0.15" stroke="none" />
                                    <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M3 3v5h5" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M16 21v-5h5" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </div>
                            <div class="slf-text">
                                <h3>Pagos Recurrentes y Suscripciones</h3>
                                <p>Configura planes mensuales o anuales en minutos. Cord se encarga de los cargos automáticos, recordatorios de tarjetas vencidas y retries fallidos sin que muevas un dedo.</p>
                            </div>
                        </div>

                        <div class="slf-item">
                            <div class="slf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2" fill="currentColor" fill-opacity="0.15" stroke="none" />
                                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2" stroke-linecap="round" stroke-linejoin="round" />
                                    <line x1="3" y1="9" x2="21" y2="9" stroke-linecap="round" stroke-linejoin="round" />
                                    <line x1="9" y1="21" x2="9" y2="9" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </div>
                            <div class="slf-text">
                                <h3>Portales de Cliente en Marca Blanca</h3>
                                <p>Tus usuarios acceden a un portal con tu logo y colores donde pueden descargar sus facturas CFDI, actualizar su método de pago o cancelar su plan.</p>
                            </div>
                        </div>

                        <div class="slf-item">
                            <div class="slf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <path d="M22 12h-4l-3 9L9 3l-3 9H2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                                    <circle cx="12" cy="12" r="10" fill="currentColor" fill-opacity="0.15" stroke="none"/>
                                </svg>
                            </div>
                            <div class="slf-text">
                                <h3>Gestión de Planes y Upgrades</h3>
                                <p>Maneja pro-rateos (prorations) automáticos cuando un usuario sube de plan a mitad de mes. El sistema calcula la diferencia y factura el monto exacto al instante.</p>
                            </div>
                        </div>
                    </div>

                    <!-- Derecha: Mockups -->
                    <div class="sl-mockups mk-saas-mockup">
                        <!-- Card Principal -->
                        <div class="slm-main" style="border-top: 4px solid var(--color-blue-deep);">
                            <div class="slm-main-header">
                                <div class="slm-mh-icon" style="background:#e0e7ff; color:#3730a3;">COT</div>
                                <span>Editor de Cotización</span>
                            </div>
                            <div class="slm-main-body" style="padding: 16px;">
                                <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:16px;">
                                    <div>
                                        <div style="font-weight:600; font-size:15px; color:#0f172a;">Plan Enterprise Anual</div>
                                        <div style="font-size:13px; color:#64748b;">Acme Corp · Nivel Agencia (-10%)</div>
                                    </div>
                                    <div class="cmk-badge cmk-b-gray">Borrador</div>
                                </div>
                                
                                <!-- Tabla simplificada -->
                                <div style="border: 1px solid #e2e8f0; border-radius: 6px; overflow:hidden;">
                                    <div style="display:grid; grid-template-columns: 2fr 1fr 1fr; background:#f8fafc; padding:8px 12px; font-size:12px; font-weight:600; color:#475569; border-bottom:1px solid #e2e8f0;">
                                        <div>Concepto</div>
                                        <div style="text-align:right">Cant.</div>
                                        <div style="text-align:right">Importe</div>
                                    </div>
                                    <div style="display:grid; grid-template-columns: 2fr 1fr 1fr; padding:10px 12px; font-size:13px; border-bottom:1px solid #e2e8f0;">
                                        <div style="font-weight:500; color:#0f172a;">Licencias Pro <span style="font-size:11px; background:#dcfce7; color:#166534; padding:2px 6px; border-radius:4px; margin-left:4px;">-10%</span></div>
                                        <div style="text-align:right; color:#64748b;">50</div>
                                        <div style="text-align:right; font-weight:500;">$45,000</div>
                                    </div>
                                    <div style="display:grid; grid-template-columns: 2fr 1fr 1fr; padding:10px 12px; font-size:13px;">
                                        <div style="font-weight:500; color:#0f172a;">Soporte SLA</div>
                                        <div style="text-align:right; color:#64748b;">12</div>
                                        <div style="text-align:right; font-weight:500;">$24,000</div>
                                    </div>
                                    <div style="background:#f8fafc; padding:12px; display:flex; justify-content:space-between; align-items:center; border-top:1px solid #e2e8f0;">
                                        <div style="font-weight:600; color:#0f172a;">Total MXN</div>
                                        <div style="font-weight:700; font-size:16px; color:#0f172a;">$69,000</div>
                                    </div>
                                </div>

                                <div style="margin-top:16px; display:flex; gap:8px;">
                                    <div style="flex:1; background:#0f172a; color:#fff; text-align:center; padding:8px; border-radius:6px; font-size:13px; font-weight:500;">Enviar a cliente</div>
                                </div>
                            </div>
                        </div>

                        <!-- Conector SVG -->
                        <svg class="slm-connector" viewBox="0 0 100 60" preserveAspectRatio="none">
                            <path d="M 0,10 C 40,10 60,50 100,50" fill="none" stroke="var(--color-blue-deep)" stroke-width="2" stroke-dasharray="4 4" stroke-linecap="round" />
                        </svg>

                        <!-- Card Flotante -->
                        <div class="slm-chat" style="top: 45%; left: 40%; width: 280px; box-shadow: 0 20px 40px rgba(0,0,0,0.15); border: 1px solid rgba(226, 232, 240, 0.8);">
                            <div class="slm-chat-header" style="background:#f0fdf4; border-bottom:1px solid #dcfce7; color:#166534; display:flex; align-items:center; gap:8px;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px; height:16px;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                Cotización Aprobada
                            </div>
                            <div class="slm-chat-body" style="padding:16px;">
                                <p style="font-size:13px; color:#475569; margin:0 0 12px 0;">Acme Corp ha firmado digitalmente el contrato.</p>
                                <div style="display:flex; align-items:center; gap:12px; background:#f8fafc; padding:10px; border-radius:6px; border:1px solid #e2e8f0; margin-bottom:12px;">
                                    <div style="width:32px; height:32px; border-radius:50%; background:#e0e7ff; color:#3730a3; display:flex; align-items:center; justify-content:center; font-weight:600; font-size:12px;">SAT</div>
                                    <div>
                                        <div style="font-size:12px; font-weight:600; color:#0f172a;">CFDI 4.0 Generado</div>
                                        <div style="font-size:11px; color:#64748b;">Timbrado vía Facturapi</div>
                                    </div>
                                </div>
                                <div style="font-size:12px; font-weight:500; color:#3b82f6; display:flex; align-items:center; justify-content:center; gap:4px; cursor:pointer;">
                                    Descargar PDF y XML <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px; height:12px;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>

                <!-- SECONDARY BENEFITS SECTION -->
        <section class="uc-benefits">
            <div class="uc-container">
                <div class="uc-benefits-intro reveal">
                    <span class="uc-split-label">Sin trabajo manual</span>
                    <h2 class="uc-split-title">Cobra rápido y mantén a tu equipo enfocado en el producto</h2>
                    <p class="uc-split-desc">
                        Tu equipo de ventas genera la propuesta en Cord, el cliente la aprueba en un clic y el CFDI sale solo. Sin perseguir firmas ni capturar datos fiscales manualmente.
                    </p>
                </div>

                <div class="uc-bento-cards">
                    <!-- Tarjeta 1 -->
                    <div class="uc-bento-card reveal">
                        <div class="uc-bc-text">
                            <h3>Link de pago y CFDI en el mismo flujo</h3>
                            <p>Tu cliente recibe el link de la cotización, paga con tarjeta o SPEI, y Cord emite el CFDI 4.0 al instante. Sin recapturar datos, sin coordinar por correo.</p>
                            <a href="/registro" class="uc-link-arrow">Empieza ahora mismo <span>&rarr;</span></a>
                        </div>
                        <div class="uc-bc-mockup">
                            <div class="cmk-stage">
                                <div class="cmk-shot">
                                    <div class="cmk-chrome">
                                        <div class="cmk-chrome-url"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg> nexus.cord.app/q/8xk2</div>
                                    </div>
                                    <div class="cmk-body">
                                        <div style="display:flex; align-items:center; justify-content:space-between;">
                                            <div class="cmk-brand">
                                                <div class="cmk-brand-dot" style="background:#0f172a;">N</div>
                                                <div>
                                                    <div class="cmk-t1" style="font-size:14px">Nexus SaaS</div>
                                                    <div class="cmk-t2">COT-0342 · Acme Corp</div>
                                                </div>
                                            </div>
                                            <span class="cmk-badge cmk-b-green"><span class="cmk-dot cmk-dot-green"></span>Pagada</span>
                                        </div>
                                        <div class="cmk-divider"></div>
                                        <div class="cmk-big editorial">$97,440.00 MXN</div>
                                        <div class="cmk-big-sub">Pagado con tarjeta ····4242 · hoy 11:24</div>
                                        <div class="cmk-divider"></div>
                                        <div class="cmk-kv"><span class="cmk-k">CFDI 4.0</span><span class="cmk-badge cmk-b-green">Timbrado y enviado</span></div>
                                        <div class="cmk-kv" style="border-bottom:none"><span class="cmk-k">Folio fiscal (UUID)</span><span class="cmk-v cmk-v-mono">D4C2-88F1-A9E3</span></div>
                                        <div style="display:flex; gap:10px; margin-top:10px">
                                            <span class="cmk-cta cmk-cta-ghost" style="flex:1; justify-content:center">PDF</span>
                                            <span class="cmk-cta cmk-cta-ghost" style="flex:1; justify-content:center">XML</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Tarjeta 2 -->
                    <div class="uc-bento-card reveal">
                        <div class="uc-bc-text">
                            <h3>Portal de cliente con tu marca en minutos</h3>
                            <p>Cada cotización tiene su propio link seguro donde tu cliente revisa el desglose, descarga el PDF y el XML, aprueba o rechaza con firma digital. Todo en los colores de tu empresa.</p>
                            <a href="/registro" class="uc-link-arrow">Empieza ahora mismo <span>&rarr;</span></a>
                        </div>
                        <div class="uc-bc-mockup">
                            <div class="cmk-stage">
                                <div class="cmk-shot">
                                    <div class="cmk-chrome">
                                        <div class="cmk-chrome-url"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg> propuestas.nexus.mx/q/8xk2</div>
                                    </div>
                                    <div class="cmk-body">
                                        <div style="display:flex; align-items:center; justify-content:space-between;">
                                            <div class="cmk-brand">
