---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
const t = useTranslations(lang);

const metaTitle = "Cord para SaaS B2B | Gestión de Suscripciones y Contratos";
const metaDesc = "Optimiza tus cobros recurrentes y contratos empresariales con Cord. La plataforma ideal para startups SaaS y negocios de software.";
---

<Layout title={metaTitle} description={metaDesc}>
    <Nav />
    
    <main class="use-case-main">
        <!-- HERO (Stripe 2-column style, Light) -->
        <header class="uc-hero">
            <div class="uc-container uc-hero-grid">
                <div class="uc-hero-content">
                    <div class="uc-eyebrow" style="color: #10b981;">Stripe para SaaS</div>
                    <h1 class="uc-title reveal">Gestión de suscripciones para el software moderno</h1>
                    <p class="uc-sub reveal">
                        Automatiza los pagos recurrentes, unifica tus contratos B2B y emite CFDI 4.0 en automático. Construido para empresas SaaS de alto crecimiento.
                    </p>
                    <div class="uc-actions reveal">
                        <a href="/registro" class="btn-luxe">
                            <span>Empezar ahora</span>
                            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            <div class="btn-shimmer"></div>
                        </a>
                        <a href="/contacto/ventas" class="btn-ghost">Contactar a ventas <span class="arrow-right">→</span></a>
                    </div>
                </div>

                <div class="uc-hero-visual reveal-mockup">
                    <div class="uc-visual-glow" style="background: radial-gradient(circle at 50% 50%, rgba(16,185,129,0.3) 0%, transparent 60%);"></div>
                    <div class="uc-mockup-window">
                        <div class="uc-mockup-top">
                            <div class="uc-dots"><span></span><span></span><span></span></div>
                        </div>
                        <div class="uc-mockup-body">
                            <div class="mock-plan">
                                <span class="mp-title">Plan Enterprise Anual</span>
                                <span class="mp-price">$120,000 <small>MXN</small></span>
                            </div>
                            <div class="mock-status">
                                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                Suscripción Activa · Próximo cobro: 14 Ene 2027
                            </div>
                            <div class="mock-cfdi">
                                <span class="cfdi-badge">CFDI 4.0</span> Timbrado y enviado
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <!-- LOGOS / TRUST -->
        <section class="uc-trust reveal">
            <p>Empresas de SaaS innovadoras crecen con Cord</p>
            <div class="uc-logos">
                <span class="trust-logo">Linear</span>
                <span class="trust-logo">Vercel</span>
                <span class="trust-logo">Stripe</span>
                <span class="trust-logo">Notion</span>
            </div>
        </section>

        <!-- FEATURES GRID -->
        <section class="uc-features">
            <div class="uc-container">
                <div class="uc-features-header reveal">
                    <h2>Diseñado para la velocidad y la escala</h2>
                    <p>Todo lo que tu SaaS necesita para gestionar su revenue, desde el primer cliente hasta tu IPO.</p>
                </div>

                <div class="uc-bento-grid">
                    <div class="uc-bento-card reveal">
                        <div class="uc-bento-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg></div>
                        <h3>Billing Engine Potente</h3>
                        <p>Soporta modelos de precios complejos: por asiento, por uso, tiers, o tarifa plana. Cord se encarga de prorrateos y upgrades automáticamente.</p>
                    </div>
                    <div class="uc-bento-card reveal">
                        <div class="uc-bento-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"></path><path d="M14 2v6h6"></path><path d="M16 13H8"></path><path d="M16 17H8"></path><path d="M10 9H8"></path></svg></div>
                        <h3>Facturación Inteligente (CFDI)</h3>
                        <p>Genera facturas mexicanas (CFDI 4.0) por cada cobro de suscripción recurrente sin intervención manual ni recaptura de RFCs.</p>
                    </div>
                    <div class="uc-bento-card reveal">
                        <div class="uc-bento-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg></div>
                        <h3>API First</h3>
                        <p>Integra el flujo de suscripciones directamente en tu app con nuestra API REST, o usa webhooks para mantener tu base de datos sincronizada.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA SECTION -->
        <section class="uc-cta-section">
            <div class="uc-container">
                <div class="uc-cta-box reveal">
                    <h2>¿Listo para escalar tu SaaS?</h2>
                    <p>Únete a las empresas que ya automatizan su pipeline B2B con Cord.</p>
                    <a href="/registro" class="btn-luxe">Comenzar gratis</a>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Layout>

<style>
    /* VARIABLES Y UTILIDADES GLOBALES PARA USE CASES */
    .use-case-main {
        background: #fff;
        padding-top: 0;
        overflow-x: hidden;
        color: #425466; /* Texto Stripe */
    }

    .uc-container {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 5%;
    }

    /* ── HERO SECTION (2-Column Light) ── */
    .uc-hero {
        position: relative;
        padding: 8rem 0 4rem;
        background: #f6f9fc; /* Fondo ultra ligero Stripe */
        overflow: hidden;
        border-bottom: 1px solid #e6ebf1;
    }
    
    /* Diagonal background cut (Stripe style) */
    .uc-hero::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: #fff;
        transform: skewY(-4deg);
        transform-origin: top left;
        z-index: 0;
        pointer-events: none;
    }

    .uc-hero-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: center;
        position: relative;
        z-index: 1;
    }

    .uc-hero-content {
        padding-right: 2rem;
    }

    .uc-eyebrow {
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        margin-bottom: 1rem;
    }

    .uc-title {
        font-size: clamp(2.2rem, 4vw, 3.8rem);
        font-weight: 800;
        color: #0a2540;
        line-height: 1.1;
        letter-spacing: -0.04em;
        margin-bottom: 1.2rem;
        text-wrap: balance;
    }

    .uc-sub {
        font-size: 1.15rem;
        color: #425466;
        line-height: 1.6;
        margin-bottom: 2rem;
        max-width: 90%;
    }

    .uc-actions {
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    /* ── BUTTONS (Light Theme) ── */
    .btn-luxe {
        position: relative;
        display: inline-flex; align-items: center; justify-content: center;
        background: #0a2540; color: #fff;
        padding: 14px 28px; border-radius: 100px;
        font-size: 0.95rem; font-weight: 600; text-decoration: none;
        overflow: hidden; transition: transform 0.3s, box-shadow 0.3s;
        box-shadow: 0 4px 14px rgba(10,37,64,0.15);
    }
    .btn-luxe span { position: relative; z-index: 2; }
    .btn-arrow { width: 16px; height: 16px; margin-left: 6px; position: relative; z-index: 2; transition: transform 0.3s; }
    .btn-luxe:hover .btn-arrow { transform: translateX(4px); }
    .btn-luxe:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(10,37,64,0.25); background: #061b31; }

    .btn-ghost {
        display: inline-flex; align-items: center;
        color: #0a2540; font-size: 0.95rem; font-weight: 600; text-decoration: none;
        transition: color 0.2s;
    }
    .btn-ghost .arrow-right { transition: transform 0.2s; display: inline-block; margin-left: 4px; }
    .btn-ghost:hover { color: #635bff; }
    .btn-ghost:hover .arrow-right { transform: translateX(4px); }

    /* ── MOCKUP (Right Side) ── */
    .uc-hero-visual {
        position: relative;
        perspective: 1000px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .uc-visual-glow {
        position: absolute;
        width: 120%; height: 120%;
        top: -10%; left: -10%;
        filter: blur(50px);
        z-index: 0;
        opacity: 0.7;
    }

    .uc-mockup-window {
        position: relative;
        z-index: 1;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 20px 40px rgba(10,37,64,0.1), 0 0 0 1px rgba(10,37,64,0.05);
        width: 100%;
        max-width: 450px;
        transform: rotateY(-10deg) rotateX(5deg);
        transition: transform 0.5s ease-out;
    }
    .uc-hero-visual:hover .uc-mockup-window {
        transform: rotateY(0deg) rotateX(0deg);
    }

    .uc-mockup-top {
        background: #f6f9fc;
        padding: 12px 16px;
        border-bottom: 1px solid rgba(10,37,64,0.05);
        border-radius: 12px 12px 0 0;
    }
    .uc-dots { display: flex; gap: 6px; }
    .uc-dots span { width: 10px; height: 10px; border-radius: 50%; background: #d3dae6; }
    .uc-dots span:nth-child(1) { background: #ff5f56; }
    .uc-dots span:nth-child(2) { background: #ffbd2e; }
    .uc-dots span:nth-child(3) { background: #27c93f; }

    .uc-mockup-body {
        padding: 30px;
    }
    
    .mock-plan {
        background: #f6f9fc;
        padding: 20px;
        border-radius: 8px;
        border: 1px solid rgba(10,37,64,0.05);
        display: flex; flex-direction: column; gap: 8px;
        margin-bottom: 20px;
    }
    .mp-title { font-size: 1.05rem; font-weight: 600; color: #0a2540; }
    .mp-price { font-size: 1.8rem; font-weight: 800; color: #0a2540; }
    .mp-price small { font-size: 1rem; color: #687385; font-weight: 500; }
    
    .mock-status {
        display: flex; align-items: center; gap: 8px;
        font-size: 0.85rem; color: #425466; font-weight: 500;
        margin-bottom: 12px;
    }
    .mock-cfdi {
        display: flex; align-items: center; gap: 8px;
        font-size: 0.85rem; color: #425466; font-weight: 500;
        padding-top: 12px;
        border-top: 1px dashed rgba(10,37,64,0.1);
    }
    .cfdi-badge {
        background: rgba(16,185,129,0.1); color: #059669;
        font-size: 0.7rem; font-weight: 700; padding: 2px 6px; border-radius: 4px;
    }

    /* ── TRUST LOGOS ── */
    .uc-trust {
        text-align: center;
        padding: 3rem 5%;
        background: #fff;
    }
    .uc-trust p {
        font-size: 0.9rem; font-weight: 600; color: #687385; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1.5rem;
    }
    .uc-logos {
        display: flex; justify-content: center; gap: 3rem; flex-wrap: wrap; align-items: center;
    }
    .trust-logo {
        font-size: 1.4rem; font-weight: 800; color: #c1c9d2; letter-spacing: -0.5px;
    }

    /* ── FEATURES ── */
    .uc-features {
        padding: 6rem 0 6rem;
        background: #fff;
    }
    .uc-features-header {
        text-align: center;
        max-width: 600px;
        margin: 0 auto 4rem;
    }
    .uc-features-header h2 { font-size: 2.2rem; font-weight: 800; color: #0a2540; margin-bottom: 1rem; }
    .uc-features-header p { font-size: 1.1rem; color: #425466; line-height: 1.6; }

    .uc-bento-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }
    .uc-bento-card {
        background: #fff;
        padding: 2.5rem;
        border-radius: 16px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 0 0 1px rgba(10,37,64,0.05);
        transition: transform 0.3s, box-shadow 0.3s;
    }
    .uc-bento-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 0 0 1px rgba(10,37,64,0.05);
    }
    .uc-bento-icon {
        width: 48px; height: 48px;
        background: #f6f9fc;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 1.5rem;
    }
    .uc-bento-card h3 { font-size: 1.2rem; font-weight: 700; color: #0a2540; margin-bottom: 0.8rem; }
    .uc-bento-card p { font-size: 0.95rem; color: #425466; line-height: 1.6; }

    /* ── CTA SECTION ── */
    .uc-cta-section {
        padding: 4rem 0 8rem;
        background: #fff;
    }
    .uc-cta-box {
        background: #0a2540;
        border-radius: 20px;
        padding: 4rem 2rem;
        text-align: center;
        color: #fff;
        position: relative;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(10,37,64,0.25);
    }
    .uc-cta-box::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: radial-gradient(circle at center top, rgba(16,185,129,0.15), transparent 70%);
        pointer-events: none;
    }
    .uc-cta-box h2 { font-size: 2.2rem; font-weight: 800; margin-bottom: 1rem; position: relative; z-index: 1; }
    .uc-cta-box p { font-size: 1.1rem; color: #aab7c4; margin-bottom: 2rem; position: relative; z-index: 1; }
    .uc-cta-box .btn-luxe { background: #10b981; color: #fff; box-shadow: 0 4px 14px rgba(16,185,129,0.3); }
    .uc-cta-box .btn-luxe:hover { background: #059669; box-shadow: 0 6px 20px rgba(16,185,129,0.4); }

    @media (max-width: 900px) {
        .uc-hero-grid { grid-template-columns: 1fr; gap: 4rem; }
        .uc-hero-content { padding-right: 0; text-align: center; }
        .uc-actions { justify-content: center; }
        .uc-title { font-size: 2.5rem; }
        .uc-bento-grid { grid-template-columns: 1fr; }
        .uc-hero::before { transform: skewY(-2deg); }
    }
</style>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener('DOMContentLoaded', () => {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if(reduced) return;

        gsap.utils.toArray('.reveal').forEach((el: any) => {
            gsap.fromTo(el, { opacity: 0, y: 20 }, {
                opacity: 1, y: 0, duration: 0.8, ease: 'power2.out',
                scrollTrigger: { trigger: el, start: 'top 85%' }
            });
        });
        
        gsap.fromTo('.reveal-mockup', { opacity: 0, x: 30, rotationY: -15 }, {
            opacity: 1, x: 0, rotationY: -10, duration: 1.2, ease: 'power3.out', delay: 0.2,
            scrollTrigger: { trigger: '.reveal-mockup', start: 'top 90%' }
        });
    });
</script>
