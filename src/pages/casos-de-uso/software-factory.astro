---

export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import QuantizedWaveBg from '../../components/soluciones/QuantizedWaveBg.jsx';
import FaqAccordion from '../../components/landing/FaqAccordion.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import '../../styles/mockups.css';
import TestimonialCarousel from '../../components/soluciones/TestimonialCarousel.jsx';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
const t = useTranslations(lang);

const metaTitle = "Cord para Software Factories — Presupuestos y Cobro por Hitos";
const metaDesc = "Envía presupuestos técnicos detallados, divide el cobro por hitos del proyecto (Setup, Core, Launch) y timbra CFDI 4.0 al aprobarse cada fase. Para dev shops y equipos de desarrollo B2B en México.";

// FAQ + JSON-LD (jul 2026, auditoría SEO/AI-SEO) — preguntas ancladas a
// capacidades reales del producto.
const FAQS = [
    {
        q: '¿Puedo cobrar un proyecto por hitos en vez de todo de una vez?',
        a: 'Sí. Divides el proyecto en fases (por ejemplo Setup, Core, Launch), cotizas cada una por separado y envías la cotización correspondiente cuando completas esa fase — tu cliente la aprueba con firma digital desde su link.',
    },
    {
        q: '¿Puedo agregar opciones (up-sells) que el cliente activa o desactiva antes de firmar?',
        a: 'Sí. El editor permite líneas adicionales — como "Migración a AWS" o "Soporte 24/7" — que el cliente puede incluir o quitar de la propuesta antes de aprobar, y el total se recalcula en vivo.',
    },
    {
        q: '¿El cliente puede pedir cambios a la propuesta antes de aprobarla?',
        a: 'Sí. Cord tiene un chat de negociación por cotización y por línea: tu cliente puede comentar, pedir ajustes o contraofertar un precio específico, y tú respondes desde el detalle sin salir de la plataforma.',
    },
    {
        q: '¿Necesito facturar en México para usar Cord con clientes extranjeros?',
        a: 'No necesariamente. Puedes cotizar en USD con tipo de cambio protegido por 30 días y, para clientes fuera de México, usar el flujo de factura comercial en vez de CFDI.',
    },
];
const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: FAQS.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
const breadcrumbSchema = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Cord', item: 'https://cordhq.app/' },
        { '@type': 'ListItem', position: 2, name: 'Software factories', item: 'https://cordhq.app/casos-de-uso/software-factory' },
    ],
};

const magneticNodes = [
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://github.com&size=128", alt: "GitHub", top: "10%", left: "30%", width: 100, zIndex: 2 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://jira.com&size=128", alt: "Jira", top: "25%", left: "65%", width: 140, zIndex: 3 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://linear.app&size=128", alt: "Linear", top: "50%", left: "15%", width: 120, zIndex: 1 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://gitlab.com&size=128", alt: "GitLab", top: "75%", left: "45%", width: 90, zIndex: 2 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://slack.com&size=128", alt: "Slack", top: "60%", left: "80%", width: 110, zIndex: 1 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://aws.amazon.com&size=128", alt: "AWS", top: "-5%", left: "75%", width: 70, zIndex: 1 }
];

const testimonialItems = [
    {
        id: 'github',
        name: 'GitHub',
        logoUrl: 'https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://github.com&size=128',
        logoUrlLarge: 'https://upload.wikimedia.org/wikipedia/commons/thumb/9/91/Octicons-mark-github.svg/512px-Octicons-mark-github.svg.png',
        quote: '«El cobro por hitos ha transformado nuestra forma de ejecutar proyectos. Cobramos al terminar sprints sin burocracia administrativa.»',
        author: 'Lead Developer',
        bgGradient: 'linear-gradient(135deg, #1e293b, #0f172a)',
        bgImage: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=2000&auto=format&fit=crop'
    },
    {
        id: 'jira',
        name: 'Jira',
        logoUrl: 'https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://jira.com&size=128',
        logoUrlLarge: 'https://upload.wikimedia.org/wikipedia/commons/thumb/8/82/Jira_%28Software%29_logo.svg/512px-Jira_%28Software%29_logo.svg.png',
        quote: '«Ahora los cambios de alcance (change requests) se cotizan y aprueban desde el mismo ticket, acelerando el desarrollo.»',
        author: 'Project Manager',
        bgGradient: 'linear-gradient(135deg, #0369a1, #075985)'
    },
    {
        id: 'linear',
        name: 'Linear',
        logoUrl: 'https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://linear.app&size=128',
        logoUrlLarge: 'https://pbs.twimg.com/profile_images/1121395911849062400/7exmJEg4_400x400.png',
        quote: '«La velocidad para enviar una propuesta técnica y que se convierta en factura es clave para mantener el ciclo ágil de desarrollo.»',
        author: 'CTO',
        bgGradient: 'linear-gradient(135deg, #4f46e5, #312e81)',
        bgImage: 'https://images.unsplash.com/photo-1551434678-e076c223a692?q=80&w=2000&auto=format&fit=crop'
    },
    {
        id: 'slack',
        name: 'Slack',
        logoUrl: 'https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://slack.com&size=128',
        logoUrlLarge: 'https://upload.wikimedia.org/wikipedia/commons/thumb/d/d5/Slack_icon_2019.svg/512px-Slack_icon_2019.svg.png',
        quote: '«Mantener a nuestros ingenieros enfocados en código y no persiguiendo pagos es el mayor valor que nos ha dado Cord.»',
        author: 'VP of Engineering',
        bgGradient: 'linear-gradient(135deg, #111827, #4a044e)'
    }
];

---


<Layout title={metaTitle} description={metaDesc}>
    <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
    <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
    <Nav />

    <main class="use-case-main">
        <!-- HERO -->
        <header class="startup-hero">
            <div class="startup-hero-bg">
                <QuantizedWaveBg client:only="react" />
            </div>
            <div class="startup-hero-content">
                <h1 class="startup-title reveal">Presupuestos a la medida para desarrollo de software</h1>
                <p class="startup-sub">
                    El desarrollo de software requiere claridad. Envía presupuestos detallados, divide los pagos por hitos (Milestones) y notifica a tu equipo de ingeniería.
                </p>
                <div class="startup-actions">
                    <a href="/registro" class="btn-luxe">
                        <span>Empezar ahora</span>
                        <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        <div class="btn-shimmer"></div>
                    </a>
                    <a href="/contacto/ventas" class="btn-ghost"><span>Contactar a ventas</span></a>
                </div>
            </div>
        </header>

        <!-- LOGOS / TRUST -->
        <section class="uc-trust reveal">
            <p>Las mejores agencias de desarrollo usan Cord</p>
            <div class="uc-logos">
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://cursor.sh&size=64" alt="Cursor" width="24" height="24" loading="lazy" />
                    <span>Cursor</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://vercel.com&size=64" alt="Vercel" width="24" height="24" loading="lazy" />
                    <span>Vercel</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://gitlab.com&size=64" alt="GitLab" width="24" height="24" loading="lazy" />
                    <span>GitLab</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://linear.app&size=64" alt="Linear" width="24" height="24" loading="lazy" />
                    <span>Linear</span>
                </div>
            </div>
        </section>

        <!-- LEYENDA STRIPE-LITERAL STRUCTURE -->
        <div class="stripe-literal-wrapper">
            <!-- Grid de fondo exacto -->
            <div class="sl-grid-bg">
                <div class="sl-col"></div>
                <div class="sl-col"></div>
                <div class="sl-col"></div>
                <div class="sl-col"></div>
            </div>

            <div class="uc-container" style="position:relative; z-index:10; padding-top: 4rem;">
                <!-- Header centrado (Captura 2) -->
                <div class="sl-header reveal">
                    <span class="sl-eyebrow">Para software factories</span>
                    <h2>Cobros basados en hitos, sin fricción administrativa</h2>
                    <p>Estructura tus proyectos por fases técnicas, comparte el presupuesto interactivo y desencadena facturas automáticas (CFDI 4.0) tan pronto como el cliente apruebe y pague un entregable.</p>
                </div>

                <!-- Split Layout (Captura 1) -->
                <div class="sl-split reveal">
                    <!-- Izquierda: Features -->
                    <div class="sl-features">
                        <div class="slf-item active">
                            <div class="slf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z" fill="currentColor" fill-opacity="0.15" stroke="none"/>
                                    <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z" stroke-linecap="round" stroke-linejoin="round"/>
                                    <line x1="4" y1="22" x2="4" y2="15" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </div>
                            <div class="slf-text">
                                <h3>Hitos de Entrega (Milestones)</h3>
                                <p>No cobres todo al principio ni todo al final. Cobra automáticamente al cumplir cada fase del proyecto y notifica al cliente para liberar el siguiente bloque.</p>
                            </div>
                        </div>

                        <div class="slf-item">
                            <div class="slf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <polyline points="16 18 22 12 16 6" fill="currentColor" fill-opacity="0.15" stroke="none" />
                                    <polyline points="16 18 22 12 16 6" stroke-linecap="round" stroke-linejoin="round" />
                                    <polyline points="8 6 2 12 8 18" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </div>
                            <div class="slf-text">
                                <h3>Propuestas técnicas detalladas</h3>
                                <p>El editor de Cord permite líneas libres con descripción larga. Describe cada entregable con el detalle que requiere y el cliente lo ve claramente antes de aprobar.</p>
                            </div>
                        </div>

                        <div class="slf-item">
                            <div class="slf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" fill="currentColor" fill-opacity="0.15" stroke="none" />
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" stroke-linecap="round" stroke-linejoin="round" />
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </div>
                            <div class="slf-text">
                                <h3>Bloqueo de desarrollo sin pago</h3>
                                <p>El dashboard te avisa si un cliente se atrasa en el pago de un hito, dándote visibilidad para pausar el código hasta que el flujo de caja esté asegurado.</p>
                            </div>
                        </div>
                    </div>

                    <!-- Derecha: Mockups con conectores -->
                    <div class="sl-mockups mk-software-mockup">
                        <!-- Card Principal -->
                        <div class="slm-main" style="border-top: 4px solid #10b981;">
                            <div class="slm-main-header">
                                <div class="slm-mh-icon" style="background:#d1fae5; color:#047857;">P</div>
                                <span>Control de Hitos</span>
                            </div>
                            <div class="slm-main-body" style="padding: 16px;">
                                <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px;">
                                    <div>
                                        <div style="font-weight:600; font-size:15px; color:#0f172a;">Build & Ship Inc.</div>
                                        <div style="font-size:13px; color:#64748b;">Proyecto MVP Fintech</div>
                                    </div>
                                    <div class="cmk-badge cmk-b-blue">35% Cobrado</div>
                                </div>
                                
                                <div style="width:100%; height:6px; background:#e2e8f0; border-radius:10px; overflow:hidden; margin-bottom:16px;">
                                    <div style="width:35%; height:100%; background:#3b82f6; border-radius:10px;"></div>
                                </div>
                                
                                <!-- Tabla de hitos -->
                                <div style="border: 1px solid #e2e8f0; border-radius: 6px; overflow:hidden;">
                                    <div style="display:flex; justify-content:space-between; background:#f8fafc; padding:8px 12px; font-size:12px; font-weight:600; color:#475569; border-bottom:1px solid #e2e8f0;">
                                        <span>Fase / Entregable</span>
                                        <span>Estado</span>
                                    </div>
                                    <div style="display:flex; justify-content:space-between; align-items:center; padding:10px 12px; font-size:13px; border-bottom:1px solid #e2e8f0;">
                                        <div style="font-weight:500; color:#0f172a;">1. UX/UI Prototipo</div>
                                        <span class="cmk-badge cmk-b-green">Pagado</span>
                                    </div>
                                    <div style="display:flex; justify-content:space-between; align-items:center; padding:10px 12px; font-size:13px; border-bottom:1px solid #e2e8f0; background:#f8fafc;">
                                        <div style="font-weight:600; color:#0f172a; display:flex; align-items:center; gap:6px;">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" style="width:14px; height:14px;"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                            2. Backend API
                                        </div>
                                        <span class="cmk-badge cmk-b-blue">Enviada hoy</span>
                                    </div>
                                    <div style="display:flex; justify-content:space-between; align-items:center; padding:10px 12px; font-size:13px; color:#94a3b8;">
                                        <div style="font-weight:500;">3. Frontend + Testing</div>
                                        <span class="cmk-badge cmk-b-gray">Bloqueado</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Conector SVG -->
                        <svg class="slm-connector" viewBox="0 0 100 60" preserveAspectRatio="none">
                            <path d="M 0,10 C 40,10 60,50 100,50" fill="none" stroke="var(--color-blue-deep)" stroke-width="2" stroke-dasharray="4 4" stroke-linecap="round" />
                        </svg>

                        <!-- Card Flotante -->
                        <div class="slm-chat" style="top: 55%; left: 35%; width: 290px; box-shadow: 0 20px 40px rgba(0,0,0,0.15); border: 1px solid rgba(226, 232, 240, 0.8);">
                            <div class="slm-chat-header" style="background:#eff6ff; border-bottom:1px solid #bfdbfe; color:#1d4ed8; display:flex; align-items:center; gap:8px;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px; height:16px;"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                                Hito 2 Liberado
                            </div>
                            <div class="slm-chat-body" style="padding:16px;">
                                <p style="font-size:13px; color:#475569; margin:0 0 12px 0;">El cliente ha realizado el pago por el Hito 2.</p>
                                <div style="display:flex; align-items:center; gap:12px; background:#f8fafc; padding:10px; border-radius:6px; border:1px solid #e2e8f0; margin-bottom:12px;">
                                    <div style="width:32px; height:32px; border-radius:50%; background:#d1fae5; color:#047857; display:flex; align-items:center; justify-content:center;">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px; height:16px;"><polyline points="20 6 9 17 4 12"/></svg>
                                    </div>
                                    <div>
                                        <div style="font-size:12px; font-weight:600; color:#0f172a;">Cobro Exitoso</div>
                                        <div style="font-size:11px; color:#64748b;">Stripe • $25,000 MXN</div>
                                    </div>
                                </div>
                                <div style="display:flex; justify-content:space-between; align-items:center; font-size:12px;">
                                    <span style="color:#64748b;">Factura CFDI 4.0</span>
                                    <span style="font-weight:500; color:#10b981;">Enviada ✓</span>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>

                <!-- SECONDARY BENEFITS SECTION -->
        <section class="uc-benefits">
            <div class="uc-container">
                <div class="uc-benefits-intro reveal">
                    <span class="uc-split-label">Sincroniza desarrollo y finanzas</span>
                    <h2 class="uc-split-title">Cobra por tus hitos técnicos a tiempo</h2>
                    <p class="uc-split-desc">
                        El desarrollo de software tiene su propio ritmo. Conecta tus repositorios y tableros de control con tu ciclo de facturación para que nunca se te olvide cobrar un entregable aprobado.
                    </p>
                </div>

                <div class="uc-bento-cards">
                    <!-- Tarjeta 1 -->
                    <div class="uc-bento-card reveal">
                        <div class="uc-bc-text">
                            <h3>Cobros por fase del proyecto</h3>
                            <p>Divide el proyecto en hitos — Setup, Core, Launch — y cotiza cada uno por separado. Cuando completes una fase, envías la cotización correspondiente y el cliente la aprueba con firma digital desde su link.</p>
                            <a href="/registro" class="uc-link-arrow">Crear propuesta por hitos <span>&rarr;</span></a>
                        </div>
                        <div class="uc-bc-mockup">
                            <div class="cmk-stage">
                                <div class="cmk-shot">
                                    <div class="cmk-nav">
                                        <div class="cmk-nav-l">
                                            <span class="cmk-nav-title">Hito 2 · Core Backend</span>
                                        </div>
                                        <span class="cmk-badge cmk-b-blue">$18,000 MXN</span>
                                    </div>
                                    <div class="cmk-body">
                                        <div class="cmk-eyebrow" style="margin-bottom:10px;">Entregables de la fase</div>
                                        <div class="cmk-kv">
                                            <span class="cmk-t1" style="font-family:ui-monospace,Menlo,monospace; font-size:12px;">PR #42 · API Auth</span>
                                            <span class="cmk-badge cmk-b-green">Merged</span>
                                        </div>
                                        <div class="cmk-kv">
                                            <span class="cmk-t1" style="font-family:ui-monospace,Menlo,monospace; font-size:12px;">PR #45 · DB Schema</span>
                                            <span class="cmk-badge cmk-b-green">Merged</span>
                                        </div>
                                        <div class="cmk-kv" style="border-bottom:none;">
                                            <span class="cmk-t1" style="font-family:ui-monospace,Menlo,monospace; font-size:12px;">Staging · aprobación del cliente</span>
                                            <span class="cmk-badge cmk-b-amber">Pendiente</span>
                                        </div>
                                        <div style="display:flex; gap:10px; margin-top:12px">
                                            <span class="cmk-cta cmk-cta-solid" style="flex:1; justify-content:center">Enviar cotización del hito</span>
                                        </div>
                                        <div style="display:flex; align-items:center; gap:8px; background:#f8fafc; padding:10px 14px; border-radius:8px; border:1px solid #f1f5f9; margin-top:12px;">
                                            <span class="cmk-dot cmk-dot-blue"></span>
                                            <span class="cmk-t2" style="color:#475569; font-weight:600;">Al aprobar el hito: firma digital + link de pago + CFDI</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Tarjeta 2 -->
                    <div class="uc-bento-card reveal">
                        <div class="uc-bc-text">
                            <h3>Presupuestos técnicos modulares</h3>
                            <p>Crea cotizaciones detalladas que tus clientes entienden, con opciones adicionales y up-sells (como "Migración AWS" o "Soporte 24/7") que pueden activar o desactivar antes de firmar.</p>
                            <a href="/registro" class="uc-link-arrow">Genera propuestas técnicas <span>&rarr;</span></a>
                        </div>
                        <div class="uc-bc-mockup">
                            <div class="cmk-stage">
                                <div class="cmk-shot">
                                    <div class="cmk-chrome">
                                        <div class="cmk-chrome-url"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg> buildship.cord.app/q/mvp2</div>
                                    </div>
                                    <div class="cmk-body">
                                        <div class="cmk-eyebrow" style="margin-bottom:10px;">Módulos adicionales de la propuesta</div>
                                        <div class="cmk-kv">
                                            <span class="cmk-t1" style="flex-direction:column; align-items:flex-start; gap:2px;">Infraestructura AWS + CI/CD<span class="cmk-t2" style="font-weight:500;">Setup inicial y pipelines</span></span>
                                            <span style="display:inline-flex; align-items:center; gap:10px;"><span class="cmk-v editorial">+$2,500</span><span class="cmk-toggle"></span></span>
