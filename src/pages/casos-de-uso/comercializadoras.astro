---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import RampShader from '../../components/soluciones/RampShader.jsx';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
const t = useTranslations(lang);

const metaTitle = "Cord para Comercializadoras B2B | Cotizaciones y Pedidos";
const metaDesc = "Digitaliza las ventas de tu comercializadora. Cotiza volumen, maneja descuentos por tier y automatiza facturas de grandes pedidos.";
---

<Layout title={metaTitle} description={metaDesc}>
    <Nav />
    
    <main class="use-case-main">
        <!-- HERO (shader full-bleed, Light) -->
        <header class="uc-hero">
            <div class="uc-hero-bg">
                <RampShader client:only="react" variant="azure" />
            </div>
            <div class="uc-container uc-hero-inner">
                <div class="uc-hero-content">
                    <h1 class="uc-title reveal">Ventas B2B al por mayor sin fricción</h1>
                    <p class="uc-sub reveal">
                        Cotiza miles de productos, aplica descuentos por volumen y cierra tratos a crédito. Todo sincronizado directamente a facturación CFDI 4.0.
                    </p>
                    <div class="uc-actions reveal">
                        <a href="/registro" class="btn-luxe">
                            <span>Empezar ahora</span>
                            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            <div class="btn-shimmer"></div>
                        </a>
                        <a href="/contacto/ventas" class="btn-ghost"><span>Contactar a ventas</span></a>
                    </div>
                </div>
            </div>
        </header>

        <!-- LOGOS / TRUST -->
        <section class="uc-trust reveal">
            <p>Distribuidores modernos operan con Cord</p>
            <div class="uc-logos">
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://grainger.com&size=64" alt="Grainger" width="24" height="24" loading="lazy" />
                    <span>Grainger</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://uline.com&size=64" alt="Uline" width="24" height="24" loading="lazy" />
                    <span>Uline</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://fastenal.com&size=64" alt="Fastenal" width="24" height="24" loading="lazy" />
                    <span>Fastenal</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://sysco.com&size=64" alt="Sysco" width="24" height="24" loading="lazy" />
                    <span>Sysco</span>
                </div>
            </div>
        </section>

        <!-- STRIPE-LIKE SPLIT SECTION -->
        <section class="uc-split-feature">
            <div class="uc-container">
                <div class="uc-split-grid">
                    
                    <div class="uc-split-text reveal">
                        <span class="uc-split-label">Operaciones B2B</span>
                        <h2 class="uc-split-title">Cotizaciones y pedidos sin fricción</h2>
                        <p class="uc-split-desc">
                            Maneja un alto volumen de ventas empresariales. Desde la cotización rápida hasta la gestión de crédito y <a href="#">complementos de pago</a> automáticos.
                        </p>
                        
                        <div class="uc-split-list">
                            <div class="uc-feature-item">
                                <div class="uc-feature-icon">
                                    <svg viewBox="0 0 24 24" fill="none">
                                        <defs>
                                            <linearGradient id="cord-emerald-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                                                <stop offset="0%" stop-color="#059669" />
                                                <stop offset="100%" stop-color="#34d399" />
                                            </linearGradient>
                                        </defs>
                                        <polygon points="5 3 19 12 5 21 5 3" fill="url(#cord-emerald-grad)" />
                                    </svg>
                                </div>
                                <div class="uc-feature-content">
                                    <h3>Descuentos Dinámicos</h3>
                                    <p>Aplica <a href="#">descuentos por volumen</a>, márgenes personalizados y niveles de precios específicos por cliente. Todo se calcula al instante en tu cotizador.</p>
                                </div>
                            </div>
                            
                            <div class="uc-feature-item">
                                <div class="uc-feature-icon">
                                    <svg viewBox="0 0 24 24" fill="none">
                                        <defs>
                                            <linearGradient id="cord-slate-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                                                <stop offset="0%" stop-color="#334155" />
                                                <stop offset="100%" stop-color="#94a3b8" />
                                            </linearGradient>
                                        </defs>
                                        <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" fill="url(#cord-slate-grad)"/>
                                        <circle cx="7" cy="7" r="2" fill="#fff"/>
                                    </svg>
                                </div>
                                <div class="uc-feature-content">
                                    <h3>Manejo de Crédito (Net 30/60)</h3>
                                    <p>Otorga términos de pago institucionales. Cord envía la factura, gestiona la cobranza y timbra el <a href="#">REP</a> cuando registras el depósito.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="uc-split-mockup reveal">
                        <div class="uc-mockup-wrapper">
                            <div class="uc-mockup-header">
                                <div class="uc-mockup-logo">
                                    <svg viewBox="0 0 24 24" width="16" height="16" fill="#0a2540"><rect x="2" y="2" width="20" height="20" rx="4"/></svg>
                                    Global Supply Co.
                                </div>
                                <div class="uc-mockup-nav">
                                    <span>Catálogo</span>
                                    <span class="active">Cotización</span>
                                    <span>Facturas</span>
                                </div>
                            </div>
                            
                            <div class="uc-mockup-body">
                                <h4>Opciones de Volumen (SKU-892)</h4>
                                <p>Selecciona la cantidad para aplicar el descuento</p>
                                
                                <div class="uc-mockup-cards">
                                    <div class="uc-mc uc-mc-1">
                                        <div class="uc-mc-title">Detalle (&lt;500)</div>
                                        <div class="uc-mc-icon">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><circle cx="7" cy="7" r="2" fill="#fff"/></svg>
                                        </div>
                                        <div class="uc-mc-btn">Precio Base</div>
                                    </div>
                                    <div class="uc-mc uc-mc-2">
                                        <div class="uc-mc-badge">Mayorista</div>
                                        <div class="uc-mc-title">Medio (500+)</div>
                                        <div class="uc-mc-icon">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                        </div>
                                        <div class="uc-mc-btn">-10% OFF</div>
                                    </div>
                                    <div class="uc-mc uc-mc-3">
                                        <div class="uc-mc-title">Fábrica (2K+)</div>
                                        <div class="uc-mc-icon">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><circle cx="7" cy="7" r="2" fill="#fff"/></svg>
                                        </div>
                                        <div class="uc-mc-btn">-25% OFF</div>
                                    </div>
                                </div>
                                
                                <div class="uc-mockup-features">
                                    <ul>
                                        <li>Precio regular</li>
                                        <li>Envío estándar LTL</li>
                                    </ul>
                                    <ul>
                                        <li>Descuento por volumen</li>
                                        <li>Prioridad de envío</li>
                                        <li>Opciones de crédito</li>
                                    </ul>
                                    <ul>
                                        <li>Precio de fábrica directo</li>
                                        <li>Flete gratuito consolidado</li>
                                        <li>Términos Net 30 disponibles</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                </div>
            </div>
        </section>

        <!-- CTA SECTION -->
        <section class="uc-cta-section">
            <div class="uc-container">
                <div class="uc-cta-box reveal">
                    <h2>Mejora la eficiencia comercial de tu empresa</h2>
                    <p>Reduce el trabajo manual y cierra pedidos al por mayor más rápido.</p>
                    <a href="/registro" class="btn-luxe" style="background: #10b981;">Comenzar gratis</a>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Layout>

<style>
    /* VARIABLES Y UTILIDADES GLOBALES PARA USE CASES */
    .use-case-main {
        background: #fff;
        padding-top: 0;
        overflow-x: hidden;
        color: #425466; /* Texto Stripe */
    }

    .uc-container {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 5%;
    }

    /* ── HERO SECTION (shader full-bleed) ── */
    .uc-hero {
        position: relative;
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        align-items: center;
        padding: 8rem 0 4rem;
        background: #ffffff;
        overflow: hidden;
        border-bottom: 1px solid #e6ebf1;
    }

    /* Shader background (R3F) — fondo absoluto del hero */
    .uc-hero-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
    }
    /* Fade suave hacia el blanco del contenido (legibilidad del texto) */
    .uc-hero-bg::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(105deg, rgba(255,255,255,0.92) 0%, rgba(255,255,255,0.55) 38%, rgba(255,255,255,0) 72%);
        pointer-events: none;
        z-index: 2;
    }

    .uc-hero-inner {
        position: relative;
        z-index: 1;
        width: 100%;
    }

    .uc-hero-content {
        max-width: 640px;
    }

    .uc-title {
        font-size: clamp(2.2rem, 4vw, 3.8rem);
        font-weight: 800;
        color: #0a2540;
        line-height: 1.1;
        letter-spacing: -0.04em;
        margin-bottom: 1.2rem;
        text-wrap: balance;
    }

    .uc-sub {
        font-size: 1.15rem;
        color: #425466;
        line-height: 1.6;
        margin-bottom: 2rem;
        max-width: 90%;
    }

    .uc-actions {
        display: flex;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
    }

    /* ── BUTTONS (estilo soluciones/startups) ── */
    .btn-luxe {
        position: relative;
        display: inline-flex; align-items: center; justify-content: center;
        background: #0a2540; color: #fff;
        padding: 18px 38px; border-radius: 100px;
        font-size: 0.95rem; font-weight: 600; text-decoration: none;
        overflow: hidden;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 8px 24px rgba(10, 37, 64, 0.2);
    }
    .btn-luxe span { position: relative; z-index: 2; }
    .btn-arrow {
        position: relative; z-index: 2; display: inline-block;
        width: 16px; height: 16px; margin-left: 6px;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .btn-luxe:hover .btn-arrow { transform: translateX(4px); }
    .btn-shimmer {
        position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.18), transparent);
        transform: skew(-20deg); transition: 0s; z-index: 1;
    }
    .btn-luxe:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(10, 37, 64, 0.3);
    }
    .btn-luxe:active {
        transform: translateY(-1px);
        box-shadow: 0 2px 4px rgba(10, 37, 64, 0.1);
    }
    .btn-luxe:hover .btn-shimmer {
        left: 150%;
        transition: left 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .btn-ghost {
        display: inline-flex; align-items: center; gap: 9px;
        color: #0a2540; text-decoration: none;
        font-size: 1rem; font-weight: 600;
        padding: 15px 26px; border-radius: 100px;
        border: 1px solid rgba(10, 37, 64, 0.15);
        background: rgba(10, 37, 64, 0.03);
        transition: background 0.3s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease;
    }
    .btn-ghost:hover {
        background: rgba(10, 37, 64, 0.08);
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.05);
    }

    /* ── TRUST LOGOS ── */
    .uc-trust {
        text-align: center;
        padding: 3rem 5%;
        background: #fff;
    }
    .uc-trust p {
        font-size: 0.9rem; font-weight: 600; color: #687385; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1.5rem;
    }
    .uc-logos {
        display: flex; justify-content: center; gap: 3rem; flex-wrap: wrap; align-items: center;
    }
    .trust-logo-item {
        display: flex; align-items: center; gap: 8px;
        font-size: 1.25rem; font-weight: 700; color: #a1a9b3; letter-spacing: -0.5px;
        filter: grayscale(100%) opacity(0.8);
        transition: all 0.3s ease;
    }
    .trust-logo-item:hover {
        filter: grayscale(0%) opacity(1);
        color: #0a2540;
    }
    .trust-logo-item img {
        border-radius: 4px;
    }

    /* ── STRIPE-LIKE SPLIT FEATURE ── */
    .uc-split-feature {
        padding: 6rem 0;
        background: #ffffff;
        border-bottom: 1px solid #e6ebf1;
    }
    
    .uc-split-grid {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 6rem;
        align-items: center;
    }

    .uc-split-text {
        max-width: 480px;
    }

    .uc-split-label {
        font-size: 1rem;
        font-weight: 700;
        color: #10b981; /* Emerald */
        margin-bottom: 1.2rem;
        display: block;
    }

    .uc-split-title {
        font-size: clamp(2.2rem, 3.5vw, 3rem);
        font-weight: 800;
        color: #0a2540;
        line-height: 1.15;
        letter-spacing: -0.03em;
        margin-bottom: 1.5rem;
        text-wrap: balance;
    }

    .uc-split-desc {
        font-size: 1.1rem;
        color: #425466;
        line-height: 1.6;
        margin-bottom: 3.5rem;
    }
    .uc-split-desc a {
        color: #0a2540;
        text-decoration: none;
        font-weight: 600;
        border-bottom: 1px solid rgba(10,37,64,0.2);
        padding-bottom: 2px;
        transition: border-color 0.2s;
    }
    .uc-split-desc a:hover {
        border-color: #0a2540;
    }

    .uc-feature-item {
        display: flex;
        gap: 1.25rem;
        margin-bottom: 3rem;
    }

    .uc-feature-icon {
        flex-shrink: 0;
        width: 36px;
        height: 36px;
    }
    .uc-feature-icon svg {
        width: 100%;
        height: 100%;
    }

    .uc-feature-content h3 {
        font-size: 1.15rem;
        font-weight: 700;
        color: #0a2540;
        margin-bottom: 0.8rem;
        line-height: 1.35;
    }

    .uc-feature-content p {
        font-size: 1rem;
        color: #425466;
        line-height: 1.6;
    }
    .uc-feature-content a {
        color: #0a2540;
        text-decoration: none;
        font-weight: 600;
        border-bottom: 1px solid rgba(10,37,64,0.2);
        padding-bottom: 2px;
        transition: border-color 0.2s;
    }
    .uc-feature-content a:hover {
        border-color: #0a2540;
    }

    /* MOCKUP UI */
    .uc-split-mockup {
        position: relative;
    }
    
    .uc-mockup-wrapper {
        position: relative;
        background: #f5f5f7;
        border-radius: 12px;
        border: 1px solid rgba(10,37,64,0.06);
        box-shadow: 0 40px 80px -20px rgba(10,37,64,0.12), 0 20px 40px -20px rgba(10,37,64,0.08);
        overflow: hidden;
    }
    
    .uc-mockup-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 24px;
        background: #fff;
        border-bottom: 1px solid rgba(10,37,64,0.06);
    }
    
    .uc-mockup-logo {
        font-weight: 800;
        color: #0a2540;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.95rem;
    }
    
    .uc-mockup-nav {
        display: flex;
        gap: 20px;
        font-size: 0.85rem;
        color: #64748b;
        font-weight: 500;
    }
    .uc-mockup-nav span.active {
        color: #0a2540;
        font-weight: 600;
        background: #f1f5f9;
        padding: 4px 10px;
        border-radius: 6px;
    }
    
    .uc-mockup-body {
        padding: 48px 32px;
        background: #f5f5f7;
        text-align: center;
    }
    
    .uc-mockup-body h4 {
        font-size: 1.25rem;
        font-weight: 800;
        color: #0a2540;
        margin-bottom: 8px;
    }
    
    .uc-mockup-body p {
        font-size: 0.9rem;
        color: #475569;
        margin-bottom: 40px;
    }
    
    .uc-mockup-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        position: relative;
        z-index: 1;
        margin-bottom: 40px;
        align-items: center;
    }
    
    .uc-mc {
        background: #fff;
        padding: 24px 16px;
        border: 1px solid rgba(10,37,64,0.06);
        position: relative;
        text-align: center;
    }
    
    .uc-mc-1 { border-radius: 12px 0 0 12px; border-right: none; }
    .uc-mc-3 { border-radius: 0 12px 12px 0; border-left: none; }
    .uc-mc-2 {
        border-radius: 12px;
        background: #ffffff;
        box-shadow: 0 20px 40px rgba(10,37,64,0.08), 0 4px 12px rgba(10,37,64,0.04);
        z-index: 2;
        padding: 36px 16px;
        border: 1px solid rgba(10,37,64,0.1);
    }
    
    .uc-mc-badge {
        position: absolute;
        top: -12px;
        left: 50%;
        transform: translateX(-50%);
        background: #10b981; /* Emerald */
        color: #fff;
        font-size: 0.65rem;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 999px;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }
    
    .uc-mc-title {
        font-size: 0.85rem;
        font-weight: 700;
        color: #0a2540;
        margin-bottom: 20px;
    }
    
    .uc-mc-icon {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        margin: 0 auto 20px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .uc-mc-1 .uc-mc-icon { background: #f1f5f9; color: #475569; } 
    .uc-mc-2 .uc-mc-icon { background: #d1fae5; color: #059669; } /* Emerald */
    .uc-mc-3 .uc-mc-icon { background: #f1f5f9; color: #0a2540; } 
    
    .uc-mc-btn {
        background: #f1f5f9;
        color: #475569;
        font-size: 0.75rem;
        font-weight: 600;
        padding: 8px 16px;
        border-radius: 6px;
        display: inline-block;
        transition: all 0.2s;
    }
    .uc-mc-2 .uc-mc-btn {
        background: #10b981;
        color: #ffffff;
    }
    .uc-mc-3 .uc-mc-btn {
        background: #f1f5f9;
        color: #0a2540;
    }
    
    .uc-mockup-features {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        text-align: left;
        font-size: 0.75rem;
        color: #475569;
        line-height: 1.5;
        padding: 0 16px;
    }
    
    .uc-mockup-features ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    
    .uc-mockup-features li {
        margin-bottom: 10px;
        position: relative;
        padding-left: 14px;
    }
    .uc-mockup-features li::before {
        content: '→';
        position: absolute;
        left: 0;
        color: #94a3b8;
        font-size: 0.7rem;
    }
    
    @media (max-width: 900px) {
        .uc-split-grid {
            grid-template-columns: 1fr;
            gap: 4rem;
        }
        .uc-split-text {
            max-width: 100%;
        }
        .uc-mockup-nav { display: none; }
        .uc-mockup-features { grid-template-columns: 1fr; gap: 24px; text-align: center; }
        .uc-mockup-features li::before { display: none; }
        .uc-mockup-features li { padding-left: 0; }
        .uc-mockup-cards { grid-template-columns: 1fr; gap: 16px; margin-bottom: 24px; }
        .uc-mc-1, .uc-mc-3 { border-radius: 8px; border: 1px solid rgba(10,25,47,0.06); }
        .uc-mc-2 { padding: 24px 16px; }
    }

    /* ── CTA SECTION ── */
    .uc-cta-section {
        padding: 4rem 0 8rem;
        background: #fff;
    }
    .uc-cta-box {
        background: #0a2540;
        border-radius: 20px;
        padding: 4rem 2rem;
        text-align: center;
        color: #fff;
        position: relative;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(10,37,64,0.25);
    }
    .uc-cta-box::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: radial-gradient(circle at center top, rgba(16,185,129,0.15), transparent 70%);
        pointer-events: none;
    }
    .uc-cta-box h2 { font-size: 2.2rem; font-weight: 800; margin-bottom: 1rem; position: relative; z-index: 1; }
    .uc-cta-box p { font-size: 1.1rem; color: #aab7c4; margin-bottom: 2rem; position: relative; z-index: 1; }
