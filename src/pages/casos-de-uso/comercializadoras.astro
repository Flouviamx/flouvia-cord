---

export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import QuantizedWaveBg from '../../components/soluciones/QuantizedWaveBg.jsx';
import FaqAccordion from '../../components/landing/FaqAccordion.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import '../../styles/mockups.css';
import TestimonialCarousel from '../../components/soluciones/TestimonialCarousel.jsx';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
const t = useTranslations(lang);

const metaTitle = "Cord para Comercializadoras B2B — Cotizaciones y Crédito en México";
const metaDesc = "Digitaliza las ventas de tu comercializadora: cotiza por volumen, controla el crédito Net 30/60 por cliente y timbra CFDI 4.0 automático en pedidos grandes. Para distribuidoras y mayoristas B2B en México.";

// FAQ + JSON-LD (jul 2026, auditoría SEO/AI-SEO) — preguntas ancladas a
// capacidades reales del producto.
const FAQS = [
    {
        q: '¿Cord marca los pedidos de un cliente con saldo vencido?',
        a: 'Sí. Defines el límite de crédito por cliente y, si un pedido nuevo lo rebasa por saldo vencido, Cord lo marca y avisa a tu equipo antes de aprobarlo — no se procesa solo.',
    },
    {
        q: '¿Puedo dar precios por volumen y por nivel de cliente al mismo tiempo?',
        a: 'Sí. Defines una matriz de precios por volumen a nivel producto y, además, un nivel de cliente (Estándar, Plata, Oro, Distribuidor) con su propio descuento — Cord aplica el que corresponda automáticamente al cotizar.',
    },
    {
        q: '¿Cómo veo qué tan vencida está mi cartera?',
        a: 'El panel de Cobranza muestra el aging de tu cartera por antigüedad, el saldo vencido y los días promedio de cobro por cliente, con recordatorios automáticos por correo y WhatsApp.',
    },
    {
        q: '¿Cord timbra CFDI para pedidos con muchas líneas de producto?',
        a: 'Sí, sin límite de líneas por cotización. Al aprobarse el pedido, Cord timbra el CFDI 4.0 completo ante el SAT vía Facturapi, sin recapturar los datos en otro sistema.',
    },
];
const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: FAQS.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
const breadcrumbSchema = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Cord', item: 'https://cordhq.app/' },
        { '@type': 'ListItem', position: 2, name: 'Comercializadoras', item: 'https://cordhq.app/casos-de-uso/comercializadoras' },
    ],
};

const magneticNodes = [
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://salesforce.com&size=128", alt: "Salesforce", top: "10%", left: "30%", width: 100, zIndex: 2 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://sap.com&size=128", alt: "SAP", top: "25%", left: "65%", width: 140, zIndex: 3 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://quickbooks.intuit.com&size=128", alt: "QuickBooks", top: "50%", left: "15%", width: 120, zIndex: 1 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://shopify.com&size=128", alt: "Shopify", top: "75%", left: "45%", width: 90, zIndex: 2 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://oracle.com&size=128", alt: "Oracle", top: "60%", left: "80%", width: 110, zIndex: 1 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://whatsapp.com&size=128", alt: "WhatsApp", top: "-5%", left: "75%", width: 70, zIndex: 1 }
];

const testimonialItems = [
    {
        id: 'salesforce',
        name: 'Salesforce',
        logoUrl: 'https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://salesforce.com&size=128',
        logoUrlLarge: 'https://upload.wikimedia.org/wikipedia/commons/thumb/f/f9/Salesforce.com_logo.svg/512px-Salesforce.com_logo.svg.png',
        quote: '«Cord se integra perfecto a nuestro CRM para cerrar cotizaciones complejas y gestionar líneas de crédito B2B sin fricción.»',
        author: 'Directora Comercial',
        bgGradient: 'linear-gradient(135deg, #0284c7, #0369a1)',
        bgImage: 'https://images.unsplash.com/photo-1556761175-5973dc0f32e7?q=80&w=2000&auto=format&fit=crop'
    },
    {
        id: 'sap',
        name: 'SAP',
        logoUrl: 'https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://sap.com&size=128',
        logoUrlLarge: 'https://upload.wikimedia.org/wikipedia/commons/thumb/5/59/SAP_2011_logo.svg/512px-SAP_2011_logo.svg.png',
        quote: '«La sincronización de pedidos por volumen y control de límites de crédito desde Cord ha optimizado la cartera vencida en un 40%.»',
        author: 'Gerente de Finanzas',
        bgGradient: 'linear-gradient(135deg, #1d4ed8, #1e3a8a)'
    },
    {
        id: 'quickbooks',
        name: 'QuickBooks',
        logoUrl: 'https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://quickbooks.intuit.com&size=128',
        logoUrlLarge: 'https://upload.wikimedia.org/wikipedia/commons/thumb/1/14/QuickBooks_logo.svg/512px-QuickBooks_logo.svg.png',
        quote: '«La conciliación de pagos SPEI y tarjetas es automática. El CFDI 4.0 fluye directo a la contabilidad sin intervención manual.»',
        author: 'Controller',
        bgGradient: 'linear-gradient(135deg, #15803d, #14532d)',
        bgImage: 'https://images.unsplash.com/photo-1542744173-8e7e53415bb0?q=80&w=2000&auto=format&fit=crop'
    },
    {
        id: 'shopify',
        name: 'Shopify',
        logoUrl: 'https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://shopify.com&size=128',
        logoUrlLarge: 'https://upload.wikimedia.org/wikipedia/commons/thumb/0/0e/Shopify_logo_2018.svg/512px-Shopify_logo_2018.svg.png',
        quote: '«Nuestros clientes B2B al por mayor tienen ahora un portal de pagos y un proceso de compra tan ágil como en B2C.»',
        author: 'Head of Wholesale',
        bgGradient: 'linear-gradient(135deg, #16a34a, #166534)'
    }
];

---


<Layout title={metaTitle} description={metaDesc}>
    <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
    <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
    <Nav />

    <main class="use-case-main">
        <!-- HERO -->
        <header class="startup-hero">
            <div class="startup-hero-bg">
                <QuantizedWaveBg client:only="react" />
            </div>
            <div class="startup-hero-content">
                <h1 class="startup-title reveal">Ventas B2B al por mayor sin fricción</h1>
                <p class="startup-sub">
                    Cotiza miles de productos, aplica descuentos por volumen y cierra tratos a crédito. Todo sincronizado directamente a facturación CFDI 4.0.
                </p>
                <div class="startup-actions">
                    <a href="/registro" class="btn-luxe">
                        <span>Empezar ahora</span>
                        <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        <div class="btn-shimmer"></div>
                    </a>
                    <a href="/contacto/ventas" class="btn-ghost"><span>Contactar a ventas</span></a>
                </div>
            </div>
        </header>

        <!-- LOGOS / TRUST -->
        <section class="uc-trust reveal">
            <p>Distribuidores modernos operan con Cord</p>
            <div class="uc-logos">
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://grainger.com&size=64" alt="Grainger" width="24" height="24" loading="lazy" />
                    <span>Grainger</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://uline.com&size=64" alt="Uline" width="24" height="24" loading="lazy" />
                    <span>Uline</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://fastenal.com&size=64" alt="Fastenal" width="24" height="24" loading="lazy" />
                    <span>Fastenal</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://sysco.com&size=64" alt="Sysco" width="24" height="24" loading="lazy" />
                    <span>Sysco</span>
                </div>
            </div>
        </section>

        <!-- LEYENDA STRIPE-LITERAL STRUCTURE -->
        <div class="stripe-literal-wrapper">
            <!-- Grid de fondo exacto -->
            <div class="sl-grid-bg">
                <div class="sl-col"></div>
                <div class="sl-col"></div>
                <div class="sl-col"></div>
                <div class="sl-col"></div>
            </div>

            <div class="uc-container" style="position:relative; z-index:10; padding-top: 4rem;">
                <!-- Header centrado -->
                <div class="sl-header reveal">
                    <span class="sl-eyebrow">Para comercializadoras</span>
                    <h2>Acelera el ciclo de ventas B2B y maneja crédito sin riesgo</h2>
                    <p>Cotiza rápidamente, aplica descuentos por volumen y aprueba líneas de crédito institucionales. Todo integrado con la emisión de facturas y el seguimiento de pagos Net 30/60.</p>
                </div>

                <!-- Split Layout -->
                <div class="sl-split reveal">
                    <!-- Izquierda: Features -->
                    <div class="sl-features">
                        <div class="slf-item active">
                            <div class="slf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" fill="currentColor" fill-opacity="0.15" stroke="none"/>
                                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" stroke-linecap="round" stroke-linejoin="round"/>
                                    <line x1="7" y1="7" x2="7.01" y2="7" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </div>
                            <div class="slf-text">
                                <h3>Descuentos Dinámicos por Volumen</h3>
                                <p>Aplica descuentos estructurados, márgenes específicos y niveles de precios según el distribuidor. El cotizador ajusta los montos al instante.</p>
                            </div>
                        </div>

                        <div class="slf-item">
                            <div class="slf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <rect x="2" y="5" width="20" height="14" rx="2" fill="currentColor" fill-opacity="0.15" stroke="none" />
                                    <rect x="2" y="5" width="20" height="14" rx="2" stroke-linecap="round" stroke-linejoin="round" />
                                    <line x1="2" y1="10" x2="22" y2="10" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </div>
                            <div class="slf-text">
                                <h3>Manejo de Crédito (Net 30)</h3>
                                <p>Asigna un límite de crédito a tus clientes recurrentes. Si el saldo excede el límite, Cord pausa los nuevos pedidos y solicita aprobación ejecutiva.</p>
                            </div>
                        </div>

                        <div class="slf-item">
                            <div class="slf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" fill="currentColor" fill-opacity="0.15" stroke="none" />
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" stroke-linecap="round" stroke-linejoin="round" />
                                    <polyline points="14 2 14 8 20 8" stroke-linecap="round" stroke-linejoin="round" />
                                    <line x1="16" y1="13" x2="8" y2="13" stroke-linecap="round" stroke-linejoin="round" />
                                    <line x1="16" y1="17" x2="8" y2="17" stroke-linecap="round" stroke-linejoin="round" />
                                    <polyline points="10 9 9 9 8 9" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </div>
                            <div class="slf-text">
                                <h3>Complementos de Pago (REP)</h3>
                                <p>Cuando recibes un pago parcial o diferido de una factura PPD, Cord genera automáticamente el Complemento de Recepción de Pago y lo envía al cliente.</p>
                            </div>
                        </div>
                    </div>

                    <!-- Derecha: Mockups -->
                    <div class="sl-mockups mk-comercializadora-mockup">
                        <!-- Card Principal -->
                        <div class="slm-main" style="border-top: 4px solid #f59e0b;">
                            <div class="slm-main-header">
                                <div class="slm-mh-icon" style="background:#fef3c7; color:#b45309;">C</div>
                                <span>Aprobación de Pedido</span>
                            </div>
                            <div class="slm-main-body" style="padding: 16px;">
                                <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px;">
                                    <div>
                                        <div style="font-weight:600; font-size:15px; color:#0f172a;">Global Supply Co.</div>
                                        <div style="font-size:13px; color:#64748b;">Límite Crédito: $150,000</div>
                                    </div>
                                    <div class="cmk-badge cmk-b-amber">Net 30</div>
                                </div>
                                
                                <div style="border: 1px solid #fcd34d; background:#fffbeb; border-radius: 6px; padding:12px; margin-bottom:16px;">
                                    <div style="font-size:13px; font-weight:600; color:#b45309; display:flex; align-items:center; gap:6px; margin-bottom:4px;">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                                        Alerta de Límite de Crédito
                                    </div>
                                    <div style="font-size:12px; color:#92400e;">
                                        Este pedido por $45,000 elevará el saldo vivo a $165,000, superando el límite aprobado.
                                    </div>
                                    <div style="margin-top:10px; display:flex; gap:8px;">
                                        <div style="background:#b45309; color:#fff; padding:4px 10px; border-radius:4px; font-size:12px; font-weight:500;">Aprobar Excepción</div>
                                        <div style="background:#fde68a; color:#92400e; padding:4px 10px; border-radius:4px; font-size:12px; font-weight:500;">Solicitar Pago</div>
                                    </div>
                                </div>
                                
                                <div style="font-size:12px; font-weight:600; color:#475569; margin-bottom:8px;">Detalle del Pedido #8924</div>
                                <div style="border: 1px solid #e2e8f0; border-radius: 6px; overflow:hidden;">
                                    <div style="display:flex; justify-content:space-between; padding:8px 12px; font-size:13px; border-bottom:1px solid #e2e8f0;">
                                        <div style="font-weight:500; color:#0f172a;">Rodamiento 6205 <span style="font-size:11px; color:#64748b;">(x500)</span></div>
                                        <div style="font-weight:500;">$24,000</div>
                                    </div>
                                    <div style="display:flex; justify-content:space-between; padding:8px 12px; font-size:13px; background:#f8fafc;">
                                        <div style="font-weight:500; color:#0f172a;">Banda transp. <span style="font-size:11px; color:#64748b;">(x80)</span></div>
                                        <div style="font-weight:500;">$21,000</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Conector SVG -->
                        <svg class="slm-connector" viewBox="0 0 100 60" preserveAspectRatio="none">
                            <path d="M 0,10 C 40,10 60,50 100,50" fill="none" stroke="var(--color-blue-deep)" stroke-width="2" stroke-dasharray="4 4" stroke-linecap="round" />
                        </svg>

                        <!-- Card Flotante -->
                        <div class="slm-chat" style="top: 50%; left: 40%; width: 280px; box-shadow: 0 20px 40px rgba(0,0,0,0.15); border: 1px solid rgba(226, 232, 240, 0.8);">
                            <div class="slm-chat-header" style="background:#fef3c7; border-bottom:1px solid #fde68a; color:#b45309; display:flex; align-items:center; gap:8px;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px; height:16px;"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                                Acción Requerida
                            </div>
                            <div class="slm-chat-body" style="padding:16px;">
                                <div class="slmc-bubble slmc-ai">
                                    Para liberar este pedido, el cliente debe saldar al menos $15,000 de sus facturas atrasadas. ¿Envío recordatorio de pago con link de pago con tarjeta?
                                </div>
                                <div style="display:flex; gap:8px; margin-top:12px;">
                                    <div style="flex:1; border:1px solid #e2e8f0; background:#f8fafc; color:#0f172a; text-align:center; padding:6px; border-radius:4px; font-size:12px; font-weight:500;">Sí, enviar link</div>
                                    <div style="flex:1; border:1px solid #e2e8f0; background:#fff; color:#475569; text-align:center; padding:6px; border-radius:4px; font-size:12px;">Descartar</div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>

                <!-- SECONDARY BENEFITS SECTION -->
        <section class="uc-benefits">
            <div class="uc-container">
                <div class="uc-benefits-intro reveal">
                    <span class="uc-split-label">Elimina la fricción en ventas B2B</span>
                    <h2 class="uc-split-title">Acelera tu ciclo comercial desde la orden hasta el pago</h2>
                    <p class="uc-split-desc">
                        Olvida los procesos manuales que retrasan el despacho de mercancía. Con Cord, tus agentes de ventas cierran pedidos más rápido, el crédito se gestiona automáticamente y la cobranza se concilia sin esfuerzo humano.
                    </p>
                </div>

                <div class="uc-bento-cards">
                    <!-- Tarjeta 1 -->
                    <div class="uc-bento-card reveal">
                        <div class="uc-bc-text">
                            <h3>Límites de crédito por cliente con bloqueo automático</h3>
                            <p>Define el límite de crédito de cada distribuidor en Cord. Si un cliente intenta pasar un nuevo pedido con saldo vencido, el sistema lo marca y tu equipo recibe la alerta antes de aprobar.</p>
                            <a href="/registro" class="uc-link-arrow">Controla tu cartera de crédito <span>&rarr;</span></a>
                        </div>
                        <div class="uc-bc-mockup">
                            <div class="cmk-stage">
                                <div class="cmk-shot">
                                    <div class="cmk-nav">
                                        <div class="cmk-nav-l">
                                            <span class="cmk-nav-title">Crédito · Distribuidora El Sol</span>
                                        </div>
                                        <span class="cmk-badge cmk-b-amber">57% utilizado</span>
                                    </div>
                                    <div class="cmk-body">
                                        <div class="cmk-kv" style="border-bottom:none; padding-top:0;">
                                            <span class="cmk-k">Crédito utilizado</span>
                                            <span class="cmk-v editorial">$85,000</span>
                                        </div>
                                        <div style="width:100%; height:8px; background:#e2e8f0; border-radius:10px; overflow:hidden; margin:2px 0 6px;">
                                            <div style="width:57%; height:100%; background:linear-gradient(90deg,#1e293b,#0f172a); border-radius:10px;"></div>
                                        </div>
                                        <div class="cmk-kv">
                                            <span class="cmk-k">Límite autorizado · Net 30</span>
                                            <span class="cmk-v editorial">$150,000 MXN</span>
                                        </div>
                                        <div class="cmk-kv">
                                            <span class="cmk-k">Saldo vencido</span>
                                            <span class="cmk-badge cmk-b-red">$12,400 · 8 días</span>
                                        </div>
                                        <div class="cmk-kv" style="border-bottom:none;">
                                            <span class="cmk-k">Pedido nuevo PO-8931</span>
                                            <span class="cmk-badge cmk-b-amber">Retenido</span>
                                        </div>
                                        <div class="cmk-alert cmk-alert-amber" style="margin-top:8px;">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                                            Pedido retenido por saldo vencido. Tu equipo recibió la alerta para revisarlo.
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Tarjeta 2 -->
                    <div class="uc-bento-card reveal">
                        <div class="uc-bc-text">
                            <h3>Cobranza vencida con recordatorios automáticos</h3>
                            <p>Cord muestra el aging de tu cartera por cliente, los saldos vencidos y los días promedio de cobro. Cuando un cliente no ha pagado, manda recordatorios automáticos por correo y WhatsApp antes y después del vencimiento.</p>
                            <a href="/registro" class="uc-link-arrow">Mejora tu ciclo de cobro <span>&rarr;</span></a>
                        </div>
                        <div class="uc-bc-mockup">
                            <div class="cmk-stage">
                                <div class="cmk-shot">
