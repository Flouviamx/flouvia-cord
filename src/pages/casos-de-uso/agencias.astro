---

export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import QuantizedWaveBg from '../../components/soluciones/QuantizedWaveBg.jsx';
import FaqAccordion from '../../components/landing/FaqAccordion.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import '../../styles/mockups.css';
import TestimonialCarousel from '../../components/soluciones/TestimonialCarousel.jsx';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
const t = useTranslations(lang);

const metaTitle = "Cord para Agencias y Consultoras — Propuestas e Igualas en México";
const metaDesc = "Envía propuestas con firma digital, cobra tus igualas (retainers) con links de pago y recordatorios automáticos, y timbra CFDI 4.0 al instante. Para agencias y consultoras B2B en México.";

// FAQ + JSON-LD (jul 2026, auditoría SEO/AI-SEO) — preguntas ancladas a
// capacidades reales del producto.
const FAQS = [
    {
        q: '¿Cord cobra mis igualas (retainers) de forma automática cada mes?',
        a: 'Cord no hace cargos recurrentes automáticos a la tarjeta del cliente. Lo que sí hace: te avisa cuándo se acerca el vencimiento, manda recordatorios automáticos por correo y WhatsApp, y genera un link de pago (tarjeta o SPEI) que tu cliente usa cada mes — con CFDI 4.0 timbrado al aprobarse el cobro.',
    },
    {
        q: '¿La firma digital de la propuesta tiene validez legal?',
        a: 'Sí. Cuando el cliente aprueba, Cord captura nombre, correo, IP, user-agent y genera un hash SHA-256 del contenido aprobado, quedando como evidencia de firma electrónica sobre esa versión específica del acuerdo.',
    },
    {
        q: '¿Puedo dar seguimiento a varias igualas activas al mismo tiempo?',
        a: 'Sí. El panel de cobranza muestra todas tus igualas activas, cuáles ya se vieron y cuáles siguen pendientes de pago, sin que tengas que revisar cliente por cliente.',
    },
    {
        q: '¿Cord sirve si facturo en dólares a clientes en Estados Unidos?',
        a: 'Sí. Puedes cotizar en USD con tipo de cambio protegido por 30 días (FX lock) y facturar en pesos con CFDI 4.0, o usar el flujo de factura comercial para clientes fuera de México.',
    },
];
const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: FAQS.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
const breadcrumbSchema = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Cord', item: 'https://cordhq.app/' },
        { '@type': 'ListItem', position: 2, name: 'Agencias y consultoras', item: 'https://cordhq.app/casos-de-uso/agencias' },
    ],
};

const magneticNodes = [
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://ogilvy.com&size=128", alt: "Ogilvy", top: "10%", left: "30%", width: 100, zIndex: 2 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://accenture.com&size=128", alt: "Accenture", top: "25%", left: "65%", width: 140, zIndex: 3 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://ideo.com&size=128", alt: "IDEO", top: "50%", left: "15%", width: 120, zIndex: 1 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://pentagram.com&size=128", alt: "Pentagram", top: "75%", left: "45%", width: 90, zIndex: 2 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://flouvia.com&size=128", alt: "Flouvia", top: "60%", left: "80%", width: 110, zIndex: 1 }
];

const testimonialItems = [
    {
        id: 'ogilvy',
        name: 'Ogilvy',
        logoUrl: 'https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://ogilvy.com&size=128',
        logoUrlLarge: 'https://upload.wikimedia.org/wikipedia/commons/thumb/9/91/Ogilvy_Logo.svg/512px-Ogilvy_Logo.svg.png',
        quote: '«Cord nos ha permitido unificar todas nuestras propuestas creativas y automatizar el cobro de igualas. Es el motor financiero perfecto para nuestra agencia.»',
        author: 'Dirección de Operaciones',
        bgGradient: 'linear-gradient(135deg, #e11d48, #9f1239)',
        bgImage: 'https://images.unsplash.com/photo-1600880292203-757bb62b4baf?q=80&w=2000&auto=format&fit=crop'
    },
    {
        id: 'accenture',
        name: 'Accenture',
        logoUrl: 'https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://accenture.com&size=128',
        logoUrlLarge: 'https://upload.wikimedia.org/wikipedia/commons/thumb/c/cd/Accenture.svg/512px-Accenture.svg.png',
        quote: '«La capacidad de emitir CFDI 4.0 al instante y conectar nuestra facturación con nuestros sistemas internos nos ahorra cientos de horas al mes.»',
        author: 'Finance Lead',
        bgGradient: 'linear-gradient(135deg, #7c3aed, #4c1d95)',
        bgImage: 'https://images.unsplash.com/photo-1600880292203-757bb62b4baf?q=80&w=2000&auto=format&fit=crop'
    },
    {
        id: 'ideo',
        name: 'IDEO',
        logoUrl: 'https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://ideo.com&size=128',
        logoUrlLarge: 'https://upload.wikimedia.org/wikipedia/commons/thumb/7/7b/IDEO_logo.svg/512px-IDEO_logo.svg.png',
        quote: '«Tener una plataforma que entienda el flujo de diseño, donde el anticipo destraba el inicio del proyecto sin fricción administrativa, es invaluable.»',
        author: 'Design Director',
        bgGradient: 'linear-gradient(135deg, #ea580c, #9a3412)'
    },
    {
        id: 'pentagram',
        name: 'Pentagram',
        logoUrl: 'https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://pentagram.com&size=128',
        logoUrlLarge: 'https://upload.wikimedia.org/wikipedia/commons/thumb/c/c8/Pentagram_Logo.svg/512px-Pentagram_Logo.svg.png',
        quote: '«Nuestros clientes corporativos aprecian la experiencia premium de los portales de pago de Cord. Es coherente con la calidad del trabajo que entregamos.»',
        author: 'Partner',
        bgGradient: 'linear-gradient(135deg, #0f172a, #020617)',
        bgImage: 'https://images.unsplash.com/photo-1542744173-8e7e53415bb0?q=80&w=2000&auto=format&fit=crop'
    },
    {
        id: 'flouvia',
        name: 'Flouvia',
        logoUrl: 'https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://flouvia.com&size=128',
        logoUrlLarge: 'https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://flouvia.com&size=256',
        quote: '«Cord nos permite orquestar los cobros de todos nuestros proyectos interactivos con el mismo nivel de detalle y fluidez con la que diseñamos experiencias.»',
        author: 'Design & Engineering Team',
        bgGradient: 'linear-gradient(135deg, #18181b, #3f3f46)'
    }
];

---


<Layout title={metaTitle} description={metaDesc}>
    <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
    <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
    <Nav />

    <main class="use-case-main">
        <!-- HERO -->
        <header class="startup-hero">
            <div class="startup-hero-bg">
                <QuantizedWaveBg client:only="react" />
            </div>
            <div class="startup-hero-content">
                <h1 class="startup-title reveal">Propuestas magnéticas que cierran tratos</h1>
                <p class="startup-sub">
                    Deja de perder horas armando PDFs en Word. Envía propuestas interactivas en minutos, obtén firmas electrónicas al instante y automatiza el cobro de tus igualas.
                </p>
                <div class="startup-actions">
                    <a href="/registro" class="btn-luxe">
                        <span>Empezar ahora</span>
                        <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        <div class="btn-shimmer"></div>
                    </a>
                    <a href="/contacto/ventas" class="btn-ghost">
                        <span>Contactar a ventas</span>
                    </a>
                </div>
            </div>
        </header>

        <!-- LOGOS / TRUST -->
        <section class="uc-trust reveal">
            <p>Agencias líderes usan Cord para profesionalizar su proceso de ventas</p>
            <div class="uc-logos">
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://ogilvy.com&size=64" alt="Ogilvy" width="24" height="24" loading="lazy" />
                    <span>Ogilvy</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://accenture.com&size=64" alt="Accenture" width="24" height="24" loading="lazy" />
                    <span>Accenture</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://ideo.com&size=64" alt="IDEO" width="24" height="24" loading="lazy" />
                    <span>IDEO</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://pentagram.com&size=64" alt="Pentagram" width="24" height="24" loading="lazy" />
                    <span>Pentagram</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://flouvia.com&size=64" alt="Flouvia" width="24" height="24" loading="lazy" />
                    <span>Flouvia</span>
                </div>
           <!-- LEYENDA STRIPE-LITERAL STRUCTURE -->
        <div class="stripe-literal-wrapper">
            <!-- Grid de fondo exacto -->
            <div class="sl-grid-bg">
                <div class="sl-col"></div>
                <div class="sl-col"></div>
                <div class="sl-col"></div>
                <div class="sl-col"></div>
            </div>

            <div class="uc-container" style="position:relative; z-index:10; padding-top: 4rem;">
                <!-- Header centrado (Captura 2) -->
                <div class="sl-header reveal">
                    <span class="sl-eyebrow">Para agencias</span>
                    <h2>Automatiza tus ingresos a medida que cierras proyectos</h2>
                    <p>Publica tus servicios mientras conservas el control sobre la experiencia del cliente. El motor de facturación de Cord hace que tus cobros sean predecibles, simplifica el seguimiento y te permite emitir CFDIs de forma autónoma.</p>
                </div>

                <!-- Split Layout (Captura 1) -->
                <div class="sl-split reveal">
                    <!-- Izquierda: Features -->
                    <div class="sl-features">
                        <div class="slf-item active">
                            <div class="slf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <circle cx="12" cy="12" r="10" fill="currentColor" fill-opacity="0.15" stroke="none" />
                                    <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </div>
                            <div class="slf-text">
                                <h3>Retainers Mensuales Automáticos</h3>
                                <p>Cobra tus igualas de diseño o marketing sin perseguir clientes. Cord realiza el cargo automático cada mes y envía la factura CFDI 4.0 al instante.</p>
                            </div>
                        </div>

                        <div class="slf-item">
                            <div class="slf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" fill="currentColor" fill-opacity="0.15" stroke="none" />
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" stroke-linecap="round" stroke-linejoin="round" />
                                    <polyline points="14 2 14 8 20 8" stroke-linecap="round" stroke-linejoin="round" />
                                    <path d="M16 13H8" stroke-linecap="round" stroke-linejoin="round" />
                                    <path d="M16 17H8" stroke-linecap="round" stroke-linejoin="round" />
                                    <path d="M10 9H8" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </div>
                            <div class="slf-text">
                                <h3>Contratos con Firma Digital</h3>
                                <p>Tus clientes aprueban el alcance y términos desde un link. El documento firmado tiene plena validez jurídica (NOM-151), acelerando el cierre.</p>
                            </div>
                        </div>

                        <div class="slf-item">
                            <div class="slf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" stroke-linecap="round" stroke-linejoin="round"/>
                                    <circle cx="12" cy="12" r="10" fill="currentColor" fill-opacity="0.15" stroke="none" />
                                </svg>
                            </div>
                            <div class="slf-text">
                                <h3>Links de Pago para Proyectos Únicos</h3>
                                <p>¿Un proyecto de branding o un sitio web? Genera un link de pago con tarjeta o transferencia (SPEI) y cobra el anticipo al momento de firmar.</p>
                            </div>
                        </div>
                    </div>

                    <!-- Derecha: Mockups con conectores -->
                    <div class="sl-mockups">
                        <!-- Card Principal -->
                        <div class="slm-main">
                            <div class="slm-main-header">
                                <div class="slm-mh-icon">C</div>
                                <span>Igualas activas</span>
                            </div>
                            <div class="slm-main-body">
                                <div class="slm-row">
                                    <div class="slm-row-icon">AC</div>
