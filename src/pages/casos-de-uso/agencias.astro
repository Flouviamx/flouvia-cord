                                                    <div class="cmk-t1" style="font-size:14px">Propuesta · Branding 2026</div>
                                                    <div class="cmk-t2">Anticipo 50% · Acme Corp</div>
                                                </div>
                                            </div>
                                            <span class="cmk-badge cmk-b-blue">Aprobada</span>
                                        </div>
                                        <div class="cmk-divider"></div>
                                        <div class="cmk-big editorial">$45,000.00 MXN</div>
                                        <div class="cmk-big-sub">Anticipo del proyecto · Total $90,000</div>
                                        <div style="display:flex; flex-direction:column; gap:10px; margin-top:16px">
                                            <span class="cmk-cta cmk-cta-solid" style="justify-content:center">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px;"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                                                Pagar con tarjeta
                                            </span>
                                            <span class="cmk-cta cmk-cta-ghost" style="justify-content:center">Transferencia SPEI</span>
                                        </div>
                                        <div style="display:flex; align-items:center; gap:8px; background:#f8fafc; padding:10px 14px; border-radius:8px; border:1px solid #f1f5f9; margin-top:14px;">
                                            <span class="cmk-dot cmk-dot-green"></span>
                                            <span class="cmk-t2" style="color:#475569; font-weight:600;">Pago protegido vía Stripe · CFDI automático al pagar</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Tarjeta 2 -->
                    <div class="uc-bento-card reveal">
                        <div class="uc-bc-text">
