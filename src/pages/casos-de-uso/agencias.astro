---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import GreenRampShader from '../../components/soluciones/GreenRampShader.jsx';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
const t = useTranslations(lang);

const metaTitle = "Cord para Agencias y Consultoras | Propuestas y Retainers";
const metaDesc = "Envía propuestas hermosas, obtén firmas vinculantes y automatiza el cobro de tus igualas (retainers).";
---

<Layout title={metaTitle} description={metaDesc}>
    <Nav />
    
    <main class="use-case-main">
        <!-- HERO SECTION -->
        <header class="uc-hero">
            <div class="uc-hero-bg">
                <GreenRampShader client:only="react" />
            </div>
            <div class="uc-container uc-hero-inner">
                <div class="uc-hero-content">
                    <h1 class="uc-title reveal">Propuestas magnéticas que cierran tratos</h1>
                    <p class="uc-sub reveal">
                        Deja de perder horas armando PDFs en Word. Envía propuestas interactivas en minutos, obtén firmas electrónicas al instante y automatiza el cobro de tus igualas.
                    </p>
                    <div class="uc-actions reveal">
                        <a href="/registro" class="btn-luxe">
                            <span>Empezar ahora</span>
                            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            <div class="btn-shimmer"></div>
                        </a>
                        <a href="/contacto/ventas" class="btn-ghost">
                            <span>Contactar a ventas</span>
                        </a>
                    </div>
                </div>
            </div>
        </header>

        <!-- LOGOS / TRUST -->
        <section class="uc-trust reveal">
            <p>Agencias líderes usan Cord para profesionalizar su proceso de ventas</p>
            <div class="uc-logos">
                <span class="trust-logo">Ogilvy</span>
                <span class="trust-logo">Accenture</span>
                <span class="trust-logo">IDEO</span>
                <span class="trust-logo">Pentagram</span>
            </div>
        </section>

        <!-- FEATURES GRID -->
        <section class="uc-features">
            <div class="uc-container">
                <div class="uc-features-header reveal">
                    <h2>Tu agencia, operando al máximo nivel</h2>
                    <p>Herramientas diseñadas para acelerar el ciclo de ventas de servicios profesionales.</p>
                </div>

                <div class="uc-bento-grid">
                    <div class="uc-bento-card reveal">
                        <div class="uc-bento-icon"><svg viewBox="0 0 24 24" fill="none" stroke="var(--color-blue-deep)" stroke-width="2"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg></div>
                        <h3>Firmas Vinculantes</h3>
                        <p>Cada propuesta aprobada incluye una firma electrónica con validez legal. Sin necesidad de usar herramientas de terceros caras.</p>
                    </div>
                    <div class="uc-bento-card reveal">
                        <div class="uc-bento-icon"><svg viewBox="0 0 24 24" fill="none" stroke="var(--color-blue-deep)" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"></rect><line x1="2" y1="10" x2="22" y2="10"></line></svg></div>
                        <h3>Cobro de Retainers (Igualas)</h3>
                        <p>Convierte a tus clientes de proyecto a iguala mensual fácilmente. Cord se encarga del cargo recurrente a tarjeta y de enviar la factura CFDI mes a mes.</p>
                    </div>
                    <div class="uc-bento-card reveal">
                        <div class="uc-bento-icon"><svg viewBox="0 0 24 24" fill="none" stroke="var(--color-blue-deep)" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg></div>
                        <h3>Plantillas Premium</h3>
                        <p>Destaca desde el primer contacto. Nuestras plantillas de propuestas gritan profesionalismo, haciendo que tu agencia parezca el doble de grande.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA SECTION -->
        <section class="uc-cta-section">
            <div class="uc-container">
                <div class="uc-cta-box reveal">
                    <h2>¿Listo para agilizar tus ventas?</h2>
                    <p>Agencias líderes usan Cord para profesionalizar su proceso de ventas.</p>
                    <a href="/registro" class="btn-luxe">Comenzar gratis</a>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Layout>

<style>
    /* VARIABLES Y UTILIDADES GLOBALES PARA USE CASES */
    .use-case-main {
        background: var(--color-bg);
        padding-top: 0;
        overflow-x: hidden;
        color: var(--color-text-muted);
    }

    .uc-container {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 5%;
    }

    /* ── HERO SECTION ── */
    .uc-hero {
        position: relative;
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        align-items: center;
        padding: 8rem 0 4rem;
        background: #ffffff;
        overflow: hidden;
        border-bottom: 1px solid var(--color-border);
    }

    /* Shader background (R3F) — fondo absoluto del hero */
    .uc-hero-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
    }
    /* Fade suave hacia el blanco del contenido (legibilidad del texto) */
    .uc-hero-bg::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(105deg, rgba(255,255,255,0.92) 0%, rgba(255,255,255,0.55) 38%, rgba(255,255,255,0) 72%);
        pointer-events: none;
        z-index: 2;
    }

    .uc-hero-inner {
        position: relative;
        z-index: 1;
        width: 100%;
    }

    .uc-hero-content {
        max-width: 640px;
    }

    .uc-title {
        font-size: clamp(2.2rem, 4vw, 3.8rem);
        font-weight: 800;
        color: var(--color-blue-deep);
        line-height: 1.1;
        letter-spacing: -0.04em;
        margin-bottom: 1.2rem;
        text-wrap: balance;
    }

    .uc-sub {
        font-size: 1.15rem;
        color: var(--color-text-muted);
        line-height: 1.6;
        margin-bottom: 2rem;
        max-width: 90%;
    }

    /* ── BUTTONS (estilo soluciones/startups) ── */
    .uc-actions {
        display: flex;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .btn-luxe {
        position: relative;
        display: inline-flex; align-items: center; justify-content: center;
        background: var(--color-blue-deep); color: #fff;
        padding: 18px 38px; border-radius: 100px;
        font-size: 0.95rem; font-weight: 600; text-decoration: none;
        overflow: hidden;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 8px 24px rgba(10, 25, 47, 0.2);
    }
    .btn-luxe span { position: relative; z-index: 2; }
    .btn-arrow {
        position: relative; z-index: 2; display: inline-block;
        width: 16px; height: 16px; margin-left: 6px;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .btn-luxe:hover .btn-arrow { transform: translateX(4px); }
    .btn-shimmer {
        position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.18), transparent);
        transform: skew(-20deg); transition: 0s; z-index: 1;
    }
    .btn-luxe:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(10, 25, 47, 0.3);
    }
    .btn-luxe:active {
        transform: translateY(-1px);
        box-shadow: 0 2px 4px rgba(10, 25, 47, 0.1);
    }
    .btn-luxe:hover .btn-shimmer {
        left: 150%;
        transition: left 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .btn-ghost {
        display: inline-flex; align-items: center; gap: 9px;
        color: #0a2540; text-decoration: none;
        font-size: 1rem; font-weight: 600;
        padding: 15px 26px; border-radius: 100px;
        border: 1px solid rgba(10, 37, 64, 0.15);
        background: rgba(10, 37, 64, 0.03);
        transition: background 0.3s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease;
    }
    .btn-ghost:hover {
        background: rgba(10, 37, 64, 0.08);
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.05);
    }

    /* ── TRUST LOGOS ── */
    .uc-trust {
        text-align: center;
        padding: 3rem 5%;
        background: var(--color-bg);
    }
    .uc-trust p {
        font-size: 0.9rem; font-weight: 600; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1.5rem;
    }
    .uc-logos {
        display: flex; justify-content: center; gap: 3rem; flex-wrap: wrap; align-items: center;
    }
    .trust-logo {
        font-size: 1.4rem; font-weight: 800; color: #c1c9d2; letter-spacing: -0.5px;
    }

    /* ── FEATURES ── */
    .uc-features {
        padding: 6rem 0 6rem;
        background: var(--color-bg);
    }
    .uc-features-header {
        text-align: center;
        max-width: 600px;
        margin: 0 auto 4rem;
    }
    .uc-features-header h2 { font-size: 2.2rem; font-weight: 800; color: var(--color-blue-deep); margin-bottom: 1rem; }
    .uc-features-header p { font-size: 1.1rem; color: var(--color-text-muted); line-height: 1.6; }

    .uc-bento-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }
    .uc-bento-card {
        background: var(--color-bg);
        padding: 2.5rem;
        border-radius: 16px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 0 0 1px var(--color-border);
        transition: transform 0.3s, box-shadow 0.3s;
    }
    .uc-bento-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 0 0 1px var(--color-border);
    }
    .uc-bento-icon {
        width: 48px; height: 48px;
        background: var(--color-bg-soft);
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 1.5rem;
    }
    .uc-bento-card h3 { font-size: 1.2rem; font-weight: 700; color: var(--color-blue-deep); margin-bottom: 0.8rem; }
    .uc-bento-card p { font-size: 0.95rem; color: var(--color-text-muted); line-height: 1.6; }

    /* ── CTA SECTION ── */
    .uc-cta-section {
        padding: 4rem 0 8rem;
        background: var(--color-bg);
    }
    .uc-cta-box {
        background: var(--color-blue-deep);
        border-radius: 20px;
        padding: 4rem 2rem;
        text-align: center;
        color: #fff;
        position: relative;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(10, 25, 47, 0.25);
    }
    .uc-cta-box::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: radial-gradient(circle at center top, rgba(255,255,255,0.1), transparent 70%);
        pointer-events: none;
    }
    .uc-cta-box h2 { font-size: 2.2rem; font-weight: 800; margin-bottom: 1rem; position: relative; z-index: 1; }
    .uc-cta-box p { font-size: 1.1rem; color: #aab7c4; margin-bottom: 2rem; position: relative; z-index: 1; }
    .uc-cta-box .btn-luxe { background: #fff; color: var(--color-blue-deep); box-shadow: 0 4px 14px rgba(255, 255, 255, 0.15); }
    .uc-cta-box .btn-luxe:hover { background: var(--color-bg-soft); box-shadow: 0 6px 20px rgba(255, 255, 255, 0.25); }

    @media (max-width: 900px) {
        .uc-hero { padding: 9rem 0 6rem; }
        .uc-hero-content { max-width: 100%; }
        .uc-title { font-size: 2.5rem; }
        .uc-bento-grid { grid-template-columns: 1fr; }
    }
</style>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener('DOMContentLoaded', () => {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if(reduced) return;

        gsap.utils.toArray('.reveal').forEach((el: any) => {
            gsap.fromTo(el, { opacity: 0, y: 20 }, {
                opacity: 1, y: 0, duration: 0.8, ease: 'power2.out',
                scrollTrigger: { trigger: el, start: 'top 85%' }
            });
        });
    });
</script>
