---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
const t = useTranslations(lang);

const metaTitle = "Cord para Agencias y Consultoras | Propuestas y Retainers";
const metaDesc = "Envía propuestas hermosas, obtén firmas vinculantes y automatiza el cobro de tus igualas (retainers).";
---

<Layout title={metaTitle} description={metaDesc}>
    <Nav />
    
    <main class="use-case-main">
        <!-- HERO SECTION -->
        <header class="uc-hero">
            <div class="uc-container uc-hero-grid">
                <div class="uc-hero-content">
                    <h1 class="uc-title reveal">Propuestas magnéticas que cierran tratos</h1>
                    <p class="uc-sub reveal">
                        Deja de perder horas armando PDFs en Word. Envía propuestas interactivas en minutos, obtén firmas electrónicas al instante y automatiza el cobro de tus igualas.
                    </p>
                    <div class="uc-actions reveal">
                        <a href="/registro" class="btn-luxe">
                            <span>Empezar ahora</span>
                            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            <div class="btn-shimmer"></div>
                        </a>
                        <a href="/contacto/ventas" class="btn-ghost">Contactar a ventas <span class="arrow-right">→</span></a>
                    </div>
                </div>

                <div class="uc-hero-visual reveal-mockup">
                    <div class="uc-visual-glow" style="background: radial-gradient(circle at 50% 50%, rgba(10,25,47,0.15) 0%, transparent 60%);"></div>
                    <div class="uc-mockup-window">
                        <div class="uc-mockup-top">
                            <div class="uc-dots"><span></span><span></span><span></span></div>
                        </div>
                        <div class="uc-mockup-body">
                            <div class="mock-plan">
                                <span class="mp-title">Campaña de Rebranding + Retainer Anual</span>
                                <span class="mp-price">$85,000 <small>MXN</small></span>
                            </div>
                            <div class="mock-status">
                                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="var(--color-ok)" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                Firmada por el cliente · Anticipo cobrado
                            </div>
                            <div class="mock-cfdi">
                                <span class="cfdi-badge" style="background: rgba(10,25,47,0.08); color: var(--color-blue-deep);">Retainer</span> Cobro programado mes a mes
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <!-- LOGOS / TRUST -->
        <section class="uc-trust reveal">
            <p>Agencias líderes usan Cord para profesionalizar su proceso de ventas</p>
            <div class="uc-logos">
                <span class="trust-logo">Ogilvy</span>
                <span class="trust-logo">Accenture</span>
                <span class="trust-logo">IDEO</span>
                <span class="trust-logo">Pentagram</span>
            </div>
        </section>

        <!-- FEATURES GRID -->
        <section class="uc-features">
            <div class="uc-container">
                <div class="uc-features-header reveal">
                    <h2>Tu agencia, operando al máximo nivel</h2>
                    <p>Herramientas diseñadas para acelerar el ciclo de ventas de servicios profesionales.</p>
                </div>

                <div class="uc-bento-grid">
                    <div class="uc-bento-card reveal">
                        <div class="uc-bento-icon"><svg viewBox="0 0 24 24" fill="none" stroke="var(--color-blue-deep)" stroke-width="2"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg></div>
                        <h3>Firmas Vinculantes</h3>
                        <p>Cada propuesta aprobada incluye una firma electrónica con validez legal. Sin necesidad de usar herramientas de terceros caras.</p>
                    </div>
                    <div class="uc-bento-card reveal">
                        <div class="uc-bento-icon"><svg viewBox="0 0 24 24" fill="none" stroke="var(--color-blue-deep)" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"></rect><line x1="2" y1="10" x2="22" y2="10"></line></svg></div>
                        <h3>Cobro de Retainers (Igualas)</h3>
                        <p>Convierte a tus clientes de proyecto a iguala mensual fácilmente. Cord se encarga del cargo recurrente a tarjeta y de enviar la factura CFDI mes a mes.</p>
                    </div>
                    <div class="uc-bento-card reveal">
                        <div class="uc-bento-icon"><svg viewBox="0 0 24 24" fill="none" stroke="var(--color-blue-deep)" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg></div>
                        <h3>Plantillas Premium</h3>
                        <p>Destaca desde el primer contacto. Nuestras plantillas de propuestas gritan profesionalismo, haciendo que tu agencia parezca el doble de grande.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA SECTION -->
        <section class="uc-cta-section">
            <div class="uc-container">
                <div class="uc-cta-box reveal">
                    <h2>¿Listo para agilizar tus ventas?</h2>
                    <p>Agencias líderes usan Cord para profesionalizar su proceso de ventas.</p>
                    <a href="/registro" class="btn-luxe">Comenzar gratis</a>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Layout>

<style>
    /* VARIABLES Y UTILIDADES GLOBALES PARA USE CASES */
    .use-case-main {
        background: var(--color-bg);
        padding-top: 0;
        overflow-x: hidden;
        color: var(--color-text-muted);
    }

    .uc-container {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 5%;
    }

    /* ── HERO SECTION ── */
    .uc-hero {
        position: relative;
        padding: 8rem 0 4rem;
        background: var(--color-bg-soft);
        overflow: hidden;
        border-bottom: 1px solid var(--color-border);
    }
    
    /* Diagonal background cut */
    .uc-hero::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: var(--color-bg);
        transform: skewY(-4deg);
        transform-origin: top left;
        z-index: 0;
        pointer-events: none;
    }

    .uc-hero-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: center;
        position: relative;
        z-index: 1;
    }

    .uc-hero-content {
        padding-right: 2rem;
    }

    .uc-title {
        font-size: clamp(2.2rem, 4vw, 3.8rem);
        font-weight: 800;
        color: var(--color-blue-deep);
        line-height: 1.1;
        letter-spacing: -0.04em;
        margin-bottom: 1.2rem;
        text-wrap: balance;
    }

    .uc-sub {
        font-size: 1.15rem;
        color: var(--color-text-muted);
        line-height: 1.6;
        margin-bottom: 2rem;
        max-width: 90%;
    }

    .uc-actions {
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    /* ── BUTTONS ── */
    .btn-luxe {
        position: relative;
        display: inline-flex; align-items: center; justify-content: center;
        background: var(--color-blue-deep); color: #fff;
        padding: 14px 28px; border-radius: 100px;
        font-size: 0.95rem; font-weight: 600; text-decoration: none;
        overflow: hidden; transition: transform 0.3s, box-shadow 0.3s, background 0.3s;
        box-shadow: 0 4px 14px rgba(10, 25, 47, 0.15);
    }
    .btn-luxe span { position: relative; z-index: 2; }
    .btn-arrow { width: 16px; height: 16px; margin-left: 6px; position: relative; z-index: 2; transition: transform 0.3s; }
    .btn-luxe:hover .btn-arrow { transform: translateX(4px); }
    .btn-luxe:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(10, 25, 47, 0.25); background: #06111f; }

    .btn-ghost {
        display: inline-flex; align-items: center;
        color: var(--color-blue-deep); font-size: 0.95rem; font-weight: 600; text-decoration: none;
        transition: color 0.2s;
    }
    .btn-ghost .arrow-right { transition: transform 0.2s; display: inline-block; margin-left: 4px; }
    .btn-ghost:hover { color: var(--color-text-muted); }
    .btn-ghost:hover .arrow-right { transform: translateX(4px); }

    /* ── MOCKUP (Right Side) ── */
    .uc-hero-visual {
        position: relative;
        perspective: 1000px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .uc-visual-glow {
        position: absolute;
        width: 120%; height: 120%;
        top: -10%; left: -10%;
        filter: blur(50px);
        z-index: 0;
        opacity: 0.7;
    }

    .uc-mockup-window {
        position: relative;
        z-index: 1;
        background: var(--color-bg);
        border-radius: 12px;
        box-shadow: 0 20px 40px rgba(10, 25, 47, 0.1), 0 0 0 1px var(--color-border);
        width: 100%;
        max-width: 450px;
        transform: rotateY(-10deg) rotateX(5deg);
        transition: transform 0.5s ease-out;
    }
    .uc-hero-visual:hover .uc-mockup-window {
        transform: rotateY(0deg) rotateX(0deg);
    }

    .uc-mockup-top {
        background: var(--color-bg-soft);
        padding: 12px 16px;
        border-bottom: 1px solid var(--color-border);
        border-radius: 12px 12px 0 0;
    }
    .uc-dots { display: flex; gap: 6px; }
    .uc-dots span { width: 10px; height: 10px; border-radius: 50%; background: #d3dae6; }
    .uc-dots span:nth-child(1) { background: #ff5f56; }
    .uc-dots span:nth-child(2) { background: #ffbd2e; }
    .uc-dots span:nth-child(3) { background: #27c93f; }

    .uc-mockup-body {
        padding: 30px;
    }
    
    .mock-plan {
        background: var(--color-bg-soft);
        padding: 20px;
        border-radius: 8px;
        border: 1px solid var(--color-border);
        display: flex; flex-direction: column; gap: 8px;
        margin-bottom: 20px;
    }
    .mp-title { font-size: 1.05rem; font-weight: 600; color: var(--color-blue-deep); }
    .mp-price { font-size: 1.8rem; font-weight: 800; color: var(--color-blue-deep); }
    .mp-price small { font-size: 1rem; color: var(--color-text-muted); font-weight: 500; }
    
    .mock-status {
        display: flex; align-items: center; gap: 8px;
        font-size: 0.85rem; color: var(--color-text-muted); font-weight: 500;
        margin-bottom: 12px;
    }
    .mock-cfdi {
        display: flex; align-items: center; gap: 8px;
        font-size: 0.85rem; color: var(--color-text-muted); font-weight: 500;
        padding-top: 12px;
        border-top: 1px dashed var(--color-border);
    }
    .cfdi-badge {
        font-size: 0.7rem; font-weight: 700; padding: 2px 6px; border-radius: 4px;
    }

    /* ── TRUST LOGOS ── */
    .uc-trust {
        text-align: center;
        padding: 3rem 5%;
        background: var(--color-bg);
    }
    .uc-trust p {
        font-size: 0.9rem; font-weight: 600; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1.5rem;
    }
    .uc-logos {
        display: flex; justify-content: center; gap: 3rem; flex-wrap: wrap; align-items: center;
    }
    .trust-logo {
        font-size: 1.4rem; font-weight: 800; color: #c1c9d2; letter-spacing: -0.5px;
    }

    /* ── FEATURES ── */
    .uc-features {
        padding: 6rem 0 6rem;
        background: var(--color-bg);
    }
    .uc-features-header {
        text-align: center;
        max-width: 600px;
        margin: 0 auto 4rem;
    }
    .uc-features-header h2 { font-size: 2.2rem; font-weight: 800; color: var(--color-blue-deep); margin-bottom: 1rem; }
    .uc-features-header p { font-size: 1.1rem; color: var(--color-text-muted); line-height: 1.6; }

    .uc-bento-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }
    .uc-bento-card {
        background: var(--color-bg);
        padding: 2.5rem;
        border-radius: 16px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 0 0 1px var(--color-border);
        transition: transform 0.3s, box-shadow 0.3s;
    }
    .uc-bento-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 0 0 1px var(--color-border);
    }
    .uc-bento-icon {
        width: 48px; height: 48px;
        background: var(--color-bg-soft);
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 1.5rem;
    }
    .uc-bento-card h3 { font-size: 1.2rem; font-weight: 700; color: var(--color-blue-deep); margin-bottom: 0.8rem; }
    .uc-bento-card p { font-size: 0.95rem; color: var(--color-text-muted); line-height: 1.6; }

    /* ── CTA SECTION ── */
    .uc-cta-section {
        padding: 4rem 0 8rem;
        background: var(--color-bg);
    }
    .uc-cta-box {
        background: var(--color-blue-deep);
        border-radius: 20px;
        padding: 4rem 2rem;
        text-align: center;
        color: #fff;
        position: relative;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(10, 25, 47, 0.25);
    }
    .uc-cta-box::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: radial-gradient(circle at center top, rgba(255,255,255,0.1), transparent 70%);
        pointer-events: none;
    }
    .uc-cta-box h2 { font-size: 2.2rem; font-weight: 800; margin-bottom: 1rem; position: relative; z-index: 1; }
    .uc-cta-box p { font-size: 1.1rem; color: #aab7c4; margin-bottom: 2rem; position: relative; z-index: 1; }
    .uc-cta-box .btn-luxe { background: #fff; color: var(--color-blue-deep); box-shadow: 0 4px 14px rgba(255, 255, 255, 0.15); }
    .uc-cta-box .btn-luxe:hover { background: var(--color-bg-soft); box-shadow: 0 6px 20px rgba(255, 255, 255, 0.25); }

    @media (max-width: 900px) {
        .uc-hero-grid { grid-template-columns: 1fr; gap: 4rem; }
        .uc-hero-content { padding-right: 0; text-align: center; }
        .uc-actions { justify-content: center; }
        .uc-title { font-size: 2.5rem; }
        .uc-bento-grid { grid-template-columns: 1fr; }
        .uc-hero::before { transform: skewY(-2deg); }
    }
</style>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener('DOMContentLoaded', () => {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if(reduced) return;

        gsap.utils.toArray('.reveal').forEach((el: any) => {
            gsap.fromTo(el, { opacity: 0, y: 20 }, {
                opacity: 1, y: 0, duration: 0.8, ease: 'power2.out',
                scrollTrigger: { trigger: el, start: 'top 85%' }
            });
        });
        
        gsap.fromTo('.reveal-mockup', { opacity: 0, x: 30, rotationY: -15 }, {
            opacity: 1, x: 0, rotationY: -10, duration: 1.2, ease: 'power3.out', delay: 0.2,
            scrollTrigger: { trigger: '.reveal-mockup', start: 'top 90%' }
        });
    });
</script>
