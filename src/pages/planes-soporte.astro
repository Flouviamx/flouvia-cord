---
// Planes de soporte — Página estilo Stripe Support Plans (Enfocado en características, no en precios)
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/landing/Nav.astro';
import Footer from '../components/landing/Footer.astro';
import PageAnims from '../components/landing/PageAnims.astro';
import Faq from '../components/landing/Faq.astro';
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
---

<Layout
    title={isEn ? "Support Plans | Cord" : "Planes de Soporte | Cord"}
    description={isEn ? "Choose the right level of guidance and technical assistance with Cord's support teams." : "Elige el nivel adecuado de orientación y asistencia técnica con los equipos de soporte de Cord."}
>
    <Nav />
    <main class="sp-main">
        <section class="sp-hero">
            <div class="sp-hero-inner">
                <p class="sp-eyebrow reveal">{isEn ? 'TECHNICAL & ACCOUNT SUPPORT' : 'SOPORTE TÉCNICO Y DE CUENTA'}</p>
                <h1 class="sp-title masked-title">{isEn ? 'Choose the right support for your business.' : 'Elige el soporte adecuado para tu empresa.'}</h1>
                <p class="sp-sub reveal">
                    {isEn ? 'All Cord clients receive email support and access to technical documentation. If you need guaranteed response times, real-time attention or an account manager, explore our advanced support plans.' : 'Todos los clientes de Cord reciben ayuda por correo electrónico y acceso a la documentación técnica. Si necesitas tiempos de respuesta garantizados, atención en tiempo real o un gerente de cuenta, conoce nuestros planes de soporte avanzado.'}
                </p>
            </div>
        </section>

        <section class="sp-table-section reveal">
            <div class="sp-table-container">
                <div class="sp-table-wrap">
                    <table class="sp-table">
                        <colgroup>
                            <col style="width: 40%;">
                            <col style="width: 20%;">
                            <col style="width: 20%;">
                            <col style="width: 20%;">
                        </colgroup>
                        <thead>
                            <tr>
                                <th></th>
                                <th>
                                    <div class="sp-tier-head">
                                        <h3>{isEn ? 'Basic' : 'Básico'}</h3>
                                        <p>{isEn ? 'Asynchronous help for general and billing questions.' : 'Ayuda asíncrona para dudas generales y facturación.'}</p>
                                    </div>
                                </th>
                                <th>
                                    <div class="sp-tier-head">
                                        <h3>Premium</h3>
                                        <p>{isEn ? 'Priority and continuous technical guidance for your team.' : 'Prioridad y orientación técnica continua para tu equipo.'}</p>
                                    </div>
                                </th>
                                <th>
                                    <div class="sp-tier-head">
                                        <h3>Enterprise</h3>
                                        <p>{isEn ? 'Dedicated technical partnership for complex architectures.' : 'Asociación técnica dedicada para arquitecturas complejas.'}</p>
                                    </div>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- SECCIÓN: CANALES -->
                            <tr class="sp-row-header">
                                <td colspan="4">{isEn ? 'Contact channels' : 'Canales de contacto'}</td>
                            </tr>
                            <tr>
                                <td>{isEn ? 'Help Center and Documentation' : 'Centro de Ayuda y Documentación'}</td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>
                            <tr>
                                <td>{isEn ? 'Email support' : 'Soporte por correo electrónico'}</td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>
                            <tr>
                                <td>{isEn ? 'Live chat support' : 'Soporte por chat en vivo'}</td>
                                <td><span class="dash">—</span></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>
                            <tr>
                                <td>{isEn ? 'Slack or Microsoft Teams channel' : 'Canal de Slack o Microsoft Teams'}</td>
                                <td><span class="dash">—</span></td>
                                <td><span class="dash">—</span></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>
                            <tr>
                                <td>{isEn ? 'Emergency phone escalation' : 'Escalamiento telefónico de emergencias'}</td>
                                <td><span class="dash">—</span></td>
                                <td><span class="dash">—</span></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>

                            <!-- SECCIÓN: TIEMPOS DE RESPUESTA -->
                            <tr class="sp-row-header">
                                <td colspan="4">{isEn ? 'Target response times (SLA)' : 'Tiempos de respuesta objetivo (SLA)'}</td>
                            </tr>
                            <tr>
                                <td>{isEn ? 'General & billing inquiries' : 'Consultas generales y facturación'}</td>
                                <td>{isEn ? '24 - 48 hours' : '24 - 48 horas'}</td>
                                <td>{isEn ? '≤ 12 hours' : '≤ 12 horas'}</td>
                                <td>{isEn ? '≤ 4 hours' : '≤ 4 horas'}</td>
                            </tr>
                            <tr>
                                <td>{isEn ? 'Technical integration inquiries' : 'Consultas técnicas de integración'}</td>
                                <td>{isEn ? '24 - 48 hours' : '24 - 48 horas'}</td>
                                <td>{isEn ? '≤ 4 hours' : '≤ 4 horas'}</td>
                                <td>{isEn ? '≤ 2 hours' : '≤ 2 horas'}</td>
                            </tr>
                            <tr>
                                <td>{isEn ? 'Outages or critical incidents' : 'Interrupciones o incidentes críticos'}</td>
                                <td>{isEn ? 'Best effort' : 'Mejor esfuerzo'}</td>
                                <td>{isEn ? '≤ 2 hours (Business hours)' : '≤ 2 horas (Horas hábiles)'}</td>
                                <td>≤ 30 min (24/7/365)</td>
                            </tr>

                            <!-- SECCIÓN: SERVICIOS AVANZADOS -->
                            <tr class="sp-row-header">
                                <td colspan="4">{isEn ? 'Advisory and advanced services' : 'Asesoramiento y servicios avanzados'}</td>
                            </tr>
                            <tr>
                                <td>{isEn ? 'Priority routing to developers' : 'Enrutamiento prioritario a desarrolladores'}</td>
                                <td><span class="dash">—</span></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>
                            <tr>
                                <td>{isEn ? 'Architecture and integration review' : 'Revisión de arquitectura e integración'}</td>
                                <td><span class="dash">—</span></td>
                                <td>{isEn ? 'Annual' : 'Anual'}</td>
                                <td>{isEn ? 'Quarterly' : 'Trimestral'}</td>
                            </tr>
                            <tr>
                                <td>{isEn ? 'Designated Technical Account Manager (TAM)' : 'Gerente Técnico de Cuenta (TAM) asignado'}</td>
                                <td><span class="dash">—</span></td>
                                <td><span class="dash">—</span></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>
                            <tr>
                                <td>{isEn ? 'High-volume event planning support' : 'Soporte en planificación de eventos de alto volumen'}</td>
                                <td><span class="dash">—</span></td>
                                <td><span class="dash">—</span></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td></td>
                                <td>
                                    <!-- Botón transparente para simetría visual -->
                                </td>
                                <td>
                                    <a href="mailto:ventas@flouvia.com?subject=Interés%20en%20Soporte%20Premium" class="sp-btn ghost">{isEn ? 'Contact sales' : 'Contactar a ventas'}</a>
                                </td>
                                <td>
                                    <a href="mailto:ventas@flouvia.com?subject=Interés%20en%20Soporte%20Enterprise" class="sp-btn solid">{isEn ? 'Contact sales' : 'Contactar a ventas'}</a>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </section>

        <section class="sp-blocks">
            <div class="sp-blocks-inner">
                <article class="sp-infoblock reveal">
                    <div class="sp-infoblock-content">
                        <h3>{isEn ? 'Priority support and contextual interactions' : 'Soporte prioritario e interacciones contextuales'}</h3>
                        <p>{isEn ? 'Companies that purchase a Premium or Enterprise plan get direct routing to specialists who deeply understand their integration model, account history, and technology stack. We solve complex problems in a fraction of the normal time, avoiding the repetition of basic explanations.' : 'Las empresas que adquieren un plan Premium o Enterprise obtienen enrutamiento directo a especialistas que conocen a fondo su modelo de integración, historial de cuenta y entorno tecnológico. Resolvemos problemas complejos en una fracción del tiempo normal, evitando la repetición de explicaciones básicas.'}</p>
                    </div>
                </article>
                <article class="sp-infoblock reveal">
                    <div class="sp-infoblock-content">
                        <h3>{isEn ? 'Continuous technical partnership (Enterprise)' : 'Asociación técnica continua (Enterprise)'}</h3>
                        <p>{isEn ? 'It is not just about fixing problems, but preventing them. With a dedicated Technical Account Manager (TAM) on the Enterprise plan, we analyze your network bottlenecks, prepare your integration for massive sales peaks, and conduct joint reviews of your payment architecture.' : 'No se trata solo de arreglar problemas, sino de prevenirlos. Con un Gerente Técnico de Cuenta (TAM) dedicado en el plan Enterprise, analizamos tus cuellos de botella de red, preparamos tu integración para picos de venta masivos (como Hot Sale o Buen Fin) y realizamos revisiones conjuntas de tu arquitectura de pagos.'}</p>
                    </div>
                </article>
            </div>
        </section>

        <!-- Reuse the FAQ component at the bottom -->
        <div style="background: var(--color-bg-alt); padding-top: 4rem;">
            <Faq />
        </div>
    </main>

    <Footer 
        ctaTitle={isEn ? "Get the level of help you need." : "Obtén el nivel de ayuda que necesitas."}
        ctaSub={isEn ? "From initial integrations to high-performance operations at scale." : "Desde integraciones iniciales hasta operaciones de alto rendimiento a escala."}
    />
    <PageAnims />
</Layout>

<style>
    .sp-main {
        background: #fff;
        color: #111827;
    }

    :global(html[data-theme="dark"]) .sp-main {
        background: #000;
        color: #f3f4f6;
    }

    .sp-hero {
        padding: 11rem 5% 4rem;
        text-align: center;
    }
    .sp-hero-inner {
        max-width: 760px;
        margin: 0 auto;
    }

    .sp-eyebrow {
        font-size: 0.75rem; font-weight: 800; letter-spacing: 1.5px;
        text-transform: uppercase; color: var(--color-blue-deep); margin: 0 0 1.2rem;
    }
    :global(html[data-theme="dark"]) .sp-eyebrow { color: #60a5fa; }

    .sp-title {
        font-size: clamp(2.4rem, 4.5vw, 3.6rem);
        font-weight: 800; line-height: 1.1; letter-spacing: -0.03em;
        margin: 0 0 1.5rem; color: #111827;
    }
    :global(html[data-theme="dark"]) .sp-title { color: #fff; }
    
    .sp-sub {
        font-size: 1.15rem; line-height: 1.6; color: #4b5563;
        margin: 0 auto;
    }
    :global(html[data-theme="dark"]) .sp-sub { color: #9ca3af; }

    /* Comparison Table Section */
    .sp-table-section {
        padding: 2rem 5% 6rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .sp-table-wrap {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .sp-table {
        width: 100%;
        min-width: 860px;
        border-collapse: collapse;
        text-align: left;
    }

    .sp-tier-head {
        padding: 1.5rem 1rem 2rem;
    }
    .sp-tier-head h3 {
        font-size: 1.4rem; font-weight: 700; color: #111827;
        margin: 0 0 0.5rem; letter-spacing: -0.02em;
    }
    :global(html[data-theme="dark"]) .sp-tier-head h3 { color: #fff; }
    .sp-tier-head p {
        font-size: 0.9rem; color: #6b7280; font-weight: 400; line-height: 1.4;
        margin: 0;
    }
    :global(html[data-theme="dark"]) .sp-tier-head p { color: #9ca3af; }

    .sp-row-header td {
        font-size: 1.05rem; font-weight: 700; color: #111827;
        padding: 3rem 1rem 1rem;
        border-bottom: 2px solid #e5e7eb;
    }
    :global(html[data-theme="dark"]) .sp-row-header td { color: #fff; border-bottom-color: #374151; }

    .sp-table tbody tr:not(.sp-row-header) td {
        padding: 1.25rem 1rem;
        border-bottom: 1px solid #e5e7eb;
        font-size: 0.95rem; color: #374151;
        vertical-align: middle;
    }
    :global(html[data-theme="dark"]) .sp-table tbody tr:not(.sp-row-header) td {
        border-bottom-color: #1f2937; color: #d1d5db;
    }

    .sp-table tbody tr:not(.sp-row-header):hover td {
        background-color: rgba(0,0,0,0.015);
    }
    :global(html[data-theme="dark"]) .sp-table tbody tr:not(.sp-row-header):hover td {
        background-color: rgba(255,255,255,0.02);
    }

    .sp-table th:first-child,
    .sp-table td:first-child {
        padding-left: 0;
    }

    .sp-table th:not(:first-child),
    .sp-table td:not(:first-child) {
        text-align: center;
    }

    .sp-table td:first-child {
        font-weight: 500;
        color: #111827;
    }
    :global(html[data-theme="dark"]) .sp-table td:first-child { color: #f3f4f6; }

    .check {
        width: 20px; height: 20px; color: var(--color-blue-deep);
        display: inline-block; vertical-align: middle;
    }
    :global(html[data-theme="dark"]) .check { color: #60a5fa; }
    
    .dash {
        color: #9ca3af;
        font-weight: 600;
    }
    :global(html[data-theme="dark"]) .dash { color: #4b5563; }

    .sp-table tfoot td {
        padding: 2.5rem 1rem 1rem;
    }

    .sp-btn {
        display: inline-flex; justify-content: center; align-items: center;
        width: 100%; padding: 10px 0; border-radius: 8px;
        font-size: 0.9rem; font-weight: 600; text-decoration: none;
        transition: all 0.2s;
    }
    .sp-btn.ghost {
        background: #f3f4f6; color: #111827;
    }
    .sp-btn.ghost:hover { background: #e5e7eb; }
    :global(html[data-theme="dark"]) .sp-btn.ghost { background: #1e293b; color: #f8fafc; }
    :global(html[data-theme="dark"]) .sp-btn.ghost:hover { background: #334155; }
    
    .sp-btn.solid {
        background: var(--color-blue-deep); color: #fff;
    }
    .sp-btn.solid:hover { opacity: 0.9; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(10,37,218,0.2); }
    :global(html[data-theme="dark"]) .sp-btn.solid { background: #3b82f6; }

    /* Info Blocks */
    .sp-blocks {
        padding: 0 5% 6rem;
        max-width: 1080px; margin: 0 auto;
    }
    .sp-blocks-inner {
        display: grid; grid-template-columns: 1fr 1fr;
        gap: 3rem;
    }
    .sp-infoblock h3 {
        font-size: 1.3rem; font-weight: 700; color: #111827;
        margin: 0 0 1rem; letter-spacing: -0.01em;
    }
    :global(html[data-theme="dark"]) .sp-infoblock h3 { color: #fff; }
    
    .sp-infoblock p {
        font-size: 1rem; line-height: 1.6; color: #4b5563;
        margin: 0;
    }
    :global(html[data-theme="dark"]) .sp-infoblock p { color: #9ca3af; }

    @media (max-width: 860px) {
        .sp-hero { padding-top: 9rem; }
        .sp-blocks-inner { grid-template-columns: 1fr; gap: 2rem; }
    }
</style>
