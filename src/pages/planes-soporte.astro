---
// Planes de soporte — Página estilo Stripe Support Plans (Enfocado en características, no en precios)
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/landing/Nav.astro';
import Footer from '../components/landing/Footer.astro';
import PageAnims from '../components/landing/PageAnims.astro';
import Faq from '../components/landing/Faq.astro';
---

<Layout
    title="Planes de Soporte | Cord"
    description="Elige el nivel adecuado de orientación y asistencia técnica con los equipos de soporte de Cord."
>
    <Nav />
    <main class="sp-main">
        <section class="sp-hero">
            <div class="sp-hero-inner">
                <p class="sp-eyebrow reveal">SOPORTE TÉCNICO Y DE CUENTA</p>
                <h1 class="sp-title masked-title">Elige el soporte adecuado para tu empresa.</h1>
                <p class="sp-sub reveal">
                    Todos los clientes de Cord reciben ayuda por correo electrónico y acceso a la documentación técnica. 
                    Si necesitas tiempos de respuesta garantizados, atención en tiempo real o un gerente de cuenta, 
                    conoce nuestros planes de soporte avanzado.
                </p>
            </div>
        </section>

        <section class="sp-table-section reveal">
            <div class="sp-table-container">
                <div class="sp-table-wrap">
                    <table class="sp-table">
                        <colgroup>
                            <col style="width: 40%;">
                            <col style="width: 20%;">
                            <col style="width: 20%;">
                            <col style="width: 20%;">
                        </colgroup>
                        <thead>
                            <tr>
                                <th></th>
                                <th>
                                    <div class="sp-tier-head">
                                        <h3>Básico</h3>
                                        <p>Ayuda asíncrona para dudas generales y facturación.</p>
                                    </div>
                                </th>
                                <th>
                                    <div class="sp-tier-head">
                                        <h3>Premium</h3>
                                        <p>Prioridad y orientación técnica continua para tu equipo.</p>
                                    </div>
                                </th>
                                <th>
                                    <div class="sp-tier-head">
                                        <h3>Enterprise</h3>
                                        <p>Asociación técnica dedicada para arquitecturas complejas.</p>
                                    </div>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- SECCIÓN: CANALES -->
                            <tr class="sp-row-header">
                                <td colspan="4">Canales de contacto</td>
                            </tr>
                            <tr>
                                <td>Centro de Ayuda y Documentación</td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>
                            <tr>
                                <td>Soporte por correo electrónico</td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>
                            <tr>
                                <td>Soporte por chat en vivo</td>
                                <td><span class="dash">—</span></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>
                            <tr>
                                <td>Canal de Slack o Microsoft Teams</td>
                                <td><span class="dash">—</span></td>
                                <td><span class="dash">—</span></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>
                            <tr>
                                <td>Escalamiento telefónico de emergencias</td>
                                <td><span class="dash">—</span></td>
                                <td><span class="dash">—</span></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>

                            <!-- SECCIÓN: TIEMPOS DE RESPUESTA -->
                            <tr class="sp-row-header">
                                <td colspan="4">Tiempos de respuesta objetivo (SLA)</td>
                            </tr>
                            <tr>
                                <td>Consultas generales y facturación</td>
                                <td>24 - 48 horas</td>
                                <td>≤ 12 horas</td>
                                <td>≤ 4 horas</td>
                            </tr>
                            <tr>
                                <td>Consultas técnicas de integración</td>
                                <td>24 - 48 horas</td>
                                <td>≤ 4 horas</td>
                                <td>≤ 2 horas</td>
                            </tr>
                            <tr>
                                <td>Interrupciones o incidentes críticos</td>
                                <td>Mejor esfuerzo</td>
                                <td>≤ 2 horas (Horas hábiles)</td>
                                <td>≤ 30 min (24/7/365)</td>
                            </tr>

                            <!-- SECCIÓN: SERVICIOS AVANZADOS -->
                            <tr class="sp-row-header">
                                <td colspan="4">Asesoramiento y servicios avanzados</td>
                            </tr>
                            <tr>
                                <td>Enrutamiento prioritario a desarrolladores</td>
                                <td><span class="dash">—</span></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>
                            <tr>
                                <td>Revisión de arquitectura e integración</td>
                                <td><span class="dash">—</span></td>
                                <td>Anual</td>
                                <td>Trimestral</td>
                            </tr>
                            <tr>
                                <td>Gerente Técnico de Cuenta (TAM) asignado</td>
                                <td><span class="dash">—</span></td>
                                <td><span class="dash">—</span></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>
                            <tr>
                                <td>Soporte en planificación de eventos de alto volumen</td>
                                <td><span class="dash">—</span></td>
                                <td><span class="dash">—</span></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td></td>
                                <td>
                                    <!-- Botón transparente para simetría visual -->
                                </td>
                                <td>
                                    <a href="mailto:ventas@flouvia.com?subject=Interés%20en%20Soporte%20Premium" class="sp-btn ghost">Contactar a ventas</a>
                                </td>
                                <td>
                                    <a href="mailto:ventas@flouvia.com?subject=Interés%20en%20Soporte%20Enterprise" class="sp-btn solid">Contactar a ventas</a>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </section>

        <section class="sp-blocks">
            <div class="sp-blocks-inner">
                <article class="sp-infoblock reveal">
                    <div class="sp-infoblock-content">
                        <h3>Soporte prioritario e interacciones contextuales</h3>
                        <p>Las empresas que adquieren un plan Premium o Enterprise obtienen enrutamiento directo a especialistas que conocen a fondo su modelo de integración, historial de cuenta y entorno tecnológico. Resolvemos problemas complejos en una fracción del tiempo normal, evitando la repetición de explicaciones básicas.</p>
                    </div>
                </article>
                <article class="sp-infoblock reveal">
                    <div class="sp-infoblock-content">
                        <h3>Asociación técnica continua (Enterprise)</h3>
                        <p>No se trata solo de arreglar problemas, sino de prevenirlos. Con un Gerente Técnico de Cuenta (TAM) dedicado en el plan Enterprise, analizamos tus cuellos de botella de red, preparamos tu integración para picos de venta masivos (como Hot Sale o Buen Fin) y realizamos revisiones conjuntas de tu arquitectura de pagos.</p>
                    </div>
                </article>
            </div>
        </section>

        <!-- Reuse the FAQ component at the bottom -->
        <div style="background: var(--color-bg-alt); padding-top: 4rem;">
            <Faq />
        </div>
    </main>

    <Footer 
        ctaTitle="Obtén el nivel de ayuda que necesitas."
        ctaSub="Desde integraciones iniciales hasta operaciones de alto rendimiento a escala."
    />
    <PageAnims />
</Layout>

<style>
    .sp-main {
        background: #fff;
        color: #111827;
    }

    :global(html[data-theme="dark"]) .sp-main {
        background: #000;
        color: #f3f4f6;
    }

    .sp-hero {
        padding: 11rem 5% 4rem;
        text-align: center;
    }
    .sp-hero-inner {
        max-width: 760px;
        margin: 0 auto;
    }

    .sp-eyebrow {
        font-size: 0.75rem; font-weight: 800; letter-spacing: 1.5px;
        text-transform: uppercase; color: var(--color-blue-deep); margin: 0 0 1.2rem;
    }
    :global(html[data-theme="dark"]) .sp-eyebrow { color: #60a5fa; }

    .sp-title {
        font-size: clamp(2.4rem, 4.5vw, 3.6rem);
        font-weight: 800; line-height: 1.1; letter-spacing: -0.03em;
        margin: 0 0 1.5rem; color: #111827;
    }
    :global(html[data-theme="dark"]) .sp-title { color: #fff; }
    
    .sp-sub {
        font-size: 1.15rem; line-height: 1.6; color: #4b5563;
        margin: 0 auto;
    }
    :global(html[data-theme="dark"]) .sp-sub { color: #9ca3af; }

    /* Comparison Table Section */
    .sp-table-section {
        padding: 2rem 5% 6rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .sp-table-wrap {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .sp-table {
        width: 100%;
        min-width: 860px;
        border-collapse: collapse;
        text-align: left;
    }

    .sp-tier-head {
        padding: 1.5rem 1rem 2rem;
    }
    .sp-tier-head h3 {
        font-size: 1.4rem; font-weight: 700; color: #111827;
        margin: 0 0 0.5rem; letter-spacing: -0.02em;
    }
    :global(html[data-theme="dark"]) .sp-tier-head h3 { color: #fff; }
    .sp-tier-head p {
        font-size: 0.9rem; color: #6b7280; font-weight: 400; line-height: 1.4;
        margin: 0;
    }
    :global(html[data-theme="dark"]) .sp-tier-head p { color: #9ca3af; }

    .sp-row-header td {
        font-size: 1.05rem; font-weight: 700; color: #111827;
        padding: 3rem 1rem 1rem;
        border-bottom: 2px solid #e5e7eb;
    }
    :global(html[data-theme="dark"]) .sp-row-header td { color: #fff; border-bottom-color: #374151; }

    .sp-table tbody tr:not(.sp-row-header) td {
        padding: 1.25rem 1rem;
        border-bottom: 1px solid #e5e7eb;
        font-size: 0.95rem; color: #374151;
        vertical-align: middle;
    }
    :global(html[data-theme="dark"]) .sp-table tbody tr:not(.sp-row-header) td {
        border-bottom-color: #1f2937; color: #d1d5db;
    }

    .sp-table tbody tr:not(.sp-row-header):hover td {
        background-color: rgba(0,0,0,0.015);
    }
    :global(html[data-theme="dark"]) .sp-table tbody tr:not(.sp-row-header):hover td {
        background-color: rgba(255,255,255,0.02);
    }

    .sp-table th:first-child,
    .sp-table td:first-child {
        padding-left: 0;
    }

    .sp-table th:not(:first-child),
    .sp-table td:not(:first-child) {
        text-align: center;
    }

    .sp-table td:first-child {
        font-weight: 500;
        color: #111827;
    }
    :global(html[data-theme="dark"]) .sp-table td:first-child { color: #f3f4f6; }

    .check {
        width: 20px; height: 20px; color: var(--color-blue-deep);
        display: inline-block; vertical-align: middle;
    }
    :global(html[data-theme="dark"]) .check { color: #60a5fa; }
    
    .dash {
        color: #9ca3af;
        font-weight: 600;
    }
    :global(html[data-theme="dark"]) .dash { color: #4b5563; }

    .sp-table tfoot td {
        padding: 2.5rem 1rem 1rem;
    }

    .sp-btn {
        display: inline-flex; justify-content: center; align-items: center;
        width: 100%; padding: 10px 0; border-radius: 8px;
        font-size: 0.9rem; font-weight: 600; text-decoration: none;
        transition: all 0.2s;
    }
    .sp-btn.ghost {
        background: #f3f4f6; color: #111827;
    }
    .sp-btn.ghost:hover { background: #e5e7eb; }
    :global(html[data-theme="dark"]) .sp-btn.ghost { background: #1e293b; color: #f8fafc; }
    :global(html[data-theme="dark"]) .sp-btn.ghost:hover { background: #334155; }
    
    .sp-btn.solid {
        background: var(--color-blue-deep); color: #fff;
    }
    .sp-btn.solid:hover { opacity: 0.9; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(10,37,218,0.2); }
    :global(html[data-theme="dark"]) .sp-btn.solid { background: #3b82f6; }

    /* Info Blocks */
    .sp-blocks {
        padding: 0 5% 6rem;
        max-width: 1080px; margin: 0 auto;
    }
    .sp-blocks-inner {
        display: grid; grid-template-columns: 1fr 1fr;
        gap: 3rem;
    }
    .sp-infoblock h3 {
        font-size: 1.3rem; font-weight: 700; color: #111827;
        margin: 0 0 1rem; letter-spacing: -0.01em;
    }
    :global(html[data-theme="dark"]) .sp-infoblock h3 { color: #fff; }
    
    .sp-infoblock p {
        font-size: 1rem; line-height: 1.6; color: #4b5563;
        margin: 0;
    }
    :global(html[data-theme="dark"]) .sp-infoblock p { color: #9ca3af; }

    @media (max-width: 860px) {
        .sp-hero { padding-top: 9rem; }
        .sp-blocks-inner { grid-template-columns: 1fr; gap: 2rem; }
    }
</style>
