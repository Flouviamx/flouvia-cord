---
// Planes de soporte — Página estilo Stripe Support Plans
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/landing/Nav.astro';
import Footer from '../components/landing/Footer.astro';
import PageAnims from '../components/landing/PageAnims.astro';
import Faq from '../components/landing/Faq.astro';
---

<Layout
    title="Planes de Soporte — Cord"
    description="Obtén la ayuda que necesitas para tu negocio. Conoce nuestros planes de soporte técnico: desde resolución básica hasta ingenieros dedicados."
>
    <Nav />
    <main class="sp-main">
        <section class="sp-hero">
            <div class="sp-hero-inner">
                <p class="sp-eyebrow reveal">SOPORTE TÉCNICO</p>
                <h1 class="sp-title masked-title">El soporte adecuado<br/>para tu operación.</h1>
                <p class="sp-sub reveal">
                    Todos los planes de Cord incluyen soporte por correo sin costo adicional.
                    Para tiempos de respuesta garantizados, atención telefónica o ayuda en integraciones complejas,
                    elige un plan de soporte Premium.
                </p>
            </div>
        </section>

        <section class="sp-plans">
            <div class="sp-plans-grid">
                
                <!-- Básico -->
                <article class="sp-card reveal">
                    <div class="sp-card-head">
                        <h2 class="sp-card-title">Básico</h2>
                        <p class="sp-card-desc">Soporte estándar para dudas generales y facturación.</p>
                        <div class="sp-card-price">
                            <span class="sp-price-amount">Incluido</span>
                        </div>
                        <a href="/registro" class="sp-btn ghost">Empieza gratis</a>
                    </div>
                    <div class="sp-card-body">
                        <h3 class="sp-features-title">Qué incluye:</h3>
                        <ul class="sp-features">
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                <span>Soporte por correo electrónico</span>
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                <span>Acceso al Centro de Ayuda</span>
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                <span>Guías de integración API básicas</span>
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                <span>Tiempos de respuesta en 24-48 hrs</span>
                            </li>
                        </ul>
                    </div>
                </article>

                <!-- Premium -->
                <article class="sp-card featured reveal">
                    <div class="sp-featured-badge">Más popular</div>
                    <div class="sp-card-head">
                        <h2 class="sp-card-title">Premium</h2>
                        <p class="sp-card-desc">Prioridad, chat en vivo y ayuda técnica con integraciones.</p>
                        <div class="sp-card-price">
                            <span class="sp-price-amount">$990</span>
                            <span class="sp-price-period">MXN / mes</span>
                        </div>
                        <a href="mailto:ventas@flouvia.com?subject=Plan%20Premium" class="sp-btn solid">Contactar a ventas</a>
                    </div>
                    <div class="sp-card-body">
                        <h3 class="sp-features-title">Todo en Básico, más:</h3>
                        <ul class="sp-features">
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                <span><b>Chat en vivo</b> con el equipo de soporte</span>
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                <span>Soporte telefónico con prioridad</span>
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                <span>Ayuda técnica en integración API/ERP</span>
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                <span>Tiempos de respuesta garantizados < 4 hrs</span>
                            </li>
                        </ul>
                    </div>
                </article>

                <!-- Enterprise -->
                <article class="sp-card reveal">
                    <div class="sp-card-head">
                        <h2 class="sp-card-title">Enterprise</h2>
                        <p class="sp-card-desc">Soporte estratégico para arquitecturas complejas y alto volumen.</p>
                        <div class="sp-card-price">
                            <span class="sp-price-amount">A medida</span>
                        </div>
                        <a href="mailto:ventas@flouvia.com?subject=Plan%20Enterprise" class="sp-btn ghost">Hablar con ventas</a>
                    </div>
                    <div class="sp-card-body">
                        <h3 class="sp-features-title">Todo en Premium, más:</h3>
                        <ul class="sp-features">
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                <span><b>Canal de Slack/Teams</b> compartido</span>
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                <span>Ingeniero de soluciones dedicado (TAM)</span>
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                <span>Soporte de incidentes críticos 24/7/365</span>
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                <span>Revisión de arquitectura trimestral</span>
                            </li>
                        </ul>
                    </div>
                </article>

            </div>
        </section>

        <section class="sp-compare reveal">
            <div class="sp-compare-inner">
                <h2 class="sp-compare-title">Comparación de características</h2>
                <div class="sp-table-wrap">
                    <table class="sp-table">
                        <thead>
                            <tr>
                                <th>Soporte y canales</th>
                                <th>Básico</th>
                                <th>Premium</th>
                                <th>Enterprise</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Centro de Ayuda y Documentación</td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>
                            <tr>
                                <td>Soporte por correo</td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>
                            <tr>
                                <td>Chat en vivo en Dashboard</td>
                                <td>-</td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>
                            <tr>
                                <td>Soporte telefónico prioritario</td>
                                <td>-</td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>
                            <tr>
                                <td>Canal de Slack/Teams dedicado</td>
                                <td>-</td>
                                <td>-</td>
                                <td><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></td>
                            </tr>
                        </tbody>
                        <thead>
                            <tr>
                                <th>Tiempos de respuesta (SLA)</th>
                                <th></th>
                                <th></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Dudas generales / Facturación</td>
                                <td>24 - 48 horas</td>
                                <td>< 12 horas</td>
                                <td>< 4 horas</td>
                            </tr>
                            <tr>
                                <td>Problemas técnicos estándar</td>
                                <td>24 - 48 horas</td>
                                <td>< 4 horas</td>
                                <td>< 2 horas</td>
                            </tr>
                            <tr>
                                <td>Incidentes críticos (Caída de servicio)</td>
                                <td>Mejor esfuerzo</td>
                                <td>< 2 horas (Horas hábiles)</td>
                                <td>< 30 min (24/7/365)</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <!-- Reuse the FAQ component at the bottom -->
        <div style="background: var(--color-bg-alt); padding-top: 4rem;">
            <Faq />
        </div>
    </main>

    <Footer 
        ctaTitle="Soporte que entiende<br/>tu negocio."
        ctaSub="Desde integraciones a la medida hasta dudas del día a día, estamos aquí."
    />
    <PageAnims />
</Layout>

<style>
    .sp-main {
        background: #fff; /* Light mode explicitly for this Stripe-like page */
        color: #111827;
    }

    /* Modificadores para forzar estilo light si hay un theme dark general */
    :global(html[data-theme="dark"]) .sp-main {
        background: #000;
        color: #fff;
    }

    .sp-hero {
        padding: 12rem 5% 5rem;
        text-align: center;
        background: radial-gradient(ellipse 70% 60% at 50% -20%, rgba(10, 37, 218, 0.08) 0%, transparent 100%);
    }
    :global(html[data-theme="dark"]) .sp-hero {
        background: radial-gradient(ellipse 70% 60% at 50% -20%, rgba(59, 130, 246, 0.15) 0%, transparent 100%);
    }
    
    .sp-hero-inner {
        max-width: 800px;
        margin: 0 auto;
    }

    .sp-eyebrow {
        font-size: 0.7rem; font-weight: 800; letter-spacing: 2.5px;
        text-transform: uppercase; color: var(--color-blue-deep); margin: 0 0 1.2rem;
    }
    :global(html[data-theme="dark"]) .sp-eyebrow { color: #60a5fa; }

    .sp-title {
        font-size: clamp(2.4rem, 5vw, 4rem);
        font-weight: 800; line-height: 1.05; letter-spacing: -0.04em;
        margin: 0 0 1.5rem;
    }
    
    .sp-sub {
        font-size: 1.15rem; line-height: 1.6; color: #4b5563;
        margin: 0 auto; max-width: 650px;
    }
    :global(html[data-theme="dark"]) .sp-sub { color: #9ca3af; }

    /* Plans Grid */
    .sp-plans {
        padding: 3rem 5% 7rem;
        max-width: 1180px; margin: 0 auto;
    }
    .sp-plans-grid {
        display: grid; grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        align-items: flex-start;
    }

    /* Cards */
    .sp-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #e5e7eb;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        display: flex; flex-direction: column;
        position: relative;
        overflow: hidden;
        transition: transform 0.3s var(--ease-spring), box-shadow 0.3s;
    }
    :global(html[data-theme="dark"]) .sp-card {
        background: #0f172a;
        border-color: #1e293b;
        box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    }
    .sp-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
    }
    :global(html[data-theme="dark"]) .sp-card:hover {
        box-shadow: 0 12px 30px rgba(0,0,0,0.6);
    }
    
    .sp-card.featured {
        border: 2px solid var(--color-blue-deep);
        box-shadow: 0 12px 30px rgba(10,37,218,0.1);
    }
    :global(html[data-theme="dark"]) .sp-card.featured {
        border-color: #3b82f6;
        box-shadow: 0 12px 30px rgba(59,130,246,0.2);
    }
    
    .sp-featured-badge {
        position: absolute; top: 0; left: 0; right: 0;
        background: var(--color-blue-deep); color: #fff;
        text-align: center; font-size: 0.75rem; font-weight: 700; letter-spacing: 1px;
        text-transform: uppercase; padding: 6px 0;
    }
    :global(html[data-theme="dark"]) .sp-featured-badge { background: #3b82f6; }

    .sp-card-head {
        padding: 2.5rem 2rem 2rem;
        border-bottom: 1px solid #f3f4f6;
    }
    :global(html[data-theme="dark"]) .sp-card-head { border-bottom-color: #1e293b; }
    .sp-card.featured .sp-card-head { padding-top: 3.5rem; }

    .sp-card-title {
        font-size: 1.5rem; font-weight: 700; margin: 0 0 0.5rem; letter-spacing: -0.02em;
    }
    .sp-card-desc {
        font-size: 0.95rem; line-height: 1.5; color: #6b7280;
        margin: 0 0 1.5rem; min-height: 42px;
    }
    :global(html[data-theme="dark"]) .sp-card-desc { color: #9ca3af; }

    .sp-card-price {
        display: flex; align-items: baseline; gap: 6px;
        margin-bottom: 1.5rem; height: 48px;
    }
    .sp-price-amount {
        font-size: 2.5rem; font-weight: 800; letter-spacing: -0.03em; line-height: 1;
    }
    .sp-price-period {
        font-size: 0.95rem; color: #6b7280; font-weight: 500;
    }
    :global(html[data-theme="dark"]) .sp-price-period { color: #9ca3af; }

    .sp-btn {
        display: flex; justify-content: center; align-items: center;
        width: 100%; padding: 12px 0; border-radius: 8px;
        font-size: 0.95rem; font-weight: 600; text-decoration: none;
        transition: all 0.2s;
    }
    .sp-btn.ghost {
        background: #f3f4f6; color: #111827;
    }
    .sp-btn.ghost:hover { background: #e5e7eb; }
    :global(html[data-theme="dark"]) .sp-btn.ghost { background: #1e293b; color: #f8fafc; }
    :global(html[data-theme="dark"]) .sp-btn.ghost:hover { background: #334155; }
    
    .sp-btn.solid {
        background: var(--color-blue-deep); color: #fff;
    }
    .sp-btn.solid:hover { opacity: 0.9; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(10,37,218,0.2); }
    :global(html[data-theme="dark"]) .sp-btn.solid { background: #3b82f6; }

    .sp-card-body {
        padding: 2rem;
        flex: 1;
    }
    
    .sp-features-title {
        font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;
        color: #111827; margin: 0 0 1.2rem;
    }
    :global(html[data-theme="dark"]) .sp-features-title { color: #f8fafc; }

    .sp-features {
        list-style: none; padding: 0; margin: 0;
        display: flex; flex-direction: column; gap: 1rem;
    }
    .sp-features li {
        display: flex; align-items: flex-start; gap: 12px;
        font-size: 0.95rem; color: #374151; line-height: 1.4;
    }
    :global(html[data-theme="dark"]) .sp-features li { color: #cbd5e1; }
    .sp-features li b { color: #111827; font-weight: 600; }
    :global(html[data-theme="dark"]) .sp-features li b { color: #fff; }
    
    .sp-features svg {
        width: 18px; height: 18px; color: var(--color-blue-deep);
        flex-shrink: 0; margin-top: 2px;
    }
    :global(html[data-theme="dark"]) .sp-features svg { color: #60a5fa; }

    /* Comparison Table */
    .sp-compare {
        padding: 0 5% 6rem;
        max-width: 1080px; margin: 0 auto;
    }
    .sp-compare-title {
        font-size: 2rem; font-weight: 800; letter-spacing: -0.03em;
        text-align: center; margin: 0 0 3rem;
    }
    
    .sp-table-wrap {
        overflow-x: auto;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background: #fff;
    }
    :global(html[data-theme="dark"]) .sp-table-wrap {
        border-color: #1e293b; background: #0f172a;
    }

    .sp-table {
        width: 100%; border-collapse: collapse; text-align: left;
        min-width: 700px;
    }
    .sp-table th, .sp-table td {
        padding: 1.2rem 1.5rem;
        border-bottom: 1px solid #e5e7eb;
    }
    :global(html[data-theme="dark"]) .sp-table th, :global(html[data-theme="dark"]) .sp-table td {
        border-bottom-color: #1e293b;
    }
    
    .sp-table th {
        font-size: 0.9rem; font-weight: 700; color: #111827;
        background: #f9fafb;
    }
    :global(html[data-theme="dark"]) .sp-table th { background: #0b1120; color: #f8fafc; }
    
    .sp-table tbody tr:last-child td { border-bottom: none; }
    
    .sp-table td {
        font-size: 0.95rem; color: #4b5563;
    }
    :global(html[data-theme="dark"]) .sp-table td { color: #cbd5e1; }
    
    .sp-table td:not(:first-child), .sp-table th:not(:first-child) {
        text-align: center;
        width: 20%;
    }
    .sp-table td:first-child { font-weight: 500; color: #111827; }
    :global(html[data-theme="dark"]) .sp-table td:first-child { color: #f8fafc; }

    .check {
        width: 20px; height: 20px; color: var(--color-blue-deep);
        display: inline-block; vertical-align: middle;
    }
    :global(html[data-theme="dark"]) .check { color: #60a5fa; }

    @media (max-width: 960px) {
        .sp-plans-grid { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; gap: 2rem; }
    }
    @media (max-width: 768px) {
        .sp-hero { padding-top: 10rem; }
        .sp-table-wrap { border-radius: 0; border-left: none; border-right: none; }
    }
</style>
