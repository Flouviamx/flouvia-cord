---
// Página de solución — una por industria (mismo lenguaje que /producto/[slug]:
// hero + mockup que vende, stats, bloques alternados, cross-links y CTA).
// Animaciones compartidas via PageAnims.astro.
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import PageAnims from '../../components/landing/PageAnims.astro';
import SolucionBlockMockup from '../../components/soluciones/SolucionBlockMockup.astro';
import { SOLUCIONES } from '../../lib/solucion';

export function getStaticPaths() {
    return SOLUCIONES.map((s) => ({ params: { slug: s.slug }, props: { solucion: s } }));
}

const { solucion } = Astro.props;
const otras = SOLUCIONES.filter((s) => s.slug !== solucion.slug);

// ── Datos estructurados (JSON-LD) — FAQPage: lo que extraen los AI Overviews.
const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: solucion.faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
};
---

<Layout
    title={solucion.metaTitle ?? `${solucion.nav} — Cord`}
    description={solucion.metaDescription ?? solucion.sub}
>
    <script
        slot="head"
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify(faqSchema)}
    />
    <Nav />
    <main>
        <!-- ── HERO ── -->
        <section class="pp-hero">
            <div class="pp-hero-mesh" aria-hidden="true"></div>
            <div class="pp-hero-inner">
                <p class="pp-eyebrow reveal">{solucion.eyebrow}</p>
                <h1 class="pp-title masked-title" set:html={solucion.titulo} />
                <p class="pp-sub reveal">{solucion.sub}</p>
                <div class="pp-actions reveal">
                    <a href="/registro" class="pp-btn-primary">
                        <span>Empezar gratis</span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </a>
                    <a href="/q/demo" class="pp-btn-ghost">Ver una cotización real</a>
                </div>
                <h3 class="pp-dolor reveal"><span>El dolor:</span> {solucion.dolor}</h3>

                <!-- Mockup específico de la industria -->
                <div class="pp-mockup-wrap reveal-mockup">
                    <div class="pp-glow" aria-hidden="true"></div>
                    <div class="pp-mockup">

                        {solucion.slug === 'distribuidoras' && (
                            <div class="mk-window">
                                <div class="mk-bar">
                                    <span class="mk-dots"><i></i><i></i><i></i></span>
                                    <span class="mk-bar-title">Precio por cliente · Cemento gris 50kg</span>
                                    <span class="mk-badge mk-badge-ok">● Lista activa</span>
                                </div>
                                <div class="mk-rows mk-rows-4">
                                    <div class="mk-row mk-row-head"><span>Cliente</span><span>Términos</span><span>Tu precio</span><span>vs lista</span></div>
                                    <div class="mk-row"><span>Distribuidora El Zarco</span><span>Net 30</span><span class="editorial mk-green">$168.50</span><span class="editorial"><i class="mk-chip">−12%</i></span></div>
                                    <div class="mk-row"><span>Constructora GAMA</span><span>Net 60</span><span class="editorial mk-green">$172.00</span><span class="editorial"><i class="mk-chip">−10%</i></span></div>
                                    <div class="mk-row"><span>Grupo Ferrex</span><span>Contado</span><span class="editorial">$182.00</span><span class="editorial mk-muted">Lista</span></div>
                                </div>
                                <div class="mk-totals">
                                    <span>Precio de lista <b class="editorial">$191.48</b></span>
                                    <span class="mk-total-final">Margen <b class="editorial">protegido</b></span>
                                </div>
                            </div>
                        )}

                        {solucion.slug === 'construccion' && (
                            <div class="mk-window">
                                <div class="mk-bar">
                                    <span class="mk-dots"><i></i><i></i><i></i></span>
                                    <span class="mk-bar-title">COT-0148 · Constructora GAMA · Obra Polanco</span>
                                    <span class="mk-badge mk-badge-sent">● Net 60</span>
                                </div>
                                <div class="mk-rows mk-rows-con">
                                    <div class="mk-row mk-row-head"><span>Material</span><span>Cant.</span><span>Precio</span><span>Importe</span></div>
                                    <div class="mk-row"><span>Cemento gris 50kg</span><span>120 sacos</span><span class="editorial">$182.00</span><span class="editorial">$21,840.00</span></div>
                                    <div class="mk-row"><span>Varilla 3/8" × 12m</span><span>340 tramos</span><span class="editorial">$168.50</span><span class="editorial">$57,290.00</span></div>
                                    <div class="mk-row"><span>Arena de río</span><span>45 m³</span><span class="editorial">$420.00</span><span class="editorial">$18,900.00</span></div>
                                    <div class="mk-row"><span>Block hueco 15×20×40</span><span>2,400 pza</span><span class="editorial">$14.20</span><span class="editorial">$34,080.00</span></div>
                                </div>
                                <div class="mk-totals">
                                    <span>Subtotal <b class="editorial">$169,370.00</b></span>
                                    <span>IVA 16% <b class="editorial">$27,099.20</b></span>
                                    <span class="mk-total-final">Total <b class="editorial">$196,469.20</b></span>
                                </div>
                                <div class="mk-credit-bar">
                                    <span>Crédito de GAMA</span>
                                    <div class="mk-credit"><i style="width:72%"></i></div>
                                    <b class="editorial">$612k / $850k</b>
                                </div>
                            </div>
                        )}

                        {solucion.slug === 'manufactura' && (
                            <div class="mk-window">
                                <div class="mk-bar">
                                    <span class="mk-dots"><i></i><i></i><i></i></span>
                                    <span class="mk-bar-title">COT-0204 · Ensambles del Norte</span>
                                    <span class="mk-badge mk-badge-draft">● Borrador</span>
                                </div>
                                <div class="mk-spec">
                                    <div class="mk-spec-line">
                                        <div><b>Placa de acero A36 · corte láser</b><i>Espesor 6mm · acabado pulido · tolerancia ±0.2mm</i></div>
                                        <span class="editorial">$1,240.00</span>
                                    </div>
                                    <div class="mk-spec-line">
                                        <div><b>Maquinado CNC · pieza 4F-22</b><i>Lote mínimo 500 pza · entrega 12 días hábiles</i></div>
                                        <span class="editorial">$86.50</span>
                                    </div>
                                </div>
                                <div class="mk-note">
                                    <span class="mk-note-label">NOTA DEL LOTE</span>
                                    <p>MOQ 500 pza · entrega 12 días tras anticipo del 50% · precio sujeto a plano final R3.</p>
                                </div>
                                <div class="mk-totals">
                                    <span class="mk-total-final">Total del lote <b class="editorial">$44,490.00</b></span>
                                </div>
                            </div>
                        )}

                        {solucion.slug === 'servicios' && (
                            <div class="mk-public">
                                <div class="mk-public-head">
                                    <span class="mk-avatar">DV</span>
                                    <div>
                                        <b>Despacho Vértice</b>
                                        <i>te envió una propuesta</i>
                                    </div>
                                    <span class="mk-badge mk-badge-sent">● Vista</span>
                                </div>
                                <div class="mk-public-total">
                                    <span>Honorarios del proyecto</span>
                                    <b class="editorial">$84,000.00</b>
                                    <i>50% anticipo · vigente al 30 jun 2026</i>
                                </div>
                                <div class="mk-public-actions">
                                    <span class="mk-approve">Aprobar propuesta</span>
                                    <span class="mk-reject">Tengo una duda</span>
                                </div>
                                <span class="mk-via">vía <b>cord</b></span>
                            </div>
                        )}

                    </div>
                </div>
            </div>
        </section>

        <!-- ── PARA QUIÉN (audiencia objetivo — extractable para AI) ── -->
        <section class="pp-audience">
            <p class="pp-eyebrow reveal">PARA QUIÉN ES</p>
            <h2 class="pp-audience-title masked-title" set:html={`Para quién es Cord<br/>${solucion.nav.toLowerCase()}.`} />
            <p class="pp-audience-copy reveal">{solucion.paraQuien}</p>
        </section>

        <!-- ── STATS ── -->
        <section class="pp-stats">
            {solucion.stats.map((s) => (
                <div class="pp-stat reveal">
                    <span
                        class="pp-stat-num editorial"
                        data-countup={s.countup !== undefined ? String(s.countup) : undefined}
                        data-decimals={s.decimals !== undefined ? String(s.decimals) : undefined}
                        data-prefix={s.prefix}
                        data-suffix={s.suffix}
                    >{s.prefix ?? ''}{s.valor}{s.suffix ?? ''}</span>
                    <span class="pp-stat-label">{s.label}</span>
                </div>
            ))}
        </section>

        <!-- ── BLOQUES DE DETALLE ── -->
        <section class="pp-blocks">
            {solucion.blocks.map((b, i) => (
                <article class:list={['pp-block', { 'pp-block-flip': i % 2 === 1 }]}>
                    <div class="pp-block-text">
                        <p class="pp-eyebrow reveal">{b.eyebrow}</p>
                        <h2 class="pp-h2 masked-title" set:html={b.titulo} />
                        <p class="pp-copy reveal">{b.copy}</p>
                        <ul class="pp-bullets">
                            {b.bullets.map((bl) => (
                                <li class="reveal">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                    <span>{bl}</span>
                                </li>
                            ))}
                        </ul>
                    </div>
                    <div class="pp-block-visual" style="align-items: center; justify-content: center; padding: 0;">
                        <SolucionBlockMockup slug={solucion.slug} index={i} />
                    </div>
                </article>
            ))}
        </section>

        {solucion.resultado && (
            <!-- ── RESULTADO REAL (caso de uso con métricas — AI-SEO) ── -->
            <section class="pp-result">
                <div class="pp-result-inner">
                    <p class="pp-eyebrow reveal">RESULTADO REAL</p>
                    <p class="pp-result-client reveal">{solucion.resultado.cliente}</p>
                    <div class="pp-result-grid">
                        {solucion.resultado.metricas.map((m) => (
                            <div class="pp-result-stat reveal">
                                <span class="pp-result-num editorial">{m.valor}</span>
                                <span class="pp-result-label">{m.label}</span>
                            </div>
                        ))}
                    </div>
                    <p class="pp-result-note reveal">{solucion.resultado.nota}</p>
                </div>
            </section>
        )}

        <!-- ── INTERLINK A FEATURE (grafo de entidades) ── -->
        <section class="pp-interlink reveal">
            <a href={solucion.interlink.href}>
                Conoce a fondo {solucion.interlink.label}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
        </section>

        <!-- ── FAQ ── -->
        <section class="pp-faq">
            <div class="pp-faq-head">
                <p class="pp-eyebrow reveal">PREGUNTAS FRECUENTES</p>
                <h2 class="pp-h2 masked-title">Lo que más nos preguntan<br/>sobre {solucion.nav.toLowerCase()}.</h2>
            </div>
            <div class="pp-faq-list">
                {solucion.faqs.map((f, i) => (
                    <div class="pp-faq-item reveal">
                        <button class="pp-faq-q" aria-expanded="false" aria-controls={`pp-faq-panel-${i}`}>
                            <span>{f.q}</span>
                            <span class="pp-faq-icon" aria-hidden="true"></span>
                        </button>
                        <div class="pp-faq-panel" id={`pp-faq-panel-${i}`} role="region">
                            <p class="pp-faq-a">{f.a}</p>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <!-- ── CROSS-LINKS ── -->
        <section class="pp-more">
            <div class="pp-more-head">
                <p class="pp-eyebrow reveal">OTRAS INDUSTRIAS</p>
                <h2 class="pp-h2 masked-title">Cord funciona<br/>en tu sector también.</h2>
            </div>
            <div class="pp-more-grid">
                {otras.map((s) => (
                    <a href={`/soluciones/${s.slug}`} class="pp-more-card reveal">
                        <b>{s.nav}</b>
                        <span>{s.sub.split('.')[0]}.</span>
                        <i class="pp-more-arrow">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </i>
                    </a>
                ))}
            </div>
        </section>
    </main>

    <Footer ctaTitle={solucion.cta.titulo} ctaSub={solucion.cta.sub} />
    <PageAnims />
</Layout>

<style>
    /* ════════ HERO ════════ */
    .pp-hero {
        position: relative;
        padding: 11.5rem 5% 5rem;
        text-align: center;
        overflow: clip;
        background: var(--color-bg);
    }
    .pp-hero-mesh {
        position: absolute; inset: -20% -10% auto;
        height: 80%;
        background:
            radial-gradient(ellipse 50% 60% at 28% 20%, rgba(10,25,47,0.05) 0%, transparent 60%),
            radial-gradient(ellipse 44% 54% at 76% 12%, rgba(10,25,47,0.04) 0%, transparent 60%);
        pointer-events: none;
    }
    .pp-hero-inner { position: relative; z-index: 1; max-width: 980px; margin: 0 auto; }

    .pp-eyebrow {
        font-size: 0.65rem; font-weight: 800; letter-spacing: 3px;
        text-transform: uppercase; color: #888; margin: 0 0 1.4rem;
    }
    .pp-title {
        font-size: clamp(2.4rem, 5.4vw, 4.4rem);
        font-weight: 800; line-height: 1.04; letter-spacing: -0.035em;
        color: var(--color-text); margin: 0 0 1.6rem;
    }
    .pp-sub {
        font-size: 1.12rem; line-height: 1.65; color: var(--color-text-muted);
        max-width: 660px; margin: 0 auto 2.2rem;
    }
    .pp-actions { display: flex; gap: 0.9rem; justify-content: center; align-items: center; flex-wrap: wrap; }
    .pp-btn-primary {
        display: inline-flex; align-items: center; gap: 10px;
        background: var(--color-blue-deep); color: #fff;
        text-decoration: none; font-size: 0.98rem; font-weight: 600;
        padding: 14px 28px; border-radius: 13px;
        box-shadow: 0 18px 44px -16px rgba(10,25,47,0.55);
        transition: transform 0.5s var(--ease-spring), box-shadow 0.5s var(--ease-spring);
    }
    .pp-btn-primary svg { width: 15px; height: 15px; transition: transform 0.5s var(--ease-spring); }
    .pp-btn-primary:hover { transform: translateY(-3px); box-shadow: 0 26px 56px -16px rgba(10,25,47,0.6); }
    .pp-btn-primary:hover svg { transform: translateX(4px); }
    .pp-btn-ghost {
        color: var(--color-text); text-decoration: none; font-weight: 600; font-size: 0.98rem;
        padding: 14px 10px;
        transition: color 0.3s;
    }
    .pp-btn-ghost:hover { color: var(--color-blue-deep); }
    .pp-dolor {
        font-size: 0.85rem; font-weight: 400; color: var(--color-text-muted); margin: 1.4rem auto 0; max-width: 540px;
        line-height: 1.5;
    }
    .pp-dolor span { font-weight: 700; color: var(--color-danger); letter-spacing: 0.2px; }

    /* ── Mockup del hero ── */
    .pp-mockup-wrap { position: relative; max-width: 760px; margin: 4.5rem auto 0; }
    .pp-glow {
        position: absolute; inset: 12% -8% -18%;
        background: radial-gradient(ellipse at center, rgba(10,25,47,0.16) 0%, transparent 65%);
        filter: blur(30px);
        pointer-events: none;
    }
    .pp-mockup {
        position: relative;
        background: linear-gradient(165deg, #0e2240 0%, #0a192f 55%, #081424 100%);
        border-radius: 22px;
        padding: 1.6rem;
        text-align: left;
        box-shadow:
            0 50px 100px -36px rgba(5,11,20,0.75),
            inset 0 0 0 0.5px rgba(255,255,255,0.08);
        color: #fff;
    }

    /* badges + avatar compartidos */
    .mk-badge {
        font-size: 0.62rem; font-weight: 700; letter-spacing: 0.4px;
        padding: 4px 10px; border-radius: 100px; white-space: nowrap;
    }
    .mk-badge-draft { color: #aab4c4; background: rgba(255,255,255,0.08); }
    .mk-badge-sent  { color: #7eb3ff; background: rgba(59,130,246,0.16); }
    .mk-badge-ok    { color: #4ade80; background: rgba(16,185,129,0.16); }
    .mk-avatar {
        width: 38px; height: 38px; border-radius: 10px; flex-shrink: 0;
        background: rgba(255,255,255,0.1); color: #fff;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 0.78rem; font-weight: 800;
    }

    /* ventana (distribuidoras + construccion) */
    .mk-bar { display: flex; align-items: center; gap: 12px; padding-bottom: 1rem; }
    .mk-dots { display: inline-flex; gap: 5px; }
    .mk-dots i { width: 9px; height: 9px; border-radius: 50%; background: rgba(255,255,255,0.14); }
    .mk-bar-title { font-size: 0.76rem; font-weight: 600; color: rgba(255,255,255,0.75); flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .mk-rows { display: flex; flex-direction: column; gap: 4px; }
    .mk-row {
        display: grid; gap: 8px; align-items: center;
        font-size: 0.78rem; color: rgba(255,255,255,0.82);
        padding: 8px 10px; border-radius: 9px;
        background: rgba(255,255,255,0.03);
    }
    .mk-rows-4 .mk-row { grid-template-columns: 1.7fr 0.8fr 0.9fr 0.8fr; }
    .mk-rows-con .mk-row { grid-template-columns: 1.7fr 0.9fr 0.8fr 1fr; }
    .mk-row span:nth-child(n+2) { text-align: right; }
    .mk-row-head { background: none; font-size: 0.6rem; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; color: rgba(255,255,255,0.35); }
    .mk-green { color: #4ade80; }
    .mk-muted { color: rgba(255,255,255,0.4); }
    .mk-chip {
        font-style: normal; font-size: 0.6rem; font-weight: 800;
        color: #052e1f; background: #4ade80;
        padding: 1px 6px; border-radius: 6px;
        vertical-align: 1px;
    }
    .mk-totals {
        display: flex; justify-content: flex-end; gap: 1.6rem; flex-wrap: wrap;
        margin-top: 1rem; padding: 0.9rem 10px 0;
        border-top: 1px solid rgba(255,255,255,0.09);
        font-size: 0.74rem; color: rgba(255,255,255,0.55);
    }
    .mk-totals b { margin-left: 7px; color: #fff; font-weight: 600; }
    .mk-total-final { font-weight: 700; color: rgba(255,255,255,0.85); }
    .mk-total-final b { font-size: 1.05rem; }

    /* barra de crédito (construccion) */
    .mk-credit-bar {
        display: flex; align-items: center; gap: 12px;
        margin-top: 0.9rem; padding: 11px 12px; border-radius: 11px;
        background: rgba(255,255,255,0.035);
        font-size: 0.72rem; color: rgba(255,255,255,0.55);
    }
    .mk-credit { flex: 1; }
    .mk-credit i { display: block; height: 6px; border-radius: 100px; background: linear-gradient(90deg, #fbbf24, #f59e0b); }
    .mk-credit-bar b { color: #fff; font-weight: 600; white-space: nowrap; }

    /* especificación (manufactura) */
    .mk-spec { display: flex; flex-direction: column; gap: 6px; }
    .mk-spec-line {
        display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem;
        padding: 11px 13px; border-radius: 11px; background: rgba(255,255,255,0.035);
    }
    .mk-spec-line b { display: block; font-size: 0.82rem; font-weight: 600; }
    .mk-spec-line i { display: block; font-style: normal; font-size: 0.7rem; color: rgba(255,255,255,0.45); margin-top: 3px; line-height: 1.4; }
    .mk-spec-line > span { white-space: nowrap; color: #fff; }
    .mk-note {
        margin-top: 0.8rem; padding: 11px 13px; border-radius: 11px;
        background: rgba(251,191,36,0.08); box-shadow: inset 0 0 0 0.5px rgba(251,191,36,0.18);
    }
    .mk-note-label { font-size: 0.58rem; font-weight: 800; letter-spacing: 1.4px; color: #fbbf24; }
    .mk-note p { margin: 4px 0 0; font-size: 0.74rem; color: rgba(255,255,255,0.7); line-height: 1.5; }

    /* propuesta pública (servicios) */
    .mk-public { position: relative; max-width: 440px; margin: 0 auto; perspective: 1000px; }
    .mk-public-card { 
        display: flex; flex-direction: column; gap: 1.25rem; padding: 1.5rem;
        background: linear-gradient(145deg, rgba(10,25,47,0.85), rgba(15,23,42,0.95));
        border-radius: 18px; box-shadow: 0 24px 48px -12px rgba(2,6,12,0.8), inset 0 1px 1px rgba(255,255,255,0.1);
        backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px); border: 1px solid rgba(255,255,255,0.08);
    }
    .mk-public-head { display: flex; align-items: center; gap: 12px; }
    .mk-public-head b { display: block; font-size: 0.92rem; }
    .mk-public-head i { display: block; font-style: normal; font-size: 0.74rem; color: rgba(255,255,255,0.5); }
    .mk-public-head .mk-badge { margin-left: auto; }
    .mk-public-total {
        text-align: center; padding: 1.4rem 1rem;
        background: rgba(255,255,255,0.04); border-radius: 16px;
        box-shadow: inset 0 0 0 0.5px rgba(255,255,255,0.07);
    }
    .mk-public-total span { display: block; font-size: 0.68rem; font-weight: 700; letter-spacing: 1.6px; text-transform: uppercase; color: rgba(255,255,255,0.45); margin-bottom: 6px; }
    .mk-public-total b { display: block; font-size: 2rem; font-weight: 600; letter-spacing: -0.03em; }
    .mk-public-total i { display: block; font-style: normal; font-size: 0.74rem; color: rgba(255,255,255,0.45); margin-top: 6px; }
    .mk-public-actions { display: flex; gap: 0.7rem; }
    .mk-approve {
        flex: 1; text-align: center;
        background: #fff; color: var(--color-blue-deep);
        font-size: 0.88rem; font-weight: 700;
        padding: 13px; border-radius: 12px;
    }
    .mk-reject {
        text-align: center; color: rgba(255,255,255,0.6);
        font-size: 0.88rem; font-weight: 600;
        padding: 13px 20px; border-radius: 12px;
        box-shadow: inset 0 0 0 1px rgba(255,255,255,0.14);
    }
    .mk-via { text-align: center; font-size: 0.68rem; color: rgba(255,255,255,0.35); }
    .mk-via b { color: rgba(255,255,255,0.6); }

    /* ── EDITOR APP SIMULATION ── */
    .mk-window {
        background: #0a192f;
        border-radius: 14px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.5), inset 0 1px 1px rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.06);
        position: relative; overflow: hidden;
    }

    /* ════════ STATS ════════ */
    .pp-stats {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem;
        max-width: 1080px; margin: 0 auto;
        padding: 5.5rem 5%;
        border-bottom: 1px solid var(--color-border);
    }
    .pp-stat { text-align: center; display: flex; flex-direction: column; gap: 0.6rem; }
    .pp-stat-num {
        font-size: clamp(2.4rem, 4.6vw, 3.6rem);
        color: var(--color-blue-deep); line-height: 1;
    }
    .pp-stat-label { font-size: 0.88rem; color: var(--color-text-muted); max-width: 240px; margin: 0 auto; line-height: 1.5; }

    /* ════════ BLOQUES ════════ */
    .pp-blocks {
        max-width: 1080px; margin: 0 auto;
        padding: 8rem 5% 6rem;
        display: flex; flex-direction: column; gap: 14rem;
    }
    .pp-block {
        display: grid; grid-template-columns: 1.1fr 0.9fr;
        gap: 4.5rem; align-items: center;
    }
    .pp-block-text, .pp-block-visual { min-width: 0; }
    .pp-block-flip .pp-block-text { order: 2; }
    .pp-block-flip .pp-block-visual { order: 1; }

    .pp-h2 {
        font-size: clamp(1.7rem, 3vw, 2.4rem);
        font-weight: 800; line-height: 1.12; letter-spacing: -0.03em;
        color: var(--color-text); margin: 0 0 1.1rem;
    }
    .pp-copy { font-size: 1.02rem; line-height: 1.7; color: var(--color-text-muted); margin: 0 0 1.6rem; }
    .pp-bullets { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.8rem; }
    .pp-bullets li { display: flex; align-items: flex-start; gap: 11px; font-size: 0.95rem; color: var(--color-text); font-weight: 500; }
    .pp-bullets svg { width: 16px; height: 16px; color: var(--color-ok); flex-shrink: 0; margin-top: 3px; }

    .pp-block-visual {
        position: relative;
        min-height: 260px;
        border-radius: 24px;
        background: transparent;
        border: none;
        display: flex; align-items: center; justify-content: center;
        padding: 1.6rem;
    }
    .pp-card-num {
        font-size: 5rem; line-height: 0.9;
        color: rgba(10,25,47,0.08);
        font-weight: 600;
    }

    /* ════════ CROSS-LINKS ════════ */
    .pp-more {
        max-width: 1080px; margin: 0 auto;
        padding: 6rem 5% 8rem;
    }
    .pp-more-head { text-align: center; margin-bottom: 3.2rem; }
    .pp-more-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.1rem; }
    .pp-more-card {
        position: relative;
        display: flex; flex-direction: column; gap: 0.5rem;
        background: var(--color-bg-soft);
        border: 1px solid var(--color-border);
        border-radius: 20px;
        padding: 1.7rem 1.8rem;
        text-decoration: none;
        transition: transform 0.5s var(--ease-spring), box-shadow 0.5s var(--ease-spring), border-color 0.4s;
    }
    .pp-more-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 30px 70px -30px rgba(10,25,47,0.18);
        border-color: rgba(10,25,47,0.12);
    }
    .pp-more-card b { font-size: 1.02rem; font-weight: 700; letter-spacing: -0.3px; color: var(--color-text); }
    .pp-more-card span { font-size: 0.86rem; line-height: 1.55; color: var(--color-text-muted); padding-right: 2.4rem; }
    .pp-more-arrow {
        position: absolute; right: 1.5rem; top: 1.6rem;
        width: 30px; height: 30px; border-radius: 50%;
        background: rgba(10,25,47,0.05); color: var(--color-blue-deep);
        display: flex; align-items: center; justify-content: center;
        transition: background 0.35s, color 0.35s, transform 0.5s var(--ease-spring);
    }
    .pp-more-arrow svg { width: 13px; height: 13px; }
    .pp-more-card:hover .pp-more-arrow { background: var(--color-blue-deep); color: #fff; transform: translateX(3px); }

    /* ════════ PARA QUIÉN ════════ */
    .pp-audience {
        max-width: 820px; margin: 0 auto;
        padding: 5.5rem 5% 0; text-align: center;
    }
    .pp-audience-title {
        font-size: clamp(1.6rem, 2.8vw, 2.2rem);
        font-weight: 800; line-height: 1.12; letter-spacing: -0.03em;
        color: var(--color-text); margin: 0 0 1.2rem;
    }
    .pp-audience-copy {
        font-size: 1.08rem; line-height: 1.75; color: var(--color-text-muted);
        max-width: 680px; margin: 0 auto;
    }

    /* ════════ RESULTADO REAL ════════ */
    .pp-result {
        padding: 5rem 5%;
        background:
            radial-gradient(ellipse at 20% 50%, #112240 0%, #0a192f 65%, #050b14 100%);
        color: #fff;
    }
    .pp-result-inner { max-width: 980px; margin: 0 auto; text-align: center; }
    .pp-result .pp-eyebrow { color: rgba(255,255,255,0.5); }
    .pp-result-client {
        font-size: 1.05rem; font-weight: 600; color: rgba(255,255,255,0.85);
        margin: 0 0 2.6rem; letter-spacing: -0.2px;
    }
    .pp-result-grid {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.4rem;
        margin-bottom: 2.4rem;
    }
    .pp-result-stat { display: flex; flex-direction: column; gap: 0.6rem; }
    .pp-result-num {
        font-size: clamp(2.6rem, 5vw, 3.8rem); line-height: 1; color: #fff;
    }
    .pp-result-label {
        font-size: 0.88rem; line-height: 1.5; color: rgba(255,255,255,0.6);
        max-width: 220px; margin: 0 auto;
    }
    .pp-result-note {
        font-size: 0.92rem; line-height: 1.65; color: rgba(255,255,255,0.55);
        max-width: 660px; margin: 0 auto;
    }

    /* ════════ INTERLINK ════════ */
    .pp-interlink { text-align: center; padding: 4.5rem 5% 0; }
    .pp-interlink a {
        display: inline-flex; align-items: center; gap: 9px;
        font-size: 1rem; font-weight: 600; color: var(--color-blue-deep);
        text-decoration: none;
        transition: gap 0.4s var(--ease-spring);
    }
    .pp-interlink a:hover { gap: 14px; }
    .pp-interlink svg { width: 16px; height: 16px; }

    /* ════════ FAQ ════════ */
    .pp-faq {
        max-width: 760px; margin: 0 auto;
        padding: 5rem 5% 2rem;
    }
    .pp-faq-head { text-align: center; margin-bottom: 2.6rem; }
    .pp-faq-head .pp-h2 { margin: 0; }
    .pp-faq-list { display: flex; flex-direction: column; }
    .pp-faq-item { border-bottom: 1px solid var(--color-border); }
    .pp-faq-q {
        display: flex; justify-content: space-between; align-items: center; gap: 1.5rem;
        width: 100%; padding: 1.5rem 0.2rem;
        cursor: pointer; background: none; border: none; text-align: left;
        font-family: var(--font-sans); font-size: 1.08rem; font-weight: 600;
        color: var(--color-text); transition: color 0.3s var(--ease-ios);
    }
    .pp-faq-q:hover, .pp-faq-item.open .pp-faq-q { color: var(--color-blue-deep); }
    .pp-faq-icon { position: relative; width: 16px; height: 16px; flex-shrink: 0; transition: transform 0.5s var(--ease-spring); }
    .pp-faq-icon::before, .pp-faq-icon::after {
        content: ''; position: absolute; top: 50%; left: 50%;
        background: var(--color-text-muted);
        transition: transform 0.4s var(--ease-spring);
    }
    .pp-faq-icon::before { width: 14px; height: 2px; transform: translate(-50%, -50%); }
    .pp-faq-icon::after { width: 2px; height: 14px; transform: translate(-50%, -50%); }
    .pp-faq-item.open .pp-faq-icon { transform: rotate(90deg); }
    .pp-faq-item.open .pp-faq-icon::after { transform: translate(-50%, -50%) scaleY(0); }
    .pp-faq-panel {
        display: grid; grid-template-rows: 0fr;
        transition: grid-template-rows 0.55s var(--ease-spring);
    }
    .pp-faq-panel > .pp-faq-a { overflow: hidden; min-height: 0; }
    .pp-faq-item.open .pp-faq-panel { grid-template-rows: 1fr; }
    .pp-faq-a {
        margin: 0; padding: 0 0.2rem;
        font-size: 1rem; line-height: 1.7; color: var(--color-text-muted); max-width: 92%;
        opacity: 0; transform: translateY(-6px);
        transition: opacity 0.45s var(--ease-ios) 0.08s, transform 0.5s var(--ease-spring) 0.08s, padding 0.45s var(--ease-spring);
    }
    .pp-faq-item.open .pp-faq-a { opacity: 1; transform: translateY(0); padding-bottom: 1.6rem; }
    @media (prefers-reduced-motion: reduce) {
        .pp-faq-panel, .pp-faq-a, .pp-faq-icon { transition: none; }
    }

    /* ════════ RESPONSIVE ════════ */
    @media (max-width: 860px) {
        .pp-hero { padding-top: 9.5rem; }
        .pp-audience { padding-top: 4rem; }
        .pp-result-grid { grid-template-columns: 1fr; gap: 2.2rem; }
        .pp-stats { grid-template-columns: 1fr; gap: 2.4rem; padding: 4rem 8%; }
        .pp-blocks { gap: 4.5rem; }
        .pp-block { grid-template-columns: 1fr; gap: 1.8rem; }
        .pp-block-flip .pp-block-text { order: 1; }
        .pp-block-flip .pp-block-visual { order: 2; }
        .pp-block-visual { min-height: 170px; }
        .pp-more-grid { grid-template-columns: 1fr; }
        .mk-rows-4 .mk-row { grid-template-columns: 1.5fr 0.8fr 0.9fr; }
        .mk-rows-4 .mk-row span:nth-child(4) { display: none; }
        .mk-rows-con .mk-row { grid-template-columns: 1.5fr 0.9fr 1fr; }
        .mk-rows-con .mk-row span:nth-child(3) { display: none; }
    }
</style>

<script>
    // FAQ: acordeón (un solo abierto a la vez); la animación la hace el CSS (grid 0fr→1fr).
    document.addEventListener('DOMContentLoaded', () => {
        const items = Array.from(document.querySelectorAll<HTMLElement>('.pp-faq-item'));
        items.forEach((item) => {
            const btn = item.querySelector<HTMLButtonElement>('.pp-faq-q');
            if (!btn) return;
            btn.addEventListener('click', () => {
                const willOpen = !item.classList.contains('open');
                items.forEach((other) => {
                    other.classList.remove('open');
                    other.querySelector('.pp-faq-q')?.setAttribute('aria-expanded', 'false');
                });
                if (willOpen) {
                    item.classList.add('open');
                    btn.setAttribute('aria-expanded', 'true');
                }
            });
        });

        // Solo ejecutar GSAP si está disponible (cargado por PageAnims o globalmente)
        if (typeof window !== 'undefined' && (window as any).gsap && (window as any).ScrollTrigger) {
            const gsap = (window as any).gsap;
            const ScrollTrigger = (window as any).ScrollTrigger;

            // ───────────────────────── HERO MOCKUP GSAP ─────────────────────────
            const wrap = document.querySelector('.pp-mockup-wrap');
            if (wrap) {
                gsap.set('.pp-mockup', { transformPerspective: 1600, transformStyle: 'preserve-3d', transformOrigin: 'center center' });
                const floatingElements = wrap.querySelectorAll('.mk-window, .mk-public-card');
                gsap.set(floatingElements, { z: 80, rotationX: 10, rotationY: -10, opacity: 0 });
                gsap.set('.pp-mockup', { rotationX: 25, rotationY: -15, scale: 0.9 });
                
                const assembleTl = gsap.timeline({
                    scrollTrigger: { trigger: wrap, start: 'top 95%', end: 'top 30%', scrub: 1 }
                });
                assembleTl.to('.pp-mockup', { rotationX: 0, rotationY: 0, scale: 1, ease: 'power2.out' }, 0);
                assembleTl.to(floatingElements, { z: 0, rotationX: 0, rotationY: 0, opacity: 1, stagger: 0.05, ease: 'back.out(1.2)' }, 0);
                
                wrap.addEventListener('mousemove', (e: Event) => {
                    const evt = e as MouseEvent;
                    const dot = document.createElement('div');
                    dot.className = 'mk-particle';
                    dot.style.left = evt.clientX + 'px';
                    dot.style.top = evt.clientY + 'px';
                    document.body.appendChild(dot);
                    gsap.to(dot, { y: -50, x: (Math.random()-0.5)*50, opacity: 0, scale: 0, duration: 1+Math.random(), onComplete: () => dot.remove() });
                });
            }

            // ───────────────────────── BLOCK MOCKUPS GSAP (SCRUB) ─────────────────────────
            
            // DISTRIBUIDORAS
            const distM0 = document.querySelector('.sbm-dist-m0');
            if (distM0) {
                distM0.addEventListener('mousemove', (e: Event) => {
                    const evt = e as MouseEvent;
                    const rect = distM0.getBoundingClientRect();
                    const x = (evt.clientX - rect.left) / rect.width - 0.5;
                    const y = (evt.clientY - rect.top) / rect.height - 0.5;
                    gsap.to(distM0.querySelector('.sbm-card'), { rotationY: x*20, rotationX: -y*20, transformPerspective: 1000, ease: 'power1.out', duration: 0.5 });
                });
                distM0.addEventListener('mouseleave', () => {
                    gsap.to(distM0.querySelector('.sbm-card'), { rotationY: 0, rotationX: 0, ease: 'power3.out', duration: 0.8 });
                });
            }
            const distM1 = document.querySelector('.sbm-dist-m1');
            if (distM1) {
                const type = distM1.querySelector('.bm-search-type');
                const res = distM1.querySelector('.bm-s-res-1');
                const tl = gsap.timeline({ scrollTrigger: { trigger: distM1, start: 'top 90%', end: 'top 40%', scrub: 1 } });
                tl.set(res, { opacity: 0, y: 10 })
                  .to(type, { opacity: 0.5, duration: 0.1, yoyo: true, repeat: 5 })
                  .to(res, { opacity: 1, y: 0, duration: 0.5, ease: 'back.out(1.5)' });
            }
            const distM2 = document.querySelector('.sbm-dist-m2');
            if (distM2) {
                const fill = distM2.querySelector('.bm-margin-bar-fill');
                gsap.to(fill, { width: '85%', ease: 'none', scrollTrigger: { trigger: distM2, start: 'top 95%', end: 'top 30%', scrub: 1 } });
            }

            // CONSTRUCCION
            const constM0 = document.querySelector('.sbm-const-m0');
            if (constM0) {
                const counter = constM0.querySelector('.sbm-countup');
                const obj = { v: 0 };
                gsap.to(obj, { v: 120, ease: 'none', scrollTrigger: { trigger: constM0, start: 'top 95%', end: 'top 30%', scrub: 1 }, onUpdate: () => counter.textContent = Math.floor(obj.v) + ' sacos' });
            }
            const constM1 = document.querySelector('.sbm-const-m1');
            if (constM1) {
                const fill = constM1.querySelector('.bm-tl-fill');
                gsap.to(fill, { height: '100%', ease: 'none', scrollTrigger: { trigger: constM1, start: 'top 95%', end: 'top 20%', scrub: 1 } });
            }
            const constM2 = document.querySelector('.sbm-const-m2');
            if (constM2) {
                const status = constM2.querySelector('.sbm-status');
                const tl = gsap.timeline({ scrollTrigger: { trigger: constM2, start: 'top 80%', end: 'top 40%', scrub: 1 } });
                tl.to(status, { background: 'rgba(6,78,59,0.9)', borderColor: 'rgba(16,185,129,0.3)', color: '#34d399', ease: 'none', onStart: () => status.textContent = 'Abono recibido', onReverseComplete: () => status.textContent = 'Pendiente' });
            }

            // MANUFACTURA
            const manuM0 = document.querySelector('.sbm-manu-m0');
            if (manuM0) {
                const lines = manuM0.querySelectorAll('.bm-term-line');
                const tl = gsap.timeline({ scrollTrigger: { trigger: manuM0, start: 'top 95%', end: 'top 30%', scrub: 1 } });
                gsap.set(lines, { opacity: 0 });
                lines.forEach((l, i) => tl.to(l, { opacity: 1, duration: 0.1 }, i*0.2));
            }
            const manuM1 = document.querySelector('.sbm-manu-m1');
            if (manuM1) {
                const flip = manuM1.querySelector('.sbm-flip-card');
                gsap.to(flip, { rotationX: 180, transformStyle: 'preserve-3d', ease: 'none', scrollTrigger: { trigger: manuM1, start: 'top 80%', end: 'top 30%', scrub: 1 } });
            }
            const manuM2 = document.querySelector('.sbm-manu-m2');
            if (manuM2) {
                const path = manuM2.querySelector('.sbm-path');
                gsap.to(path, { strokeDashoffset: 0, ease: 'none', scrollTrigger: { trigger: manuM2, start: 'top 95%', end: 'top 20%', scrub: 1 } });
            }

            // SERVICIOS
            const servM0 = document.querySelector('.sbm-serv-m0');
            if (servM0) {
                const rows = servM0.querySelectorAll('.sbm-stag-row');
                const tl = gsap.timeline({ scrollTrigger: { trigger: servM0, start: 'top 90%', end: 'top 30%', scrub: 1 } });
                gsap.set(rows, { opacity: 0, x: -20 });
                rows.forEach((r, i) => tl.to(r, { opacity: 1, x: 0, duration: 0.2 }, i*0.2));
            }
            const servM1 = document.querySelector('.sbm-serv-m1');
            if (servM1) {
                const card = servM1.querySelector('.sbm-brand-card');
                const btn = servM1.querySelector('.sbm-btn');
                const tl = gsap.timeline({ scrollTrigger: { trigger: servM1, start: 'top 90%', end: 'top 30%', scrub: 1 } });
                tl.to(card, { borderColor: '#10b981', boxShadow: '0 0 30px rgba(16,185,129,0.2)', ease: 'none' }, 0)
                  .to(btn, { background: '#10b981', color: '#fff', ease: 'none' }, 0);
            }
            const servM2 = document.querySelector('.sbm-serv-m2');
            if (servM2) {
                const matrix = servM2.querySelector('.sbm-matrix-text');
                const orig = '&lt;cfdi:Comprobante&gt;<br/>&nbsp;&nbsp;&lt;cfdi:Emisor Rfc="DESP21"/&gt;<br/>&lt;/cfdi:Comprobante&gt;';
                const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&*';
                ScrollTrigger.create({
                    trigger: servM2, start: 'top 80%', once: true,
                    onEnter: () => {
                        let iters = 0;
                        const interval = setInterval(() => {
                            matrix.innerHTML = orig.split('').map(c => Math.random() < 0.1 ? chars[Math.floor(Math.random()*chars.length)] : c).join('');
                            if (iters++ > 20) { clearInterval(interval); matrix.innerHTML = orig; }
                        }, 50);
                    }
                });
            }
        }
    });
</script>
