---
// Página de solución (Empresas, Startups).
// Diseño alineado al estilo Cord.
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import PageAnims from '../../components/landing/PageAnims.astro';
import SolucionBlockMockup from '../../components/soluciones/SolucionBlockMockup.astro';
import { SOLUCIONES } from '../../lib/solucion';
import { SOLUCIONES_EN } from '../../lib/solucion.en';
import { getLangFromUrl } from '../../i18n/utils';

export function getStaticPaths() {
    return SOLUCIONES.map((s) => ({ params: { slug: s.slug }, props: { solucion: s } }));
}

const lang = getLangFromUrl(Astro.url);
const isEn = Astro.props.isEn || lang === 'en';
const currentSol = Astro.props.solucion || Astro.props.solucion;
const solucion = isEn && currentSol ? SOLUCIONES_EN.find((s) => s.slug === currentSol.slug) || currentSol : currentSol;
const otras = (isEn ? SOLUCIONES_EN : SOLUCIONES).filter((s) => s.slug !== solucion.slug);

const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: solucion.faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
};

// Array estático de logos (Stripe-style logo cloud)
const clientLogos = ['GAMA', 'ACEROS', 'VERTICE', 'ZARCO', 'FERREX', 'CEMENTOS'];
---

<Layout
    title={solucion.metaTitle ?? `${solucion.nav} — Cord`}
    description={solucion.metaDescription ?? solucion.sub}
>
    <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
    <Nav />
    <main class="stripe-main">
        
        <!-- ── HERO (Stripe Slanted Background) ── -->
        <header class="stripe-hero">
            <div class="stripe-hero-bg">
                <div class="stripe-hero-grid"></div>
                <div class="stripe-hero-gradient"></div>
            </div>
            
            <div class="stripe-hero-content">
                <div class="stripe-hero-tag reveal">
                    {solucion.eyebrow}
                </div>
                
                <h1 class="stripe-title masked-title" set:html={solucion.titulo} />
                
                <p class="stripe-sub reveal">{solucion.sub}</p>
                
                <div class="stripe-actions reveal">
                    <a href="/contacto" class="stripe-btn-primary">
                        {isEn ? 'Contact sales' : 'Contactar a ventas'}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </a>
                    <a href="/registro" class="stripe-btn-ghost">
                        {isEn ? 'Start now' : 'Empezar ahora'}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </a>
                </div>
            </div>
        </header>

        <!-- ── LOGO CLOUD (Stripe Style) ── -->
        <section class="stripe-clients reveal">
            <div class="stripe-container">
                <p class="stripe-clients-title">
                    {isEn ? 'Over 100 industry leaders trust Cord to scale their operations' : 'Más de 100 empresas líderes en su sector confían en Cord para escalar su operación'}
                </p>
                <div class="stripe-logo-grid">
                    {clientLogos.map(logo => (
                        <div class="stripe-logo">{logo}</div>
                    ))}
                </div>
            </div>
        </section>

        <!-- ── BENTO GRID FEATURES ── -->
        <section class="stripe-bento-section">
            <div class="stripe-container">
                <div class="stripe-section-header reveal">
                    <h2 class="stripe-h2">{isEn ? 'A complete ecosystem for your commercial process' : 'Un ecosistema completo para tu proceso comercial'}</h2>
                    <p class="stripe-p">{solucion.paraQuien}</p>
                </div>

                <div class="stripe-bento-grid">
                    {solucion.blocks.map((block, idx) => (
                        <div class={`stripe-bento-card reveal ${idx === 0 || idx === 3 ? 'span-2' : ''}`}>
                            <div class="stripe-bento-inner">
                                <div class="stripe-bento-graphic">
                                    <SolucionBlockMockup slug={solucion.slug} index={idx} />
                                </div>
                                <div class="stripe-bento-text">
                                    <span class="stripe-bento-eyebrow">{block.eyebrow}</span>
                                    <h3 class="stripe-bento-title">{block.titulo}</h3>
                                    <p class="stripe-bento-desc">{block.copy}</p>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- ── STATS (Stripe Metric Cards) ── -->
        <section class="stripe-stats-section reveal">
            <div class="stripe-container">
                <div class="stripe-stats-grid">
                    {solucion.stats.map(st => (
                        <div class="stripe-stat-card">
                            <div class="stripe-stat-line"></div>
                            <div class="stripe-stat-val editorial">
                                {st.prefix}
                                {st.countup ? (
                                    <span class="count-up" data-val={st.countup} data-dec={st.decimals || 0}>{st.countup}</span>
                                ) : (
                                    st.valor
                                )}
                                {st.suffix}
                            </div>
                            <div class="stripe-stat-label">{st.label}</div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- ── TESTIMONIAL ── -->
        {solucion.resultado && (
            <section class="stripe-testimonial-section reveal">
                <div class="stripe-container">
                    <div class="stripe-testimonial-card">
                        <div class="stripe-quote-mark">“</div>
                        <h2 class="stripe-testimonial-text">{solucion.resultado.nota}</h2>
                        <div class="stripe-testimonial-author">
                            <div class="stripe-author-avatar"></div>
                            <div class="stripe-author-info">
                                <b>{solucion.resultado.cliente}</b>
                                <span>{isEn ? 'Verified Customer' : 'Cliente Verificado'}</span>
                            </div>
                        </div>
                        <div class="stripe-testimonial-metrics">
                            {solucion.resultado.metricas.map(m => (
                                <div>
                                    <b class="editorial">{m.valor}</b>
                                    <span>{m.label}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            </section>
        )}

        <!-- ── FAQ ── -->
        <section class="stripe-faq-section reveal">
            <div class="stripe-container">
                <h2 class="stripe-h2">{isEn ? 'Frequently asked questions' : 'Preguntas frecuentes'}</h2>
                <div class="stripe-faq-list">
                    {solucion.faqs.map(f => (
                        <details class="stripe-faq-item">
                            <summary>
                                <h3>{f.q}</h3>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                            </summary>
                            <div class="stripe-faq-a"><p>{f.a}</p></div>
                        </details>
                    ))}
                </div>
            </div>
        </section>

        <!-- ── CTA ── -->
        <section class="stripe-cta-section reveal">
            <div class="stripe-container">
                <div class="stripe-cta-card">
                    <h2 class="stripe-h2">{solucion.cta.titulo}</h2>
                    <p class="stripe-p">{solucion.cta.sub}</p>
                    <div class="stripe-actions">
                        <a href="/registro" class="stripe-btn-primary">
                            {isEn ? 'Start now' : 'Empezar ahora'}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </a>
                        <a href="/contacto" class="stripe-btn-ghost">
                            {isEn ? 'Contact sales' : 'Contactar a ventas'}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </a>
                    </div>
                </div>
            </div>
        </section>
        
        <Footer />
    </main>

    <PageAnims />
    
    <script>
        import { gsap } from 'gsap';
        
        // Efecto hover interactivo para las tarjetas Bento tipo Stripe
        const cards = document.querySelectorAll('.stripe-bento-card');
        
        cards.forEach(card => {
            card.addEventListener('mousemove', (e: Event) => {
                const mouseEvent = e as MouseEvent;
                const rect = card.getBoundingClientRect();
                const x = mouseEvent.clientX - rect.left;
                const y = mouseEvent.clientY - rect.top;
                
                (card as HTMLElement).style.setProperty('--mouse-x', `${x}px`);
                (card as HTMLElement).style.setProperty('--mouse-y', `${y}px`);
            });
        });
    </script>
</Layout>

<style>
    /* ════════════════════════════════════════════════════════════════
       VARIABLES & TOKENS GLOBALES (ESTILO CORD)
    ════════════════════════════════════════════════════════════════ */
    :root {
        --stripe-bg: #0a192f; /* Navy profundo de Cord */
        --stripe-text: #ffffff;
        --stripe-muted: #8a93a5;
        --stripe-accent: #10b981; /* Verde Cord */
        --stripe-accent-light: #34d399;
        --stripe-cyan: #3b82f6; /* Azul Cord */
        --stripe-border: rgba(255, 255, 255, 0.08);
        --stripe-card-bg: rgba(255, 255, 255, 0.03);
        --stripe-font-sans: var(--font-sans, "Inter", system-ui, sans-serif);
    }
    
    .stripe-main {
        background-color: var(--stripe-bg);
        color: var(--stripe-text);
        font-family: var(--stripe-font-sans);
        overflow-x: hidden;
    }
    
    .stripe-container {
        max-width: 1140px;
        margin: 0 auto;
        padding: 0 20px;
    }
    
    .editorial {
        font-family: var(--font-mono, ui-monospace, monospace);
        font-variant-numeric: tabular-nums;
        letter-spacing: -0.02em;
    }

    /* ════════════════════════════════════════════════════════════════
       CORD HERO (Grid & Gradients)
    ════════════════════════════════════════════════════════════════ */
    .stripe-hero {
        position: relative;
        padding: 160px 20px 80px;
        min-height: 85vh;
        display: flex;
        align-items: center;
        overflow: hidden;
    }
    
    .stripe-hero-bg {
        position: absolute;
        inset: -20%;
        z-index: 0;
        background: var(--stripe-bg);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        overflow: hidden;
    }
    
    .stripe-hero-grid {
        position: absolute;
        inset: 0;
        background-image: 
            linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
        background-size: 80px 80px;
        opacity: 0.5;
    }
    
    .stripe-hero-gradient {
        position: absolute;
        top: -30%;
        right: -10%;
        width: 80%;
        height: 150%;
        background: radial-gradient(ellipse at center, rgba(16, 185, 129, 0.15) 0%, rgba(59, 130, 246, 0.1) 40%, transparent 70%);
        filter: blur(80px);
    }
    
    .stripe-hero-content {
        position: relative;
        z-index: 10;
        max-width: 800px;
        margin: 0 auto;
    }
    
    .stripe-hero-tag {
        display: inline-block;
        color: var(--stripe-cyan);
        font-weight: 600;
        font-size: 0.9rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
    }
    
    .stripe-title {
        font-size: clamp(3rem, 6vw, 5rem);
        line-height: 1.05;
        font-weight: 700;
        letter-spacing: -0.04em;
        margin-bottom: 1.5rem;
        color: #fff;
    }
    
    .stripe-sub {
        font-size: clamp(1.1rem, 2vw, 1.4rem);
        line-height: 1.5;
        color: var(--stripe-muted);
        max-width: 650px;
        margin-bottom: 3rem;
        font-weight: 400;
    }
    
    .stripe-actions {
        display: flex;
        gap: 16px;
        align-items: center;
        flex-wrap: wrap;
    }
    
    .stripe-btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--stripe-accent);
        color: #fff;
        padding: 12px 24px;
        border-radius: 999px;
        font-size: 1rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s ease;
        box-shadow: 0 4px 14px 0 rgba(16, 185, 129, 0.39);
    }
    
    .stripe-btn-primary:hover {
        background: var(--stripe-accent-light);
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(16, 185, 129, 0.4);
    }
    
    .stripe-btn-primary svg {
        width: 16px;
        height: 16px;
        transition: transform 0.2s;
    }
    
    .stripe-btn-primary:hover svg {
        transform: translateX(3px);
    }
    
    .stripe-btn-ghost {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 24px;
        border-radius: 999px;
        color: #fff;
        font-weight: 600;
        font-size: 1rem;
        text-decoration: none;
        background: rgba(255,255,255,0.1);
        transition: background 0.2s;
    }
    
    .stripe-btn-ghost:hover {
        background: rgba(255,255,255,0.15);
    }
    
    .stripe-btn-ghost svg {
        width: 16px;
        height: 16px;
        transition: transform 0.2s;
    }
    
    .stripe-btn-ghost:hover svg {
        transform: translateX(3px);
    }

    /* ════════════════════════════════════════════════════════════════
       LOGO CLOUD
    ════════════════════════════════════════════════════════════════ */
    .stripe-clients {
        padding: 4rem 0;
        position: relative;
        z-index: 10;
    }
    
    .stripe-clients-title {
        text-align: center;
        color: var(--stripe-muted);
        font-size: 0.95rem;
        font-weight: 500;
        margin-bottom: 2rem;
    }
    
    .stripe-logo-grid {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 2rem;
        opacity: 0.6;
    }
    
    .stripe-logo {
        font-family: var(--font-mono);
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: #fff;
    }

    /* ════════════════════════════════════════════════════════════════
       BENTO GRID
    ════════════════════════════════════════════════════════════════ */
    .stripe-bento-section {
        padding: 6rem 0;
        position: relative;
        z-index: 10;
    }
    
    .stripe-section-header {
        margin-bottom: 4rem;
        max-width: 600px;
    }
    
    .stripe-h2 {
        font-size: clamp(2rem, 4vw, 2.75rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin-bottom: 1.5rem;
    }
    
    .stripe-p {
        font-size: 1.25rem;
        color: var(--stripe-muted);
        line-height: 1.5;
    }
    
    .stripe-bento-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
    }
    
    .stripe-bento-card {
        position: relative;
        background: var(--stripe-card-bg);
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid var(--stripe-border);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
    }
    
    .stripe-bento-card.span-2 {
        grid-column: span 2;
    }
    
    /* Interactive Hover Glow (Stripe signature) */
    .stripe-bento-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: radial-gradient(
            800px circle at var(--mouse-x, 0) var(--mouse-y, 0),
            rgba(255, 255, 255, 0.06),
            transparent 40%
        );
        z-index: 0;
        opacity: 0;
        transition: opacity 0.3s;
        pointer-events: none;
    }
    
    .stripe-bento-card:hover::before {
        opacity: 1;
    }
    
    .stripe-bento-inner {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 2.5rem;
    }
    
    .span-2 .stripe-bento-inner {
        flex-direction: row;
        align-items: center;
        gap: 4rem;
    }
    
    .stripe-bento-graphic {
        flex: 1;
        min-height: 250px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
    }
    
    .stripe-bento-text {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    
    .stripe-bento-eyebrow {
        color: var(--stripe-cyan);
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 1rem;
    }
    
    .stripe-bento-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: #fff;
        line-height: 1.2;
        margin-bottom: 1rem;
        letter-spacing: -0.02em;
    }
    
    .stripe-bento-desc {
        color: var(--stripe-muted);
        line-height: 1.5;
        font-size: 1.1rem;
    }

    /* ════════════════════════════════════════════════════════════════
       STATS
    ════════════════════════════════════════════════════════════════ */
    .stripe-stats-section {
        padding: 4rem 0;
        position: relative;
        z-index: 10;
    }
    
    .stripe-stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        border-top: 1px solid var(--stripe-border);
        padding-top: 4rem;
    }
    
    .stripe-stat-card {
        display: flex;
        flex-direction: column;
    }
    
    .stripe-stat-line {
        width: 30px;
        height: 2px;
        background: var(--stripe-accent);
        margin-bottom: 1.5rem;
    }
    
    .stripe-stat-val {
        font-size: 3rem;
        font-weight: 700;
        line-height: 1;
        margin-bottom: 0.75rem;
        color: #fff;
    }
    
    .stripe-stat-label {
        font-size: 1rem;
        color: var(--stripe-muted);
        line-height: 1.4;
    }

    /* ════════════════════════════════════════════════════════════════
       TESTIMONIAL
    ════════════════════════════════════════════════════════════════ */
    .stripe-testimonial-section {
        padding: 6rem 0;
        position: relative;
        z-index: 10;
    }
    
    .stripe-testimonial-card {
        background: var(--stripe-card-bg);
        border: 1px solid var(--stripe-border);
        border-radius: 24px;
        padding: 4rem;
        position: relative;
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
    }
    
    .stripe-quote-mark {
        font-size: 6rem;
        color: var(--stripe-accent);
        line-height: 0;
        margin-bottom: 2rem;
        font-family: serif;
    }
    
    .stripe-testimonial-text {
        font-size: clamp(1.5rem, 3vw, 2.5rem);
        font-weight: 500;
        line-height: 1.3;
        margin-bottom: 3rem;
        letter-spacing: -0.02em;
    }
    
    .stripe-testimonial-author {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 3rem;
    }
    
    .stripe-author-avatar {
        width: 48px;
        height: 48px;
        background: #fff;
        border-radius: 50%;
        opacity: 0.9;
    }
    
    .stripe-author-info b {
        display: block;
        font-size: 1.1rem;
        color: #fff;
    }
    
    .stripe-author-info span {
        font-size: 0.9rem;
        color: var(--stripe-muted);
    }
    
    .stripe-testimonial-metrics {
        display: flex;
        gap: 3rem;
        border-top: 1px solid var(--stripe-border);
        padding-top: 2rem;
    }
    
    .stripe-testimonial-metrics b {
        display: block;
        font-size: 2rem;
        color: #fff;
        margin-bottom: 0.25rem;
    }
    
    .stripe-testimonial-metrics span {
        font-size: 0.9rem;
        color: var(--stripe-muted);
    }

    /* ════════════════════════════════════════════════════════════════
       FAQ
    ════════════════════════════════════════════════════════════════ */
    .stripe-faq-section {
        padding: 6rem 0;
        position: relative;
        z-index: 10;
    }
    
    .stripe-faq-list {
        max-width: 800px;
        margin-top: 3rem;
    }
    
    .stripe-faq-item {
        border-bottom: 1px solid var(--stripe-border);
    }
    
    .stripe-faq-item summary {
        padding: 1.5rem 0;
        cursor: pointer;
        list-style: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .stripe-faq-item summary::-webkit-details-marker {
        display: none;
    }
    
    .stripe-faq-item summary h3 {
        font-size: 1.1rem;
        font-weight: 600;
        margin: 0;
        color: #fff;
    }
    
    .stripe-faq-item summary svg {
        width: 20px;
        height: 20px;
        color: var(--stripe-muted);
        transition: transform 0.2s ease;
    }
    
    .stripe-faq-item[open] summary svg {
        transform: rotate(180deg);
    }
    
    .stripe-faq-a {
        padding-bottom: 1.5rem;
        color: var(--stripe-muted);
        line-height: 1.6;
    }

    /* ════════════════════════════════════════════════════════════════
       CTA
    ════════════════════════════════════════════════════════════════ */
    .stripe-cta-section {
        padding: 6rem 0 10rem;
        position: relative;
        z-index: 10;
    }
    
    .stripe-cta-card {
        background: radial-gradient(circle at top, rgba(16, 185, 129, 0.1), transparent 50%), var(--stripe-card-bg);
