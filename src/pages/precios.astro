        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--color-text-muted);
        margin-top: 0.35rem;
        flex-shrink: 0;
    }
    .pr-roi-step label {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    /* Range slider */
    .pr-roi-range-wrap { display: flex; flex-direction: column; gap: 4px; }
    .pr-roi-range-labels { display: flex; justify-content: space-between; font-size: 0.7rem; color: var(--color-text-muted); padding: 0 2px; }
    .pr-roi-range {
        -webkit-appearance: none;
        width: 100%;
        height: 4px;
        border-radius: 100px;
        background: var(--color-border);
        outline: none;
        cursor: pointer;
        accent-color: var(--color-blue-deep);
    }
    .pr-roi-range::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: var(--color-blue-deep);
        box-shadow: 0 1px 4px rgba(10,25,47,0.35);
        cursor: pointer;
        transition: transform 0.15s;
    }
    .pr-roi-range::-webkit-slider-thumb:hover { transform: scale(1.15); }
    .pr-roi-range::-moz-range-thumb {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: var(--color-blue-deep);
        border: none;
        cursor: pointer;
    }

    /* ════════ COMPARADOR ════════ */
    .pr-compare { max-width: 1080px; margin: 0 auto; padding: 3rem 5%; }
    @media (min-width: 860px) { .pr-compare { padding: 4rem 5%; } }
    .pr-compare-head { text-align: center; margin-bottom: 2rem; }
    @media (min-width: 860px) { .pr-compare-head { margin-bottom: 3rem; } }
    
    .pr-table-scroll { 
        overflow-x: auto; -webkit-overflow-scrolling: touch; 
        border-radius: 12px; padding-bottom: 1rem;
        box-shadow: inset -15px 0 15px -15px rgba(0,0,0,0.05); /* Ayuda visual para scroll horizontal */
    }
    @media (min-width: 860px) { .pr-table-scroll { border-radius: 18px; padding-bottom: 0; box-shadow: none; } }
    
    .pr-table { width: 100%; border-collapse: collapse; min-width: 920px; }
    .pr-table thead th { position: sticky; top: 0; }
    .pr-th-feat { width: 28%; }
    .pr-th-plan {
        padding: 1rem 0.7rem; text-align: center; vertical-align: bottom;
        border-bottom: 2px solid var(--color-border);
    }
    .pr-th-plan b { display: block; font-size: 1rem; font-weight: 700; color: var(--color-text); }
    .pr-th-plan span { display: block; font-size: 0.76rem; color: var(--color-text-muted); margin-top: 2px; }
    .pr-th-plan.is-featured { background: var(--color-bg-soft); border-radius: 14px 14px 0 0; border-bottom-color: var(--color-blue-deep); }
    .pr-th-plan.is-featured b { color: var(--color-blue-deep); }

    .pr-group-row td {
        padding: 1.4rem 1rem 0.6rem;
        font-size: 0.66rem; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase;
        color: #99a2af;
    }
    .pr-cell-feat { padding: 0.85rem 1rem; font-size: 0.88rem; color: var(--color-text); border-bottom: 1px solid var(--color-border); }
    .pr-cell-val {
        padding: 0.85rem 0.7rem; text-align: center; border-bottom: 1px solid var(--color-border);
        font-size: 0.82rem; color: var(--color-text); font-weight: 600;
    }
    .pr-cell-val.is-featured { background: var(--color-bg-soft); }
    .pr-yes {
        display: inline-flex; width: 22px; height: 22px; border-radius: 50%;
        background: rgba(10,25,47,0.08); color: #0a192f;
        align-items: center; justify-content: center;
    }
    .pr-yes svg { width: 12px; height: 12px; }
    .pr-no { color: #c2c8d0; }
    .pr-txt { font-size: 0.82rem; }

    /* ── Tabla: fila de botones al fondo (Linear / pill shimmer) ── */
    .pr-tfoot-row { border-top: 2px solid var(--color-border); }
    .pr-tfoot-empty { padding: 2rem 1rem 1.5rem; }
    .pr-tfoot-cell { padding: 2rem 0.7rem 1.5rem; text-align: center; vertical-align: top; }
    .pr-tfoot-cell.is-featured { background: var(--color-bg-soft); border-radius: 0 0 14px 14px; }
    .pr-tfoot-btn {
        position: relative; overflow: hidden;
        display: inline-block; width: 100%;
        font-size: 0.85rem; font-weight: 600;
        padding: 11px 12px; border-radius: 999px;
        text-decoration: none; text-align: center;
        transition: transform 0.22s var(--ease-spring), box-shadow 0.22s, background 0.22s, color 0.22s;
    }
    .pr-tfoot-btn::after {
        content: '';
        position: absolute; inset: 0;
        background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.18) 50%, transparent 60%);
        transform: translateX(-110%);
        transition: transform 0.55s cubic-bezier(0.16,1,0.3,1);
        pointer-events: none;
    }
    .pr-tfoot-btn:hover::after { transform: translateX(110%); }
    .pr-tfoot-btn:active { transform: scale(0.97); }
    .pr-tfoot-btn-solid { background: #111827; color: #fff; border: 1px solid transparent; }
    .pr-tfoot-btn-solid:hover { background: #0a192f; transform: translateY(-1px); box-shadow: 0 6px 18px rgba(10,25,47,0.3); }
    .pr-tfoot-sales {
        display: block; margin-top: 0.5rem; font-size: 0.76rem;
        color: var(--color-text-muted); text-decoration: none; transition: color 0.2s;
    }
    .pr-tfoot-sales:hover { color: var(--color-text); }

    /* ── FAQ padding override ── */
    :global(.pr-faq-acc) { padding: 3rem 5% 7rem; }
    @media (min-width: 860px) { :global(.pr-faq-acc) { padding: 4rem 5% 8rem; } }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const isEn = document.documentElement.lang === 'en';

        // ── Toggle mensual/anual ──
        const toggles = document.querySelectorAll('.billing-toggle-checkbox');

        toggles.forEach(toggle => {
            toggle.addEventListener('change', (e) => {
                const isAnnual = (e.target as HTMLInputElement).checked;

                // Sync all toggles
                toggles.forEach(t => {
                    if (t !== e.target) {
                        (t as HTMLInputElement).checked = isAnnual;
                    }
                });

                // Update prices
                document.querySelectorAll('.plan-price').forEach(priceDiv => {
                    const monthly = priceDiv.getAttribute('data-monthly');
                    const annual = priceDiv.getAttribute('data-annual');
                    if (monthly && annual) {
                        const valSpan = priceDiv.querySelector('.plan-amount-val');
                        if (valSpan) valSpan.textContent = isAnnual ? annual : monthly;
                    }
                });

                // Update CTA hrefs (plan cards + tfoot)
                const cycle = isAnnual ? 'anual' : 'mensual';
                document.querySelectorAll('[data-base-href]').forEach(cta => {
                    const baseHref = cta.getAttribute('data-base-href');
                    if (baseHref) {
                        cta.setAttribute('href', `${baseHref}&cycle=${cycle}`);
                    }
                });
            });
        });

        // ── Calculadora de valor ──
        const qty        = document.getElementById('roi-qty') as HTMLInputElement | null;
        const ticket     = document.getElementById('roi-ticket') as HTMLInputElement | null;
        const qtyRange   = document.getElementById('roi-qty-range') as HTMLInputElement | null;
        const tickRange  = document.getElementById('roi-ticket-range') as HTMLInputElement | null;
        const pipeline   = document.getElementById('roi-pipeline');
        const pct        = document.getElementById('roi-pct');
        const foot       = document.getElementById('roi-foot');
        const PRO        = isEn ? 30 : 590;

        const calc = () => {
            const q = Math.max(0, parseFloat(qty?.value || '0') || 0);
            const t = Math.max(0, parseFloat(ticket?.value || '0') || 0);
            const total = q * t;
            if (pipeline) pipeline.textContent = '$' + new Intl.NumberFormat('es-MX').format(Math.round(total));
            const p = total > 0 ? (PRO / total) * 100 : 0;
            if (pct) pct.textContent = total > 0 ? p.toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + '%' : '—';
            if (foot) {
                const veces = t > 0 ? Math.max(1, Math.round(t / PRO)) : 0;
                foot.textContent = t > 0
                    ? (isEn ? `A single extra quote per month pays for the plan ~${veces} times.` : `Una sola cotización extra al mes paga el plan ~${veces} veces.`)
                    : (isEn ? 'Enter your average ticket to see the math.' : 'Ingresa tu ticket promedio para ver la cuenta.');
            }
        };

        // Sync sliders → number inputs
        qtyRange?.addEventListener('input', () => {
            if (qty) { qty.value = qtyRange.value; calc(); }
        });
        tickRange?.addEventListener('input', () => {
            if (ticket) { ticket.value = tickRange.value; calc(); }
        });
        // Sync number inputs → sliders
        qty?.addEventListener('input', () => {
            if (qtyRange) qtyRange.value = qty.value;
            calc();
        });
        ticket?.addEventListener('input', () => {
            if (tickRange) tickRange.value = ticket.value;
            calc();
        });
        calc();

        // ── Aurora viajera en tarjetas de plan ──
        const cards = [...document.querySelectorAll<HTMLElement>('.plan')];
        const featured = document.querySelector<HTMLElement>('.plan-featured');
        const gridWrap = document.querySelector<HTMLElement>('.pr-grid-wrap');

        function setAurora(active: HTMLElement | null) {
            cards.forEach(c => c.classList.remove('aurora-active'));
            active?.classList.add('aurora-active');
        }

        // Predeterminado: plan destacado
        setAurora(featured);

        cards.forEach(card => {
            card.addEventListener('mouseenter', () => setAurora(card));
        });

        // Al salir del grupo de tarjetas → vuelve al destacado
        gridWrap?.addEventListener('mouseleave', () => setAurora(featured));
    });
</script>
