    .pr-roi-sub { font-size: clamp(1rem, 4vw, 1.02rem); line-height: 1.65; color: var(--color-text-muted); margin: 0 0 2rem; }
    .pr-roi-fields { display: flex; flex-direction: column; gap: 1.1rem; width: 100%; }
    @media (min-width: 860px) { .pr-roi-fields { max-width: 380px; } }
    .pr-roi-fields label { display: flex; flex-direction: column; gap: 0.5rem; }
