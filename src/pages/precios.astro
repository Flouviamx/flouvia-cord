<script>
    document.addEventListener('DOMContentLoaded', () => {
        const isEn = document.documentElement.lang === 'en';
        
        // ── Toggle mensual/anual ──
        const toggles = document.querySelectorAll('.billing-toggle-checkbox');
        
        toggles.forEach(toggle => {
            toggle.addEventListener('change', (e) => {
                const isAnnual = (e.target as HTMLInputElement).checked;
                
                // Sync all toggles
                toggles.forEach(t => {
                    if (t !== e.target) {
                        (t as HTMLInputElement).checked = isAnnual;
                    }
                });

                // Update prices
                document.querySelectorAll('.plan-price').forEach(priceDiv => {
                    const monthly = priceDiv.getAttribute('data-monthly');
                    const annual = priceDiv.getAttribute('data-annual');
                    if (monthly && annual) {
                        const valSpan = priceDiv.querySelector('.plan-amount-val');
                        if (valSpan) valSpan.textContent = isAnnual ? annual : monthly;
                    }
                });

                // Update CTA hrefs
                document.querySelectorAll('.plan-cta').forEach(cta => {
                    const baseHref = cta.getAttribute('data-base-href');
                    if (baseHref) {
                        const cycle = isAnnual ? 'anual' : 'mensual';
                        cta.setAttribute('href', `${baseHref}&cycle=${cycle}`);
                    }
                });
            });
        });

        // ── Calculadora de valor ──
        const qty = document.getElementById('roi-qty') as HTMLInputElement | null;
        const ticket = document.getElementById('roi-ticket') as HTMLInputElement | null;
        const pipeline = document.getElementById('roi-pipeline');
        const pct = document.getElementById('roi-pct');
        const foot = document.getElementById('roi-foot');
        const PRO = isEn ? 30 : 590;
        const calc = () => {
            const q = Math.max(0, parseFloat(qty?.value || '0') || 0);
            const t = Math.max(0, parseFloat(ticket?.value || '0') || 0);
            const total = q * t;
            if (pipeline) pipeline.textContent = '$' + new Intl.NumberFormat('es-MX').format(Math.round(total));
            const p = total > 0 ? (PRO / total) * 100 : 0;
            if (pct) pct.textContent = total > 0 ? p.toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + '%' : '—';
            if (foot) {
                const veces = t > 0 ? Math.max(1, Math.round(t / PRO)) : 0;
                foot.textContent = t > 0
                    ? (isEn ? `A single extra quote per month pays for the plan ~${veces} times.` : `Una sola cotización extra al mes paga el plan ~${veces} veces.`)
                    : (isEn ? 'Enter your average ticket to see the math.' : 'Ingresa tu ticket promedio para ver la cuenta.');
            }
        };
        qty?.addEventListener('input', calc);
        ticket?.addEventListener('input', calc);
        calc();
    });
</script>
