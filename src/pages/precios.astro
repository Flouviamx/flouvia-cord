    .pr-roi-split b { font-size: 1.3rem; font-weight: 600; }
    @media (min-width: 860px) { .pr-roi-split b { font-size: 1.5rem; } }
    .pr-roi-split b i { font-style: normal; font-size: 0.8rem; color: rgba(255,255,255,0.5); }
    .pr-roi-foot { font-size: 0.84rem; color: rgba(255,255,255,0.6); margin: 1.2rem 0 1.6rem; line-height: 1.5; }
    .pr-roi-cta {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        font-size: 0.9rem;
        font-weight: 600;
        color: #fff;
