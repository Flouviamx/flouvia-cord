<script>
    // Tabs de framework + copiar (sin dependencias).
    function initElTabs() {
        const wrap = document.querySelector('[data-el-tabs]');
        if (!wrap) return;
        const tabs = Array.from(wrap.querySelectorAll<HTMLElement>('.el-tab'));
        const panels = Array.from(wrap.querySelectorAll<HTMLElement>('.el-panel'));

        const show = (id: string) => {
            tabs.forEach((t) => t.classList.toggle('active', t.dataset.tab === id));
            panels.forEach((p) => {
                const on = p.dataset.panel === id;
                p.classList.toggle('active', on);
                p.hidden = !on;
            });
        };
        tabs.forEach((t) => t.addEventListener('click', () => show(t.dataset.tab!)));

        const copyBtn = wrap.querySelector<HTMLButtonElement>('[data-copy]');
        copyBtn?.addEventListener('click', async () => {
            const active = wrap.querySelector<HTMLElement>('.el-panel.active code');
            try {
                await navigator.clipboard.writeText(active?.textContent || '');
                const label = copyBtn.querySelector('span');
                copyBtn.classList.add('done');
                if (label) label.textContent = document.documentElement.lang === 'en' ? 'Copied!' : '¡Copiado!';
                setTimeout(() => { copyBtn.classList.remove('done'); if (label) label.textContent = document.documentElement.lang === 'en' ? 'Copy' : 'Copiar'; }, 2000);
            } catch {}
        });
    }
    // Copiar el comando `npm install` del hero.
    function initInstallCmd() {
        const box = document.querySelector('[data-install-cmd]');
        if (!box) return;
        const btn = box.querySelector<HTMLButtonElement>('.el-cmd-copy');
        btn?.addEventListener('click', async () => {
            try {
                await navigator.clipboard.writeText('npm install @flouviahq/elements');
                btn.classList.add('done');
                setTimeout(() => btn.classList.remove('done'), 2000);
            } catch {}
        });
    }

    function init() { initElTabs(); initInstallCmd(); }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
</script>
