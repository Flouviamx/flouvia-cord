---
// Cómo funciona — Página dedicada al flujo completo de Cord.
// Mejorada con sección de características clave y diseño premium.
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/landing/Nav.astro';
import Footer from '../components/landing/Footer.astro';
import PageAnims from '../components/landing/PageAnims.astro';
import Steps from '../components/landing/Steps.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
const t = useTranslations(lang);
const l = (p: string) => lang === 'es' ? p : `/en${p === '/' ? '' : p}`;

const title = isEn ? "How it works | Cord" : "Cómo funciona | Cord";
const description = isEn 
    ? "Discover how Cord works. From first contact to CFDI without friction, all in a single platform designed for B2B."
    : "Descubre cómo funciona Cord. Del primer contacto al CFDI sin fricción, todo en una sola plataforma diseñada para B2B.";
---

<Layout title={title} description={description}>
    <Nav />
    <main>
        <section class="cf-hero">
            <div class="cf-mesh" aria-hidden="true"></div>
            <div class="cf-hero-inner">
                <p class="cf-eyebrow reveal">{isEn ? 'HOW CORD WORKS' : 'CÓMO FUNCIONA CORD'}</p>
                <h1 class="cf-title masked-title" set:html={isEn ? 'Sell faster. Get paid on time.' : 'Vende más rápido. Cobra a tiempo.'} />
                <p class="cf-sub reveal">
                    {isEn 
                        ? 'Forget static PDFs, endless email threads, and double data entry. Cord optimizes the entire B2B sales cycle so you can focus on closing deals.'
                        : 'Olvídate de los PDFs estáticos, los hilos interminables de correo y la doble captura. Cord optimiza todo el ciclo de ventas B2B para que tú te enfoques en cerrar tratos.'}
                </p>
                <div class="cf-hero-actions reveal">
                    <a href={l("/registro")} class="cf-btn-primary">{isEn ? 'Start for free' : 'Empieza gratis'}</a>
                    <a href={l("/q/demo")} class="cf-btn-secondary">{isEn ? 'View interactive demo' : 'Ver demo interactiva'}</a>
                </div>
            </div>
            
            <!-- Mockup flotante en el hero -->
            <div class="cf-hero-mockup reveal">
                <div class="cf-mockup-glass">
                    <div class="cf-mockup-header">
                        <div class="cf-dots"><span></span><span></span><span></span></div>
                        <div class="cf-url">cordhq.app/quote/xyz</div>
                    </div>
                    <div class="cf-mockup-body">
                        <div class="cf-skeleton-line title"></div>
                        <div class="cf-skeleton-line"></div>
                        <div class="cf-skeleton-line short"></div>
                        <div class="cf-mockup-btn">{isEn ? 'Approve quote' : 'Aprobar cotización'}</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Componente existente de pasos -->
        <div class="cf-steps-wrapper">
            <Steps />
        </div>

        <!-- Nueva sección de Características Clave -->
        <section class="cf-features">
            <div class="cf-features-inner">
                <div class="cf-features-head reveal">
                    <h2 class="cf-h2 masked-title">{isEn ? 'Everything you need, without the complexity of an ERP.' : 'Todo lo que necesitas, sin la complejidad de un ERP.'}</h2>
                    <p class="cf-p">{isEn ? 'Designed for the speed of modern sales, with the financial rigor your operation demands.' : 'Diseñado para la velocidad de las ventas modernas, con el rigor financiero que exige tu operación.'}</p>
                </div>

                <div class="cf-grid">
                    <article class="cf-card reveal">
                        <div class="cf-card-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        </div>
                        <h3>{isEn ? 'One-click approvals' : 'Aprobaciones con un clic'}</h3>
                        <p>{isEn 
                            ? 'Your client receives a unique link. Without passwords or signups, they can review the details, accept the terms, and approve the quote instantly from their phone.'
                            : 'Tu cliente recibe un enlace único. Sin contraseñas ni registros, puede revisar el detalle, aceptar los términos y aprobar la cotización al instante desde su celular.'}</p>
                    </article>

                    <article class="cf-card reveal">
                        <div class="cf-card-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                        </div>
                        <h3>{isEn ? 'Real-time notifications' : 'Notificaciones en tiempo real'}</h3>
                        <p>{isEn 
                            ? 'Stop asking "Did you check my email?". Cord alerts you the exact moment your client opens the quote so you can call at the perfect time.'
                            : 'Deja de preguntar "¿Ya pudiste revisar mi correo?". Cord te avisa exactamente en el momento en que tu cliente abre la cotización para que llames en el momento perfecto.'}</p>
                    </article>

                    <article class="cf-card reveal">
                        <div class="cf-card-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
                        </div>
                        <h3>{isEn ? 'Catalog and dynamic pricing' : 'Catálogo y Precios dinámicos'}</h3>
                        <p>{isEn 
                            ? 'Manage multiple price lists or negotiated prices per client. If you update a base price, the rules apply automatically for everyone.'
                            : 'Maneja múltiples listas de precios o precios negociados por cliente. Si actualizas un precio base, las reglas se aplican automáticamente para todos.'}</p>
                    </article>

                    <article class="cf-card reveal">
                        <div class="cf-card-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                        </div>
                        <h3>{isEn ? 'Native e-invoicing (CFDI 4.0)' : 'Facturación nativa (CFDI 4.0)'}</h3>
                        <p>{isEn 
                            ? 'Once the project is delivered or shipped, turn the approved quote into a valid SAT invoice in a couple of clicks, without typing errors.'
                            : 'Una vez que el proyecto se entrega o el producto se envía, convierte la cotización aprobada en una factura válida ante el SAT en un par de clics, sin errores de captura.'}</p>
                    </article>
                </div>
            </div>
        </section>
    </main>

    <Footer
        ctaTitle={isEn ? 'Ready to professionalize your sales?' : '¿Listo para profesionalizar tus ventas?'}
        ctaSub={isEn ? 'Start for free today — 5 active quotes per month, no credit card.' : 'Empieza gratis hoy — 5 cotizaciones activas al mes, sin tarjeta de crédito.'}
    />
    <PageAnims />
</Layout>

<style>
    /* Hero Section - Mobile First */
    .cf-hero {
        position: relative;
        padding: 8rem 5% 4rem;
        text-align: center;
        overflow: clip;
        background: #050b14; /* Match steps background */
    }
    @media (min-width: 860px) {
        .cf-hero { padding: 12rem 5% 8rem; }
    }
    :global(html[data-theme="light"]) .cf-hero {
        background: #f8fafc;
    }

    .cf-mesh {
        position: absolute; inset: -20% -10% auto;
        height: 100%;
        background:
            radial-gradient(ellipse 50% 60% at 28% 20%, rgba(10,37,218,0.15) 0%, transparent 60%),
            radial-gradient(ellipse 44% 54% at 76% 12%, rgba(10,37,218,0.1) 0%, transparent 60%);
        pointer-events: none;
    }
    
    .cf-hero-inner { position: relative; z-index: 2; max-width: 880px; margin: 0 auto; }
    
    .cf-eyebrow {
        font-size: 0.75rem; font-weight: 800; letter-spacing: 2px;
        text-transform: uppercase; color: var(--color-blue-deep); margin: 0 0 1rem;
    }
    @media (min-width: 860px) {
        .cf-eyebrow { margin: 0 0 1.4rem; }
    }
    :global(html[data-theme="dark"]) .cf-eyebrow { color: #60a5fa; }

    .cf-title {
        font-size: clamp(2.4rem, 8vw, 4.8rem);
        font-weight: 800; line-height: 1.05; letter-spacing: -0.035em;
        color: #fff; margin: 0 0 1.2rem;
    }
    @media (min-width: 860px) {
        .cf-title { margin: 0 0 1.5rem; }
    }
    :global(html[data-theme="light"]) .cf-title { color: #111827; }

    .cf-sub {
        font-size: clamp(1rem, 4vw, 1.15rem);
        line-height: 1.6; color: rgba(255,255,255,0.7);
        max-width: 650px; margin: 0 auto 2rem;
    }
    @media (min-width: 860px) {
        .cf-sub { margin: 0 auto 2.5rem; }
    }
    :global(html[data-theme="light"]) .cf-sub { color: #4b5563; }

    .cf-hero-actions {
        display: flex; gap: 1rem; flex-direction: column; justify-content: center;
        margin-bottom: 3.5rem;
    }
    @media (min-width: 600px) {
        .cf-hero-actions { flex-direction: row; margin-bottom: 4rem; }
    }
    
    .cf-btn-primary {
        background: var(--color-blue-deep); color: #fff;
        padding: 14px 28px; border-radius: 8px;
        font-weight: 600; text-decoration: none;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    :global(html[data-theme="dark"]) .cf-btn-primary { background: #3b82f6; }
    .cf-btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(10,37,218,0.3);
    }
    
    .cf-btn-secondary {
        background: rgba(255,255,255,0.1); color: #fff;
        padding: 14px 28px; border-radius: 8px;
        font-weight: 600; text-decoration: none;
        backdrop-filter: blur(10px);
        transition: background 0.2s;
    }
    :global(html[data-theme="light"]) .cf-btn-secondary {
        background: rgba(0,0,0,0.05); color: #111827;
    }
    .cf-btn-secondary:hover { background: rgba(255,255,255,0.15); }
    :global(html[data-theme="light"]) .cf-btn-secondary:hover { background: rgba(0,0,0,0.1); }

    /* Floating Mockup */
    .cf-hero-mockup {
        position: relative; z-index: 1;
        max-width: 700px; margin: 0 auto;
        transform: perspective(1000px) rotateX(8deg);
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        border-radius: 12px;
    }
    @media (min-width: 860px) {
        .cf-hero-mockup { border-radius: 16px; box-shadow: 0 30px 60px rgba(0,0,0,0.4); }
    }
    :global(html[data-theme="light"]) .cf-hero-mockup { box-shadow: 0 20px 40px rgba(10,37,218,0.15); }
    @media (min-width: 860px) {
        :global(html[data-theme="light"]) .cf-hero-mockup { box-shadow: 0 30px 60px rgba(10,37,218,0.15); }
    }
    
    .cf-mockup-glass {
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        overflow: hidden;
    }
    @media (min-width: 860px) {
        .cf-mockup-glass { border-radius: 16px; }
    }
    :global(html[data-theme="light"]) .cf-mockup-glass {
        background: rgba(255, 255, 255, 0.8);
        border: 1px solid rgba(0,0,0,0.1);
    }

    .cf-mockup-header {
        display: flex; align-items: center; justify-content: center;
        padding: 10px 16px; background: rgba(0,0,0,0.2);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        position: relative;
    }
    @media (min-width: 860px) {
        .cf-mockup-header { padding: 12px 20px; }
    }
    :global(html[data-theme="light"]) .cf-mockup-header {
        background: rgba(0,0,0,0.03); border-bottom: 1px solid rgba(0,0,0,0.05);
    }
    
    .cf-dots { position: absolute; left: 16px; display: flex; gap: 5px; }
    @media (min-width: 860px) { .cf-dots { left: 20px; gap: 6px; } }
    .cf-dots span { width: 8px; height: 8px; border-radius: 50%; background: #4b5563; }
    @media (min-width: 860px) { .cf-dots span { width: 10px; height: 10px; } }
    .cf-dots span:nth-child(1) { background: #ef4444; }
    .cf-dots span:nth-child(2) { background: #eab308; }
    .cf-dots span:nth-child(3) { background: #22c55e; }
    
    .cf-url { font-size: 0.65rem; color: rgba(255,255,255,0.5); font-family: monospace; }
    @media (min-width: 860px) { .cf-url { font-size: 0.75rem; } }
    :global(html[data-theme="light"]) .cf-url { color: rgba(0,0,0,0.5); }

    .cf-mockup-body { padding: 24px; text-align: left; }
    @media (min-width: 860px) { .cf-mockup-body { padding: 40px; } }
    
    .cf-skeleton-line { height: 12px; background: rgba(255,255,255,0.1); border-radius: 4px; margin-bottom: 12px; width: 100%; }
    .cf-skeleton-line.title { height: 20px; width: 60%; margin-bottom: 18px; }
    .cf-skeleton-line.short { width: 80%; }
    @media (min-width: 860px) {
        .cf-skeleton-line { height: 16px; margin-bottom: 16px; }
        .cf-skeleton-line.title { height: 28px; margin-bottom: 24px; }
    }
    :global(html[data-theme="light"]) .cf-skeleton-line { background: rgba(0,0,0,0.05); }
    
    .cf-mockup-btn {
        margin-top: 24px; display: inline-block;
        background: var(--color-ok, #10b981); color: #fff;
        padding: 10px 20px; border-radius: 6px;
        font-weight: 600; font-size: 0.85rem;
    }
    @media (min-width: 860px) {
        .cf-mockup-btn { margin-top: 32px; padding: 12px 24px; font-size: 0.9rem; }
    }

    /* Features Section - Mobile First */
    .cf-features {
        padding: 5rem 5%;
        background: #fff;
    }
    @media (min-width: 860px) {
        .cf-features { padding: 8rem 5%; }
    }
    :global(html[data-theme="dark"]) .cf-features { background: #050b14; }

    .cf-features-inner { max-width: 1100px; margin: 0 auto; }
    
    .cf-features-head { text-align: center; margin-bottom: 3.5rem; max-width: 700px; margin-left: auto; margin-right: auto; }
    @media (min-width: 860px) { .cf-features-head { margin-bottom: 5rem; } }
    
    .cf-h2 {
        font-size: clamp(2rem, 6vw, 3rem);
        font-weight: 800; line-height: 1.1; letter-spacing: -0.03em;
        color: #111827; margin: 0 0 1rem;
    }
    @media (min-width: 860px) { .cf-h2 { margin: 0 0 1.2rem; } }
    :global(html[data-theme="dark"]) .cf-h2 { color: #fff; }
    
    .cf-p { font-size: clamp(1rem, 4vw, 1.15rem); color: #4b5563; line-height: 1.6; }
    :global(html[data-theme="dark"]) .cf-p { color: #9ca3af; }

    .cf-grid {
        display: grid; grid-template-columns: 1fr;
        gap: 1.5rem;
    }
    @media (min-width: 768px) {
        .cf-grid { grid-template-columns: repeat(2, 1fr); gap: 2rem; }
    }

    .cf-card {
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        padding: 2rem;
        border-radius: 16px;
        transition: transform 0.3s var(--ease-spring);
    }
    @media (min-width: 860px) {
        .cf-card { padding: 3rem; border-radius: 20px; }
    }
    :global(html[data-theme="dark"]) .cf-card {
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.05);
    }
    .cf-card:hover { transform: translateY(-4px); }

    .cf-card-icon {
        width: 48px; height: 48px;
        background: rgba(10,37,218,0.1);
        color: var(--color-blue-deep);
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 1.2rem;
    }
    @media (min-width: 860px) {
        .cf-card-icon { width: 54px; height: 54px; border-radius: 14px; margin-bottom: 1.5rem; }
    }
    :global(html[data-theme="dark"]) .cf-card-icon {
        background: rgba(59,130,246,0.15); color: #60a5fa;
    }
    .cf-card-icon svg { width: 24px; height: 24px; }
    @media (min-width: 860px) { .cf-card-icon svg { width: 28px; height: 28px; } }

    .cf-card h3 {
        font-size: 1.25rem; font-weight: 700; color: #111827; margin: 0 0 0.8rem;
    }
    @media (min-width: 860px) {
        .cf-card h3 { font-size: 1.4rem; margin: 0 0 1rem; }
    }
    :global(html[data-theme="dark"]) .cf-card h3 { color: #fff; }
    
    .cf-card p {
        font-size: 0.95rem; color: #4b5563; line-height: 1.6; margin: 0;
    }
    @media (min-width: 860px) {
        .cf-card p { font-size: 1rem; }
    }
    :global(html[data-theme="dark"]) .cf-card p { color: #9ca3af; }
</style>
