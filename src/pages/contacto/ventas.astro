---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl } from '../../i18n/utils';
import PriceAuroraBg from '../../components/landing/PriceAuroraBg.jsx';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';

const title = isEn ? "Contact Sales | Cord" : "Contacto de Ventas | Cord";
const description = isEn
    ? "Talk to the Cord team. Start a personalized demo in under 24 hours."
    : "Habla con el equipo de Cord. Empieza tu demo personalizada en menos de 24 horas.";

const t = {
    // Left panel
    headline:   isEn ? "B2B quotes that\nclose themselves." : "Cotizaciones B2B\nque cierran solas.",
    sub:        isEn ? "Talk to our team and start a personalized demo in under 24 hours." : "Habla con nuestro equipo y empieza una demo personalizada en menos de 24 horas.",
    feat1:      isEn ? "Digital portal your client approves and signs from the link" : "Portal digital que tu cliente firma desde el link",
    feat2:      isEn ? "CFDI 4.0 automatically issued at close" : "CFDI 4.0 timbrado automáticamente al cierre",
    feat3:      isEn ? "No commissions — payments go directly to your account" : "Sin comisiones — el pago va directo a tu cuenta",
    m1v: "5 min", m1l: isEn ? "to your first quote" : "primera cotización",
    m2v: "3×",   m2l: isEn ? "faster than Excel" : "más rápido que Excel",
    m3v: "$0",   m3l: isEn ? "commissions" : "de comisiones",
    badge:      isEn ? "We reply within 24 business hours" : "Respuesta en menos de 24 horas hábiles",
    // Step 1
    s1t: isEn ? "What's your work email?" : "¿Cuál es tu correo?",
    s1d: isEn ? "We'll use it to send you details and schedule a call." : "Lo usaremos para enviarte la info y agendar tu demo.",
    s1l: isEn ? "Work email" : "Correo corporativo",
    s1p: "tu@empresa.com",
    s1h: isEn ? "No spam, ever." : "Sin correos no deseados.",
    // Step 2
    s2t: isEn ? "Tell us about yourself" : "Cuéntanos sobre ti",
    s2d: isEn ? "A bit of context helps us tailor your demo." : "Un poco de contexto nos ayuda a personalizar tu demo.",
    s2fn: isEn ? "First name" : "Nombre",
    s2ln: isEn ? "Last name" : "Apellidos",
    s2co: isEn ? "Company" : "Empresa",
    s2ro: isEn ? "Job title" : "Cargo",
    s2in: isEn ? "Industry" : "Industria",
    // Step 3
    s3t: isEn ? "How do you work today?" : "¿Cómo operan hoy?",
    s3d: isEn ? "Understanding your current setup helps us focus the demo." : "Entender tu situación actual nos ayuda a enfocar tu demo.",
    s3tm: isEn ? "Sales team size" : "Equipo de ventas",
    s3qu: isEn ? "Quotes per month" : "Cotizaciones al mes",
    s3to: isEn ? "Current tool" : "Herramienta actual",
    // Step 4
    s4t: isEn ? "What are you looking to solve?" : "¿Qué quieres resolver?",
    s4d: isEn ? "Pick all that apply — we'll personalize your demo around these." : "Selecciona todo lo que aplique — personalizamos tu demo en base a esto.",
    s4ch: isEn ? "Main challenges (pick all that apply)" : "Retos principales (puedes elegir varios)",
    s4tl: isEn ? "When do you need this?" : "¿Para cuándo?",
    s4ms: isEn ? "Anything else? (optional)" : "¿Algo más? (opcional)",
    s4mp: isEn ? "E.g. We need ERP integration and automated credit approvals…" : "Ej. Necesitamos integrar con nuestro ERP y automatizar las aprobaciones de crédito…",
    // Success
    succT: isEn ? "You're all set!" : "¡Todo listo!",
    succD: isEn ? "A Cord specialist will reach out within 24 hours." : "Un especialista de Cord te contactará en menos de 24 horas.",
    succC: isEn ? "Explore pricing while you wait →" : "Explora los planes mientras esperas →",
    // Buttons
    cont: isEn ? "Continue" : "Continuar",
    back: isEn ? "← Back" : "← Atrás",
    subm: isEn ? "Send request" : "Enviar solicitud",
    stepOf: (n: number) => isEn ? `Step ${n} of 4` : `Paso ${n} de 4`,
};

const industries    = isEn ? ['Distribution','Manufacturing','Construction','B2B Services','Software / SaaS','Agency','Wholesale','Other'] : ['Distribución','Manufactura','Construcción','Servicios B2B','Software / SaaS','Agencia','Comercio mayorista','Otro'];
const industryVals  = ['distribucion','manufactura','construccion','servicios','saas','agencia','mayorista','otro'];

const teamSizes     = isEn ? ['Just me','2 – 10','11 – 50','+50 people'] : ['Solo yo','2 – 10','11 – 50','+50 personas'];
const teamVals      = ['solo','2_10','11_50','50plus'];

const quoteLbls     = isEn ? ['Under 50','50 – 200','200 – 500','+500'] : ['Menos de 50','50 – 200','200 – 500','+500'];
const quoteVals     = ['lt50','50_200','200_500','500plus'];

const toolLbls      = isEn ? ['Excel / Word','ERP (SAP, Oracle…)','In-house system','No system'] : ['Excel / Word','ERP (SAP, Oracle…)','Sistema propio','Sin sistema'];
const toolVals      = ['excel','erp','sistema_propio','sin_sistema'];

const challengeLbls = isEn ? ['Client portal','Auto CFDI invoicing','Collections & AR','Discount approvals','Integrations / API','Analytics & margins'] : ['Portal del cliente','CFDI automático','Cobranza y cobro','Aprobaciones de descuentos','Integraciones / API','Analítica y márgenes'];
const challengeVals = ['portal','cfdi','cobranza','aprobaciones','integraciones','analitica'];

const timelineLbls  = isEn ? ['ASAP','1 – 3 months','Just exploring'] : ['Lo antes posible','1 – 3 meses','Solo explorando'];
const timelineVals  = ['urgente','1_3meses','explorando'];
---

<Layout title={title} description={description}>
<div class="vs-layout">

  <!-- ══════════════════════════════════════════════════
       LEFT — Brand & Trust
  ══════════════════════════════════════════════════ -->
  <aside class="vs-left" aria-hidden="true">
    <PriceAuroraBg client:only="react" />
    <div class="vs-mesh"></div>
    <div class="vs-left-inner">

      <a href="/" class="vs-logo-link">
        <img src="/imgs/logo-cord-white.png" alt="Cord" class="vs-logo" />
      </a>

      <div class="vs-pitch">
        <h2 class="vs-headline">{t.headline}</h2>
        <p class="vs-sub">{t.sub}</p>
        <ul class="vs-feats">
          {[t.feat1, t.feat2, t.feat3].map(f => (
            <li class="vs-feat">
              <span class="vs-feat-icon">
                <svg viewBox="0 0 12 10" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="1 5 4 8 11 1"/>
                </svg>
              </span>
              <span>{f}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="vs-metrics">
        {[[t.m1v,t.m1l],[t.m2v,t.m2l],[t.m3v,t.m3l]].map(([v,l], i) => (<>
          {i > 0 && <span class="vs-metric-sep" aria-hidden="true"></span>}
          <div class="vs-metric">
            <span class="vs-metric-val">{v}</span>
            <span class="vs-metric-lbl">{l}</span>
          </div>
        </>))}
      </div>

      <div class="vs-left-foot">
        <div class="vs-badge">
          <span class="vs-pulse" aria-hidden="true"></span>
          <span>{t.badge}</span>
        </div>
        <a href="mailto:cord@flouvia.com" class="vs-mail">cord@flouvia.com</a>
      </div>

    </div>
  </aside>

  <!-- ══════════════════════════════════════════════════
       RIGHT — Form Wizard
  ══════════════════════════════════════════════════ -->
  <main class="vs-right">

    <!-- Mobile compact header -->
    <div class="vs-mob-bar">
      <a href="/"><img src="/imgs/logo-cord-white.png" alt="Cord" class="vs-mob-logo" /></a>
    </div>

    <div class="vs-form-wrap">

      <!-- Progress -->
      <div class="vs-prog-track" aria-hidden="true">
        <div class="vs-prog-fill" id="vsProgFill" style="width:25%"></div>
      </div>
      <p class="vs-step-ctr" id="vsStepCtr">{t.stepOf(1)}</p>

      <!-- Form -->
      <form id="vsForm" novalidate>
        <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true"
               style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;" />

        <div class="vs-slides" id="vsSlides">

          <!-- ─── STEP 1: Email ─────────────────── -->
          <div class="vs-slide" data-step="0">
            <h1 class="vs-stitle">{t.s1t}</h1>
            <p class="vs-sdesc">{t.s1d}</p>
            <div class="vs-fields">
              <div class="vs-fgroup">
                <label for="vsEmail" class="vs-lbl">{t.s1l}</label>
                <input type="email" id="vsEmail" name="email" class="vs-input vs-input-hero"
                       placeholder={t.s1p} autocomplete="email" required />
                <p class="vs-hint">{t.s1h}</p>
              </div>
            </div>
            <div class="vs-actions vs-actions-end">
              <button type="button" class="vs-btn-next" data-next="1">
                {t.cont}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            </div>
          </div>

          <!-- ─── STEP 2: Company info ──────────── -->
          <div class="vs-slide" data-step="1" style="display:none">
            <h1 class="vs-stitle">{t.s2t}</h1>
            <p class="vs-sdesc">{t.s2d}</p>
            <div class="vs-fields">
              <div class="vs-frow2">
                <div class="vs-fgroup">
                  <label for="vsFirstName" class="vs-lbl">{t.s2fn}</label>
                  <input type="text" id="vsFirstName" name="firstName" class="vs-input"
                         placeholder="Elena" autocomplete="given-name" required />
                </div>
                <div class="vs-fgroup">
                  <label for="vsLastName" class="vs-lbl">{t.s2ln}</label>
                  <input type="text" id="vsLastName" name="lastName" class="vs-input"
                         placeholder="García" autocomplete="family-name" />
                </div>
              </div>
              <div class="vs-fgroup">
                <label for="vsCompany" class="vs-lbl">{t.s2co}</label>
                <input type="text" id="vsCompany" name="company" class="vs-input"
                       placeholder="Mi Empresa S.A. de C.V." autocomplete="organization" required />
              </div>
              <div class="vs-fgroup">
                <label for="vsRole" class="vs-lbl">{t.s2ro}</label>
                <input type="text" id="vsRole" name="role" class="vs-input"
                       placeholder="Director de Ventas · CFO · Gerente" autocomplete="organization-title" />
              </div>
              <div class="vs-fgroup">
                <label class="vs-lbl">{t.s2in}</label>
                <div class="vs-chips" data-name="industry" data-type="single">
                  {industries.map((ind, i) => (
                    <button type="button" class="vs-chip" data-value={industryVals[i]}>{ind}</button>
                  ))}
                </div>
                <input type="hidden" name="industry" class="vs-chip-val" />
              </div>
            </div>
            <div class="vs-actions">
              <button type="button" class="vs-btn-back" data-prev="0">{t.back}</button>
              <button type="button" class="vs-btn-next" data-next="2">
                {t.cont}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            </div>
          </div>

          <!-- ─── STEP 3: Operations ────────────── -->
          <div class="vs-slide" data-step="2" style="display:none">
            <h1 class="vs-stitle">{t.s3t}</h1>
            <p class="vs-sdesc">{t.s3d}</p>
            <div class="vs-fields">
              <div class="vs-fgroup">
                <label class="vs-lbl">{t.s3tm}</label>
                <div class="vs-chips" data-name="teamSize" data-type="single">
                  {teamSizes.map((sz, i) => (
                    <button type="button" class="vs-chip" data-value={teamVals[i]}>{sz}</button>
                  ))}
                </div>
                <input type="hidden" name="teamSize" class="vs-chip-val" data-req="true" />
              </div>
              <div class="vs-fgroup">
                <label class="vs-lbl">{t.s3qu}</label>
                <div class="vs-chips" data-name="monthlyQuotes" data-type="single">
                  {quoteLbls.map((q, i) => (
                    <button type="button" class="vs-chip" data-value={quoteVals[i]}>{q}</button>
                  ))}
                </div>
                <input type="hidden" name="monthlyQuotes" class="vs-chip-val" data-req="true" />
              </div>
              <div class="vs-fgroup">
                <label class="vs-lbl">{t.s3to}</label>
                <div class="vs-chips" data-name="currentTool" data-type="single">
                  {toolLbls.map((tl, i) => (
                    <button type="button" class="vs-chip" data-value={toolVals[i]}>{tl}</button>
                  ))}
                </div>
                <input type="hidden" name="currentTool" class="vs-chip-val" data-req="true" />
              </div>
            </div>
            <div class="vs-actions">
              <button type="button" class="vs-btn-back" data-prev="1">{t.back}</button>
              <button type="button" class="vs-btn-next" data-next="3">
                {t.cont}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            </div>
          </div>

          <!-- ─── STEP 4: Challenges ────────────── -->
          <div class="vs-slide" data-step="3" style="display:none">
            <h1 class="vs-stitle">{t.s4t}</h1>
            <p class="vs-sdesc">{t.s4d}</p>
            <div class="vs-fields">
              <div class="vs-fgroup">
                <label class="vs-lbl">{t.s4ch}</label>
                <div class="vs-chips" data-name="challenges" data-type="multi">
                  {challengeLbls.map((ch, i) => (
                    <button type="button" class="vs-chip" data-value={challengeVals[i]}>{ch}</button>
                  ))}
                </div>
                <input type="hidden" name="challenges" class="vs-chip-val" data-req="true" />
              </div>
              <div class="vs-fgroup">
                <label class="vs-lbl">{t.s4tl}</label>
                <div class="vs-chips" data-name="timeline" data-type="single">
                  {timelineLbls.map((tl, i) => (
                    <button type="button" class="vs-chip" data-value={timelineVals[i]}>{tl}</button>
                  ))}
                </div>
                <input type="hidden" name="timeline" class="vs-chip-val" data-req="true" />
              </div>
              <div class="vs-fgroup">
                <label for="vsMessage" class="vs-lbl">{t.s4ms}</label>
                <textarea id="vsMessage" name="message" class="vs-input vs-textarea"
                          placeholder={t.s4mp} rows="3"></textarea>
              </div>
            </div>
            <div class="vs-actions">
              <button type="button" class="vs-btn-back" data-prev="2">{t.back}</button>
              <button type="submit" class="vs-btn-submit" id="vsSubmitBtn">
                {t.subm}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- ─── SUCCESS ───────────────────────── -->
          <div class="vs-slide vs-success-slide" data-step="success" style="display:none">
            <div class="vs-success-icon" id="vsSuccessIcon" aria-hidden="true">
              <svg class="vs-check-svg" viewBox="0 0 64 64" fill="none">
                <circle class="vs-check-circle" cx="32" cy="32" r="28"
                        stroke="#0a192f" stroke-width="2" stroke-linecap="round"/>
                <polyline class="vs-check-mark" points="20 32 28 40 44 24"
                          stroke="#0a192f" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h1 class="vs-stitle">{t.succT}</h1>
            <p class="vs-sdesc" id="vsSuccessDesc">{t.succD}</p>
            <a href="/precios" class="vs-succ-cta">{t.succC}</a>
          </div>

        </div><!-- /vs-slides -->
      </form>

    </div><!-- /vs-form-wrap -->
  </main>

</div><!-- /vs-layout -->
</Layout>

<!-- Hide global nav/footer on this standalone page -->
<style is:global>
  body:has(.vs-layout) #navbar,
  body:has(.vs-layout) footer { display: none !important; }
  body:has(.vs-layout) { overflow-x: hidden; }
</style>

<style>
/* ══════════════════════════════════════════════════════════
   LAYOUT
══════════════════════════════════════════════════════════ */
.vs-layout {
  display: grid;
  grid-template-columns: 38% 1fr;
  min-height: 100vh;
}

/* ══════════════════════════════════════════════════════════
   LEFT PANEL
══════════════════════════════════════════════════════════ */
.vs-left {
  position: sticky;
  top: 0;
  height: 100vh;
  overflow: hidden;
  background-color: #08152a;
}

.vs-mesh {
  position: absolute;
  inset: 0;
  z-index: 1;
  background-image: radial-gradient(rgba(255,255,255,0.018) 1px, transparent 1px);
  background-size: 28px 28px;
  pointer-events: none;
}

.vs-left-inner {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  height: 100%;
  padding: 48px 52px;
}

.vs-logo-link { display: inline-block; margin-bottom: 0; }
.vs-logo { height: 20px; width: auto; opacity: 0.92; }

.vs-pitch {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 48px 0 32px;
}

.vs-headline {
  font-size: clamp(1.9rem, 2.6vw, 2.5rem);
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.04em;
  line-height: 1.1;
  margin: 0 0 18px 0;
  white-space: pre-line;
}

.vs-sub {
  font-size: 0.95rem;
  line-height: 1.65;
  color: rgba(226, 232, 240, 0.65);
  margin: 0 0 40px 0;
  font-weight: 400;
  max-width: 340px;
}

.vs-feats {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.vs-feat {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  color: rgba(226, 232, 240, 0.82);
  font-size: 0.875rem;
  line-height: 1.55;
}

.vs-feat-icon {
  flex-shrink: 0;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.75);
  margin-top: 1px;
}
.vs-feat-icon svg { width: 10px; height: 10px; }

/* Metrics strip */
.vs-metrics {
  display: flex;
  align-items: center;
  gap: 0;
  padding: 28px 0;
  border-top: 1px solid rgba(255,255,255,0.06);
  border-bottom: 1px solid rgba(255,255,255,0.06);
  margin-bottom: 32px;
}

.vs-metric { flex: 1; text-align: center; }
.vs-metric-val {
  display: block;
  font-size: 1.5rem;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.04em;
  line-height: 1;
  margin-bottom: 4px;
}
.vs-metric-lbl {
  display: block;
  font-size: 0.72rem;
  color: rgba(148,163,184,0.75);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-weight: 500;
}
.vs-metric-sep {
  width: 1px;
  height: 36px;
  background: rgba(255,255,255,0.07);
}

/* Left footer */
.vs-left-foot {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.vs-badge {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.82rem;
  color: rgba(226,232,240,0.65);
  font-weight: 500;
}

.vs-pulse {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #10b981;
  flex-shrink: 0;
  box-shadow: 0 0 0 0 rgba(16,185,129,0.45);
  animation: vs-pulse 2.2s infinite;
}
@keyframes vs-pulse {
  0%   { box-shadow: 0 0 0 0 rgba(16,185,129,0.45); }
  70%  { box-shadow: 0 0 0 8px rgba(16,185,129,0); }
  100% { box-shadow: 0 0 0 0 rgba(16,185,129,0); }
}

.vs-mail {
  font-size: 0.82rem;
  color: rgba(148,163,184,0.6);
  text-decoration: none;
  transition: color 0.2s;
}
.vs-mail:hover { color: rgba(226,232,240,0.8); }

/* ══════════════════════════════════════════════════════════
   MOBILE BAR (left panel collapsed to header)
══════════════════════════════════════════════════════════ */
.vs-mob-bar {
  display: none;
  align-items: center;
  height: 60px;
  padding: 0 24px;
  background: #0a192f;
  flex-shrink: 0;
}
.vs-mob-logo { height: 17px; width: auto; }

/* ══════════════════════════════════════════════════════════
   RIGHT PANEL
══════════════════════════════════════════════════════════ */
.vs-right {
  background: #ffffff;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

.vs-form-wrap {
  flex: 1;
  max-width: 580px;
  width: 100%;
  margin: 0 auto;
  padding: 56px 48px 80px;
  display: flex;
  flex-direction: column;
}

/* Progress */
.vs-prog-track {
  width: 100%;
  height: 2px;
  background: rgba(0,0,0,0.06);
  border-radius: 2px;
  overflow: hidden;
  margin-bottom: 14px;
}
.vs-prog-fill {
  height: 100%;
  background: #0a192f;
  border-radius: 2px;
  transition: width 0.5s cubic-bezier(0.16,1,0.3,1);
}

.vs-step-ctr {
  font-size: 0.78rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.09em;
  color: #86868b;
  margin: 0 0 52px 0;
}

/* ══════════════════════════════════════════════════════════
   SLIDE TYPOGRAPHY
══════════════════════════════════════════════════════════ */
.vs-stitle {
  font-size: clamp(1.8rem, 3vw, 2.4rem);
  font-weight: 700;
  color: #050505;
  letter-spacing: -0.04em;
  line-height: 1.1;
  margin: 0 0 12px 0;
}

.vs-sdesc {
  font-size: 1rem;
  line-height: 1.6;
  color: #6e6e73;
  margin: 0 0 44px 0;
  font-weight: 400;
}

/* ══════════════════════════════════════════════════════════
   FORM FIELDS
══════════════════════════════════════════════════════════ */
.vs-fields {
  display: flex;
  flex-direction: column;
  gap: 32px;
}

.vs-fgroup {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.vs-frow2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.vs-lbl {
  font-size: 0.85rem;
  font-weight: 600;
  color: #3d3d3d;
  letter-spacing: 0.01em;
}

.vs-hint {
  font-size: 0.8rem;
  color: #86868b;
  margin: 0;
  line-height: 1.4;
}

.vs-input {
  width: 100%;
  padding: 14px 18px;
  background: #f5f5f7;
  border: none;
  border-radius: 12px;
  font-size: 0.975rem;
  color: #1d1d1f;
  font-family: var(--font-sans, 'Inter', sans-serif);
  transition: background 0.18s ease, box-shadow 0.18s ease;
  outline: none;
  box-sizing: border-box;
  -webkit-appearance: none;
}

.vs-input-hero {
  font-size: 1.3rem;
  padding: 18px 22px;
  border-radius: 14px;
  letter-spacing: -0.01em;
}

.vs-textarea {
  resize: vertical;
  min-height: 90px;
  line-height: 1.5;
}

.vs-input::placeholder { color: #aeaeb2; }
.vs-input:hover { background: #e8e8ed; }
.vs-input:focus {
  background: #ffffff;
  box-shadow: 0 0 0 3.5px rgba(10,25,47,0.13), 0 1px 4px rgba(0,0,0,0.05);
}
.vs-input.vs-invalid {
  background: #fff0f0;
  box-shadow: 0 0 0 3px rgba(239,68,68,0.18);
}

/* ══════════════════════════════════════════════════════════
   CHIPS
══════════════════════════════════════════════════════════ */
.vs-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 9px;
}

.vs-chip {
  display: inline-flex;
  align-items: center;
  padding: 10px 20px;
  border-radius: 999px;
  background: #f5f5f7;
  border: 1.5px solid transparent;
  color: #1d1d1f;
  font-size: 0.875rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.18s cubic-bezier(0.16,1,0.3,1);
  font-family: var(--font-sans, 'Inter', sans-serif);
  white-space: nowrap;
  line-height: 1;
  user-select: none;
}

.vs-chip:hover {
  background: #e8e8ed;
  transform: translateY(-1px);
}

.vs-chip:active { transform: scale(0.97); }

.vs-chip.vs-sel {
  background: #ffffff;
  border-color: #0a192f;
  color: #0a192f;
  font-weight: 600;
  box-shadow: 0 2px 14px rgba(10,25,47,0.12), 0 0 0 0.5px #0a192f;
}

.vs-chip.vs-invalid-chip {
  border-color: rgba(239,68,68,0.4);
}

/* ══════════════════════════════════════════════════════════
   ACTIONS
══════════════════════════════════════════════════════════ */
.vs-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  margin-top: 48px;
  padding-top: 28px;
  border-top: 1px solid rgba(0,0,0,0.06);
}

.vs-actions-end { justify-content: flex-end; }

.vs-btn-back {
  background: none;
  border: none;
  color: #86868b;
  font-size: 0.88rem;
  font-weight: 500;
  cursor: pointer;
  padding: 8px 4px;
  transition: color 0.2s;
  font-family: var(--font-sans, 'Inter', sans-serif);
  letter-spacing: 0.01em;
}
.vs-btn-back:hover { color: #0a192f; }

.vs-btn-next,
.vs-btn-submit {
  display: inline-flex;
  align-items: center;
  gap: 9px;
  background: #0a192f;
  color: #ffffff;
  border: none;
  border-radius: 999px;
  padding: 14px 30px;
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.28s cubic-bezier(0.16,1,0.3,1);
  box-shadow: 0 4px 18px rgba(10,25,47,0.22), 0 1px 3px rgba(10,25,47,0.1);
  font-family: var(--font-sans, 'Inter', sans-serif);
  letter-spacing: -0.01em;
  position: relative;
  overflow: hidden;
}

.vs-btn-next::after,
.vs-btn-submit::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.07) 50%, transparent 60%);
  transform: translateX(-110%);
  transition: transform 0.55s ease;
}
.vs-btn-next:hover::after,
.vs-btn-submit:hover::after { transform: translateX(110%); }

.vs-btn-next:hover,
.vs-btn-submit:hover {
  background: #112240;
  box-shadow: 0 8px 28px rgba(10,25,47,0.28);
  transform: translateY(-1px);
}
.vs-btn-next:active,
.vs-btn-submit:active { transform: scale(0.97); box-shadow: 0 2px 8px rgba(10,25,47,0.2); }

.vs-btn-next svg,
.vs-btn-submit svg {
  width: 15px;
  height: 15px;
  flex-shrink: 0;
  transition: transform 0.28s cubic-bezier(0.16,1,0.3,1);
}
.vs-btn-next:hover svg,
.vs-btn-submit:hover svg { transform: translateX(4px); }

.vs-btn-next:disabled,
.vs-btn-submit:disabled {
  opacity: 0.55;
  cursor: not-allowed;
  transform: none;
  pointer-events: none;
}

/* ══════════════════════════════════════════════════════════
   SUCCESS SLIDE
══════════════════════════════════════════════════════════ */
.vs-success-slide {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding-top: 16px;
}

.vs-success-icon {
  width: 64px;
  height: 64px;
  margin-bottom: 32px;
}

.vs-check-svg { width: 64px; height: 64px; }

.vs-check-circle {
  stroke-dasharray: 176;
  stroke-dashoffset: 176;
}
.vs-check-mark {
  stroke-dasharray: 40;
  stroke-dashoffset: 40;
}

.vs-succ-cta {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-top: 32px;
  font-size: 0.9rem;
  font-weight: 600;
  color: #0a192f;
  text-decoration: none;
  border-bottom: 1.5px solid rgba(10,25,47,0.2);
  padding-bottom: 2px;
  transition: all 0.2s;
}
.vs-succ-cta:hover {
  color: #112240;
  border-color: #0a192f;
  gap: 10px;
}

/* ══════════════════════════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════════════════════════ */
@media (max-width: 900px) {
  .vs-layout {
    grid-template-columns: 1fr;
    grid-template-rows: auto 1fr;
  }
  .vs-left { display: none; }
  .vs-mob-bar { display: flex; }
  .vs-right { min-height: calc(100vh - 60px); }
  .vs-form-wrap { padding: 36px 28px 60px; }
  .vs-stitle { font-size: 1.7rem; }
}

@media (max-width: 480px) {
  .vs-form-wrap { padding: 28px 20px 56px; }
  .vs-frow2 { grid-template-columns: 1fr; }
  .vs-stitle { font-size: 1.5rem; }
  .vs-chip { padding: 9px 16px; font-size: 0.82rem; }
  .vs-btn-next, .vs-btn-submit { padding: 13px 24px; font-size: 0.9rem; }
  .vs-input-hero { font-size: 1.1rem; padding: 16px 18px; }
}

/* ══════════════════════════════════════════════════════════
   SLIDE TRANSITIONS (JS manages display, GSAP manages anim)
══════════════════════════════════════════════════════════ */
.vs-slide { will-change: transform, opacity; }
</style>

<script>
import { gsap } from 'gsap';

document.addEventListener('DOMContentLoaded', () => {
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isEn    = location.pathname.startsWith('/en');

  // ─── Entrance animation ────────────────────────────────
  if (!reduced) {
    const left = document.querySelector('.vs-left');
    if (left) gsap.from(left, { x: -24, opacity: 0, duration: 0.9, ease: 'power3.out' });

    const right = document.querySelector('.vs-form-wrap');
    if (right) gsap.from(right, { x: 24, opacity: 0, duration: 0.9, ease: 'power3.out', delay: 0.06 });

    const leftItems = document.querySelectorAll('.vs-logo, .vs-headline, .vs-sub, .vs-feat, .vs-metrics, .vs-left-foot');
    if (leftItems.length) {
      gsap.from(leftItems, { y: 18, opacity: 0, duration: 0.65, stagger: 0.07, ease: 'power2.out', delay: 0.25 });
    }
  }

  // ─── Chip logic ────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.vs-chips').forEach(group => {
    const type  = group.dataset.type || 'single';
    const name  = group.dataset.name || '';
    const hidden = document.querySelector<HTMLInputElement>(`input[name="${name}"]`);

    group.querySelectorAll<HTMLButtonElement>('.vs-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        if (type === 'single') {
          group.querySelectorAll('.vs-chip').forEach(c => c.classList.remove('vs-sel'));
          chip.classList.add('vs-sel');
          if (hidden) hidden.value = chip.dataset.value || '';
        } else {
          chip.classList.toggle('vs-sel');
          const selected = [...group.querySelectorAll('.vs-chip.vs-sel')]
            .map(c => (c as HTMLButtonElement).dataset.value || '').filter(Boolean);
          if (hidden) hidden.value = selected.join(',');
        }
      });
    });
  });

  // ─── Slide management ──────────────────────────────────
  const slides    = document.querySelectorAll<HTMLElement>('.vs-slide');
  const progFill  = document.getElementById('vsProgFill');
  const stepCtr   = document.getElementById('vsStepCtr');
  const progPct   = [25, 50, 75, 100];

  let current = 0;

  function updateProgress(step: number) {
    if (progFill && step < progPct.length) {
      progFill.style.width = `${progPct[step]}%`;
    }
    if (stepCtr && step < 4) {
      stepCtr.textContent = isEn ? `Step ${step + 1} of 4` : `Paso ${step + 1} de 4`;
    }
    if (step === 4) {
      const track = document.querySelector('.vs-prog-track') as HTMLElement;
      const ctr   = document.querySelector('.vs-step-ctr') as HTMLElement;
      if (track) gsap.to(track, { opacity: 0, duration: 0.3, onComplete: () => track.style.display = 'none' });
      if (ctr)   gsap.to(ctr,   { opacity: 0, duration: 0.3, onComplete: () => ctr.style.display   = 'none' });
    }
  }

  function goToSlide(from: number, to: number, dir: 'fwd' | 'bk') {
    const fromEl = slides[from];
    const toEl   = slides[to];
    if (!fromEl || !toEl) return;

    const xOut = dir === 'fwd' ? -28 : 28;
    const xIn  = dir === 'fwd' ?  28 : -28;

    if (reduced) {
      fromEl.style.display = 'none';
      toEl.style.display   = 'block';
      updateProgress(to);
      return;
    }

    gsap.to(fromEl, {
      x: xOut, opacity: 0, duration: 0.28, ease: 'power2.in',
      onComplete: () => {
        fromEl.style.display = 'none';
        gsap.set(fromEl, { x: 0, opacity: 1 });
        toEl.style.display = 'block';
        gsap.fromTo(toEl, { x: xIn, opacity: 0 }, { x: 0, opacity: 1, duration: 0.38, ease: 'power3.out' });
      }
    });
    updateProgress(to);
  }

  // ─── Validation ────────────────────────────────────────
  function validateSlide(idx: number): boolean {
    const slide = slides[idx];
    if (!slide) return true;
    let ok = true;

    // Text/email inputs
    slide.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input[required], textarea[required]').forEach(el => {
      if (el.type === 'hidden') return;
      const valid = el.checkValidity() && el.value.trim() !== '';
      el.classList.toggle('vs-invalid', !valid);
      if (!valid) ok = false;
    });

    // Chip groups that are required
    slide.querySelectorAll<HTMLInputElement>('input.vs-chip-val[data-req="true"]').forEach(el => {
      const empty = !el.value.trim();
      if (empty) {
        ok = false;
        const groupName = el.name;
        const group = slide.querySelector<HTMLElement>(`.vs-chips[data-name="${groupName}"]`);
        if (group) {
          gsap.fromTo(group, { x: -4 }, { x: 0, duration: 0.25, ease: 'power1.out',
            repeat: 3, yoyo: true });
          group.querySelectorAll('.vs-chip').forEach(c => c.classList.add('vs-invalid-chip'));
          setTimeout(() => group.querySelectorAll('.vs-chip').forEach(c => c.classList.remove('vs-invalid-chip')), 1200);
        }
      }
    });

    return ok;
  }

  // ─── Next buttons ──────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.vs-btn-next').forEach(btn => {
    btn.addEventListener('click', () => {
      const next = parseInt(btn.dataset.next || '1', 10);
      if (validateSlide(current)) {
        goToSlide(current, next, 'fwd');
        current = next;
      }
    });
  });

  // ─── Back buttons ──────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.vs-btn-back').forEach(btn => {
    btn.addEventListener('click', () => {
      const prev = parseInt(btn.dataset.prev || '0', 10);
      goToSlide(current, prev, 'bk');
      current = prev;
    });
  });

  // ─── Submit ────────────────────────────────────────────
  const form = document.getElementById('vsForm') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!validateSlide(current)) return;

      const submitBtn = document.getElementById('vsSubmitBtn') as HTMLButtonElement | null;
      if (submitBtn) { submitBtn.disabled = true; submitBtn.style.opacity = '0.6'; }

      const fd      = new FormData(form);
      const payload = Object.fromEntries(fd.entries());

      try {
        const res = await fetch('/api/contacto/ventas', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error('bad status');
      } catch {
        if (submitBtn) { submitBtn.disabled = false; submitBtn.style.opacity = '1'; }
        alert(isEn
          ? 'Could not send your message. Please try again or email cord@flouvia.com.'
          : 'No pudimos enviar tu mensaje. Intenta de nuevo o escríbenos a cord@flouvia.com.');
        return;
      }

      // Personalize success message
      const firstName = (fd.get('firstName') as string || '').trim().split(' ')[0];
      const email     = (fd.get('email') as string || '').toLowerCase().trim();
      const desc = document.getElementById('vsSuccessDesc');
      if (desc && firstName && email) {
        desc.textContent = isEn
          ? `A Cord specialist will reach out to ${email} within 24 hours, ${firstName}.`
          : `Un especialista de Cord te escribirá a ${email} en menos de 24 horas, ${firstName}.`;
      }

      // Go to success
      const successSlide = slides[slides.length - 1];
      const fromEl       = slides[current];

      if (!reduced) {
        gsap.to(fromEl, {
          y: -20, opacity: 0, duration: 0.3, ease: 'power2.in',
          onComplete: () => {
            fromEl.style.display = 'none';
            successSlide.style.display = 'flex';
            gsap.from(successSlide, { y: 24, opacity: 0, duration: 0.5, ease: 'power3.out' });
            // Animate checkmark
            const circle = successSlide.querySelector<SVGCircleElement>('.vs-check-circle');
            const mark   = successSlide.querySelector<SVGPolylineElement>('.vs-check-mark');
            if (circle) gsap.to(circle, { strokeDashoffset: 0, duration: 0.7, ease: 'power2.out', delay: 0.15 });
            if (mark)   gsap.to(mark,   { strokeDashoffset: 0, duration: 0.45, ease: 'power2.out', delay: 0.7 });
          }
        });
      } else {
        fromEl.style.display    = 'none';
        successSlide.style.display = 'flex';
        const circle = successSlide.querySelector<SVGCircleElement>('.vs-check-circle');
        const mark   = successSlide.querySelector<SVGPolylineElement>('.vs-check-mark');
        if (circle) circle.style.strokeDashoffset = '0';
        if (mark)   mark.style.strokeDashoffset   = '0';
      }

      updateProgress(4);
    });

    // Keyboard: Enter advances
    form.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key !== 'Enter') return;
      const tag = (e.target as HTMLElement).tagName;
      if (tag === 'TEXTAREA') return;
      e.preventDefault();
      if (current === 3) {
        form.dispatchEvent(new Event('submit', { bubbles: true }));
      } else {
        const nextBtn = slides[current]?.querySelector<HTMLButtonElement>('.vs-btn-next');
        if (nextBtn) nextBtn.click();
      }
    });
  }
});
</script>
