---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';

const title = isEn
    ? "Contact Sales | Cord by Flouvia"
    : "Contacto de Ventas | Cord by Flouvia";

const description = isEn
    ? "Get in touch with the Cord sales team to learn how we can help digitize your B2B quotes and orders."
    : "Comunícate con el equipo de ventas de Cord para descubrir cómo digitalizar tus cotizaciones y pedidos B2B.";
---

<Layout title={title} description={description}>
    <!-- Minimal Header -->
    <header class="minimal-header">
        <a href="/" class="logo-link">
            <img src="/imgs/logo-cord-navy.png" alt="Cord" class="logo-img" />
        </a>
        <a href="/app" class="dashboard-link">
            {isEn ? "Dashboard" : "Dashboard"} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </a>
    </header>

    <main class="minimal-contact-page">
        <section class="card-section">
            <div class="stepper-card reveal-mockup">
                <!-- Stepper Header -->
                <div class="stepper-header">
                    <div class="step active">
                        <span class="step-indicator"></span>
                        <span class="step-label">{isEn ? "Your email" : "Tu correo"}</span>
                    </div>
                    <div class="step">
                        <span class="step-indicator"></span>
                        <span class="step-label">{isEn ? "Your info" : "Tu información"}</span>
                    </div>
                    <div class="step">
                        <span class="step-indicator"></span>
                        <span class="step-label">{isEn ? "Let's talk" : "Hablemos"}</span>
                    </div>
                </div>
                <!-- Stepper Progress & Form -->
                <div class="stepper-progress">
                    <div class="progress-bar" id="progressBar" style="width: 33.33%;"></div>
                </div>

                    <form id="contactWizard" class="minimal-form" novalidate>
                    <!-- Honeypot anti-spam: oculto para humanos, los bots lo rellenan -->
                    <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;" />
                    <!-- STEP 1: Email & ERP -->
                    <div class="step-content" id="step-1">
                        <h1 class="step-title">{isEn ? "We'll get you to the right place" : "Te llevamos al lugar correcto"}</h1>
                        <p class="step-subtitle">{isEn ? "We just need a few details to tailor our solution." : "Solo necesitamos un par de datos para empezar."}</p>

                        <div class="form-fields">
                            <div class="form-row-horizontal">
                                <label for="email">{isEn ? "Work email" : "Correo corporativo"}</label>
                                <input type="email" id="email" name="email" placeholder="elena@tu-empresa.com" required />
                            </div>
                            <div class="form-row-horizontal">
                                <label for="erp">{isEn ? "Current ERP system" : "Sistema ERP actual"}</label>
                                <div class="select-wrapper">
                                    <select id="erp" name="erp">
                                        <option value="" disabled selected>{isEn ? "Select..." : "Selecciona..."}</option>
                                        <option value="SAP">SAP</option>
                                        <option value="Oracle">Oracle NetSuite</option>
                                        <option value="Microsoft">Microsoft Dynamics</option>
                                        <option value="Odoo">Odoo</option>
                                        <option value="Contpaqi">CONTPAQi / ASPEL</option>
                                        <option value="Propio">{isEn ? "In-house / Custom" : "Desarrollo propio"}</option>
                                        <option value="Otro">{isEn ? "Other / None" : "Otro / Ninguno"}</option>
                                    </select>
                                    <svg class="select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                                </div>
                            </div>
                        </div>

                        <div class="form-actions">
                            <button type="button" class="continue-btn js-next">
                                {isEn ? "Continue" : "Continuar"} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                            </button>
                        </div>
                    </div>

                    <!-- STEP 2: Personal Info -->
                    <div class="step-content" id="step-2" style="display: none;">
                        <h1 class="step-title">{isEn ? "Tell us about yourself" : "Cuéntanos sobre ti"}</h1>
                        <p class="step-subtitle">{isEn ? "Basic info to personalize your experience." : "Queremos saber con quién hablaremos."}</p>
                        
                        <div class="form-fields">
                            <div class="form-row-horizontal">
                                <label for="firstName">{isEn ? "First Name" : "Nombre"}</label>
                                <input type="text" id="firstName" name="firstName" placeholder="Elena" required />
                            </div>
                            <div class="form-row-horizontal">
                                <label for="lastName">{isEn ? "Last Name" : "Apellidos"}</label>
                                <input type="text" id="lastName" name="lastName" placeholder="García" required />
                            </div>
                            <div class="form-row-horizontal">
                                <label for="company">{isEn ? "Company Name" : "Nombre de la empresa"}</label>
                                <input type="text" id="company" name="company" placeholder="Ejemplo Corporativo S.A." required />
                            </div>
                            <div class="form-row-horizontal">
                                <label for="role">{isEn ? "Job Title" : "Cargo o puesto"}</label>
                                <input type="text" id="role" name="role" placeholder="Director de Ventas / CFO" required />
                            </div>
                        </div>
                        
                        <div class="form-actions">
                            <button type="button" class="continue-btn btn-back js-prev">
                                {isEn ? "Back" : "Atrás"}
                            </button>
                            <button type="button" class="continue-btn js-next">
                                {isEn ? "Continue" : "Continuar"} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                            </button>
                        </div>
                    </div>

                    <!-- STEP 3: Let's talk -->
                    <div class="step-content" id="step-3" style="display: none;">
                        <h1 class="step-title">{isEn ? "How can we help?" : "¿En qué te podemos ayudar?"}</h1>
                        <p class="step-subtitle">{isEn ? "Give us a bit of context." : "Danos contexto sobre tus operaciones B2B."}</p>
                        
                        <div class="form-fields">
                            <div class="form-row-stacked">
                                <label>{isEn ? "Monthly Sales Volume" : "Volumen B2B Mensual"}</label>
                                <div class="radio-card-grid">
                                    <label class="radio-card">
                                        <input type="radio" name="volume" value="1m_10m" required />
                                        <span class="radio-card-content">
                                            <span class="radio-title">$1M - $10M MXN</span>
                                        </span>
                                    </label>
                                    <label class="radio-card">
                                        <input type="radio" name="volume" value="10m_50m" />
                                        <span class="radio-card-content">
                                            <span class="radio-title">$10M - $50M MXN</span>
                                        </span>
                                    </label>
                                    <label class="radio-card">
                                        <input type="radio" name="volume" value="50m_200m" />
                                        <span class="radio-card-content">
                                            <span class="radio-title">$50M - $200M MXN</span>
                                        </span>
                                    </label>
                                    <label class="radio-card">
                                        <input type="radio" name="volume" value="over_200m" />
                                        <span class="radio-card-content">
                                            <span class="radio-title">{isEn ? "Over $200M" : "Más de $200M MXN"}</span>
                                        </span>
                                    </label>
                                </div>
                            </div>
                            <div class="form-row-horizontal" style="align-items: flex-start;">
                                <label for="message" style="margin-top: 14px;">{isEn ? "Key challenges" : "Principales retos"}</label>
                                <textarea id="message" name="message" rows="3" placeholder={isEn ? "E.g. We need to automate our credit approvals and SAT invoicing..." : "Ej. Necesitamos automatizar nuestro portal de distribuidores y timbrado..."}></textarea>
                            </div>
                        </div>
                        
                        <div class="form-actions">
                            <button type="button" class="continue-btn btn-back js-prev">
                                {isEn ? "Back" : "Atrás"}
                            </button>
                            <button type="submit" class="continue-btn">
                                {isEn ? "Submit" : "Enviar"} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                            </button>
                        </div>
                    </div>
                    
                    <!-- SUCCESS MESSAGE -->
                    <div class="step-content" id="step-success" style="display: none; text-align: center; padding: 40px 0;">
                        <div class="success-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                        </div>
                        <h1 class="step-title">{isEn ? "Thanks for reaching out!" : "¡Gracias por contactarnos!"}</h1>
                        <p class="step-subtitle" style="margin-bottom: 0;">{isEn ? "A Cord expert will be in touch shortly." : "Un experto de Cord se pondrá en contacto contigo muy pronto."}</p>
                    </div>
                </form>
            </div>
        </section>
        
        <!-- Gradient splash in bottom right (like screenshot) but with Cord tones -->
        <div class="bottom-gradient-splash"></div>
    </main>
</Layout>

<style is:global>
    .js-anim .reveal-mockup { opacity: 0; }
</style>

<style>
    /* Reset layout background to a soft white/gray */
    :global(body) {
        background-color: #f5f5f7; /* Apple's signature light gray */
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    .minimal-header {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px 40px;
        z-index: 100;
        background: transparent;
    }

    .logo-img {
        height: 22px;
        width: auto;
    }

    .dashboard-link {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--color-blue-deep, #0a192f);
        text-decoration: none;
        transition: opacity 0.2s;
    }

    .dashboard-link:hover {
        opacity: 0.7;
    }

    .dashboard-link svg {
        width: 16px;
        height: 16px;
    }

    .minimal-contact-page {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }
    
    /* Bottom Right Gradient Splash (Cord Aurora Effect) */
    .bottom-gradient-splash {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 120vw;
        height: 120vh;
        transform: translate(-50%, -50%);
        background: radial-gradient(circle at 50% 50%, rgba(10, 25, 47, 0.08), transparent 50%),
                    radial-gradient(circle at 80% 20%, rgba(92, 235, 223, 0.12), transparent 40%),
                    radial-gradient(circle at 20% 80%, rgba(10, 25, 47, 0.06), transparent 40%);
        filter: blur(120px);
        z-index: 0;
        pointer-events: none;
        opacity: 0.9;
    }

    .card-section {
        position: relative;
        z-index: 10;
        width: 100%;
        max-width: 800px;
        padding: 0 20px;
    }

    .stepper-card {
        background: #ffffff;
        border-radius: 40px; /* Apple extreme rounding */
        box-shadow: 
            0 4px 24px rgba(0,0,0,0.02),
            0 16px 48px rgba(0,0,0,0.04),
            0 40px 100px rgba(10, 25, 47, 0.06),
            0 0 0 1px rgba(0,0,0,0.02);
        padding: 64px 80px;
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    
    .stepper-card:hover {
        transform: translateY(-2px);
        box-shadow: 
            0 8px 32px rgba(0,0,0,0.03),
            0 24px 64px rgba(0,0,0,0.05),
            0 60px 120px rgba(10, 25, 47, 0.08),
            0 0 0 1px rgba(0,0,0,0.02);
    }

    /* Stepper Header */
    .stepper-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 16px;
    }

    .step {
        display: flex;
        align-items: center;
        gap: 8px;
        opacity: 0.4;
        transition: opacity 0.3s;
    }

    .step.active {
        opacity: 1;
    }

    .step-indicator {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        border: 2px solid var(--color-blue-deep, #0a192f);
        background: transparent;
    }

    .step.active .step-indicator {
        border: 2px solid var(--color-blue-deep, #0a192f);
        box-shadow: inset 0 0 0 2px #fff, inset 0 0 0 4px var(--color-blue-deep, #0a192f);
        background: var(--color-blue-deep, #0a192f);
    }
    
    .step.completed .step-indicator {
        background: var(--color-blue-deep, #0a192f);
        border: 2px solid var(--color-blue-deep, #0a192f);
        color: white;
    }

    .step-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--color-blue-deep, #0a192f);
    }

    .stepper-progress {
        width: 100%;
        height: 3px;
        background: rgba(10, 25, 47, 0.05);
        border-radius: 2px;
        margin-bottom: 56px;
        overflow: hidden;
    }

    .progress-bar {
        height: 100%;
        background: var(--color-blue-deep, #0a192f); 
        border-radius: 2px;
        transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* Step Content */
    .step-content {
        padding: 0 4px;
    }

    .step-title {
        font-size: 2.2rem;
        font-weight: 700;
        color: #050505;
        margin: 0 0 10px 0;
        letter-spacing: -0.04em;
        line-height: 1.1;
    }

    .step-subtitle {
        font-size: 1.1rem;
        color: #666666;
        margin: 0 0 48px 0;
        line-height: 1.5;
        font-weight: 400;
    }

    .form-fields {
        display: flex;
        flex-direction: column;
        gap: 36px;
    }

    .minimal-form {
        display: flex;
        flex-direction: column;
    }

    .form-row-horizontal {
        display: grid;
        grid-template-columns: 200px 1fr;
        align-items: center;
        gap: 32px;
    }
    
    .form-row-stacked {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }
    
    .form-row-stacked label {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--color-blue-deep, #0a192f);
    }

    .form-row-horizontal label {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--color-blue-deep, #0a192f);
        line-height: 1.4;
    }

    .minimal-form input,
    .minimal-form select,
    .minimal-form textarea {
        width: 100%;
        padding: 16px 20px;
        font-family: var(--font-sans);
        font-size: 1.05rem;
        color: #000000;
        background-color: #f5f5f7; /* Apple secondary background */
        border: none;
        border-radius: 12px;
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
        outline: none;
    }
    
    .minimal-form textarea {
        resize: vertical;
        min-height: 100px;
    }

    .minimal-form input::placeholder,
    .minimal-form textarea::placeholder {
        color: #86868b; /* Apple placeholder text */
        transition: opacity 0.2s ease;
    }

    .minimal-form input:focus::placeholder {
        opacity: 0.3;
    }

    .minimal-form input:hover,
    .minimal-form select:hover,
    .minimal-form textarea:hover {
        background-color: #e5e5ea;
    }

    .minimal-form input:focus,
    .minimal-form select:focus,
    .minimal-form textarea:focus {
        background-color: #ffffff;
        box-shadow: 0 0 0 4px rgba(10, 25, 47, 0.15); /* Cord Navy Focus Ring */
    }
    
    /* Mostrar error visual de HTML5 validación custom */
    .minimal-form input:invalid.has-error,
    .minimal-form select:invalid.has-error {
        border-color: #ef4444;
        background-color: #fef2f2;
        box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.1);
    }

    /* Transición suave para los labels cuando el input está enfocado */
    .form-row-horizontal:focus-within label {
        color: var(--color-blue-deep, #0a192f);
        transform: translateX(2px);
    }
    
    .form-row-horizontal label {
        transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), color 0.3s ease;
    }

    .select-wrapper {
        position: relative;
    }

    .minimal-form select {
        appearance: none;
        cursor: pointer;
        padding-right: 36px;
    }

    .select-arrow {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        width: 14px;
        height: 14px;
        color: var(--color-text-muted, #555556);
        pointer-events: none;
        transition: transform 0.3s ease;
    }
    
    .select-wrapper:hover .select-arrow {
        transform: translateY(-50%) scale(1.1);
        color: var(--color-blue-deep, #0a192f);
    }
    
    /* Radio Cards */
    .radio-card-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }
    
    .radio-card {
        cursor: pointer;
        position: relative;
    }
    
    .radio-card input {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
    }
    
    .radio-card-content {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 18px;
        background: #f5f5f7;
        border: 2px solid transparent;
        border-radius: 16px;
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
        height: 100%;
        text-align: center;
    }
    
    .radio-title {
        font-size: 1rem;
        font-weight: 500;
        color: #1d1d1f;
        transition: color 0.2s ease;
    }
    
    .radio-card:hover .radio-card-content {
        background: #e5e5ea;
        transform: scale(0.98);
    }
    
    .radio-card input:checked + .radio-card-content {
        background: #ffffff;
        border: 2px solid #0a192f;
        box-shadow: 0 8px 24px rgba(10, 25, 47, 0.12);
        transform: scale(1);
    }
    
    .radio-card input:checked + .radio-card-content .radio-title {
        color: #0a192f;
        font-weight: 600;
    }
    
    .radio-card input:focus-visible + .radio-card-content {
        box-shadow: 0 0 0 4px rgba(10, 25, 47, 0.15);
    }

    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 16px;
        margin-top: 48px;
        padding-top: 32px;
        border-top: 1px solid rgba(10, 25, 47, 0.06);
    }
    
    .btn-back {
        background-color: transparent !important;
        color: var(--color-blue-deep, #0a192f) !important;
        box-shadow: none !important;
        border: 1px solid rgba(10, 25, 47, 0.1) !important;
    }
    
    .btn-back:hover {
        background-color: rgba(10, 25, 47, 0.04) !important;
        transform: none !important;
    }

    .continue-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        background-color: var(--color-blue-deep, #0a192f);
        color: #ffffff;
        font-family: var(--font-sans);
        font-size: 1rem;
        font-weight: 600;
        border: none;
        border-radius: 999px; /* Apple pill button */
        padding: 14px 32px;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 4px 16px rgba(10, 25, 47, 0.2);
    }

    .continue-btn:hover {
        background-color: #0d213f;
        box-shadow: 0 8px 24px rgba(10, 25, 47, 0.3);
        transform: scale(1.02);
    }

    .continue-btn:active {
        transform: scale(0.98);
        box-shadow: 0 2px 8px rgba(10, 25, 47, 0.2);
    }

    .continue-btn svg {
        width: 16px;
        height: 16px;
        transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .continue-btn:hover svg {
        transform: translateX(4px);
    }
    
    .success-icon {
        width: 64px;
        height: 64px;
        margin: 0 auto 24px;
        border-radius: 50%;
        background: rgba(10, 25, 47, 0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-blue-deep, #0a192f);
    }
    
    .success-icon svg {
        width: 32px;
        height: 32px;
    }

    /* RESPONSIVE */
    @media (max-width: 950px) {
        .stepper-card {
            grid-template-columns: 1fr;
        }
        
        .trust-panel {
            padding: 40px 32px;
        }
    }

    @media (max-width: 768px) {
        .form-row-horizontal {
            grid-template-columns: 1fr;
            gap: 10px;
        }
        
        .form-row-horizontal label {
            margin-top: 0 !important;
        }
        
        .stepper-header {
            flex-direction: column;
            gap: 16px;
            align-items: flex-start;
        }
        
        .stepper-form-column {
            padding: 40px 32px;
        }

        .stepper-card {
            border-radius: 16px;
        }

        .minimal-header {
            padding: 24px;
        }
        
        .form-actions {
            margin-top: 32px;
            padding-top: 24px;
        }
        
        .radio-card-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<script>
    import { gsap } from 'gsap';
    
    document.addEventListener('DOMContentLoaded', () => {
        const isEnPage = location.pathname.startsWith('/en');
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduced) {
            gsap.set('.reveal-mockup', { opacity: 1, y: 0 });
            return;
        }

        // Animación de entrada suave del card central
        const card = document.querySelector<HTMLElement>('.reveal-mockup');
        if (card) {
            gsap.set(card, { y: 20, scale: 0.98, opacity: 0 });
            gsap.to(card, { 
                opacity: 1, y: 0, scale: 1, duration: 1.0, ease: 'power3.out', delay: 0.1 
            });
        }
        
        // --- WIZARD LOGIC ---
        const form = document.getElementById('contactWizard') as HTMLFormElement;
        const nextBtns = document.querySelectorAll('.js-next');
        const prevBtns = document.querySelectorAll('.js-prev');
        const steps = [
            document.getElementById('step-1'),
            document.getElementById('step-2'),
            document.getElementById('step-3'),
            document.getElementById('step-success')
        ];
        const stepIndicators = document.querySelectorAll('.step');
        const progressBar = document.getElementById('progressBar');
        
        let currentStep = 0;
        
        const updateUI = (oldStep: number, newStep: number) => {
            // Validate before moving forward
            if (newStep > oldStep && form) {
                const fields = steps[oldStep]?.querySelectorAll('input, select, textarea');
                let isValid = true;
                fields?.forEach((el) => {
                    const field = el as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;
                    if (!field.checkValidity()) {
                        field.classList.add('has-error');
                        isValid = false;
                        field.reportValidity();
                    } else {
                        field.classList.remove('has-error');
                    }
                });
                if (!isValid) return false;
            }
        
            // Animate transition
            const outgoing = steps[oldStep];
            const incoming = steps[newStep];
            
            if (outgoing && incoming) {
                gsap.to(outgoing, {
                    opacity: 0, y: -10, duration: 0.3, ease: 'power2.in',
                    onComplete: () => {
                        outgoing.style.display = 'none';
                        incoming.style.display = 'block';
                        gsap.fromTo(incoming, 
                            { opacity: 0, y: 10 },
                            { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' }
                        );
                    }
                });
            }
            
            // Update Stepper Progress
            if (newStep < 3) {
                stepIndicators.forEach((el, index) => {
                    const indicator = el.querySelector('.step-indicator');
                    
                    if (index < newStep) {
                        el.classList.add('completed');
                        el.classList.remove('active');
                        if (indicator) {
                            indicator.innerHTML = '<svg viewBox="0 0 24 24" width="10" height="10" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round" style="margin: 0 auto; display: block; position: relative; top: 1px;"><polyline points="20 6 9 17 4 12"></polyline></svg>';
                        }
                    } else if (index === newStep) {
                        el.classList.add('active');
                        el.classList.remove('completed');
                        if (indicator) indicator.innerHTML = '';
                    } else {
                        el.classList.remove('active', 'completed');
                        if (indicator) indicator.innerHTML = '';
                    }
                });
                
                if (progressBar) {
                    progressBar.style.width = `${((newStep + 1) / 3) * 100}%`;
                }
            } else {
                // If success step, maybe hide the stepper header
                const header = document.querySelector('.stepper-header') as HTMLElement;
                const prog = document.querySelector('.stepper-progress') as HTMLElement;
                if(header) gsap.to(header, {opacity: 0, duration: 0.3, onComplete: () => header.style.display = 'none'});
                if(prog) gsap.to(prog, {opacity: 0, duration: 0.3, onComplete: () => prog.style.display = 'none'});
            }
            
            return true;
        };
        
        nextBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                if (currentStep < 2) {
                    if(updateUI(currentStep, currentStep + 1)) {
                        currentStep++;
                    }
                }
            });
        });
        
        prevBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                if (currentStep > 0) {
                    updateUI(currentStep, currentStep - 1);
                    currentStep--;
                }
            });
        });
        
        // Handle Submit — envío REAL a /api/contacto/ventas (correo a ventas + ack).
        if(form) {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();

                // Valida el paso actual (volumen + mensaje) antes de enviar.
                const fields = steps[currentStep]?.querySelectorAll('input, select, textarea');
                let isValid = true;
                fields?.forEach((el) => {
                    const field = el as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;
                    if (!field.checkValidity()) {
                        field.classList.add('has-error');
                        field.reportValidity();
                        isValid = false;
                    }
                });
                if (!isValid) return;

                const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
                if (submitBtn) { submitBtn.disabled = true; submitBtn.style.opacity = '0.6'; }

                const fd = new FormData(form);
                const payload = Object.fromEntries(fd.entries());

                try {
                    const res = await fetch('/api/contacto/ventas', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload),
                    });
                    if (!res.ok) throw new Error('bad status');
                } catch (err) {
                    // Si el envío falla, reactiva el botón y avisa (sin perder el lead capturado).
                    if (submitBtn) { submitBtn.disabled = false; submitBtn.style.opacity = '1'; }
                    alert(isEnPage
                        ? 'We could not send your message. Please try again or email hola@flouvia.com.'
                        : 'No pudimos enviar tu mensaje. Intenta de nuevo o escríbenos a hola@flouvia.com.');
                    return;
                }

                // Éxito → pantalla de confirmación.
                if(updateUI(currentStep, 3)) {
                    currentStep = 3;
                }
            });
            
            // Handle Keyboard Navigation (Enter key)
            form.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    // Prevent default on everything except textareas
                    if ((e.target as HTMLElement).tagName !== 'TEXTAREA') {
                        e.preventDefault();
                        
                        // If it's the last step, submit
                        if (currentStep === 2) {
                            form.dispatchEvent(new Event('submit'));
                        } else if (currentStep < 2) {
                            // Find and click the next button
                            const currentStepEl = steps[currentStep];
                            const nextBtn = currentStepEl?.querySelector('.js-next') as HTMLButtonElement;
                            if (nextBtn) nextBtn.click();
                        }
                    }
                }
            });
        }
    });
</script>
