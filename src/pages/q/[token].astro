---
// Link público — Quiet Luxury edition.
import Layout from '../../layouts/Layout.astro';
import QuoteCard from '../../components/q/QuoteCard.astro';
import { getCotizacionByToken, markViewed } from '../../lib/queries';
import { findQuoteByToken, ORG as mockOrg } from '../../lib/mock';

const { token } = Astro.params;
let result;

if (token === 'demo') {
    result = {
        quote: {
            id: 'q-demo-123',
            folio: 'COT-0004',
            cliente: 'Desarrollos Inmobiliarios Polanco',
            clienteInicial: 'DP',
            status: 'viewed',
            terminos: 'Contado',
            vigencia: '12 jul 2026',
            creada: '10 jul 2026',
            token: 'demo',
            diasVigencia: 2,
            pagoDisponible: true,
            items: [
                {
                    id: 'b5a98cbe',
                    descripcion: 'Arena Fina (Metro Cúbico)',
                    cantidad: 11,
                    unidad: 'pieza',
                    precioLista: 445.0,
                    precioNegociado: 445.0,
                    aprobado: true,
                    comentarios: [
                        { tipo: 'cliente', contenido: '¿Me puedes confirmar si la arena viene en costales o a granel?', cuando: 'hace 30 min' },
                        { tipo: 'vendedor', contenido: 'Viene en costales de 50kg para facilitar la maniobra en la obra.', cuando: 'hace 10 min' }
                    ]
                },
                {
                    id: '6611006c',
                    descripcion: 'Bomba de Agua Periférica 1/2 HP',
                    cantidad: 17,
                    unidad: 'pieza',
                    precioLista: 848.0,
                    precioNegociado: 848.0,
                    aprobado: true
                },
                {
                    id: '02cb2884',
                    descripcion: 'Bomba de Agua Periférica 1/2 HP',
                    cantidad: 12,
                    unidad: 'pieza',
                    precioLista: 850.0,
                    precioNegociado: 850.0,
                    aprobado: true
                }
            ],
            eventos: [
                { tipo: 'viewed', detalle: 'Alejandro (Desarrollos Inmobiliarios Polanco) abrió el link', cuando: 'hace 5 min' },
                { tipo: 'sent', detalle: 'Enviada por correo a compras@dipolanco.mx', cuando: 'hace 1 hora' }
            ],
            notas: 'Precios sujetos a cambio sin previo aviso. Tiempo de entrega: 2 días hábiles tras confirmación de pago. La descarga de material corre por cuenta del cliente.'
        },
        org: {
            nombre: 'Mi negocio',
            inicial: 'MN',
            rfc: 'MNEG890101XYZ',
            colorMarca: '#0a192f',
            logoUrl: '',
            pdfMensaje: '',
            ivaPct: 16,
            embedDomains: '',
            emailContacto: 'ventas@minegocio.mx',
            telefono: '55 1234 5678',
            whatsapp: '525512345678',
            portalBanner: '',
            portalBienvenida: '',
            portalMostrarChat: true,
            portalPowered: true
        },
        conversacion: [
            { tipo: 'vendedor', detalle: '¡Hola Alejandro! Te comparto la cotización de los materiales para la obra. Cualquier duda sigo a tus órdenes por aquí o por WhatsApp.', cuando: 'hace 1 hora', mine: false },
            { tipo: 'cliente', detalle: 'Gracias. Veo que las bombas de agua tienen distinto precio, ¿es por la marca?', cuando: 'hace 20 min', mine: true },
            { tipo: 'vendedor', detalle: 'Es correcto, unas son Truper y las otras son pretul. Te separé las partidas para que decidas cuáles te convienen más.', cuando: 'hace 15 min', mine: false }
        ]
    };
} else {
    result = await getCotizacionByToken(token ?? '');
}

if (!result) return Astro.redirect('/');
const { quote: q, org: ORG, conversacion } = result;

if (token !== 'demo') {
    await markViewed(token ?? '');
}

const yaAprobada = ['approved', 'paid', 'invoiced'].includes(q.status);
const yaRechazada = q.status === 'rejected';
// Regreso del flujo de pago (Stripe Elements): el webhook confirma en segundos
// (tarjeta) o al liquidar el SPEI — mientras, se avisa que el pago va en camino.
const regresoDePago = Astro.url.searchParams.get('pagado') === '1' && q.status !== 'paid';
const pagoActivo = !!(import.meta.env.STRIPE_SECRET_KEY || process.env.STRIPE_SECRET_KEY);
// Términos de crédito (Net 30/60): el pago NO se pide al aprobar — se habilita
// cuando llega la fecha de vencimiento (getCotizacionByToken calcula pagoDisponible).
// Con cobros parciales (anticipo/cuotas), mandan LOS COBROS: hay botón de pago
// solo si existe un cobro pendiente cuya fecha ya llegó.
const cobrosQ: any[] = Array.isArray((q as any).cobros) ? (q as any).cobros : [];
const hayCobroPagable = cobrosQ.some((co: any) => co.status === 'pendiente' && !co.venceEnFuturo);
const pagoDisponible = cobrosQ.length > 0 ? hayCobroPagable : (q as any).pagoDisponible !== false;
const puedePagar = pagoActivo && pagoDisponible && (
    ORG.aceptaTransferencia ||
    ((ORG.aceptaTarjeta || ORG.cobroSpeiAuto) && ORG.stripeAccountId && ORG.stripeChargesEnabled)
);

const color = ORG.colorMarca || '#0a192f';
---

<Layout title={`Cotización ${q.folio} — ${ORG.nombre}`} noindex={true}>
    <div class="qp-bg" aria-hidden="true">
        <div class="qp-orb qp-orb-top"></div>
        <div class="qp-orb qp-orb-bot" style={`background: radial-gradient(circle, ${color}14 0%, transparent 70%)`}></div>
    </div>

    <main class="qp-main">
        {regresoDePago && (
            <div class="qp-payback" role="status">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" fill="currentColor" fill-opacity="0.1"/><polyline points="8 12.5 11 15.5 16 9.5"/></svg>
                <span>Recibimos tu pago. La cotización se marcará como pagada automáticamente en cuanto Stripe lo confirme — con tarjeta toma segundos; por SPEI, al liquidarse la transferencia.</span>
            </div>
        )}
        <QuoteCard
            quote={q}
            org={ORG}
            conversacion={conversacion}
            yaAprobada={yaAprobada}
            yaRechazada={yaRechazada}
            puedePagar={puedePagar}
            standalone={true}
        />

        {ORG.portalPowered !== false && (
            <a href="/" class="qp-via">
                Cotización enviada vía
                <img src="/imgs/logo-cord-navy.png" alt="Cord" />
                — crea las tuyas gratis →
            </a>
        )}
    </main>
</Layout>

<style>
    .qp-bg {
        position: fixed; inset: 0; z-index: 0;
        background: #f3f2ef;
        overflow: hidden; pointer-events: none;
    }
    .qp-orb { position: absolute; border-radius: 50%; filter: blur(90px); }
    .qp-orb-top {
        width: 70vw; height: 70vw; top: -30%; left: -15%;
        background: radial-gradient(circle, rgba(10,25,47,0.05) 0%, transparent 70%);
    }
    .qp-orb-bot { width: 55vw; height: 55vw; bottom: -20%; right: -10%; opacity: 0.7; }

    .qp-main {
        position: relative; z-index: 1;
        min-height: 100svh;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        gap: 1.8rem; padding: 3.5rem 5% 4rem;
    }

    .qp-payback {
        display: flex; align-items: flex-start; gap: 10px;
        max-width: 560px; width: 100%;
        background: #ffffff; border-radius: 16px;
        padding: 13px 16px;
        font-size: 0.82rem; color: #065f46; line-height: 1.5;
        box-shadow: 0 2px 4px rgba(10,25,47,0.04), 0 18px 40px -14px rgba(10,25,47,0.12);
        border: 1px solid rgba(16,185,129,0.2);
        animation: qp-payback-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .qp-payback svg { flex-shrink: 0; margin-top: 1px; color: #10b981; }
    @keyframes qp-payback-in { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
    @media (prefers-reduced-motion: reduce) { .qp-payback { animation: none; } }

    .qp-via {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 0.76rem; font-weight: 500;
        color: rgba(10,25,47,0.3); text-decoration: none;
        letter-spacing: 0.01em;
        transition: color 0.3s;
    }
    .qp-via img { height: 11px; width: auto; opacity: 0.45; transition: opacity 0.3s; }
    .qp-via:hover { color: rgba(10,25,47,0.65); }
    .qp-via:hover img { opacity: 0.8; }

    @media print {
        .qp-bg, .qp-via, .qp-payback { display: none !important; }
        .qp-main { min-height: 0; padding: 0; display: block; }
    }
</style>
