---
// Link público de cotización — LA página mejor diseñada de Cord.
// Es lo que ve el cliente final: marca del negocio, items, total y aprobar.
// Cada cotización enviada es un demo del producto (loop viral con "vía cord").
//
// El corazón de la tarjeta vive en components/q/QuoteCard.astro (reutilizado por
// /embed/[token] para CORD Elements). Aquí solo se añade el "chrome" de la
// página pública: watermark, loop viral "vía Cord" y el fondo.
import Layout from '../../layouts/Layout.astro';
import QuoteCard from '../../components/q/QuoteCard.astro';
import { getCotizacionByToken, markViewed } from '../../lib/queries';

const { token } = Astro.params;
const result = await getCotizacionByToken(token ?? '');
if (!result) return Astro.redirect('/');
const { quote: q, org: ORG, conversacion } = result;

// Registra la apertura del cliente (y pasa a 'viewed' si estaba 'sent').
await markViewed(token ?? '');

// Estado actual: si ya se decidió, el cliente ve el resultado, no los botones.
const yaAprobada = ['approved', 'paid', 'invoiced'].includes(q.status);
const yaRechazada = q.status === 'rejected';
const pagoActivo = !!(import.meta.env.STRIPE_SECRET_KEY || process.env.STRIPE_SECRET_KEY);
const puedePagar = pagoActivo && ['approved', 'invoiced'].includes(q.status);
---

<Layout title={`Cotización ${q.folio} — ${ORG.nombre}`} noindex={true}>
    <main class="q-page">
        {ORG.portalPowered !== false && <div class="q-watermark editorial" aria-hidden="true">Cord</div>}

        <QuoteCard
            quote={q}
            org={ORG}
            conversacion={conversacion}
            yaAprobada={yaAprobada}
            yaRechazada={yaRechazada}
            puedePagar={puedePagar}
        />

        {ORG.portalPowered !== false && (
            <!-- Loop viral (oculto si el plan permite quitar la marca) -->
            <a href="/" class="q-via">
                Cotización enviada vía <img src="/imgs/logo-cord-navy.svg" alt="Cord" /> — crea las tuyas gratis →
            </a>
        )}
    </main>
</Layout>

<style>
    .q-page {
        min-height: 100svh;
        background: var(--color-bg-soft);
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 1.4rem;
        padding: 3rem 5%;
        position: relative;
        overflow: clip;
    }
    .q-watermark {
        position: fixed; bottom: -8vw; right: -3vw;
        font-size: 28vw; line-height: 0.85; letter-spacing: -0.04em;
        color: rgba(0,0,0,0.022);
        pointer-events: none; user-select: none; white-space: nowrap;
        z-index: 0;
    }

    .q-via {
        position: relative; z-index: 1;
        display: inline-flex; align-items: center; gap: 7px;
        font-size: 0.8rem; font-weight: 500; color: var(--color-text-muted);
        text-decoration: none;
        transition: color 0.3s;
    }
    .q-via img { height: 12px; width: auto; opacity: 0.75; transition: opacity 0.3s; }
    .q-via:hover { color: var(--color-blue-deep); }
    .q-via:hover img { opacity: 1; }

    /* ── Impresión: el link público ES el PDF del cliente ── */
    @media print {
        .q-page { background: #fff; padding: 0; min-height: 0; display: block; }
        .q-watermark, .q-via { display: none !important; }
    }
</style>
