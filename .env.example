# ── Neon (PostgreSQL serverless) — base de datos del SaaS ──
# Crear proyecto en neon.tech (o vía Vercel Marketplace → Neon) y pegar la URL:
DATABASE_URL=

# ── Clerk (app NUEVA con signup ABIERTO — no invitation-only) ──
PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Stripe Billing (suscripciones + pago de cotizaciones) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Emails transaccionales (Resend) ──
RESEND_API_KEY=
# Remitente de los recordatorios de cobro (dominio verificado en Resend):
RESEND_FROM=
# Secreto para proteger el cron de recordatorios (Vercel manda Authorization: Bearer):
CRON_SECRET=

# ── CFDI — PAC de timbrado (mismo proveedor que la app de Shopify) ──
PAC_API_KEY=

# ── IA: armar cotizaciones desde texto (/api/cotizaciones/ai-draft) ──
# Llave de Anthropic (console.anthropic.com) o Vercel AI Gateway. Sin esto, el
# botón "Armar con IA" del editor devuelve un aviso de "no configurada".
ANTHROPIC_API_KEY=
# Opcional: modelo (default claude-opus-4-8). Para esta extracción puedes bajar
# costo con AI_MODEL=claude-haiku-4-5 o claude-sonnet-4-6.
AI_MODEL=
