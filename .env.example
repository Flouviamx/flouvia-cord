# ── Neon (PostgreSQL serverless) — base de datos del SaaS ──
# Crear proyecto en neon.tech (o vía Vercel Marketplace → Neon) y pegar la URL.
# ⚠️ USA EL ENDPOINT POOLED: el host debe contener "-pooler"
#   (ej. ...-pooler.<region>.aws.neon.tech). El driver HTTP abre una conexión por
#   query; sin el pooler, un pico de usuarios concurrentes agota las conexiones
#   directas de Neon y la app tira 500s. El dashboard de Neon lo etiqueta "Pooled
#   connection"; la integración de Vercel Marketplace lo inyecta pooled por default.
DATABASE_URL=

# ── Rate limiting durable (opcional pero recomendado en prod) ──
# Sin estas dos, el rate limit cae a un contador in-memory POR INSTANCIA (se
# multiplica por el número de réplicas de Vercel). Con Upstash, el límite es
# global y compartido entre todas las instancias. Crear en upstash.com (Redis).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Correo entrante del agente de cobranza (opcional) ──
# Secreto que debe mandar el proveedor de correo (Resend/SendGrid Inbound) como
# `Authorization: Bearer <secreto>` para invocar /api/webhooks/inbound-email.
# Sin él, ese endpoint rechaza todo (fail-closed).
INBOUND_EMAIL_SECRET=

# ── Clerk (app NUEVA con signup ABIERTO — no invitation-only) ──
PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhook secret (Clerk Dashboard → Webhooks → signing secret). Formato: whsec_...
# Endpoint a registrar: https://cord.flouvia.com/api/clerk/webhook
# Eventos: user.created, user.deleted,
#          organization.created, organization.updated, organization.deleted,
#          organizationMembership.created, organizationMembership.updated,
#          organizationMembership.deleted
# (Clerk Organizations modo híbrido — sincroniza orgs/miembros hacia Neon.)
CLERK_WEBHOOK_SECRET=

# ── Stripe Billing (suscripciones + pago de cotizaciones) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe Connect (cobro directo a la cuenta del dueño del negocio, vía Embedded Components)
# Secreto del webhook de "eventos en cuentas conectadas" (account.updated, checkout.session.*)
STRIPE_CONNECT_WEBHOOK_SECRET=

# ── Emails transaccionales (Resend) ──
# SIN esto NO se manda ningún correo (ni al enviar una cotización, ni recordatorios).
# El dominio remitente debe estar verificado en Resend. Usamos flouvia.com (ya
# verificado), NO cord.flouvia.com.
RESEND_API_KEY=
RESEND_FROM="Cord <cotizaciones@flouvia.com>"
# Destinatario de los leads del formulario /contacto/ventas (default: hola@flouvia.com):
SALES_EMAIL=
# Secreto para proteger el cron de recordatorios (Vercel manda Authorization: Bearer):
CRON_SECRET=

# ── CFDI 4.0 — timbrado vía Facturapi (facturapi.io) ──
# Llave secreta de Facturapi: sk_test_… (pruebas) o sk_live_… (producción).
# Modo UNA-SOLA-CUENTA: timbra todo bajo TU RFC. Sin esta llave (y sin CSD por
# org), el timbrado es SIMULADO (se marca provider_data.simulado=true).
FACTURAPI_API_KEY=
# Llave de CUENTA de Facturapi ("User key"/Secret key del panel → User keys).
# Habilita el modo MULTI-TENANT: cada cliente sube su CSD en Ajustes › Datos
# fiscales y Cord crea su organización Facturapi para timbrar bajo SU RFC.
FACTURAPI_USER_KEY=
# FACTURAPI_URL=          # opcional, default https://www.facturapi.io/v2
# PAC_API_KEY=            # (legado: contrato PAC genérico, ya no usado por MexicoSatProvider)

# ── IA: armar cotizaciones desde texto (/api/cotizaciones/ai-draft) ──
# Llave de Anthropic (console.anthropic.com) o Vercel AI Gateway. Sin esto, el
# botón "Armar con IA" del editor devuelve un aviso de "no configurada".
ANTHROPIC_API_KEY=
# Opcional: modelo (default claude-opus-4-8). Para esta extracción puedes bajar
# costo con AI_MODEL=claude-haiku-4-5 o claude-sonnet-4-6.
AI_MODEL=
